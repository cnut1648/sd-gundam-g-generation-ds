{
 "file": "_STGX3A.bin",
 "source_size": 27864,
 "built_size": 29576,
 "edits": [
  {
   "jp_offset": "0x13a2",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "西玛大人！前卫部队他们……！！",
   "zh_hex": "15e7f8e845efa5efb2ef97ef51e9b2ef70e7c9e80ce7bb0909ef97ef97000000000000"
  },
  {
   "jp_offset": "0x13cd",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "可恶……！",
   "zh_hex": "15e7c4e7de0909ef970000"
  },
  {
   "jp_offset": "0x13d6",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "不是说好、联邦军会被本队那边引开的吗{00}！？",
   "zh_hex": "15e7b5e7b6e7ede7c702ef2eefaae7e0e7e2e7f1efa6e7c9e7b7e899e9d0e7fae7b4e80200ef97050000000000"
  },
  {
   "jp_offset": "0x141b",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "呵呵……吉翁那帮家伙、都慌了神了",
   "zh_hex": "15ef3def3d0909e7d9ee88e7b7e910e7dfe7fd02e840eb05e7bae9aae7ba000000"
  },
  {
   "jp_offset": "0x142f",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "……喂、包围圈布置得怎么样了？",
   "zh_hex": "150909e8bd02eabbe9dee9fbe831ea0ee80ae7f2e7bde7dae7ba05000000"
  },
  {
   "jp_offset": "0x1462",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "别动队正在切断其后方、应该就快完成了",
   "zh_hex": "15e7e5ef30e7c9ef3bef29ef3fe982e8cfe7feefb102e873e898e7c5e85fe87ee837e7ba0000000000"
  },
  {
   "jp_offset": "0x1499",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "好、等包围圈一完成、就发起总攻！",
   "zh_hex": "15e7c702e826eabbe9dee9fbefb6e87ee83702e7c5e870e847e881ef67ef9700000000"
  },
  {
   "jp_offset": "0x14d2",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……是！",
   "zh_hex": "150909e7b6ef970000"
  },
  {
   "jp_offset": "0x14ff",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "……轨道舰队已与西玛舰队接触、进度一{00}切如预想",
   "zh_hex": "150909e9cce82ae7d4e7c9ef3ae832e7f8e845e7d4e7c9b7ef4802e892e96d8700ef3fe7f0ea5ae7e6000000000000"
  },
  {
   "jp_offset": "0x1567",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "艾裘·迪拉兹……",
   "zh_hex": "15e8d6ea83ef4bea11e7c2e85609090000"
  },
  {
   "jp_offset": "0x1571",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "虽说结果是白白舍弃了一个有能之人、但{00}这也是不得已",
   "zh_hex": "15e8b8e7ede868e871e7b6e809e809eb17e938e7baefb6e828e7cbe7c6e7cdefb202e7db00e7b9e7c0e7b6e7b5e80aef3a00000000"
  },
  {
   "jp_offset": "0x15df",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "高举吉翁理想之旗的、并不是迪拉兹舰队{00}……",
   "zh_hex": "15e812ea21e7d9ee88e872e7e6e7cdeb0be7b402e957e7b5e7b6ea11e7c2e856e7d4e7c9000909000000"
  },
  {
   "jp_offset": "0x1648",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……而是我们才对",
   "zh_hex": "150909e89ce7b6efcce7bbe836e7be00000000"
  },
  {
   "jp_offset": "0x166b",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "啧……！",
   "zh_hex": "15e9fa0909ef970000"
  },
  {
   "jp_offset": "0x1673",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "我才不要、就这样死在这种地方……！",
   "zh_hex": "15efcce836e7b5ef2a02e7c5e7b9e7daef6aef29e7b9e7d1ef63efb10909ef9700000000"
  },
  {
   "jp_offset": "0x16b5",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "西玛大人、您要去哪里！？",
   "zh_hex": "15e7f8e845efa5efb202e835ef2ae7ebe8ffef31ef97050000"
  },
  {
   "jp_offset": "0x16dd",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "不是还有那台新型机吗！？我也上！",
   "zh_hex": "15e7b5e7b6e7f7e7cbe7b7ea16ef8ae977e7e4e80206058be7c0b206000000000000000000"
  },
  {
   "jp_offset": "0x172f",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "我才不会死……！无论发生什么、我都要{00}活下去！",
   "zh_hex": "15efcce836e7b5e7e2ef6a0909ef97e7dce8dce870ef8de7dde7bd02efcce840ef2a00e8d4ef4de7ebef97000000000000"
  },
  {
   "jp_offset": "0x1775",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "啧……可恶啊……！！",
   "zh_hex": "15e9fa0909e7c4e7dee7c30909ef97ef97000000"
  },
  {
   "jp_offset": "0x17b2",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "西、西玛大人……！！",
   "zh_hex": "15e7f802e7f8e845efa5efb20909ef97ef9700000000"
  },
  {
   "jp_offset": "0x17ee",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "科塞尔！？",
   "zh_hex": "15ebe3e950e7e1ef97050000"
  },
  {
   "jp_offset": "0x17ff",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "可恶……为什么、会变成这样……！！",
   "zh_hex": "15e7c4e7de0909e7c1e7dde7bd02e7e2e955e837e7b9e7da0909ef97ef97000000"
  },
  {
   "jp_offset": "0x1842",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……怎么回事！？",
   "zh_hex": "150909e7f2e7bdef52efb8ef9705000000"
  },
  {
   "jp_offset": "0x1867",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "敌、敌人……后方出现了一支新的部队！{00}！",
   "zh_hex": "15e7e302e7e3efb20909e7feefb1efbee82fe7baefb6e883ef8ae7b4ef70e7c9ef9700ef97000000000000"
  },
  {
   "jp_offset": "0x1899",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "你说什么！？",
   "zh_hex": "15e7b8e7ede7dde7bdef97050000"
  },
  {
   "jp_offset": "0x18c7",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "这里是别动队、已成功切断敌方部队的后{00}路！！",
   "zh_hex": "15e7b9ef31e7b6e7e5ef30e7c902ef3ae837e9b1ef3fe982e7e3efb1ef70e7c9e7b4e7fe00e8d2ef97ef97000000"
  },
  {
   "jp_offset": "0x1907",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "西玛大人……！",
   "zh_hex": "15e7f8e845efa5efb20909ef9700000000"
  },
  {
   "jp_offset": "0x1932",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "哈哈……看来、是我大限将至了啊",
   "zh_hex": "15e7e8e7e80909e7f6efcf02e7b6efccefa5eb23e84ae897e7bae7c300000000000000"
  },
  {
   "jp_offset": "0x194b",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "说到底、我们就像那转瞬即逝的蜉蝣一样{00}……",
   "zh_hex": "15e7ede7d7e9b402efcce7bbe7c5e8e9e7b7e9c2ebdfe855ec9de7b4ebf0ebf1efb6e7da00090900000000"
  },
  {
   "jp_offset": "0x1992",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "呵呵……这下胜负已分",
   "zh_hex": "15ef3def3d0909e7b9ef4de8dbe92cef3aefae00000000"
  },
  {
   "jp_offset": "0x19a4",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "全舰齐射……",
   "zh_hex": "15efb4e7d4e924ef6509090000"
  },
  {
   "jp_offset": "0x19d5",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "呼……真是千钧一发啊",
   "zh_hex": "15ea3c0909e820e7b6eafdeebaefb6e870e7c300000000"
  },
  {
   "jp_offset": "0x1a00",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "强尼莱汀中佐！？",
   "zh_hex": "15e8ade896e846ed7cef4eefbaef97050000"
  },
  {
   "jp_offset": "0x1a24",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "骑兵队驾到、抱歉让你们久等了",
   "zh_hex": "15eca3ef93e7c9e953e7d702e922e927e7f9e7b8e7bbe9dbe826e7ba00000000000000"
  },
  {
   "jp_offset": "0x1a5a",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "难道说……你是来救我们的吗？",
   "zh_hex": "15e866e82ae7ed0909e7b8e7b6d9e8ca8be7bbe7b4e8020500000000000000"
  },
  {
   "jp_offset": "0x1a73",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "为了我们这恶名远扬的西玛舰队、还特地{00}……",
   "zh_hex": "15e7c1e7baefcce7bbe7b9e7dee8ace94cebc6e7b4e7f8e845e7d4e7c902e7f7e7cfef6300090900000000"
  },
  {
   "jp_offset": "0x1aa2",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "……也用不着如此妄自菲薄",
   "zh_hex": "150909e7c0efb3e7b5e86de7f0e7caecc6efb5ea6cee97000000"
  },
  {
   "jp_offset": "0x1ab5",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "既然并肩作战、你们西玛舰队、也同样是{00}我的战友……",
   "zh_hex": "15e8c4e7efe957eb16ef2fef2802e7b8e7bbe7f8e845e7d4e7c902e7c0e85de7dae7b600efcce7b4ef28e960090900000000"
  },
  {
   "jp_offset": "0x1ad5",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "眼睁睁看着战友陷入危机、又谈何大义",
   "zh_hex": "15e90bed90ed90e7f6e86def28e960eaf9e891e935e7e402e8f1eaf4efbcefa5e8ce0000000000"
  },
  {
   "jp_offset": "0x1b0f",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "……嘛、这些场面上的大道理、就先搁一{00}边吧",
   "zh_hex": "150909e93602e7b9e8a4e876e862b2e7b4bee82ae87202e7c5b8ed6a8700e899e7d000000000000000000000000000"
  },
  {
   "jp_offset": "0x1b29",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "我和你们、可是从一年战争起就相识了",
   "zh_hex": "15efcce7d3e7b8e7bb02e7c4e7b6e88aefb6e909ef28e852e847e7c5e8b1e92fe7ba00000000"
  },
  {
   "jp_offset": "0x1b3d",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "把你们丢下不管、我可睡不安稳",
   "zh_hex": "15e81be7b8e7bbebb0ef4de7b5e93b02efcce7c4ebdee7b5e7fceb3e0000000000"
  },
  {
   "jp_offset": "0x1b78",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "你们……",
   "zh_hex": "15e7b8e7bb09090000"
  },
  {
   "jp_offset": "0x1b9c",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "迪拉兹中将的本队、已经朝殖民地去了",
   "zh_hex": "15ea11e7c2e856ef4ee84ae7b4efa6e7c902ef3ae8b7eaade8a9ef38ef63e7ebe7ba000000000000"
  },
  {
   "jp_offset": "0x1bb2",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "不必再久留了、赶紧把敌人收拾掉、撤退{00}！",
   "zh_hex": "15e7b5e860e80be9dbe98ce7ba02ea04eaede81be7e3efb2e926eae6e9d302e90ae88000ef9700000000"
  },
  {
   "jp_offset": "0x1bef",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……明白！",
   "zh_hex": "150909ef39e809ef970000"
  },
  {
   "jp_offset": "0x1c1c",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "哎呀哎呀……总算是收拾干净了",
   "zh_hex": "15e9dce9c6e9dce9c60909e881e889e7b6e926eae6e8d3ecb0e7ba0000000000"
  },
  {
   "jp_offset": "0x1c32",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "也不知敌方后续何时会来、这种地方、还{00}是赶紧离开吧",
   "zh_hex": "15e7c0e7b5e85ae7e3efb1e7fee9adefbcef2de7e2efcf02e7b9e7d1ef63efb102e7f700e7b6ea04eaede901e7fae7d000000000000000"
  },
  {
   "jp_offset": "0x1c78",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……强尼莱汀中佐！",
   "zh_hex": "150909e8ade896e846ed7cef4eefbaef970000"
  },
  {
   "jp_offset": "0x1c9d",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "嗯？怎么了、西玛中佐？",
   "zh_hex": "15e86505e7f2e7bde7ba02e7f8e845ef4eefba050000000000"
  },
  {
   "jp_offset": "0x1cc8",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "啊……",
   "zh_hex": "15e7c309090000"
  },
  {
   "jp_offset": "0x1cce",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "……不、谢谢你来救我们",
   "zh_hex": "150909e7b502e8b2e8b2e7b8efcfe8caefcce7bb0000000000"
  },
  {
   "jp_offset": "0x1ce2",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "我真的很感激你们……",
   "zh_hex": "15efcce820e7b4e981e87de9b9e7b8e7bb09090000000000"
  },
  {
   "jp_offset": "0x1d0d",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……我们、是战友嘛",
   "zh_hex": "150909efcce7bb02e7b6ef28e960e936000000"
  },
  {
   "jp_offset": "0x1d40",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "…………",
   "zh_hex": "150909090900000000"
  },
  {
   "jp_offset": "0x1d6e",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……本队来电！",
   "zh_hex": "150909efa6e7c9efcfead3ef9700000000"
  },
  {
   "jp_offset": "0x1d7a",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "迪拉兹中将的本队、已成功夺取殖民地{00}布雷德岛！",
   "zh_hex": "15ea11e7c2e856c0e84ae7b4d2e7c902ef3ae837e9b1ea17e987e8a9ef38bf00e831e8afe82cecd006000000000000000000"
  },
  {
   "jp_offset": "0x1d94",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "『星之屑作战』的最终阶段、已经发动！",
   "zh_hex": "150cef69e7cdeb31ef2fef280de7b4e8c5e8e2ebfbea6b02ef3ae8b7e870ef30ef97000000000000"
  },
  {
   "jp_offset": "0x1dc8",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "我们这边的指示呢？",
   "zh_hex": "15efcce7bbe7b9e899e7b4e8c0eab0e90705000000"
  },
  {
   "jp_offset": "0x1dee",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "速与本队会合",
   "zh_hex": "15e9dae832d2e7c9e7e2a00000000000"
  },
  {
   "jp_offset": "0x1e19",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "从这里赶过去的话、抵达大概会在作战开{00}始后一会儿吧",
   "zh_hex": "15e88ae7b9ef31ea04ef36e7ebe7b4e81f02e96eef2befa5ec76e7e2ef29ef2fef28e7fa00e908e7feefb6e7e2eb7ce7d00000000000"
  },
  {
   "jp_offset": "0x1e55",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……真是抱歉",
   "zh_hex": "150909e820e7b6e922e927000000"
  },
  {
   "jp_offset": "0x1e5f",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "刚才那一战、莉莉·玛莲号也受了不小的{00}损伤",
   "zh_hex": "15e8bce836e7b7efb6ef2802e81ee81eef4be845ecffe833e7c0e8c8e7bae7b5e83ee7b400ea28e8f90000000000"
  },
  {
   "jp_offset": "0x1e97",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "没事……迟到的份、大闹一场补回来就是{00}了",
   "zh_hex": "15e7d8efb80909ea10e7d7e7b4ea2202efa5ead8efb6e876ea81ef52efcfe7c5e7b600e7ba0000000000000000"
  },
  {
   "jp_offset": "0x1eb3",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "嘛……总之、眼下先与本队会合要紧",
   "zh_hex": "15e9360909e881e7cd02e90bef4def8be832efa6e7c9e7e2efc0ef2aeaed000000000000"
  },
  {
   "jp_offset": "0x1ec8",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "我们赶紧赶路吧",
   "zh_hex": "15efcce7bbea04eaedea04e8d2e7d00000000000"
  },
  {
   "jp_offset": "0x1ef3",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "是！明白！",
   "zh_hex": "15e7b6ef97ef39e809ef97000000"
  },
  {
   "jp_offset": "0x1f16",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "…………",
   "zh_hex": "150909090900000000"
  },
  {
   "jp_offset": "0x1f3a",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "哟、怎么了西玛中佐？难得见你这么没精{00}神啊",
   "zh_hex": "15eb2c02e7f2e7bde7bae7f8e845c0a305e866e80ae85ce7b8e7b9e7bde7d8e98d00e9aae7c300000000000000000000"
  },
  {
   "jp_offset": "0x1f76",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "……啊、是强尼莱汀中佐啊、我在想点事{00}……",
   "zh_hex": "150909e7c302e7b6e8ade896e846ed7cef4eefbae7c302efccef29e7e6e822efb80009090000000000"
  },
  {
   "jp_offset": "0x1faa",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "嘛、当指挥官也不轻松啊",
   "zh_hex": "15e93602ef53e8c0e949ef92e7c0e7b5e990e9e0e7c30000000000"
  },
  {
   "jp_offset": "0x1fda",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "不是那样……",
   "zh_hex": "15e7b5e7b6e7b7e7da09090000"
  },
  {
   "jp_offset": "0x1ff1",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "……强尼莱汀中佐、你知道蜉蝣……这种{00}东西吗？",
   "zh_hex": "150909e8ade896e846ed7cc0a302e7b8e85ae82aebf0ebf10909e7b9e7d100e8bae7f8e80205000000000000"
  },
  {
   "jp_offset": "0x2025",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "蜉蝣？好像是种虫子的名字吧……",
   "zh_hex": "15ebf0ebf105e7c7e8e9e7b6e7d1eb6de886e7b4e8ace980e7d0090900000000"
  },
  {
   "jp_offset": "0x2052",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "听说那蜉蝣、变成成虫之后、过个几天就{00}死了",
   "zh_hex": "15e8d1e7ede7b7ebf0ebf102e955e837e837eb6de7cde7fe02ef36e828eaa5e844e7c500ef6ae7ba00000000"
  },
  {
   "jp_offset": "0x208e",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "那它怎么了？",
   "zh_hex": "15e7b7e978e7f2e7bde7ba05000000"
  },
  {
   "jp_offset": "0x20b8",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "以前有人说我们『就像蜉蝣一样』",
   "zh_hex": "15e7f3ef51e7cbefb2e7edefcce7bb0ce7c5e8e9ebf0ebf1efb6e7da0d0000"
  },
  {
   "jp_offset": "0x20d7",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "把转瞬即逝的蜉蝣、拿来跟我们西玛舰队{00}相提并论",
   "zh_hex": "15e81be9c2ebdfe855ec9de7b4ebf0ebf102e9a7efcfe973efcce7bbe7f8e845e7d4e7c900e8b1e821e957e8dc00000000"
  },
  {
   "jp_offset": "0x20f7",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "从一年战争到现在、什么坏事都干过……",
   "zh_hex": "15e88aefb6e909ef28e852e7d7e82fef2902e7dde7bde9edefb8e840e8d3ef36090900000000000000"
  },
  {
   "jp_offset": "0x2112",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "背着恶名、苟且偷生至今的我们",
   "zh_hex": "15e9e4e86de7dee8ac02ee94e999ebb4ef8de897efb9e7b4efcce7bb0000000000"
  },
  {
   "jp_offset": "0x212c",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "很可笑吧？我们这种人、竟也被比作蜉蝣",
   "zh_hex": "15e981e7c4ea1ce7d0058be7bbe7b9e7d1b402ef2ce7c0e7f1e825ef2febf0ebf100000000000000"
  },
  {
   "jp_offset": "0x215b",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "倒也不见得吧？",
   "zh_hex": "15e848e7c0e7b5e85ce80ae7d0050000"
  },
  {
   "jp_offset": "0x2186",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……咦？",
   "zh_hex": "150909ef4905000000"
  },
  {
   "jp_offset": "0x21a8",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "蜉蝣啊、要以幼虫之身、度过好几年、才{00}终于变成成虫",
   "zh_hex": "15ebf0ebf1e7c302ef2ae7f3ec66eb6de7cde88d02e96def36e7c7eaa5e90902e83600e8e2e879e955e837e837eb6d00000000"
  },
  {
   "jp_offset": "0x21e2",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "呵呵……那不就是一直挣扎着的我们本身{00}吗",
   "zh_hex": "15ef3def3d0909e7b7e7b5e7c5e7b6efb6e875ebcae84be86de7b4efcce7bbefa6e88d00e8020000000000"
  },
  {
   "jp_offset": "0x21f7",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "以幼虫之姿狼狈地混着日子、早晚有天、{00}转瞬即逝……",
   "zh_hex": "15e7f3ec66eb6de7cdebbeec7bee61ef63ea41e86de98ae88602e963ea69e7cbe8440200e9c2ebdfe855ec9d090900000000"
  },
  {
   "jp_offset": "0x2232",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……不是这样的",
   "zh_hex": "150909e7b5e7b6e7b9e7dae7b40000"
  },
  {
   "jp_offset": "0x223d",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "正因为哪怕只有几天能化为成虫、蜉蝣才{00}能一直等下去",
   "zh_hex": "15ef3bef33e7c1e8ffe958ef32e7cbeaa5e844e7c6e9a5e7c1e837eb6d02ebf0ebf1e83600e7c6efb6e875e826ef4de7eb00000000"
  },
  {
   "jp_offset": "0x225c",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "对它自己来说、别人怎么看根本无所谓",
   "zh_hex": "15e7bee978efb5e8c9efcfe7ed02e7e5efb2e7f2e7bde7f6e9b8efa6e7dce7fbe92b0000000000"
  },
  {
   "jp_offset": "0x2276",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "正是怀着定要飞向天空的觉悟、才挺过那{00}些年的、不是吗？",
   "zh_hex": "15ef3be7b6eb03e86de867ef2aea45efc1e844e93fe7b4e8aeea1902e836eb5cef36e7b700e8a4e909e7b402e7b5e7b6e8020500000000"
  },
  {
   "jp_offset": "0x22b6",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "强尼莱汀中佐……",
   "zh_hex": "15e8ade896e846ed7cef4eefba09090000"
  },
  {
   "jp_offset": "0x22bf",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "你这人……真是看不出来、还挺有学问啊",
   "zh_hex": "15e7b8e7b9efb20909e820e7b6e7f6e7b5efbeefcf02e7f7eb5ce7cbeb55e997e7c3000000"
  },
  {
   "jp_offset": "0x22ff",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……喂、我说你啊！",
   "zh_hex": "150909e8bd02efcce7ede7b8e7c3ef97000000"
  },
  {
   "jp_offset": "0x230a",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "难得想用段漂亮话来收尾、你最后却给我{00}来这么一句！",
   "zh_hex": "15e866e80ae7e6efb3ea6bead0eaa2e81fefcfe926ebc002e7b8e8c5e7feeadfe839efcc00efcfe7b9e7bdefb6ebb9ef97000000000000"
  },
  {
   "jp_offset": "0x2327",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "别看我这样、在吉翁也算是出身名门的呢{00}……",
   "zh_hex": "15e7e5e7f68be7b9e7da02ef29e7d9ee88e7c0e889e7b6afe88de8ace90ce7b4e907000909000000000000"
  },
  {
   "jp_offset": "0x2361",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "……嘛、不管怎样、你这番话我很受用、{00}强尼莱汀中佐",
   "zh_hex": "150909e93602e7b5e93be7f2e7da02e7b8e7b9ee6de81fefcce981e8c8efb30200e8ade896e846ed7cef4eefba0000000000"
  },
  {
   "jp_offset": "0x237c",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "心里头、多少也轻松了一些",
   "zh_hex": "15e82def31e92e02e7e9eface7c0e990e9e0e7baefb6e8a400000000000000"
  },
  {
   "jp_offset": "0x23ae",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……那真是多谢了",
   "zh_hex": "150909e7b7e820e7b6e7e9e8b2e7ba000000"
  },
  {
   "jp_offset": "0x23bb",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……同一时刻",
   "zh_hex": "150909e85defb6ef2de91f000000"
  },
  {
   "jp_offset": "0x23c6",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "金平糖·地球间航路",
   "zh_hex": "15e902e887eefa04bf95e8fce9c1e8d200000000"
  },
  {
   "jp_offset": "0x23d6",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "阿克西斯先遣舰队",
   "zh_hex": "15e7d2e7d5e7f8e7c8ef8bedc0e7d4e7c9000000"
  },
  {
   "jp_offset": "0x5ed2",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "这是……！！",
   "zh_hex": "15e7b9e7b60909ef97ef970000"
  },
  {
   "jp_offset": "0x5ef7",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "这是我们阿克西斯开发的MA、诺耶·吉{00}尔",
   "zh_hex": "15e7b9e7b68be7bbe7d2e7d5e7f8e7c8e7fae870e7b413ea9c02e972ea3104e7d900e7e10000000000000000000000"
  },
  {
   "jp_offset": "0x5f2a",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "了不起！！",
   "zh_hex": "15e7bae7b5e847ef97ef970000"
  },
  {
   "jp_offset": "0x5f32",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "简直就像吉翁的精神、化作了实体一般！",
   "zh_hex": "15e9abe875e7c5e8e9e7d9ee88e7b4e98de9aa02e9a5ef2fe7bae87fbc87ea80060000000000000000"
  },
  {
   "jp_offset": "0x5f6d",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "我们是以不与联邦交战为条件、才获准滞{00}留地球圈的……",
   "zh_hex": "158be7bbe7b6e7f3e7b5e832ef2ed1e861ef28e7c1e9d4e99102e836e9d8e87aeef800e98cbf95e9fbe7b40909000000000000000000000000"
  },
  {
   "jp_offset": "0x5f91",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "因此也只能提供这种程度的援助了……",
   "zh_hex": "15ef33e7cae7c0ef32e7c6e821eca9e7b9e7d1ea7de96de7b4e863ea23e7ba0909000000"
  },
  {
   "jp_offset": "0x5fc0",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "不、这就足够了",
   "zh_hex": "15e7b502e7b9e7c5ea1ee920e7ba0000"
  },
  {
   "jp_offset": "0x5fd0",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "正因为有阿克西斯舰队在、我们才能毫无{00}后顾之忧地作战",
   "zh_hex": "15ef3bef33e7c1e7cbe7d2e7d5e7f8e7c8e7d4e7c9ef2902efcce7bbe836e7c6ea0ae7dc00e7feea1fe7cdee1def63ef2fef280000000000"
  },
  {
   "jp_offset": "0x6008",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "卡多少佐……",
   "zh_hex": "15e801e7e9efacefba090900000000"
  },
  {
   "jp_offset": "0x602c",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "大功告成之日、士兵的回收{00}就拜托了……！",
   "zh_hex": "15bee9b1e8e5e837e7cde98a02a5cee7b48ce92600e7c5e91ae7f4e7ba0909060000000000000000000000"
  },
  {
   "jp_offset": "0x605e",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "……是、卡多少佐……祝您武运长久",
   "zh_hex": "150909e7b602e801e7e9b1a30909ed97e835e8ece986ef34e9db00000000000000000000"
  },
  {
   "jp_offset": "0x6094",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "……为了吉翁的荣光！",
   "zh_hex": "150909e7c1e7bae7d9ee88e7b4eb19e83d0600000000"
  },
  {
   "jp_offset": "0x6106",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "一路辛苦了",
   "zh_hex": "15efb6e8d2ea58e9e6e7ba0000"
  },
  {
   "jp_offset": "0x6113",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "感谢你、将这条『宇宙世纪路线』一直玩{00}到了最后",
   "zh_hex": "15e87de8b2e7b802e84ae7b9e9d40ce8bee8bfe83ceb99e8d2e9160defb6e875e97000e7d7e7bae8c5e7fe0000000000000000"
  },
  {
   "jp_offset": "0x6133",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "另外、隆德·贝尔队的战斗、就先在此告{00}一段落了……",
   "zh_hex": "15e99be8f702ed16e82cef4be857e7e1e7c9e7b4ef28e7ff02e7c5ef8bef29e7cae8e500efb6ea6be92ae7ba0909000000"
  },
  {
   "jp_offset": "0x6152",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "游戏本身仍然可以继续、今后也请你继续{00}尽情享受",
   "zh_hex": "15ea94ea3eefa6e88deab9e7efe7c4e7f3e9d6e9ad02efb9e7fee7c0e83ae7b8e9d6e9ad00e8f2e88bec06e8c80000000000"
  },
  {
   "jp_offset": "0x6177",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "另外、为将本路线一直玩到最后的你、还{00}准备了特别关卡",
   "zh_hex": "15e99be8f702e7c1e84aefa6e8d2e916efb6e875e970e7d7e8c5e7fee7b4e7b802e7f700e87ae877e7bae7cfe7e5e8bbe80100000000000000"
  },
  {
   "jp_offset": "0x619e",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "那是与我们分头、一直另行作战的大天使{00}队的特别演习",
   "zh_hex": "15e7b7e7b6e832efcce7bbefaee92e02efb6e875e99befd6ef2fef28e7b4efa5e844e83f00e7c9e7b4e7cfe7e5ea2feab6000000000000"
  },
  {
   "jp_offset": "0x61bf",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "与他们一战、亲自检验一下你培养至今的{00}部队实力、也不错",
   "zh_hex": "15e832e80ce7bbefb6ef2802e894efb5ee40ea99efb6ef4de7b8edfeec0be897efb9e7b400ef70e7c9e87fefb002e7c0e7b5e8850000000000"
  },
  {
   "jp_offset": "0x61e4",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "在自由对战中选择『特殊演习』、便可与{00}他们一战",
   "zh_hex": "15ef29efb5e8a6e7beef28ef4ee966eaaa0ce7cfed7bea2feab60d02e8fae7c4e83200e80ce7bbefb6ef2800000000000000"
  },
  {
   "jp_offset": "0x6209",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "……那么、『SD高达G世代DS』",
   "zh_hex": "150909e7b7e7bd020cef9eef96e812ef2beed1e83ce8e7ef96ef9e0d0000000000000000"
  },
  {
   "jp_offset": "0x622d",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "今后也希望你、慢慢地尽情玩到最后",
   "zh_hex": "15efb9e7fee7c0e87be965e7b802e979e979ef63e8f2e88be970e7d7e8c5e7fe0000000000"
  },
  {
   "jp_offset": "0x62a6",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "谢谢你、一直陪着我这样一个靠不住的舰{00}长走到现在",
   "zh_hex": "15e8b2e8b2e7b802efb6e875ef42e86defcce7b9e7daefb6e828e8c7e7b5e859e7b4e7d400ef34e890e7d7e82fef29000000000000"
  },
  {
   "jp_offset": "0x62c5",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "这条『平成高达路线』、就到此告一段落{00}了",
   "zh_hex": "15e7b9e9d40ce887e837e812ef2be8d2e9160d02e7c5e7d7e7cae8e5efb6ea6be92a00e7ba000000000000"
  },
  {
   "jp_offset": "0x62e3",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "虽说、我们预防者的战斗、已经到此结束{00}了……",
   "zh_hex": "15e8b8e7ed02efcce7bbea5ae968ef6ee7b4ef28e7ff02ef3ae8b7e7d7e7cae868e89500e7ba0909000000000000"
  },
  {
   "jp_offset": "0x62fd",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "不过游戏本身还可以继续玩哦、今后也请{00}你继续尽情享受",
   "zh_hex": "15e7b5ef36ea94ea3eefa6e88de7f7e7c4e7f3e9d6e9ade970e91902efb9e7fee7c0e83a00e7b8e9d6e9ade8f2e88bec06e8c80000000000000000"
  },
  {
   "jp_offset": "0x6323",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "为将这条路线一直玩到最后的你、还准备{00}了新的关卡哦",
   "zh_hex": "15e7c1e84ae7b9e9d4e8d2e916efb6e875e970e7d7e8c5e7fee7b4e7b802e7f7e87ae87700e7baef8ae7b4e8bbe801e919000000000000"
  },
  {
   "jp_offset": "0x6347",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "那是与我们分头、一直在和提坦斯、新吉{00}翁作战的……",
   "zh_hex": "15e7b7e7b6e8328be7bbcde92e0287e875ef29e7d3e821e843e7c802ef8ae7d900ee88ef2fef28e7b40909000000000000"
  },
  {
   "jp_offset": "0x6362",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "……隆德·贝尔队进行的特别演习哦",
   "zh_hex": "150909ed16e82c04e857e7e1e7c9e8929fe7b4e7cfe7e5ea2feab6e91900000000000000"
  },
  {
   "jp_offset": "0x6375",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "在自由对战中选择『特别演习』、就能和{00}他们交战哦",
   "zh_hex": "15ef29efb5e8a6e7beef28ef4ee966eaaa0ce7cfe7e5ea2feab60d02e7c5e7c6e7d300e80ce7bbe861ef28e919000000000000"
  },
  {
   "jp_offset": "0x639b",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "请你务必、来挑战看看哦",
   "zh_hex": "15e83ae7b8e94fe86002efcfeae7ef28e7f6e7f6e919000000"
  },
  {
   "jp_offset": "0x63a9",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "……那么、『SD高达G世代DS』",
   "zh_hex": "150909e7b7e7bd020cef9eef96e812ef2beed1e83ce8e7ef96ef9e0d0000000000000000"
  },
  {
   "jp_offset": "0x63cd",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "『自由对战的战火！冲锋吧、大天使号！{00}！』",
   "zh_hex": "150cefb5e8a6e7beef28e7b4ef28e8daef97e95ee967e7d002efa5e844e83fe833ef9700ef970d000000000000"
  },
  {
   "jp_offset": "0x644e",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "我是主天使号的舰长、娜塔尔·巴基露露{00}中佐",
   "zh_hex": "15efcce7b6e954e844e83fe833e7b4e7d4ef3402e7eae945e7e1ef4be85be829e858e85800ef4eefba000000"
  },
  {
   "jp_offset": "0x645e",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "首先、请允许我向你一路以来出色的指挥{00}致以敬意",
   "zh_hex": "15ef40b802e83aecade8a78b9de7b887e8d2e7f3d9afe89fe7b4e8c0e94900ea32e7f3ee38ef3c0000000000000000000000000000"
  },
  {
   "jp_offset": "0x6480",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "多亏了你的协力、我们才得以一直奋战到{00}了最后",
   "zh_hex": "15e7e9eab7e7bae7b8e7b4e8f6efb002efcce7bbe836e80ae7f3efb6e875ef46ef28e7d700e7bae8c5e7fe00000000000000"
  },
  {
   "jp_offset": "0x64a2",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "这条『对手路线』、就到此结束了",
   "zh_hex": "15e7b9e9d40ce7beef66e8d2e9160d02e7c5e7d7e7cae868e895e7ba000000000000"
  },
  {
   "jp_offset": "0x64b8",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "虽说、我们主天使队的战斗、已经到此结{00}束……",
   "zh_hex": "15e8b8e7ed02efcce7bbe954e844e83fe7c9e7b4ef28e7ff02ef3ae8b7e7d7e7cae86800e895090900000000"
  },
  {
   "jp_offset": "0x64d1",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "游戏本身仍然可以继续、今后也请你继续{00}尽情享受",
   "zh_hex": "15ea94ea3eefa6e88deab9e7efe7c4e7f3e9d6e9ad02efb9e7fee7c0e83ae7b8e9d6e9ad00e8f2e88bec06e8c8000000000000"
  },
  {
   "jp_offset": "0x64f5",
   "jp_len": 43,
   "kind": "dialogue",
   "zh_text": "自由对战今后仍可继续、另外、只要选择{00}『特别演习』……",
   "zh_hex": "15efb5e8a6e7beef28efb9e7feeab9e7c4e9d6e9ad02e99be8f702ef32ef2ae966eaaa000ce7cfe7e5ea2feab60d0909000000000000"
  },
  {
   "jp_offset": "0x6520",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "还能与隆德·贝尔、预防者进行联合演习",
   "zh_hex": "15e7f7e7c6e832ed16e82cef4be857e7e102ea5ae968ef6ee892efd6ef2eefc0ea2feab600000000"
  },
  {
   "jp_offset": "0x653e",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "我相信、以你的实力、与他们一战也定能{00}取胜",
   "zh_hex": "15efcce8b1e90f02e7f3e7b8e7b4e87fefb002e832e80ce7bbefb6ef28e7c0e867e7c600e987e8db00000000000000"
  },
  {
   "jp_offset": "0x6563",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "……那么、『SD高达G世代DS』",
   "zh_hex": "150909e7b7e7bd020cef9eef96e812ef2beed1e83ce8e7ef96ef9e0d0000000000000000"
  },
  {
   "jp_offset": "0x6587",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "今后也祝你武运长久",
   "zh_hex": "15efb9e7fee7c0ed97e7b8e8ece986ef34e9db00000000"
  }
 ]
}
