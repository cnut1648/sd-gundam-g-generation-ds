{
 "file": "_STGSP6S.bin",
 "source_size": 36540,
 "built_size": 37866,
 "edits": [
  {
   "jp_offset": "0x17b9",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "嗯？怎么回事？",
   "zh_hex": "15e86505e7f2e7bdef52efb8050000"
  },
  {
   "jp_offset": "0x17de",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "军本部发来了通信",
   "zh_hex": "15e7e0efa6ef70e870efcfe7baef59e90f0000"
  },
  {
   "jp_offset": "0x17e9",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "命令我们与地球轨道舰队会合",
   "zh_hex": "15e853e94e8be7bbe832bf95e9cce82ae7d4e7c9e7e2a0000000000000"
  },
  {
   "jp_offset": "0x181c",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "军方动作还真快啊",
   "zh_hex": "15e7e0efb1ef30ef2fe7f7e820e85fe7c30000"
  },
  {
   "jp_offset": "0x1829",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "好、航向地球！与轨道舰队会合！",
   "zh_hex": "15e7c702e9c19dbf9506e832e9cce82ae7d4e7c9e7e2a0060000000000000000"
  },
  {
   "jp_offset": "0x1859",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "这里是主天使队、娜塔尔·巴基露露中佐",
   "zh_hex": "15e7b9ef31e7b6e954e844e83fe7c902e7eae945e7e1ef4be85be829e858e858ef4eefba0000"
  },
  {
   "jp_offset": "0x1889",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "我是地球轨道舰队司令",
   "zh_hex": "158be7b6bf95e9cce82ae7d4e7c9eafee94e0000000000"
  },
  {
   "jp_offset": "0x1895",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "追讨海盗、辛苦了啊、巴基露露中佐",
   "zh_hex": "15e8dde9f7e91be9f302ea58e9e6e7bae7c302e85be829e858e858ef4eefba0000"
  },
  {
   "jp_offset": "0x18ce",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "那就是你们俘获的海盗旗舰吧？",
   "zh_hex": "15e7b7e7c5e7b6e7b8e7bbeadbe9d8e7b4e91be9f3eb0be7d4e7d0050000"
  },
  {
   "jp_offset": "0x18e4",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "事不宜迟、立刻把它移交给我们吧",
   "zh_hex": "15efb8e7b5ecc9ea1002e86be91fe81be978ec83e861e839efcce7bbe7d00000"
  },
  {
   "jp_offset": "0x1911",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……什么？",
   "zh_hex": "150909e7dde7bd050000"
  },
  {
   "jp_offset": "0x1918",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "请、请等一下！你们是不是有什么误会！{00}？",
   "zh_hex": "15e83a02e83ae826efb6ef4def97e7b8e7bbe7b6e7b5e7b6e7cbe7dde7bdea33e7e2ef9700050000"
  },
  {
   "jp_offset": "0x1935",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "他们是我们的合作者……",
   "zh_hex": "15e80ce7bbe7b6efcce7bbe7b4efc0ef2fef6e09090000"
  },
  {
   "jp_offset": "0x1969",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……并非如此",
   "zh_hex": "150909e957e8f0e7f0e7ca0000"
  },
  {
   "jp_offset": "0x1999",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "那些人、是十字先锋",
   "zh_hex": "15e7b7e8a4efb202e7b6ea4ae980ef8be9670000"
  },
  {
   "jp_offset": "0x19aa",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "是一直袭击我们木星公社运输船团的海盗",
   "zh_hex": "15e7b6efb6e875e9aee7ccefcce7bbefa9ef69e9a4ed96e986e8b9ea02ea5ee7b4e91be9f30000"
  },
  {
   "jp_offset": "0x19ed",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……木星帝国！？",
   "zh_hex": "150909efa9ef69e8f8efc4ef97050000"
  },
  {
   "jp_offset": "0x1a19",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "贝拉小姐……！",
   "zh_hex": "15e857e7c2e83ee9210909ef970000"
  },
  {
   "jp_offset": "0x1a48",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……司令！！",
   "zh_hex": "150909eafee94eef97ef970000"
  },
  {
   "jp_offset": "0x1a6c",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "你们主天使队奉政府之命前去讨伐海盗、{00}并成功将其俘获",
   "zh_hex": "15e7b8e7bbe954e844e83fe7c9eac1ea68ea60e7cde853ef51e7ebe9f7eb26e91be9f30200e957e837e9b1e84ae8cfeadbe9d80000"
  },
  {
   "jp_offset": "0x1a8d",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "……是这么回事吧？巴基露露中佐",
   "zh_hex": "150909e7b6e7b9e7bdef52efb8e7d005e85be829e858e858ef4eefba0000"
  },
  {
   "jp_offset": "0x1aa1",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "否则、连你们也会被当成海盗同伙、一并{00}击毁",
   "zh_hex": "15e9bbea8702e86ee7b8e7bbe7c0e7e2e7f1ef53e837e91be9f3e85de7fd02efb6e95700e7cce97c0000"
  },
  {
   "jp_offset": "0x1ad6",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "你们、竟然比起我们更相信木星那些人！{00}？",
   "zh_hex": "15e7b8e7bb02ef2ce7efe825e8478be7bbe952e8b1e90fd4b5e7b7e8a4b406000500000000000000"
  },
  {
   "jp_offset": "0x1b07",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……那是当然！",
   "zh_hex": "150909e7b7e7b6ef53e7efef970000"
  },
  {
   "jp_offset": "0x1b12",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "十字先锋、可是和联邦交过战的！！",
   "zh_hex": "15ea4ae980ef8be96702e7c4e7b6e7d3ef2eefaae861ef36ef28e7b4ef97ef970000"
  },
  {
   "jp_offset": "0x1b2e",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "和长期与联邦合作的木星公社、信用度天{00}差地别！",
   "zh_hex": "15e7d3ef34eac9e832ef2eefaaefc0ef2fe7b4efa9ef69e9a4ed9602e90fefb3e96de84400e9c7ef63e7e5ef970000"
  },
  {
   "jp_offset": "0x1b55",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "来吧、巴基露露中佐！把那帮海盗交出来{00}！！",
   "zh_hex": "15efcfe7d002e85be829e858e858ef4eefbaef97e81be7b7e910e91be9f3e861efbeefcf00ef97ef970000"
  },
  {
   "jp_offset": "0x1b93",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "唔……！",
   "zh_hex": "15e81d0909ef970000"
  },
  {
   "jp_offset": "0x1bb5",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "巴基露露中佐！！",
   "zh_hex": "15e85be829e858e858ef4eefbaef97ef970000"
  },
  {
   "jp_offset": "0x1be3",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "此令恕难从命！",
   "zh_hex": "15e7cae94eeb04e866e88ae853060000"
  },
  {
   "jp_offset": "0x1c11",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bd06050000"
  },
  {
   "jp_offset": "0x1c41",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……巴基露露舰长！",
   "zh_hex": "150909e85be829e858e858e7d4ef34ef970000"
  },
  {
   "jp_offset": "0x1c6c",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "放心、我绝不会把你们交出去",
   "zh_hex": "15e86ce82d02efcce91ce7b5e7e2e81be7b8e7bbe861efbee7eb0000"
  },
  {
   "jp_offset": "0x1ca8",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "你这是什么意思、中佐！？",
   "zh_hex": "15e7b8e7b9e7b6e7dde7bdef3cefca02ef4eefbaef97050000"
  },
  {
   "jp_offset": "0x1cdd",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "我曾从某人身上学到",
   "zh_hex": "15efccea2ae88aeae8efb2e88def4ceb55e7d70000"
  },
  {
   "jp_offset": "0x1cf2",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "在作为军人行动之前、首先得作为一个人{00}、做正确的事！",
   "zh_hex": "15ef29ef2fe7c1e7e0efb2efd6ef30e7cdef5102ef40ef8be80aef2fe7c1efb6e828efb20002e81cef3be88ce7b4efb8ef970000"
  },
  {
   "jp_offset": "0x1d38",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "这里由我来挡住！快走、贝拉·罗纳！",
   "zh_hex": "15e7b9ef31e8a6efccefcfea77e859ef97e85fe89002e857e7c2ef4be7ece882ef970000"
  },
  {
   "jp_offset": "0x1d6a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "是、是的！！",
   "zh_hex": "15e7b602e7b6e7b4ef97ef970000"
  },
  {
   "jp_offset": "0x1d98",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "可恶的海盗、休想逃！！",
   "zh_hex": "15e7c4e7dee7b4e91be9f302e90ee7e6e8c2ef97ef970000"
  },
  {
   "jp_offset": "0x1dc0",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "是埋伏……！？",
   "zh_hex": "15e7b6ed44edd60909ef97050000"
  },
  {
   "jp_offset": "0x1df1",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "可恶！",
   "zh_hex": "15e7c4e7deef970000"
  },
  {
   "jp_offset": "0x1e1d",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "不行、托比亚！！",
   "zh_hex": "15e7b59f02e7f4e825e7d606060000000000"
  },
  {
   "jp_offset": "0x1e28",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "我们不能和联邦军交战！",
   "zh_hex": "15efcce7bbe7b5e7c6e7d3ef2eefaae7e0e861ef28ef970000"
  },
  {
   "jp_offset": "0x1e5b",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "可、可是、贝拉小姐！再这样下去……",
   "zh_hex": "15e7c402e7c4e7b602e857e7c2e83ee921ef97e80be7b9e7daef4de7eb09090000"
  },
  {
   "jp_offset": "0x1e7a",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x1e7b",
   "jp_len": 51,
   "kind": "script",
   "zh_hex": "1533020001060c02137812330200010622001320113302000106190006220013f91133020002150909ef3def3d02e7d8e88502e7f4e825e7d60000"
  },
  {
   "jp_offset": "0x1f0b",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "这可让人为难啊……非得让你们打一场不{00}可！",
   "zh_hex": "15e7b9e7c4e7f9efb2e7c1e866e7c30909e8f0e80ae7f9e7b8e7bbe7f5efb6e876e7b500e7c4ef970000"
  },
  {
   "jp_offset": "0x1f45",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "扎比涅！？",
   "zh_hex": "15e84be825eacf0605000000"
  },
  {
   "jp_offset": "0x1f71",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "呵呵呵呵……",
   "zh_hex": "15ef3def3def3def3d09090000"
  },
  {
   "jp_offset": "0x1fa0",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "可恶、该死的海盗们！！",
   "zh_hex": "15e7c4e7de02e898ef6ae7b4e91be9f3e7bbef97ef970000"
  },
  {
   "jp_offset": "0x1fd3",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "司令！！",
   "zh_hex": "15eafee94eef97ef970000"
  },
  {
   "jp_offset": "0x1ff6",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "你们都给我待在原地别动！敢动就把你们{00}也当海盗同伙！",
   "zh_hex": "15e7b8e7bbe840e839efcceaa8ef29e8e4ef63e7e5ef30ef97e8cdef30e7c5e81be7b8e7bb00e7c0ef53e91be9f3e85de7fdef970000"
  },
  {
   "jp_offset": "0x2033",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "事到如今、还说这种话……！",
   "zh_hex": "15efb8e7d7e7f0efb902e7f7e7ede7b9e7d1e81f0909ef970000"
  },
  {
   "jp_offset": "0x2065",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "巴基露露中佐、你这家伙！？",
   "zh_hex": "15e85be829e858e858ef4eefba02e7b8e7b9e7dfe7fdef97050000"
  },
  {
   "jp_offset": "0x208c",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "你根本不懂木星帝国的危险、你的劝告、{00}我不会听从",
   "zh_hex": "15e7b8e9b8efa6e7b5e8b0efa9ef69e8f8efc4e7b4e935e93202e7b8e7b4ebb6e8e50200efcce7b5e7e2e8d1e88a0000"
  },
  {
   "jp_offset": "0x20ab",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "我们主天使队、将支援先锋母舰！",
   "zh_hex": "158be7bbe954e844e83fe7c902e84ae883e863b8e967e9d5e7d40600000000000000"
  },
  {
   "jp_offset": "0x20ca",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "各舰立刻进入战斗态势！掩护贝拉舰长突{00}破包围！！",
   "zh_hex": "15e819e7d4e86be91fe892e891ef28e7ffe994e8fdef97ec72e8e0e857e7c2e7d4ef34e8b600ef6deabbe9deef97ef970000"
  },
  {
   "jp_offset": "0x2111",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "好！趁现在！全舰、立刻后退！！",
   "zh_hex": "15e7c7ef97e9eae82fef29ef97efb4e7d402e86be91fe7fee880ef97ef970000"
  },
  {
   "jp_offset": "0x2151",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "看来、木星帝国已经往地球圈派进了相当{00}多的部队",
   "zh_hex": "15e7f6efcf02efa9ef69e8f8efc4ef3ae8b7e911ef63efd3e9fbe985e892e7bae8b1ef5300e7e9e7b4ef70e7c90000"
  },
  {
   "jp_offset": "0x2176",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "打着协助讨伐海盗的名义、在各地驻扎部{00}队",
   "zh_hex": "15e7f5e86de8f6ea23e9f7eb26e91be9f3e7b4e8ace8ce02ef29e819ef63eca2e84bef7000e7c90000"
  },
  {
   "jp_offset": "0x21af",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "对不起、都是因为我们……",
   "zh_hex": "15e7bee7b5e84702e840e7b6ef33e7c1efcce7bb09090000"
  },
  {
   "jp_offset": "0x21dc",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "不、不怪你们、是被木星帝国利用了",
   "zh_hex": "15e7b502e7b5ea07e7b8e7bb02e7b6e7f1d4b5e8f8a1e82ed8e7ba000000000000"
  },
  {
   "jp_offset": "0x2214",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "木星帝国那帮家伙、如今在地球圈大摇大{00}摆地横行",
   "zh_hex": "15efa9ef69e8f8efc4e7b7e910e7dfe7fd02e7f0efb9ef29ef63efd3e9fbefa5ebccefa500eb8bef63ec77efd60000"
  },
  {
   "jp_offset": "0x2235",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "离他们动手也不远了",
   "zh_hex": "15e901e80ce7bbef30ef66e7c0e7b5e94ce7ba0000"
  },
  {
   "jp_offset": "0x226c",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "地球联邦、还没察觉到木星帝国的恶意",
   "zh_hex": "15ef63efd3ef2eefaa02e7f7e7d8ea8be8aee7d7efa9ef69e8f8efc4e7b4e7deef3c0000"
  },
  {
   "jp_offset": "0x2287",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "一旦木星帝国就这样发动进攻……",
   "zh_hex": "15efb6ebcdefa9ef69e8f8efc4e7c5e7b9e7dae870ef30e892ef6709090000"
  },
  {
   "jp_offset": "0x22bd",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "联邦军恐怕一下就撑不住了",
   "zh_hex": "15ef2eefaae7e0eb33e958efb6ef4de7c5ea29e7b5e859e7ba0000"
  },
  {
   "jp_offset": "0x22fc",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……我父亲他",
   "zh_hex": "150909efcce888e894e80c0000"
  },
  {
   "jp_offset": "0x2304",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我父亲曾说过、地球这种东西、他根本不{00}需要",
   "zh_hex": "15efcce888e894ea2ae7edef3602ef63efd3e7b9e7d1e8bae7f802e80ce9b8efa6e7b500e92def2a0000"
  },
  {
   "jp_offset": "0x2339",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "那意思是……木星帝国连地球本身都要当{00}成攻击目标吗？",
   "zh_hex": "15e7b7ef3cefcae7b60909efa9ef69e8f8efc4e86eef63efd3efa6e88de840ef2aef5300e837ef67e7ccefd4e96fe802050000"
  },
  {
   "jp_offset": "0x2375",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "我不知道原因、但父亲他……一直憎恨着{00}地球",
   "zh_hex": "158be7b5e85ae82ae8e4ef3302e7dbe888e894e80c090987e875eb34e9bee86d00bf95000000000000"
  },
  {
   "jp_offset": "0x2395",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "尽管我不愿相信父亲会做出那种事……",
   "zh_hex": "15e8f2e93befcce7b5e961e8b1e90fe888e894e7e2e81cefbee7b7e7d1efb809090000"
  },
  {
   "jp_offset": "0x23ca",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "若战火之雨、再次落在无辜的人们头上…{00}…",
   "zh_hex": "15e7e7ef28e8dae7cdebad02e80be864e92aef29e7dced0de7b4efb2e7bbe92eef4c0900090000"
  },
  {
   "jp_offset": "0x23ed",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "那必将如昔日的纷争一般、催生出无数悲{00}剧",
   "zh_hex": "15e7b7e860e84ae7f0ec55e98ae7b4ecf8e85287ea8002ed22b6afe7dce914e9df00ecb50000000000"
  },
  {
   "jp_offset": "0x240d",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "唯独这一点、必须阻止才行",
   "zh_hex": "15ea89e8eee7b9efb6e82202e860e9a2e8efe869e836efd60000"
  },
  {
   "jp_offset": "0x2440",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "只能阻止它了……靠我们自己的手",
   "zh_hex": "15ef32e7c6e8efe869e978e7ba0909e8c7efcce7bbefb5e8c9e7b4ef660000"
  },
  {
   "jp_offset": "0x245d",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x245e",
   "jp_len": 56,
   "kind": "script",
   "zh_hex": "153302000106c000137812330200010658001320113302000115e81be819e834ecbae7bae892d90200e820e7b6e922e92709090000"
  },
  {
   "jp_offset": "0x24b1",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "无妨、我们只做认定该做的事",
   "zh_hex": "15e7dce97f028be7bbef32e81ce8a0e867e898e81ce7b4a90000"
  },
  {
   "jp_offset": "0x24f0",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "胜算虽低、只能干了",
   "zh_hex": "15e8dbe889e8b8ec0802ef32e7c6e8d3e7ba0000"
  },
  {
   "jp_offset": "0x2512",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x2513",
   "jp_len": 53,
   "kind": "script",
   "zh_hex": "1533020001068f00137812330200010642001320113302000115e7b502e7e7efa9ef69e8f8efc4ef3ceb2de7beef63efd3efbeef66e7b7efcce7bbe7c500e7cbe8dbe8890000"
  },
  {
   "jp_offset": "0x2563",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "托比亚",
   "zh_hex": "15e7f4e825e7d60000"
  },
  {
   "jp_offset": "0x2587",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "杜加奇若恨地球……",
   "zh_hex": "15e8cbe854e904e7e7e9bebf9509090000"
  },
  {
   "jp_offset": "0x259e",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "那个男人、一定会想亲手给地球来上致命{00}一击",
   "zh_hex": "15e7b7e828ea95efb202efb6e867e7e2e7e6e894ef66e839ef63efd3efcfef4cea32e85300efb6e7cc0000"
  },
  {
   "jp_offset": "0x25be",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "只要抓住这一点……！",
   "zh_hex": "15ef32ef2ae962e859e7b9efb6e8220909ef970000"
  },
  {
   "jp_offset": "0x25e5",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "木星帝国受杜加奇严密管制……",
   "zh_hex": "15d4b5e8f8a1e8c8e8cbe854e904eaa1e9bde93be8de09090000"
  },
  {
   "jp_offset": "0x261e",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "打倒杜加奇即可",
   "zh_hex": "15e7f5e848e8cbe854e904e855e7c40000"
  },
  {
   "jp_offset": "0x264b",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "行动吧、舰长！别让悲剧重演！",
   "zh_hex": "159fef30e7d002e7d4ef3406e7e5e7f9e9dfecb5e8a1ea2f060000"
  },
  {
   "jp_offset": "0x268d",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "正有此意",
   "zh_hex": "15ef3be7cbe7caef3c0000"
  },
  {
   "jp_offset": "0x26a4",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x26a5",
   "jp_len": 44,
   "kind": "script",
   "zh_hex": "1533020001069c00137812330200010646001320113302000115e819e7d4e86be855e87ae877efbee7cc0000"
  },
  {
   "jp_offset": "0x26d1",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "从现在起、我们就向木星帝国军发起决战{00}！！",
   "zh_hex": "15e88ae82fef29e84702efcce7bbe7c5efc1efa9ef69e8f8efc4e7e0e870e847e8abef2800ef97ef970000"
  },
  {
   "jp_offset": "0x70aa",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "唔……！竟要栽在这种地方……！！",
   "zh_hex": "15e81d090906ef2cef2aec5def29e7b9e7d1bfd00909060600000000000000"
  },
  {
   "jp_offset": "0x732e",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "诸位、是地球轨道舰队的吧？",
   "zh_hex": "15ea56e83402e7b6bf95e9cce82ae7d4e7c9e7b4e7d00500000000"
  },
  {
   "jp_offset": "0x7340",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我们奉杜加奇阁下之命、特来支援贵队！{00}！",
   "zh_hex": "158be7bbeac1e8cbe854e904e8d789e7cde85302e7cfd9e883e863e930e7c906000600000000000000"
  },
  {
   "jp_offset": "0x737d",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "哦哦、是木星的诸位啊！！多谢相助！",
   "zh_hex": "15e919e91902e7b6efa9ef69e7b4ea56e834e7c3ef97ef97e7e9e8b2e8b1ea23ef970000"
  },
  {
   "jp_offset": "0x73d7",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "（呵呵……扎比涅·夏尔……干得漂亮）",
   "zh_hex": "150aef3def3d0909e84be825eacf04ef37e7e10909e8d3e80aead0eaa20b0000000000"
  },
  {
   "jp_offset": "0x73ef",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "（这下、要让大军开进地球圈、就更容易{00}了……）",
   "zh_hex": "150ae7b98902ef2ae7f9bee7e0e7fae892bf95e9fb02e7c5e952ed2fe96400e7ba09090b0000000000000000"
  },
  {
   "jp_offset": "0x7414",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "好！MS队、出击！！",
   "zh_hex": "15e7c7ef97efa7ef9ee7c902efbee7ccef97ef970000"
  },
  {
   "jp_offset": "0x7423",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "与联邦军联手、把那帮海盗一举击溃！！",
   "zh_hex": "15e832ef2eefaae7e0ef2eef6602e81be7b7e910e91be9f3efb6ea21e7ccec79ef97ef970000"
  },
  {
   "jp_offset": "0x7462",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x7471",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "难道是……贝尔纳黛特！？",
   "zh_hex": "15e866e82ae7b60909e857e7e1e882ea9ae7cf0605000000"
  },
  {
   "jp_offset": "0x7499",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "托比亚……！！",
   "zh_hex": "15e7f4e825e7d60909060600000000"
  },
  {
   "jp_offset": "0x74bd",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "果然是你、贝尔纳黛特！！",
   "zh_hex": "15e871e7efe7b6e7b802e857e7e1e882ea9ae7cfef97ef970000"
  },
  {
   "jp_offset": "0x74c9",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "你怎么会在这里……！？",
   "zh_hex": "15e7b8e7f2e7bde7e2ef29e7b9ef310909ef97050000"
  },
  {
   "jp_offset": "0x74ef",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "不行、托比亚！快逃！！",
   "zh_hex": "15e7b59f02e7f4e825e7d606e85fe8c20606000000000000"
  },
  {
   "jp_offset": "0x751a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "贝尔纳黛特！？",
   "zh_hex": "15e857e7e1e882ea9ae7cfef97050000"
  },
  {
   "jp_offset": "0x753e",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "不行啊！",
   "zh_hex": "15e7b5efd6e7c3ef970000"
  },
  {
   "jp_offset": "0x7546",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "这台机体不是我在开、是电脑在操控它…{00}…！",
   "zh_hex": "15e7b9ea16e7e4ef4fe7b5e7b6efccef29e7fa02e7b6ead3eb67ef29eac7ea3fe978090009ef970000"
  },
  {
   "jp_offset": "0x755f",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我根本拦不住它！所以快逃啊、托比亚！{00}！",
   "zh_hex": "158be9b8d2eb89e7b5e859e97806e7fbe7f3e85fe8c2e7c302e7f4e825e7d606000600000000000000"
  },
  {
   "jp_offset": "0x7594",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "可恶！杜加奇！！竟然对亲生女儿做出这{00}种事！",
   "zh_hex": "15e7c4e7de06e8cbe854e9040606ef2ce7efe7bee894b6b0eb7ce81cafe7b900e7d1a90600000000000000000000"
  },
  {
   "jp_offset": "0x75c9",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "托比亚……！",
   "zh_hex": "15e7f4e825e7d6090906000000"
  },
  {
   "jp_offset": "0x75ec",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "别怕、贝尔纳黛特！！我马上……",
   "zh_hex": "15e7e5e95802e857e7e1e882ea9ae7cfef97ef97efcce84fef4c09090000"
  },
  {
   "jp_offset": "0x7603",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "立刻把你从那里面救出来！！",
   "zh_hex": "15e86be91fe81be7b8e88ae7b7ef31e862e8caefbeefcfef97ef970000"
  },
  {
   "jp_offset": "0x763a",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "那是什么……！？那台机动装甲……",
   "zh_hex": "15e7b7e7b6e7dde7bd0909ef9705e7b7ea16e7e4ef30e98febdb09090000"
  },
  {
   "jp_offset": "0x764d",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "里面不是贝尔纳黛特、我感觉到了另一股{00}气息！！",
   "zh_hex": "15ef31e862e7b5e7b6e857e7e1e882ea9ae7cf02efcce87de8aee7d7e7bae99befb6edac00e8edec6aef97ef970000"
  },
  {
   "jp_offset": "0x7666",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "是谁！是谁在那里面！？",
   "zh_hex": "15e7b6e923ef97e7b6e923ef29e7b7ef31e862ef97050000"
  },
  {
   "jp_offset": "0x76ab",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "呼哈哈哈哈！好眼力啊、臭小子！！",
   "zh_hex": "15ea3ce7e8e7e8e7e8e7e8ef97e7c7e90befb0e7c302ecfde83ee886ef97ef970000"
  },
  {
   "jp_offset": "0x76cf",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x76d0",
   "jp_len": 42,
   "kind": "script",
   "zh_hex": "1533020001064f0113781233020001068d001320113302000115e7b9ea8aea71ef9705e7b6e888e894efa5efb2ef97050000"
  },
  {
   "jp_offset": "0x771b",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "杜加奇！",
   "zh_hex": "15e8cbe854e904060000"
  },
  {
   "jp_offset": "0x7732",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x7733",
   "jp_len": 51,
   "kind": "script",
   "zh_hex": "1533020001063c011378123302000106800013201133020001060300068000133d113302000215ef3be7b602e83ee8860000"
  },
  {
   "jp_offset": "0x7766",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "操控它的是杜加奇……",
   "zh_hex": "15eac7ea3fe978e7b4e7b6e8cbe854e90409090000"
  },
  {
   "jp_offset": "0x777e",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "是把他的思维模式转写而成的生体头脑",
   "zh_hex": "15e7b6e81be80ce7b4efcaea54ea91ea26e9c2ede3e89ce837e7b4ef8def4fe92eeb670000"
  },
  {
   "jp_offset": "0x7792",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "可就算你看穿了、又能怎样呢、臭小子？",
   "zh_hex": "15e7c4e7c5e889e7b8e7f6ea7ee7ba02e8f1e7c6e7f2e7dae90702ecfde83ee886050000"
  },
  {
   "jp_offset": "0x77b7",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x77b8",
   "jp_len": 35,
   "kind": "script",
   "zh_hex": "1533020001068f0013781233020001064200132011330200011509e7dde7bd06050000"
  },
  {
   "jp_offset": "0x77e6",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x77e7",
   "jp_len": 63,
   "kind": "script",
   "zh_hex": "1533020001063c011378123302000106800013201133020001060300068000133d113302000215e7b8e7e6e8cae7b4b0e95602e7c500ef298be7b4aec00000"
  },
  {
   "jp_offset": "0x7826",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "你还下得了手吗！？",
   "zh_hex": "15e7b8e7f7ef4de80ae7baef66e802ef97050000"
  },
  {
   "jp_offset": "0x783d",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x783e",
   "jp_len": 43,
   "kind": "script",
   "zh_hex": "1533020001068f00137812330200010642001320113302000115e7b7e7c4e7b6e7b8e7b4e894ef8defadeb7ce7c3ef97ef970000"
  },
  {
   "jp_offset": "0x7869",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "这是人说得出口的话吗！你这混蛋——！{00}！",
   "zh_hex": "15e7b9e7b6efb2e7ede80aefbeeabde7b4e81fe802ef97e7b8e7b9ea41ea6debafebafef9700ef970000"
  },
  {
   "jp_offset": "0x788c",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x788d",
   "jp_len": 53,
   "kind": "script",
   "zh_hex": "1533020001063c011378123302000106800013201133020001060300068000133d113302000215e7e8e7e8e7e8e7e802e7c4ea1ce897eacaef970000"
  },
  {
   "jp_offset": "0x78c2",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "战斗哪分什么卑劣与高尚！这可是战争啊{00}！",
   "zh_hex": "15ef28e7ffe8ffefaee7dde7bdec4bec0de832e812ecceef97e7b9e7c4e7b6ef28e852e7c300ef970000"
  },
  {
   "jp_offset": "0x78eb",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "c9"
  },
  {
   "jp_offset": "0x78ec",
   "jp_len": 34,
   "kind": "script",
   "zh_hex": "1533020001068f00137812330200010642001320113302000115e82ce801eee20909ef97ef970000"
  },
  {
   "jp_offset": "0x7936",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "战争……！？",
   "zh_hex": "15ef28e8520909ef97050000"
  },
  {
   "jp_offset": "0x794b",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "格拉克斯·杜加奇！不管你怎么想……",
   "zh_hex": "15e824e7c2e7d5e7c804e8cbe854e90406e7b5e93be7b8e7f2e7bde7e6090900000000"
  },
  {
   "jp_offset": "0x796d",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "我可不是在跟你打什么战争！！",
   "zh_hex": "15efcce7c4e7b5e7b6ef29e973e7b8e7f5e7dde7bdef28e852ef97ef970000"
  },
  {
   "jp_offset": "0x7986",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "贝尔纳黛特、我要夺回来！",
   "zh_hex": "15e857e7e1e882ea9ae7cf02efccef2aea17ef52efcfef970000"
  },
  {
   "jp_offset": "0x79be",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……就是现在！！",
   "zh_hex": "150909e7c5e7b6e82fef29ef97ef970000"
  },
  {
   "jp_offset": "0x79ea",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "我一定要把贝尔纳黛特夺回来！！",
   "zh_hex": "15efccefb6e867ef2ae81be857e7e1e882ea9ae7cfea17ef52efcfef97ef970000"
  },
  {
   "jp_offset": "0x7a2e",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "唔！这臭小子！！",
   "zh_hex": "15e81def97e7b9ecfde83ee886ef97ef970000"
  },
  {
   "jp_offset": "0x7a6a",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "她可不是属于你的东西！",
   "zh_hex": "15e88ee7c4e7b5e7b6ea24e879e7b8e7b4e8bae7f8ef970000"
  },
  {
   "jp_offset": "0x7aaa",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "那么、就照我们海盗的作风……",
   "zh_hex": "15e7b7e7bd02e7c5ea1aefcce7bbe91be9f3e7b4ef2feb7509090000"
  },
  {
   "jp_offset": "0x7aea",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "我就把她笑纳了！！",
   "zh_hex": "15efcce7c5e81be88eea1ce882e7baef97ef970000"
  },
  {
   "jp_offset": "0x7b26",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "托比亚！！",
   "zh_hex": "15e7f4e825e7d6060600000000"
  },
  {
   "jp_offset": "0x7b52",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "已经没事了、贝尔纳黛特……",
   "zh_hex": "15ef3ae8b7e7d8efb8e7ba02e857e7e1e882ea9ae7cf09090000"
  },
  {
   "jp_offset": "0x7b87",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "嗯！……嗯！！",
   "zh_hex": "15e865ef970909e865ef97ef970000"
  },
  {
   "jp_offset": "0x7bde",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "托比亚……",
   "zh_hex": "15e7f4e825e7d609090000"
  },
  {
   "jp_offset": "0x7c00",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "怎么了、贝尔纳黛特？睡不着吗？",
   "zh_hex": "15e7f2e7bde7ba02e857e7e1e882ea9ae7cf05ebdee7b5e86de802050000"
  },
  {
   "jp_offset": "0x7c32",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "我在想一些事情……",
   "zh_hex": "15efccef29e7e6efb6e8a4efb8e88b09090000"
  },
  {
   "jp_offset": "0x7c65",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……贝尔纳黛特？",
   "zh_hex": "150909e857e7e1e882ea9ae7cf050000"
  },
  {
   "jp_offset": "0x7c8a",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "我父亲他……",
   "zh_hex": "15efcce888e894e80c09090000"
  },
  {
   "jp_offset": "0x7c92",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "……我总觉得、父亲他、其实早就已经死{00}了",
   "zh_hex": "150909efcce881e8aee80a02e888e894e80c02e8cfe87fe963e7c5ef3ae8b7ef6a00e7ba0000"
  },
  {
   "jp_offset": "0x7caf",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "所以如今对木星军下令的、是父亲的复制{00}人偶！",
   "zh_hex": "15e7fbe7f3e7f0efb9e7beefa9ef69e7e0ef4de94ee7b402e7b6e888e894e7b4e9eee8de00efb2ea85ef970000"
  },
  {
   "jp_offset": "0x7cce",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "否则、他绝不会做出那么残忍的事……！",
   "zh_hex": "15e9bbea8702e80ce91ce7b5e7e2e81cefbee7b7e7bde97beb59e7b4efb80909ef970000"
  },
  {
   "jp_offset": "0x7d01",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "贝尔纳黛特……",
   "zh_hex": "15e857e7e1e882ea9ae7cf09090000"
  },
  {
   "jp_offset": "0x7d25",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "听我说、托比亚！所以……所以……",
   "zh_hex": "15e8d18be7ed02e7f4e825e7d606e7fbe7f30909e7fbe7f3090900000000"
  },
  {
   "jp_offset": "0x7d3a",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "所以快阻止他！求你阻止他吧！！",
   "zh_hex": "15e7fbe7f3e85fe8efe869e80cef97e93ae7b8e8efe869e80ce7d0ef97ef970000"
  },
  {
   "jp_offset": "0x7d4c",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "别再让父亲的怨念、做出更残忍的事了！{00}！",
   "zh_hex": "15e7e5e80be7f9e888e894e7b4ec19ea2702e81cefbee952e97beb59e7b4efb8e7baef9700ef970000"
  },
  {
   "jp_offset": "0x7d80",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "……放心吧、贝尔纳黛特",
   "zh_hex": "150909e86ce82de7d002e857e7e1e882ea9ae7cf0000"
  },
  {
   "jp_offset": "0x7d93",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "我、我一定会……！！",
   "zh_hex": "15efcc02efccefb6e867e7e20909ef97ef970000"
  },
  {
   "jp_offset": "0x7dbb",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯",
   "zh_hex": "150909e8650000"
  },
  {
   "jp_offset": "0x7dda",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……巴基露露舰长！",
   "zh_hex": "150909e85be829e858e858e7d4ef34ef970000"
  },
  {
   "jp_offset": "0x7dff",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "啊、明白了！",
   "zh_hex": "15e7c302ef39e809e7baef970000"
  },
  {
   "jp_offset": "0x7e0a",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "各机、都冲向那台机动装甲！",
   "zh_hex": "15e819e7e402e840e95eefc1e7b7ea16e7e4ef30e98febdbef970000"
  },
  {
   "jp_offset": "0x7e1b",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "拦下它、把困在它内部的那名少女救出来{00}！",
   "zh_hex": "15eb89ef4de97802e81beaffef29e978e99aef70e7b4e7b7e8acefacefade8caefbeefcf00ef970000"
  },
  {
   "jp_offset": "0x7e5a",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "就趁现在！……救出贝尔纳黛特！！",
   "zh_hex": "15e7c5e9eae82fef29ef970909e8caefbee857e7e1e882ea9ae7cfef97ef970000"
  },
  {
   "jp_offset": "0x7e8e",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "我这就来！",
   "zh_hex": "158be7b9e7c5d9060000"
  }
 ]
}
