{
 "file": "_STG19B_1.bin",
 "source_size": 33732,
 "built_size": 35367,
 "edits": [
  {
   "jp_offset": "0x1472",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "维修工作进展得怎么样了？",
   "zh_hex": "15ea54e9b0eae4ef2fe892e989e80ae7f2e7bde7dae7ba050000"
  },
  {
   "jp_offset": "0x149a",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "据说很快就能完工了、不过永恒号那边稍{00}微慢了些……",
   "zh_hex": "15e8cce7ede981e85fe7c5e7c6e87eeae4e7ba02e7b5ef36e9bfeb85e833e7b7e899ead500eb58e979e7bae8a409090000"
  },
  {
   "jp_offset": "0x14d4",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "毕竟在我们赶到之前、他们就已经损失惨{00}重了呢",
   "zh_hex": "15ea2cef2cef29efcce7bbea04e7d7e7cdef5102e80ce7bbe7c5ef3ae8b7ea28e8a5ed5d00e8a1e7bae9070000"
  },
  {
   "jp_offset": "0x14ed",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "不必勉强赶工、在这里、就连扎夫特的巡{00}逻队也……",
   "zh_hex": "15e7b5e860eb2ae8adea04eae402ef29e7b9ef3102e7c5e86ee84be830e7cfe7b4ec1200ec3fe7c9e7c009090000"
  },
  {
   "jp_offset": "0x1551",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "雷达有反应！多艘战舰、正朝我们接近！",
   "zh_hex": "15e8afef2be7cbe87ce87306e7e9eb18ef28e7d402ef3beaad8be7bbb7960600000000000000"
  },
  {
   "jp_offset": "0x1583",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "扎夫特！？",
   "zh_hex": "15e84be830e7cfef97050000"
  },
  {
   "jp_offset": "0x15a5",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "不对！这股反应是……",
   "zh_hex": "15e7b5e7beef97e7b9edace87ce873e7b609090000"
  },
  {
   "jp_offset": "0x15b3",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……是联邦军！",
   "zh_hex": "150909e7b6ef2eefaae7e0ef970000"
  },
  {
   "jp_offset": "0x15d9",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "难道是OZ吗！？",
   "zh_hex": "15e866e82ae7b6ed1ceedae8020605000000"
  },
  {
   "jp_offset": "0x15ff",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "要是在这里遭到攻击、就无处可逃了……{00}！！",
   "zh_hex": "15ef2ae7b6ef29e7b9ef31eb1ee7d7ef67e7cc02e7c5e7dce903e7c4e8c2e7ba090900ef97ef970000"
  },
  {
   "jp_offset": "0x161a",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "大天使号、立即出击！迎击OZ！",
   "zh_hex": "15efa5e844e83fe83302e86be855efbee7ccef97e931e7cced1ceedaef970000"
  },
  {
   "jp_offset": "0x1636",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "也通知贝拉舰长和迪安娜女王！",
   "zh_hex": "15e7c0ef59e85ae857e7c2e7d4ef34e7d3ea11e7fce7eaefade884ef970000"
  },
  {
   "jp_offset": "0x1663",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "是、是！！",
   "zh_hex": "15e7b602e7b6ef97ef970000"
  },
  {
   "jp_offset": "0x1684",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "各舰已就位！",
   "zh_hex": "15e819e7d4ef3ae7c5e834ef970000"
  },
  {
   "jp_offset": "0x16b9",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……永恒号！？",
   "zh_hex": "150909e9bfeb85e833ef97050000"
  },
  {
   "jp_offset": "0x16e7",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "我们这边的修理也差不多完成了、从后头{00}放上几炮还是做得到的",
   "zh_hex": "15efcce7bbe7b9e899e7b4e9b0e872e7c0e9c7e7b5e7e9e87ee837e7ba02e88ae7fee92e00e86cef4ceaa5e95ae7f7e7b6e81ce80ae7d7e7b40000"
  },
  {
   "jp_offset": "0x1727",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……明白了",
   "zh_hex": "150909ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x1732",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "那么、就请到先锋母舰后方、为我们提{00}供支援",
   "zh_hex": "15e7b7e7bd02e7c5e83ae7d7b8e967e9d5e7d4e7fed002e7c18be7bbe82100eca9e883e86300000000000000"
  },
  {
   "jp_offset": "0x1762",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "我明白了",
   "zh_hex": "15efccef39e809e7ba0000"
  },
  {
   "jp_offset": "0x1793",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "……舰长！！敌方舰队、已进入攻击范围{00}！",
   "zh_hex": "150909e7d4ef34ef97ef97e7e3efb1e7d4e7c902ef3ae892e891ef67e7ccec8ee9de00ef970000"
  },
  {
   "jp_offset": "0x17c8",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "全员、准备迎击战！！",
   "zh_hex": "15efb4e84902e87ae877e931e7ccef28ef97ef970000"
  },
  {
   "jp_offset": "0x17fb",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "我是主天使号的娜塔尔·巴基露露少佐！",
   "zh_hex": "15efcce7b6e954e844e83fe833e7b4e7eae945e7e1ef4be85be829e858e858efacefbaef970000"
  },
  {
   "jp_offset": "0x180f",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "本舰、向身为叛逃舰的贵舰、要求立即无{00}条件投降！！",
   "zh_hex": "15efa6e7d402efc1e88de7c1ef43e8c2e7d4e7b4e930e7d402ef2ae93ae86be855e7dc00e9d4e991e948e943ef97ef970000"
  },
  {
   "jp_offset": "0x1848",
   "jp_len": 33,
   "kind": "script",
   "zh_hex": "152d3302000106c70013c42933020001065f00136c283302000115e7f202e7f2e7bde7e20909e7b6e7eae945e7e1ef97050000"
  },
  {
   "jp_offset": "0x188a",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "巴基露露小姐……！？",
   "zh_hex": "15e85be829e858e858e83ee9210909ef97050000"
  },
  {
   "jp_offset": "0x18ba",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "好久不见了、拉米亚斯舰长",
   "zh_hex": "15e7c7e9dbe7b5e85ce7ba02e7c2e878e7d6e7c8e7d4ef340000"
  },
  {
   "jp_offset": "0x18c6",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "竟以这样的方式重逢、我感到很遗憾",
   "zh_hex": "15ef2ce7f3e7b9e7dae7b4efb1ea26e8a1ed1102efcce87de7d7e981eba9ed610000"
  },
  {
   "jp_offset": "0x18f8",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……是啊",
   "zh_hex": "150909e7b6e7c30000"
  },
  {
   "jp_offset": "0x191b",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "阿拉斯加的事、我也有所耳闻",
   "zh_hex": "15e7d2e7c2e7c8e854e7b4efb802efcce7c0e7cbe7fbee89ebac0000"
  },
  {
   "jp_offset": "0x192f",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "……但请您就这样投降、再与军部高层好{00}好谈一次！",
   "zh_hex": "150909e7dbe83ae835e7c5e7b9e7dae948e94302e80be832e7e0ef70e812ebc1e7c700e7c7eaf4efb6e864ef970000"
  },
  {
   "jp_offset": "0x194b",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "我也会尽我所能、为您辩护！",
   "zh_hex": "15efcce7c0e7e2e8f2efcce7fbe7c602e7c1e835eeb2e8e0ef970000"
  },
  {
   "jp_offset": "0x197a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "谢谢你……娜塔尔",
   "zh_hex": "15e8b2e8b2e7b80909e7eae945e7e10000"
  },
  {
   "jp_offset": "0x1987",
   "jp_len": 20,
   "kind": "script",
   "zh_hex": "152d3302000115e7c4e7b60909e7b7e7d1efb802efcce81ce7b5e7d70000"
  },
  {
   "jp_offset": "0x19b6",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "舰长……！？",
   "zh_hex": "15e7d4ef340909ef97050000"
  },
  {
   "jp_offset": "0x19da",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "并不只是阿拉斯加的事……",
   "zh_hex": "15e957e7b5ef32e7b6e7d2e7c2e7c8e854e7b4efb809090000"
  },
  {
   "jp_offset": "0x19ea",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "我们选择了、与那企图扩大战火的OZ战{00}斗到底",
   "zh_hex": "158be7bbe966eaaae7ba02e832e7b7ebdaeb2dec1abeef28e8dae7b4ed1ceedaef2800e7ffe7d7e9b400000000"
  },
  {
   "jp_offset": "0x1a12",
   "jp_len": 27,
   "kind": "script",
   "zh_hex": "152d3302000115ef33e7ca02efcce7bbe91ce7b5e948e94302e7c0e91ce7b5e947e7c9ef970000"
  },
  {
   "jp_offset": "0x1a52",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "哎、要是说说就能讲通、这世上的纷争早{00}就没了、对吧、舰长？",
   "zh_hex": "15e9dc02ef2ae7b6e7ede7ede7c5e7c6eba2ef5902e7b9e83cef4ce7b4ecf8e852e96300e7c5e7d8e7ba02e7bee7d002e7d4ef34050000"
  },
  {
   "jp_offset": "0x1ab5",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "正因为不明白、才会成为敌人、然后……",
   "zh_hex": "15ef3bef33e7c1e7b5ef39e80902e836e7e2e837e7c1e7e3efb202e7efe7fe09090000"
  },
  {
   "jp_offset": "0x1acf",
   "jp_len": 21,
   "kind": "script",
   "zh_hex": "152d33020001150909e860e9a2e7cce848e7e3efb20000"
  },
  {
   "jp_offset": "0x1ae8",
   "jp_len": 31,
   "kind": "script",
   "zh_hex": "152d3302000115e7b5e983e7cde7d4efa5e844e83fe833efb9e844e7c5e7f9efcce9bae978e983e891e91b00e9b4e7d00000"
  },
  {
   "jp_offset": "0x1b2c",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "敌MS部队展开！",
   "zh_hex": "15e7e3efa7ef9eef70e7c9e989e7faef970000"
  },
  {
   "jp_offset": "0x1b52",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "迎击！全舰、进入一级战斗配置！！",
   "zh_hex": "15e931e7ccef97efb4e7d402e892e891efb6eaeeef28e7ffea34ea0eef97ef970000"
  },
  {
   "jp_offset": "0x1b8a",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "那么……该怎么办才好呢？没想到大幕、{00}已经拉开了啊",
   "zh_hex": "15e7b7e7bd0909e898e7f2e7bde8eae836e7c7e90705e7d8e7e6e7d7efa5ec140200ef3ae8b7e7c2e7fae7bae7c30000"
  },
  {
   "jp_offset": "0x1bc3",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "看来双方战力、几乎不相上下……",
   "zh_hex": "15e7f6efcfeabcefb1ef28efb002eaa5e933e7b5e8b1ef4cef4d09090000"
  },
  {
   "jp_offset": "0x1bf5",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "介入也得看准时机",
   "zh_hex": "15ea84e891e7c0e80ae7f6e87aef2de7e40000"
  },
  {
   "jp_offset": "0x1c09",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "总之、情报还不够",
   "zh_hex": "15e881e7cd02e88be913e7f7e7b5e9200000"
  },
  {
   "jp_offset": "0x1c1c",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "我从殖民地内部潜入、先着手收集情报吧",
   "zh_hex": "158be88ae8a9ef38bfe99acceb3ce89102b8e86daee926ea98e88be913e7d000000000000000"
  },
  {
   "jp_offset": "0x1c58",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "要队长您亲自前往吗？",
   "zh_hex": "15ef2ae7c9ef34e835e894efb5ef51e911e802050000"
  },
  {
   "jp_offset": "0x1c7f",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "毕竟这舞台非同一般啊",
   "zh_hex": "15ea2cef2ce7b9eb9eea16e8f0e85defb6ea80e7c30000"
  },
  {
   "jp_offset": "0x1c8a",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "孟德尔殖民地……只要周旋得当、诸多事{00}情都能了结",
   "zh_hex": "15ec5ee82ce7e1e8a9ef38ef630909ef32ef2aea5cec1fe80aef5302ea56e7e9efb800e88be840e7c6e7bae8680000"
  },
  {
   "jp_offset": "0x1cc3",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……什么？",
   "zh_hex": "150909e7dde7bd050000"
  },
  {
   "jp_offset": "0x1ce5",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "没什么、我自言自语罢了",
   "zh_hex": "15e7d8e7dde7bd02efccefb5efd7efb5edb6eaefe7ba0000"
  },
  {
   "jp_offset": "0x1cf1",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "维萨留斯号在当前位置待命、不要离开这{00}里……明白吗？",
   "zh_hex": "15ea54e83be98ce7c8e833ef29ef53ef51e834ea0eeaa8e85302e7b5ef2ae901e7fae7b900ef310909ef39e809e802050000"
  },
  {
   "jp_offset": "0x1d29",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "这种感觉……难道说！？",
   "zh_hex": "15e7b9e7d1e87de8ae0909e866e82ae7ed0605000000"
  },
  {
   "jp_offset": "0x1d5b",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "怎么了、穆少佐！？",
   "zh_hex": "15e7f2e7bde7ba02eb10efacefbaef97050000"
  },
  {
   "jp_offset": "0x1d83",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "是扎夫特！克鲁泽就在附近！！",
   "zh_hex": "15e7b6e84be830e7cfef97e7d5e8a2e984e7c5ef29eaf8efd8ef97ef970000"
  },
  {
   "jp_offset": "0x1db2",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……你说什么！？",
   "zh_hex": "150909e7b8e7ede7dde7bdef97050000"
  },
  {
   "jp_offset": "0x1de2",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "穆先生！？",
   "zh_hex": "15eb10ef8bef8def97050000"
  },
  {
   "jp_offset": "0x1e06",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "基拉！快去追穆少佐！！",
   "zh_hex": "15e829e7c2ef97e85fe7ebe8ddeb10efacefbaef97ef970000"
  },
  {
   "jp_offset": "0x1e1a",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "如果真像他说的、克鲁泽就在那里、他一{00}个人太危险了！",
   "zh_hex": "15e7f0e871e820e8e9e80ce7ede7b402e7d5e8a2e984e7c5ef29e7b7ef3102e80cefb600e828efb2e86ae935e932e7baef970000"
  },
  {
   "jp_offset": "0x1e54",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……明白了！",
   "zh_hex": "150909ef39e809e7baef970000"
  },
  {
   "jp_offset": "0x1e8e",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "哎呀、你真厉害啊……",
   "zh_hex": "15e9dce9c602e7b8e820ecbbe988e7c309090000"
  },
  {
   "jp_offset": "0x1eb7",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "这点战果、还不值得您这般夸奖",
   "zh_hex": "15e7b9e822ef28e87102e7f7e7b5ec48e80ae835e7b9ea80e8dfec5c0000"
  },
  {
   "jp_offset": "0x1efa",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "这下、您该明白本舰的实力了吧",
   "zh_hex": "15e7b9ef4d02e835e898ef39e809efa6e7d4e7b4e87fefb0e7bae7d00000"
  },
  {
   "jp_offset": "0x1f11",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我劝您就此停止抵抗、乖乖投降吧",
   "zh_hex": "15efccebb6e835e7c5e7cae934e869e96ee91202e9a3e9a3e948e943e7d00000"
  },
  {
   "jp_offset": "0x1f4f",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "不……不能投降",
   "zh_hex": "15e7b50909e7b5e7c6e948e9430000"
  },
  {
   "jp_offset": "0x1f79",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "玛琉·拉米亚斯！！请您也别太固执了！",
   "zh_hex": "15e845ead2ef4be7c2e878e7d6e7c8ef97ef97e83ae835e7c0e7e5e86aeac0e9fce7baef970000"
  },
  {
   "jp_offset": "0x1f95",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "您若再继续抵抗下去、我就只能击破贵舰{00}了！",
   "zh_hex": "15e835e7e7e80be9d6e9ade96ee912ef4de7eb02efcce7c5ef32e7c6e7ccef6de930e7d400e7baef970000"
  },
  {
   "jp_offset": "0x1fce",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "那么、就试试看吧",
   "zh_hex": "15e7b7e7bd02e7c5e91de91de7f6e7d00000"
  },
  {
   "jp_offset": "0x1fde",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "您若说要击破大天使号、那我便奉陪到底{00}！",
   "zh_hex": "15e835e7e7e7edef2ae7ccef6defa5e844e83fe83302e7b7efcce8faeac1ef42e7d7e9b400ef970000"
  },
  {
   "jp_offset": "0x201b",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……舰长！？",
   "zh_hex": "150909e7d4ef34ef97050000"
  },
  {
   "jp_offset": "0x204c",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "你是拦不住我的、娜塔尔",
   "zh_hex": "15e7b8e7b6eb89e7b5e859efcce7b402e7eae945e7e10000"
  },
  {
   "jp_offset": "0x205e",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "我们有了目标……",
   "zh_hex": "15efcce7bbe7cbe7baefd4e96f09090000"
  },
  {
   "jp_offset": "0x206f",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "在达成终结这场战争的目标之前、我们绝{00}不能输！",
   "zh_hex": "15ef29ef2be837e8e2e868e7b9e876ef28e852e7b4efd4e96fe7cdef5102efcce7bbe91c00e7b5e7c6e8b9ef970000"
  },
  {
   "jp_offset": "0x20b9",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "……是啊、我们已经无法停下脚步了",
   "zh_hex": "150909e7b6e7c302efcce7bbef3ae8b7e7dce84ee934ef4deb68ea93e7ba0000"
  },
  {
   "jp_offset": "0x20f2",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "我十分清楚、这是一条无比艰难的道路",
   "zh_hex": "158bea4acde995ebd302e7b9e7b687e9d4e7dce825eb42e866e7b4e82ae8d20000000000"
  },
  {
   "jp_offset": "0x2134",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "但我们会冲破一切困难、用这双手亲手夺{00}得和平……！",
   "zh_hex": "15e7dbefcce7bbe7e2e95eef6defb6ef3feaffe86602efb3e7b9eabcef66e894ef66ea1700e80ae7d3e8870909ef970000"
  },
  {
   "jp_offset": "0x2156",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "对吧、贝拉？",
   "zh_hex": "15e7bee7d002e857e7c2050000"
  },
  {
   "jp_offset": "0x2184",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯",
   "zh_hex": "150909e8650000"
  },
  {
   "jp_offset": "0x21b0",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "啊、真是够了！！",
   "zh_hex": "15e7c302e820e7b6e920e7baef97ef970000"
  },
  {
   "jp_offset": "0x21bb",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "面对一艘都快沉了的破船、你们还在磨蹭{00}什么呢！！",
   "zh_hex": "15e862e7beefb6eb18e840e85fe983e7bae7b4ef6dea0202e7b8e7bbe7f7ef29ec81ec9800e7dde7bde907ef97ef970000"
  },
  {
   "jp_offset": "0x21d9",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "只要把它击沉、不就一了百了了吗！！",
   "zh_hex": "15ef32ef2ae81be978e7cce98302e7b5e7c5efb6e7baebdce7bae7bae802ef97ef970000"
  },
  {
   "jp_offset": "0x220d",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "阿兹拉埃尔理事……！？",
   "zh_hex": "15e7d2e856e7c2e96ae7e1e872efb80909ef97050000"
  },
  {
   "jp_offset": "0x223d",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "到此为止了！暂时撤退！！",
   "zh_hex": "15e7d7e7cae7c1e869e7baef97e9ffef2de90ae880ef97ef970000"
  },
  {
   "jp_offset": "0x226a",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "诶！？",
   "zh_hex": "15eaf3ef97050000"
  },
  {
   "jp_offset": "0x228d",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "状况已经对我方不利了",
   "zh_hex": "15e98be8d0ef3ae8b7e7be8bd0e7b5e82ee7ba00000000"
  },
  {
   "jp_offset": "0x22b7",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "可是、那些家伙……",
   "zh_hex": "15e7c4e7b602e7b7e8a4e7dfe7fd09090000"
  },
  {
   "jp_offset": "0x22de",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "您是想在这里战死吗！？",
   "zh_hex": "15e835e7b6e7e6ef29e7b9ef31ef28ef6ae802ef97050000"
  },
  {
   "jp_offset": "0x2309",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "……！！",
   "zh_hex": "150909ef97ef970000"
  },
  {
   "jp_offset": "0x230f",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "啊、知道了知道了！后退也好撤退也罢、{00}随你的便！",
   "zh_hex": "15e7c302e85ae82ae7bae85ae82ae7ba06e7fee880e7c0e7c7e90ae880e7c0eaef0200e9a1e7b8e7b4e8fa0600000000"
  },
  {
   "jp_offset": "0x235b",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "主天使号、后退！！",
   "zh_hex": "15e954e844e83fe83302e7fee880ef97ef970000"
  },
  {
   "jp_offset": "0x238a",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "连收手的时机都把握得这么漂亮、不愧是{00}你、娜塔尔……",
   "zh_hex": "15e86ee926ef66e7b4ef2de7e4e840e81beb37e80ae7b9e7bdead0eaa202e7b5ea08e7b600e7b802e7eae945e7e109090000"
  },
  {
   "jp_offset": "0x23b7",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "……真是了不起的觉悟、拉米亚斯舰长",
   "zh_hex": "150909e820e7b6e7bae7b5e847e7b4e8aeea1902e7c2e878e7d6e7c8e7d4ef340000"
  },
  {
   "jp_offset": "0x23eb",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "看来、隼人舰长把指挥权交给你、果然是{00}正确的",
   "zh_hex": "15e7f6efcf02ea35efb2e7d4ef34e81be8c0e949eb39e861e839e7b802e871e7efe7b600ef3be88ce7b40000"
  },
  {
   "jp_offset": "0x2415",
   "jp_len": 33,
   "kind": "script",
   "zh_hex": "152d3302000106c70013c42933020001065f00136c2833020001150909e7b502e7d8e7dde7bd0000"
  },
  {
   "jp_offset": "0x2436",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "多亏了大家的帮助、否则我一定会输给她",
   "zh_hex": "15e7e9eab7e7baefa5e7dfe7b4e910ea2302e9bbea87efccefb6e867e7e2e8b9e839e88e0000"
  },
  {
   "jp_offset": "0x2456",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "和娜塔尔她相比、我这点指挥官的本事…{00}…",
   "zh_hex": "15e7d3e7eae945e7e1e88ee8b1e825028be7b9e822e8c0e9498fe7b4d2a9090009000000000000"
  },
  {
   "jp_offset": "0x248c",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "……事实真的是这样吗？",
   "zh_hex": "150909efb8e87fe820e7b4e7b6e7b9e7dae802050000"
  },
  {
   "jp_offset": "0x24b7",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "拉克丝小姐……？",
   "zh_hex": "15e7c2e7d5e8a3e83ee9210909050000"
  },
  {
   "jp_offset": "0x24dc",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "能击退主天使号、是因为大家齐心协力…{00}…",
   "zh_hex": "15e7c6e7cce880e954e844e83fe83302e7b6ef33e7c1efa5e7dfe924e82de8f6efb00900090000"
  },
  {
   "jp_offset": "0x24fa",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "但是、正因为是您、大家才愿意出力、不{00}是吗？",
   "zh_hex": "15e7dbe7b602ef3bef33e7c1e7b6e83502efa5e7dfe836e961ef3cefbeefb002e7b500e7b6e802050000"
  },
  {
   "jp_offset": "0x253d",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "激发出身边众人的力量、也正是指挥官的{00}职责啊",
   "zh_hex": "15e9b9e870afe88de899eafbb4e7b4dae85102e7c0ef3be7b6e8c0e9498fe7b400eda8eba6e7c3000000000000"
  },
  {
   "jp_offset": "0x255c",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "能击退娜塔尔那样的人物、我想、正是靠{00}您的实力",
   "zh_hex": "15e7c6e7cce880e7eae945e7e1e7b7e7dae7b4efb2e99e02efcce7e602ef3be7b6e8c700e835e7b4e87fefb00000"
  },
  {
   "jp_offset": "0x2585",
   "jp_len": 37,
   "kind": "script",
   "zh_hex": "152d3302000106c70013c42933020001065f00136c283302000115e7b6efcc0909e7cce880e7bae7eae945e7e1e8020909050000"
  },
  {
   "jp_offset": "0x25c5",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "这就是所谓的人望吧……",
   "zh_hex": "15e7b9e7c5e7b6e7fbe92be7b4efb2e965e7d009090000"
  },
  {
   "jp_offset": "0x25d7",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "我觉得、你该对自己的实力、再多一点自{00}信才好",
   "zh_hex": "15efcce8aee80a02e7b8e898e7beefb5e8c9e7b4e87fefb002e80be7e9efb6e822efb500e90fe836e7c70000"
  },
  {
   "jp_offset": "0x2613",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "对自己……有自信……",
   "zh_hex": "15e7beefb5e8c90909e7cbefb5e90f09090000"
  },
  {
   "jp_offset": "0x2644",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "连收手的时机都把握得这么漂亮、不愧是{00}你、娜塔尔……",
   "zh_hex": "15e86ee926ef66e7b4ef2de7e4e840e81beb37e80ae7b9e7bdead0eaa202e7b5ea08e7b600e7b802e7eae945e7e109090000"
  },
  {
   "jp_offset": "0x267b",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "总算是挺过来了……",
   "zh_hex": "15e881e889e7b6eb5cef36efcfe7ba09090000"
  },
  {
   "jp_offset": "0x26a9",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "拉米亚斯舰长！进入殖民地的穆少佐、让{00}人担心！",
   "zh_hex": "15e7c2e878e7d6e7c8e7d4ef34ef97e892e891e8a9ef38ef63e7b4eb10efacefba02e7f900efb2e9fde82def970000"
  },
  {
   "jp_offset": "0x26c6",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "派些能动的人进去……",
   "zh_hex": "15e985e8a4e7c6ef30e7b4efb2e892e7eb09090000"
  },
  {
   "jp_offset": "0x2700",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……穆！？",
   "zh_hex": "150909eb10ef97050000"
  },
  {
   "jp_offset": "0x272e",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "玛琉小姐！穆先生他、被扎夫特……",
   "zh_hex": "15e845ead2e83ee921ef97eb10ef8bef8de80c02e7f1e84be830e7cf09090000"
  },
  {
   "jp_offset": "0x2766",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "……呵呵、我现在、没打算在这里和你们{00}交手",
   "zh_hex": "150909ef3def3d02efcce82fef2902e7d8e7f5e889ef29e7b9ef31e7d3e7b8e7bb00e861ef660000"
  },
  {
   "jp_offset": "0x277f",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "毕竟、我的神意高达也受了相当严重的损{00}伤",
   "zh_hex": "15ea2cef2c028be7b4e9aaef3ce812ef2be7c0e8c8e7bae8b1c4eaa1e8a1e7b4ea2800e8f900000000"
  },
  {
   "jp_offset": "0x27c2",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "你打算就这么离开吗？",
   "zh_hex": "15e7b8e7f5e889e7c5e7b9e7bde901e7fae802050000"
  },
  {
   "jp_offset": "0x27ed",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "是啊……以你们口中所说的和平方式",
   "zh_hex": "15e7b6e7c30909e7f3e7b8e7bbeabdef4ee7fbe7ede7b4e7d3e887efb1ea260000"
  },
  {
   "jp_offset": "0x2805",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "作为证明",
   "zh_hex": "15ef2fe7c1eba3ef390000"
  },
  {
   "jp_offset": "0x2810",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我就把本舰拘押的俘虏、交还给你们吧",
   "zh_hex": "158be7c5e81bd2e7d4ecdaed60e7b4eadbebee02e861e7f7e839e7b8e7bbe7d000000000"
  },
  {
   "jp_offset": "0x285e",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "扎夫特舰、射出了逃生舱！",
   "zh_hex": "15e84be830e7cfe7d402ef65efbee7bae8c2ef8debebef970000"
  },
  {
   "jp_offset": "0x2876",
   "jp_len": 59,
   "kind": "script",
   "zh_hex": "152d3302000106c70013c42933020001065f00136c2833020001060300065f001389283302000215e8c2ef8debebef9705ef31e862e7d7e9b4ecc3e86de7dde7bdefb209090000"
  },
  {
   "jp_offset": "0x28e3",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "……是、是大天使号！！",
   "zh_hex": "150909e7b602e7b6efa5e844e83fe833ef97ef970000"
  },
  {
   "jp_offset": "0x28f0",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "大天使号！救救我……！我……我在这里{00}……！",
   "zh_hex": "15efa5e844e83fe833ef97e8cae8caefcc0909ef97efcc0909efccef29e7b9ef31000909ef970000"
  },
  {
   "jp_offset": "0x291c",
   "jp_len": 33,
   "kind": "script",
   "zh_hex": "152d3302000106340013c42933020001061900136c283302000115e9d7e84cef97050000"
  },
  {
   "jp_offset": "0x294f",
   "jp_len": 51,
   "kind": "script",
   "zh_hex": "152d3302000106c70013c42933020001065f00136c2833020001060300065f001389283302000215e9d7e84c02e820e7b4e7b6e7b8e802ef97050000"
  },
  {
   "jp_offset": "0x298d",
   "jp_len": 56,
   "kind": "script",
   "zh_hex": "152d3302000106be0013c42933020001065600136c28330200010632000656001345293302000215e845ead2e83ee9210909ef97ef97efcc02efcc0909ef970000"
  },
  {
   "jp_offset": "0x29d0",
   "jp_len": 68,
   "kind": "script",
   "zh_hex": "152d3302000106c70013c42933020001065f00136c2833020001060300065f001389283302000215e7d8efb8e7b402e7b8eb4eeab3efb6e82202efcce7bbe84fef4ce7c5efcfef52e92600e8c2ef8debeb09090000"
  },
  {
   "jp_offset": "0x2a1f",
   "jp_len": 51,
   "kind": "script",
   "zh_hex": "152d3302000106be0013c42933020001065600136c28330200010632000656001345293302000215e93ae93ae7b8e7bbe7ba02e85fe8cae8caefcc0909ef970000"
  },
  {
   "jp_offset": "0x2a52",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "关、关键……！关键在我手上、就在我这{00}里！",
   "zh_hex": "15e8bb02e8bbeb710909ef97e8bbeb71ef29efccef66ef4c02e7c5ef29efcce7b900ef31ef970000"
  },
  {
   "jp_offset": "0x2a6a",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "能结束这场战争的关键……",
   "zh_hex": "15e7c6e868e895e7b9e876ef28e852e7b4e8bbeb7109090000"
  },
  {
   "jp_offset": "0x2a86",
   "jp_len": 47,
   "kind": "script",
   "zh_hex": "152d3302000106c70013c42933020001065f00136c2833020001060300065f001389283302000215e8bbeb710909050000"
  },
  {
   "jp_offset": "0x2ada",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "是的……是非常重要的关键",
   "zh_hex": "15e7b6e7b40909e7b6e8f0efc7e8a1ef2ae7b4e8bbeb710000"
  },
  {
   "jp_offset": "0x2ae7",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "所以最好尽快回收、难保不会有人来碍事",
   "zh_hex": "15e7fbe7f3e8c5e7c7e8f2e85fef52e92602e866ea47e7b5e7e2e7cbefb2efcfe8c6efb80000"
  },
  {
   "jp_offset": "0x2b68",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "能结束战争的关键吗……",
   "zh_hex": "15e7c6e868e895ef28e852e7b4e8bbeb71e80209090000"
  },
  {
   "jp_offset": "0x2b7a",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "那可真有意思",
   "zh_hex": "15e7b7e7c4e820e7cbef3cefca0000"
  },
  {
   "jp_offset": "0x2b9c",
   "jp_len": 51,
   "kind": "script",
   "zh_hex": "152d33020001065e0013c42933020001062900136c28330200010603000629001389283302000215eb10e7e1e945ef4be7d2e856e7c2e96ae7e10909ef97ef970000"
  },
  {
   "jp_offset": "0x2be1",
   "jp_len": 50,
   "kind": "script",
   "zh_hex": "152d3302000106650113c4293302000106c800136c283302000115e7b7e828ebeb0909e7c5e7f9efcce7bbe7b9e899e926ef4de7d00000"
  },
  {
   "jp_offset": "0x2c38",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "……！！",
   "zh_hex": "150909ef97ef970000"
  },
  {
   "jp_offset": "0x2c63",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……你、真碍事",
   "zh_hex": "150909e7b802e820e8c6efb80000"
  },
  {
   "jp_offset": "0x2c92",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "基拉！基拉啊啊啊！！",
   "zh_hex": "15e829e7c2ef97e829e7c2e7c3e7c3e7c3ef97ef970000"
  },
  {
   "jp_offset": "0x2cc1",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "芙蕾！",
   "zh_hex": "15e9d7e84cef970000"
  },
  {
   "jp_offset": "0x2ce8",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "嘿嘿！这家伙、才不会给你呢！",
   "zh_hex": "15e85ee85eef97e7b9e7dfe7fd02e836e7b5e7e2e839e7b8e907ef970000"
  },
  {
   "jp_offset": "0x2d24",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "你这家伙——！！",
   "zh_hex": "15e7b8e7b9e7dfe7fdebafebafef97ef970000"
  },
  {
   "jp_offset": "0x2d4e",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……哼",
   "zh_hex": "150909e8b30000"
  },
  {
   "jp_offset": "0x2d7a",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "所以我才说要抓紧的……呵呵",
   "zh_hex": "15e7fbe7f3efcce836e7edef2ae962eaede7b40909ef3def3d0000"
  },
  {
   "jp_offset": "0x2d99",
   "jp_len": 70,
   "kind": "script",
   "zh_hex": "152d33020001065e0013c42933020001062900136c28330200010603000629001389283302000215ec4aef4be8a2ef4be7d5e8a2e9840909ef97e7b8e7b9e7dfe7fd02e88aefb6e7fa00e908e7c5efb4e85ae82a09090000"
  },
  {
   "jp_offset": "0x2dea",
   "jp_len": 58,
   "kind": "script",
   "zh_hex": "152d33020001065a0113c42933020001069600136c283302000115e9dce9c602efcce873e898e7edef3602e82fef29e7dcef3ce861ef280909e7d500e99fe7cfe7ecef4be85be7d9e8820000"
  },
  {
   "jp_offset": "0x2e24",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "比起担心我、不如去担心穆吧？",
   "zh_hex": "15e825e847e9fde82d8b02e7b5e7f0e7ebe9fde82deb10e7d005000000"
  },
  {
   "jp_offset": "0x2e4d",
   "jp_len": 45,
   "kind": "script",
   "zh_hex": "152d33020001065e0013c42933020001062900136c28330200010603000629001389283302000215e81d09090000"
  },
  {
   "jp_offset": "0x2e8e",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "无妨……反正用不了多久、我就会再次与{00}你们交手",
   "zh_hex": "15e7dce97f0909e87cef3befb3e7b5e7bae7e9e9db02efcce7c5e7e2e80be864e83200e7b8e7bbe861ef660000"
  },
  {
   "jp_offset": "0x2eaa",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "门即将打开！",
   "zh_hex": "15e90ce855e84ae7f5e7fa060000"
  },
  {
   "jp_offset": "0x2ecd",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "门！？你这家伙、到底想干什么！？",
   "zh_hex": "15e90cef9705e7b8e7b9e7dfe7fd02e7d7e9b4e7e6e8d3e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x2ef7",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "用不着我来明说！哈哈哈哈！",
   "zh_hex": "15efb3e7b5e86defccefcfef39e7edef97e7e8e7e8e7e8e7e8ef970000"
  },
  {
   "jp_offset": "0x2f3e",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "劳·鲁·克鲁泽……你这家伙……",
   "zh_hex": "15ec4aef4be8a2ef4be7d5e8a2e9840909e7b8e7b9e7dfe7fd09090000"
  },
  {
   "jp_offset": "0x2fc3",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "你说俘虏……就是这个孩子吗？……这还{00}是个孩子吧？",
   "zh_hex": "15e7b8e7edeadbebee0909e7c5e7b6e7b9e828e956e886e802050909e7b9e7f700e7b6e828e956e886e7d0050000"
  },
  {
   "jp_offset": "0x2ffa",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "她是已故的乔治·阿尔斯塔外务次官的女{00}儿",
   "zh_hex": "15e88ee7b6ef3aea09e7b4edd0ea79ef4be7d2e7e1e7c8e945e8f7e94fe864ef92e7b4efad00eb7c0000"
  },
  {
   "jp_offset": "0x303d",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "巴、巴基露露中尉……？",
   "zh_hex": "15e85b02e85be829e858e858ef4eefc60909050000"
  },
  {
   "jp_offset": "0x3064",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "好久不见了、芙蕾·阿尔斯塔、你还好吗{00}？",
   "zh_hex": "15e7c7e9dbe7b5e85ce7ba02e9d7e84cef4be7d2e7e1e7c8e94502e7b8e7f7e7c7e80200050000"
  },
  {
   "jp_offset": "0x30a3",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "啊……我、我……",
   "zh_hex": "15e7c30909efcc02efcc09090000"
  },
  {
   "jp_offset": "0x30ca",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "那么？关键到底是什么？你真的拿着它吗{00}？",
   "zh_hex": "15e7b7e7bd05e8bbeb71e7d7e9b4e7b6e7dde7bd05e7b8e820e7b4e9a7e86de978e80200050000"
  },
  {
   "jp_offset": "0x310a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "这、这个……",
   "zh_hex": "15e7b902e7b9e82809090000"
  },
  {
   "jp_offset": "0x312e",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "哦、是张光盘啊……怎么、看着还挺像真{00}的嘛？",
   "zh_hex": "15e91902e7b6eac5e83dec2fe7c30909e7f2e7bd02e7f6e86de7f7eb5ce8e9e82000e7b4e936050000"
  },
  {
   "jp_offset": "0x3171",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "克、克鲁泽队长……那个戴面具的人……{00}让我交出去……",
   "zh_hex": "15e7d502e7d5e8a2e984e7c9ef340909e7b7e828eb06e862ea14e7b4efb2090900e7f9efcce861efbee7eb09090000"
  },
  {
   "jp_offset": "0x31ae",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "唔……能结束战争的关键、是吗……",
   "zh_hex": "15e81d0909e7c6e868e895ef28e852e7b4e8bbeb7102e7b6e80209090000"
  },
  {
   "jp_offset": "0x31df",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "穆……！",
   "zh_hex": "15eb100909ef970000"
  },
  {
   "jp_offset": "0x3202",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "没什么大碍、只是稍微大意了一下……唔{00}、好痛！",
   "zh_hex": "15e7d8e7dde7bdefa5e8c602ef32e7b6ead5eb58efa5ef3ce7baefb6ef4d0909e81d0002e7c7ea0bef970000"
  },
  {
   "jp_offset": "0x323e",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "伤势虽然不深、但切莫勉强、穆少佐",
   "zh_hex": "15e8f9e8fde8b8e7efe7b5eb0d02e7dbef3feba0eb2ae8ad02eb10efacefba0000"
  },
  {
   "jp_offset": "0x325a",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "米莉亚莉亚、麻烦你送少佐去医务室",
   "zh_hex": "15e878e81ee7d6e81ee7d602ea36e95be7b8e9baefacefbae7ebecb9e94fec620000"
  },
  {
   "jp_offset": "0x32a3",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……是",
   "zh_hex": "150909e7b60000"
  },
  {
   "jp_offset": "0x3301",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "玛琉小姐……",
   "zh_hex": "15e845ead2e83ee92109090000"
  },
  {
   "jp_offset": "0x3325",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "基拉、你……",
   "zh_hex": "15e829e7c202e7b809090000"
  },
  {
   "jp_offset": "0x3349",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "对不起……明明有我跟在他身边的……",
   "zh_hex": "15e7bee7b5e8470909ef39ef39e7cbefcce973ef29e80ce88de899e7b409090000"
  },
  {
   "jp_offset": "0x3379",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "基拉、你不必自责、是他自己一个人冲出{00}去的……",
   "zh_hex": "15e829e7c202e7b8e7b5e860efb5eba602e7b6e80cefb5e8c9efb6e828efb2e95eefbe00e7ebe7b409090000"
  },
  {
   "jp_offset": "0x339d",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "话说回来、扎夫特竟然转到了殖民地那边{00}……",
   "zh_hex": "15e81fe7edef52efcf02e84be830e7cfef2ce7efe9c2e7d7e7bae8a9ef38ef63e7b7e8990009090000"
  },
  {
   "jp_offset": "0x33b9",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "里面到底发生了什么？",
   "zh_hex": "15ef31e862e7d7e9b4e870ef8de7bae7dde7bd050000"
  },
  {
   "jp_offset": "0x33e2",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "那个……",
   "zh_hex": "15e7b7e8280909000000000000"
  },
  {
   "jp_offset": "0x79a6",
   "jp_len": 54,
   "kind": "script",
   "zh_hex": "152d3302000106010013b62d330200010100040006c70013c42933020001065f00136c283302000115ef2ce7d7e7cae7c1e869090000"
  },
  {
   "jp_offset": "0x7a0e",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "您是说、要和主天使号交战吗？",
   "zh_hex": "15e835e7b6e7ed02ef2ae7d3e954e844e83fe833e861ef28e802050000"
  },
  {
   "jp_offset": "0x7a1e",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "大天使级的实力、您也是清楚的吧！？",
   "zh_hex": "15efa5e844e83feaeee7b4e87fefb002e835e7c0e7b6e995ebd3e7b4e7d0ef97050000"
  },
  {
   "jp_offset": "0x7a59",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "我懂的、娜塔尔……",
   "zh_hex": "15efcce8b0e7b402e7eae945e7e109090000"
  },
  {
   "jp_offset": "0x7a6c",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "但是、我们绝不能就此停下脚步！",
   "zh_hex": "15e7dbe7b602efcce7bbe91ce7b5e7c6e7c5e7cae934ef4deb68ea93ef970000"
  },
  {
   "jp_offset": "0x7ab7",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "不要——！！",
   "zh_hex": "15e7b5ef2aebafebafef97ef970000"
  },
  {
   "jp_offset": "0x7ae6",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "芙蕾！",
   "zh_hex": "15e9d7e84cef970000"
  }
 ]
}
