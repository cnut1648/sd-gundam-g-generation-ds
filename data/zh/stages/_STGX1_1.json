  },
  {
   "jp_offset": "0x463c",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "还能与隆德·贝尔、预防者进行联合演习",
   "zh_hex": "15e7f7e7c6e832ed16e82cef4be857e7e102ea5ae968ef6ee892efd6ef2eefc0ea2feab600000000"
  },
  {
   "jp_offset": "0x465a",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "我相信、以贵官的本事、与他们一战也定{00}能取胜",
   "zh_hex": "15efcce8b1e90f02e7f3e930ef92e7b4efa6efb802e832e80ce7bbefb6ef28e7c0e86700e7c6e987e8db00000000000000"
  },
  {
   "jp_offset": "0x467f",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "……那么、『SD高达G世代DS』",
   "zh_hex": "150909e7b7e7bd020cef9eef96e812ef2beed1e83ce8e7ef96ef9e0d0000000000000000"
  },
  {
   "jp_offset": "0x46a3",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "今后也祝愿贵官奋战不懈",
   "zh_hex": "15efb9e7fee7c0ed97e961e930ef92ef46ef28e7b5ec6f00000000"
  }
 ]
}
