   "zh_hex": "15ea94ea3eefa6e88deab9e7c4e9d6e9ad02e7cde7fee7c0e87be965e7b8e7c6e8f2e88b00e970ef4de7eb0000000000"
  },
  {
   "jp_offset": "0x4293",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "此外、为将本路线玩到最后的你、还准备{00}了特别关卡",
