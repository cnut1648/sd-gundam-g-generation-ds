  },
  {
   "jp_offset": "0x4222",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "一路辛苦了",
   "zh_hex": "15efb6e8d2ea58e9e6e7ba0000"
  },
  {
   "jp_offset": "0x422f",
   "jp_len": 32,
   "kind": "dialogue",
