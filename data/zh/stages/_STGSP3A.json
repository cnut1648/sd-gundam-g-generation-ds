{
 "file": "_STGSP3A.bin",
 "source_size": 49220,
 "built_size": 51812,
 "edits": [
  {
   "jp_offset": "0x14b5",
   "jp_len": 121,
   "kind": "dialogue",
   "zh_text": "あいうえおかダチッツテ{01}デ、トドナ。ニネハバパ·々ビたプベブマミだムメっ？！ちャラリン下がつてとなぬ開我官』のはば間機貴近軍見向ま行むすじー…ね国士佐みそやょよへ死·{00}！接{01}M佐にな、{00}{01}！様{00}Mわなな、{00}{01}ぁ核脉冲引擎、点火！！",
   "zh_hex": "15161718191a1b6566676869016a026b6c6d036e6f7071720407732a767775797a2b7b7c2d05062c7e808185891c2e2f3133358d8b8f0d37383991929496989a9d3d9f3f2524080936a1a5a33e284344453ba7040006b70113782f3302000106d70013202e3302000115e8f3ebe9e95ee9d0ec1e02e822e8daef97ef970000"
  },
  {
   "jp_offset": "0x154f",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "轨道修正……目标、地球！！",
   "zh_hex": "15e9cce82ae9b0ef3b0909d5e96f02bf95060600000000000000"
  },
  {
   "jp_offset": "0x1584",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "去吧、阿克西斯！！连同这段令人憎恶的{00}记忆、一并坠下去……！",
   "zh_hex": "15e7ebe7d002e7d2e7d5e7f8e7c8ef97ef97e86ee85de7b9ea6be94eefb2eb34e7dee7b400e996eac602efb6e957eb53ef4de7eb0909ef970000"
  },
  {
   "jp_offset": "0x15c0",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "阿克西斯、开始移动了！！",
   "zh_hex": "15e7d2e7d5e7f8e7c802e7fae908ec83ef30e7baef97ef970000"
  },
  {
   "jp_offset": "0x15e8",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "全舰、最大战速！全速赶往阿克西斯！！",
   "zh_hex": "15efb4e7d402e8c5efa5ef28e9daef97efb4e9daea04e911e7d2e7d5e7f8e7c8ef97ef970000"
  },
  {
   "jp_offset": "0x1620",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "大佐……！！",
   "zh_hex": "15efa5efba0909ef97ef970000"
  },
  {
   "jp_offset": "0x164e",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "还是现身了吗……隆德·贝尔！！",
   "zh_hex": "15e7f7e7b6e82fe88de7bae8020909ed16e82cef4be857e7e1ef97ef970000"
  },
  {
   "jp_offset": "0x1683",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "夏亚……我绝不会让你再这样胡来下去！",
   "zh_hex": "15ef37e7d60909efcce91ce7b5e7e2e7f9e7b8e80be7b9e7daec8befcfef4de7ebef970000"
  },
  {
   "jp_offset": "0x16b8",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "全舰、调头迎击隆德·贝尔队！",
   "zh_hex": "15efb4e7d402e95ce92ee931e7cced16e82cef4be857e7e1e7c9ef970000"
  },
  {
   "jp_offset": "0x16cc",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "只要挡下这一波攻击、{00}胜利就是我们的了！",
   "zh_hex": "15ef32ef2aea7789e7b987e9a89ee7cc0200e8dbe82ee7c5e7b68be7bbe7b4e7ba0600000000000000"
  },
  {
   "jp_offset": "0x1708",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "新吉翁、看来已经开始行动了！",
   "zh_hex": "15ef8ae7d9ee8802e7f6d9ef3ae8b7e7fae9089fef30e7ba060000000000"
  },
  {
   "jp_offset": "0x1736",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "好、我方也应战！",
   "zh_hex": "15e7c702efccefb1e7c0e873ef28ef970000"
  },
  {
   "jp_offset": "0x1743",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "全员、战斗开始！！",
   "zh_hex": "15efb4e84902ef28e7ffe7fae908ef97ef970000"
  },
  {
   "jp_offset": "0x1776",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "夏亚……！！",
   "zh_hex": "15ef37e7d60909ef97ef970000"
  },
  {
   "jp_offset": "0x17a0",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……是阿姆罗啊！",
   "zh_hex": "150909e7b6e7d2e823e7ece7c3ef970000"
  },
  {
   "jp_offset": "0x1826",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "可恶、阿姆罗！！",
   "zh_hex": "15e7c4e7de02e7d2e823e7ecef97ef970000"
  },
  {
   "jp_offset": "0x183c",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "留在地球上的人类、不过是地上的跳蚤、{00}你为何就是不懂！",
   "zh_hex": "15e98cef29bf95b2e7b4b4e84102e7b5ef36e7b6bfb2e7b4edbbe3ef0200e7b8e7c18ae7c5e7b6e7b5e8b00600000000000000000000"
  },
  {
   "jp_offset": "0x188f",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "你才是……！！",
   "zh_hex": "15e7b8e836e7b60909ef97ef970000"
  },
  {
   "jp_offset": "0x18a4",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "你总是这样居高临下地轻视别人、又能懂{00}得什么！",
   "zh_hex": "15e7b8e881e7b6e7b9e7daea4ce812ed1eef4def63e990e9d9e7e5efb202e8f1e7c6e8b000e80ae7dde7bdef970000"
  },
  {
   "jp_offset": "0x18eb",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "你说我轻视！？我若真的轻视他人……",
   "zh_hex": "15e7b8e7edefcce990e9d9ef9705efcce7e7e820e7b4e990e9d9e80cefb209090000"
  },
  {
   "jp_offset": "0x1912",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "又岂会特地把精神感应框架的情报、泄露{00}给你！",
   "zh_hex": "15e8f1eac3e7e2e7cfbfe81be98de9aae87de873eef3e99de7b4e88be91302ed7ee85800e839e7b80600000000"
  },
  {
   "jp_offset": "0x194f",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x1986",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "和你这种驾着破烂机体的人交手、根本毫{00}无意义！",
   "zh_hex": "15e7d3e7b8e7b9e7d1e953e86def6dec28e7e4ef4fe7b4efb2e861ef6602e9b8efa6ea0a00e7dcef3ce8ceef970000"
  },
  {
   "jp_offset": "0x19d2",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "夏亚、你这家伙！？",
   "zh_hex": "15ef37e7d602e7b8e7b9e7dfe7fdef97050000"
  },
  {
   "jp_offset": "0x1a0b",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "唔……！",
   "zh_hex": "15e81d0909ef970000"
  },
  {
   "jp_offset": "0x1a3b",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "没错、阿姆罗！这才不愧是我的劲敌！",
   "zh_hex": "15e7d8e88502e7d2e823e7ecef97e7b9e836e7b5ea08e7b6efcce7b4eb50e7e3ef970000"
  },
  {
   "jp_offset": "0x1a65",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "竟敢小看我……！",
   "zh_hex": "15ef2ce8cde83ee7f6efcc0909ef970000"
  },
  {
   "jp_offset": "0x1a70",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "你就是这样、永远只会一味地轻视他人！",
   "zh_hex": "15e7b8e7c5e7b6e7b9e7da02e9bfe94cef32e7e2efb6ed36ef63e990e9d9e80cefb2ef970000"
  },
  {
   "jp_offset": "0x1ab5",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "阿姆罗……！",
   "zh_hex": "15e7d2e823e7ec0909ef970000"
  },
  {
   "jp_offset": "0x1ae2",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……倩恩！？",
   "zh_hex": "150909ed4ae7ee0605000000"
  },
  {
   "jp_offset": "0x1b06",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "精神感应框架越多、对阿姆罗就越有利！",
   "zh_hex": "15e98de9aae87de873eef3e99dea57e7e902e7bee7d2e823e7ece7c5ea57e7cbe82e06000000"
  },
  {
   "jp_offset": "0x1b1d",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "所以、阿姆罗、我也……",
   "zh_hex": "15e7fbe7f302e7d2e823e7ec02efcce7c009090000"
  },
  {
   "jp_offset": "0x1b44",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "不行！快回去、倩恩！！",
   "zh_hex": "15e7b59f06e85f8ce7eb02ed4ae7ee060600000000000000"
  },
  {
   "jp_offset": "0x1b77",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "我怎能就这样、{00}眼睁睁看着你一个人战斗……！！",
   "zh_hex": "158be7f2e7c6e7c5e7b9e7da0200e90bed90ed90e7f6e86de7b887e828b4ef28e7ff0909060600000000000000"
  },
  {
   "jp_offset": "0x1b97",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "求你了、阿姆罗！也让我来助你一臂之力{00}吧！！",
   "zh_hex": "15e93ae7b8e7ba02e7d2e823e7ecef97e7c0e7f9efccefcfea23e7b8efb6ee92e7cdefb000e7d0ef97ef970000"
  },
  {
   "jp_offset": "0x1bc9",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "倩恩、你这是……",
   "zh_hex": "15ed4ae7ee02e7b8e7b9e7b609090000"
  },
  {
   "jp_offset": "0x1bf9",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "住手吧、奎丝！！",
   "zh_hex": "15e859ef66e7d002eb82e8a3ef97ef970000"
  },
  {
   "jp_offset": "0x1c06",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "你做这种事、到头来只会让自己更加痛苦{00}啊！！",
   "zh_hex": "15e7b8e81ce7b9e7d1efb802e7d7e92eefcfef32e7e2e7f9efb5e8c9e952e854ea0be9e600e7c3ef97ef970000"
  },
  {
   "jp_offset": "0x1c3c",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "事到如今、还说什么呢！！",
   "zh_hex": "15efb8e7d7e7f0efb902e7f7e7ede7dde7bde907ef97ef970000"
  },
  {
   "jp_offset": "0x1c45",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "我已经有夏亚了、你这种人算什么……！",
   "zh_hex": "15efccef3ae8b7e7cbef37e7d6e7ba02e7b8e7b9e7d1efb2e889e7dde7bd0909ef970000"
  },
  {
   "jp_offset": "0x1c5c",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "只要这场作战成功、我就把拉拉从夏亚心{00}里赶出去！",
   "zh_hex": "15ef32ef2ae7b9e876ef2fef28e837e9b102efcce7c5e81be7c2e7c2e88aef37e7d6e82d00ef31ea04efbee7ebef970000"
  },
  {
   "jp_offset": "0x1c97",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "奎丝！你这孩子……！！",
   "zh_hex": "15eb82e8a3ef97e7b8e7b9e956e8860909ef97ef970000"
  },
  {
   "jp_offset": "0x1cc0",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "吵死了！我最讨厌你了！！",
   "zh_hex": "15ec51ef6ae7baef97efcce8c5e9f7eb2be7b8e7baef97ef970000"
  },
  {
   "jp_offset": "0x1cf9",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "都怪你这家伙在、阿姆罗他才……！",
   "zh_hex": "15e840ea07e7b8e7b9e7dfe7fdef2902e7d2e823e7ece80ce8360909ef970000"
  },
  {
   "jp_offset": "0x1d25",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "搞什么？这孩子……？",
   "zh_hex": "15ec1ce7dde7bd05e7b9e956e8860909050000"
  },
  {
   "jp_offset": "0x1d58",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "我绝不许你妨碍大佐！",
   "zh_hex": "15efcce91ce7b5e8a7e7b8e97fe8c6efa5efbaef970000"
  },
  {
   "jp_offset": "0x1d82",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "这个少女……{00}难道是被夏亚给迷住了吗！？",
   "zh_hex": "15e7b9e828b1b0090900e866e82ae7b6e7f1ef37e7d6e839eaf7e859e7bae80206050000000000"
  },
  {
   "jp_offset": "0x1d9d",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "竟然连这种孩子都拿来利用……！可恶的{00}夏亚！",
   "zh_hex": "15ef2ce7efe86ee7b9e7d1e956e886e840e9a7d9e82ed8090906e7c4e7dee7b400ef37e7d606000000000000"
  },
  {
   "jp_offset": "0x1dd6",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "夏亚的心里、还残留着{00}这个女人的影子……",
   "zh_hex": "15ef37e7d6e7b4e82def3102e7f7e97be98ce86d00e7b9e828b0b4e7b4ea8ee886090900000000"
  },
  {
   "jp_offset": "0x1dee",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "真是个讨厌的女人、这家伙！",
   "zh_hex": "15e820e7b6e828e9f7eb2be7b4efadefb202e7b9e7dfe7fdef970000"
  },
  {
   "jp_offset": "0x1e15",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "唔！这孩子、简直就像当年的我……！",
   "zh_hex": "15e81def97e7b9e956e88602e9abe875e7c5e8e9ef53e909e7b4efcc0909ef970000"
  },
  {
   "jp_offset": "0x1e2b",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "等一下！我……！！",
   "zh_hex": "15e826efb6ef4def97efcc0909ef97ef970000"
  },
  {
   "jp_offset": "0x1e55",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "我才不管！我绝不让你靠近大佐！",
   "zh_hex": "15efcce836e7b5e93bef97efcce91ce7b5e7f9e7b8e8c7efd8efa5efbaef970000"
  },
  {
   "jp_offset": "0x1e93",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "卡缪！纵然是你、也休想妨碍我和阿姆罗{00}的这场决战！",
   "zh_hex": "15e801e917ef97e8e6e7efe7b6e7b802e7c0e90ee7e6e97fe8c6efcce7d3e7d2e823e7ec00e7b4e7b9e876e8abef28ef970000"
  },
  {
   "jp_offset": "0x1ecb",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "你总是这样、自以为是地想把一切都了结{00}掉……！",
   "zh_hex": "15e7b8e881e7b6e7b9e7da02efb5e7f3e7c1e7b6ef63e7e6e81befb6ef3fe840e7bae86800e9d30909ef970000"
  },
  {
   "jp_offset": "0x1ee7",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "果然、你就是个{00}不该活在世上的人、夏亚！！",
   "zh_hex": "15e871e7ef02e7b8e7c5e7b6e82800e7b5e898e8d4ef29e83cb2e7b4b402ef37e7d60606000000000000"
  },
  {
   "jp_offset": "0x1f29",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "克瓦特罗……",
   "zh_hex": "15e7d5e99fe7cfe7ec09090000"
  },
  {
   "jp_offset": "0x1f32",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "事到如今、要阻止你、就只剩下取你性命{00}这一条路了",
   "zh_hex": "15efb8e7d7e7f0efb902ef2ae8efe869e7b802e7c5ef32ea3aef4de987e7b8e951e85300e7b9efb6e9d4e8d2e7ba0000"
  },
  {
   "jp_offset": "0x1f50",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "抱歉、动手了！！",
   "zh_hex": "15e922e92702ef30ef66e7baef97ef970000"
  },
  {
   "jp_offset": "0x1f7d",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "你既然如此确信、那也好、捷多·亚西塔",
   "zh_hex": "15e7b8e8c4e7efe7f0e7cae88ce90f02e7b7e7c0e7c702e7bce7e9ef4be7d6e7f8e9450000"
  },
  {
   "jp_offset": "0x1f98",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "但是、哪怕要打倒你、我也定要把该做的{00}事贯彻到底给你看！",
   "zh_hex": "15e7dbe7b602e8ffe958ef2ae7f5e848e7b802efcce7c0e867ef2ae81be898e81ce7b400efb8ed07ebc5e7d7e9b4e839e7b8e7f6ef970000"
  },
  {
   "jp_offset": "0x1fe0",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "已经够了吧……夏亚",
   "zh_hex": "15ef3ae8b7e920e7bae7d00909ef37e7d60000"
  },
  {
   "jp_offset": "0x200a",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "哈曼、你想做什么……？",
   "zh_hex": "15e7e8e87402e7b8e7e6e81ce7dde7bd0909050000"
  },
  {
   "jp_offset": "0x2030",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "就算你做了这种事、拉拉也不会因此回来",
   "zh_hex": "15e7c5e889e7b8e81ce7bae7b9e7d1efb802e7c2e7c2e7c0e7b5e7e2ef33e7caef52efcf0000"
  },
  {
   "jp_offset": "0x2067",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x2088",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "你自己也明白吧？",
   "zh_hex": "15e7b8efb5e8c9e7c0ef39e809e7d0050000"
  },
  {
   "jp_offset": "0x209a",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "就算做了这种事、到头来、也只会让你更{00}加空虚……",
   "zh_hex": "15e7c5e889e81ce7bae7b9e7d1efb802e7d7e92eefcf02e7c0ef32e7e2e7f9e7b8e95200e854e93febef09090000"
  },
  {
   "jp_offset": "0x20cf",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "不对！我只是、不愿眼看着这个世界、被{00}引向错误的方向罢了！！",
   "zh_hex": "15e7b5e7beef97efccef32e7b602e7b5e961e90be7f6e86de7b9e828e83ce8f502e7f100e9d0efc1e885ea33e7b4efb1efc1eaefe7baef97ef970000"
  },
  {
   "jp_offset": "0x2110",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "你的答案、和从前一模一样啊……夏亚",
   "zh_hex": "15e7b8e7b4ea96ee3f02e7d3e88aef51efb6ea91efb6e7dae7c30909ef37e7d60000"
  },
  {
   "jp_offset": "0x2122",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "那时的我太不成熟、没能体会到、你内心{00}深处的那份痛楚……",
   "zh_hex": "15e7b7ef2de7b4efcce86ae7b5e837eb9202e7d8e7c6ef4fe7e2e7d702e7b8e99ae82d00eb0de903e7b4e7b7ea22ea0bebd309090000"
  },
  {
   "jp_offset": "0x2147",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "可是、夏亚……",
   "zh_hex": "15e7c4e7b602ef37e7d609090000"
  },
  {
   "jp_offset": "0x214f",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "你不是曾跨越了那份伤痛、对我说过、要{00}和我重新来过吗？",
   "zh_hex": "15e7b8e7b5e7b6ea2aeeacea57e7bae7b7ea22e8f9ea0b02e7beefcce7edef3602ef2a00e7d3efcce8a1ef8aefcfef36e802050000"
  },
  {
   "jp_offset": "0x2171",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "现在重来、也一定还来得及、{00}所以、夏亚……",
   "zh_hex": "15e82fef29e8a1d902e7c087e867e7f7d9e80ae9cf0200e7fbe7f302ef37e7d609090000000000"
  },
  {
   "jp_offset": "0x21a2",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "住口、哈曼！！",
   "zh_hex": "15e859eabd02e7e8e874ef97ef970000"
  },
  {
   "jp_offset": "0x21ad",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "谁要是敢插手我和阿姆罗的决战、纵然是{00}你、我也绝不轻饶！",
   "zh_hex": "15e923ef2ae7b6e8cdeb08ef66efcce7d3e7d2e823e7ece7b4e8abef2802e8e6e7efe7b600e7b802efcce7c0e91ce7b5e990eab5ef970000"
  },
  {
   "jp_offset": "0x21ed",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "夏亚！",
   "zh_hex": "15ef37e7d6060000"
  },
  {
   "jp_offset": "0x21f5",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "果然、你心里还是放不下……",
   "zh_hex": "15e871e7ef02e7b8e82def31e7f7e7b6e86ce7b5ef4d09090000"
  },
  {
   "jp_offset": "0x2227",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "住手吧……夏亚、其实你自己心里、也很{00}清楚吧？",
   "zh_hex": "15e859ef66e7d00909ef37e7d602e8cfe87fe7b8efb5e8c9e82def3102e7c0e98100e995ebd3e7d0050000"
  },
  {
   "jp_offset": "0x225f",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "哈曼？",
   "zh_hex": "15e7e8e874050000"
  },
  {
   "jp_offset": "0x2282",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "就算你做了这种事、拉拉也不会因此回来",
   "zh_hex": "15e7c5e889e7b8e81ce7bae7b9e7d1efb802e7c2e7c2e7c0e7b5e7e2ef33e7caef52efcf0000"
  },
  {
   "jp_offset": "0x229e",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "到头来、也只会让你更加空虚而已……",
   "zh_hex": "15e7d7e92eefcf02e7c0ef32e7e2e7f9e7b8e952e854e93febefe89cef3a09090000"
  },
  {
   "jp_offset": "0x22ca",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x22d0",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "不对！我只是、不愿眼看着这个世界、被{00}引向错误的方向罢了！！",
   "zh_hex": "15e7b5e7beef97efccef32e7b602e7b5e961e90be7f6e86de7b9e828e83ce8f502e7f100e9d0efc1e885ea33e7b4efb1efc1eaefe7baef97ef970000"
  },
  {
   "jp_offset": "0x2311",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……骗人",
   "zh_hex": "150909eb49efb20000"
  },
  {
   "jp_offset": "0x2318",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "你到现在、都还没能忘记拉拉……",
   "zh_hex": "15e7b8e7d7e82fef2902e840e7f7e7d8e7c6ea4de996e7c2e7c209090000"
  },
  {
   "jp_offset": "0x2333",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "所以你才想和阿姆罗做个了断、才做出这{00}种事来的！",
   "zh_hex": "15e7fbe7f3e7b8e836e7e6e7d3e7d2e823e7ece81ce828e7bae98202e836e81cefbee7b900e7d1efb8efcfe7b4ef970000"
  },
  {
   "jp_offset": "0x236b",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "哈曼、我……",
   "zh_hex": "15e7e8e87402efcc09090000"
  },
  {
   "jp_offset": "0x2390",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "可是、你想起来啊、夏亚！！",
   "zh_hex": "15e7c4e7b602e7b8e7e6e847efcfe7c302ef37e7d6ef97ef970000"
  },
  {
   "jp_offset": "0x239f",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "你不是曾跨越那份伤痛、对我说过要和我{00}重新来过吗？",
   "zh_hex": "15e7b8e7b5e7b6ea2aeeacea57e7b7ea22e8f9ea0b02e7beefcce7edef36ef2ae7d3efcc00e8a1ef8aefcfef36e802050000"
  },
  {
   "jp_offset": "0x23c2",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "若那份心意还残留着、那么夏亚、你其实{00}还……！",
   "zh_hex": "15e7e7e7b7ea22e82def3ce7f7e97be98ce86d02e7b7e7bdef37e7d602e7b8e8cfe87f00e7f70909ef970000"
  },
  {
   "jp_offset": "0x2422",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……夏亚！！",
   "zh_hex": "150909ef37e7d6ef97ef970000"
  },
  {
   "jp_offset": "0x2446",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "……这、是我和阿姆罗之间的决战",
   "zh_hex": "150909e7b902e7b6efcce7d3e7d2e823e7ece7cde8fce7b4e8abef280000"
  },
  {
   "jp_offset": "0x2457",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "谁要是敢插嘴、哈曼、纵然是你也……",
   "zh_hex": "15e923ef2ae7b6e8cdeb08eae202e7e8e87402e8e6e7efe7b6e7b8e7c009090000"
  },
  {
   "jp_offset": "0x2491",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "夏亚！",
   "zh_hex": "15ef37e7d6060000"
  },
  {
   "jp_offset": "0x24be",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "啊……",
   "zh_hex": "15e7c309090000"
  },
  {
   "jp_offset": "0x24ce",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "讨厌、恶心……",
   "zh_hex": "15e9f7eb2b02e7dee82d09090000"
  },
  {
   "jp_offset": "0x24e6",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "为什么、会变成这样……",
   "zh_hex": "15e7c1e7dde7bd02e7e2e955e837e7b9e7da09090000"
  },
  {
   "jp_offset": "0x24fa",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "夏亚……！！",
   "zh_hex": "15ef37e7d60909ef97ef970000"
  },
  {
   "jp_offset": "0x2532",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "我、我本想成为超越大佐的男人……",
   "zh_hex": "15efcc02efccefa6e7e6e837e7c1eaf6ea57efa5efbae7b4ea95efb209090000"
  },
  {
   "jp_offset": "0x2551",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……！",
   "zh_hex": "150909ef970000"
  },
  {
   "jp_offset": "0x2587",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "为什么、我竟会败在{00}这种外行的手里……！！",
   "zh_hex": "15e7c1e7dde7bd028bef2ce7e2e88fef2900e7b9e7d1e8f79fe7b4aeef310909060600000000000000"
  },
  {
   "jp_offset": "0x25cf",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "我绝饶不了你、这家伙！！",
   "zh_hex": "15efcce91ceab5e7b5e7bae7b802e7b9e7dfe7fdef97ef970000"
  },
  {
   "jp_offset": "0x260d",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "可恶！还没完呢！！",
   "zh_hex": "15e7c4e7deef97e7f7e7d8e87ee907ef97ef970000"
  },
  {
   "jp_offset": "0x2649",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "夏亚！……我绝不会让你得逞！！",
   "zh_hex": "15ef37e7d6ef970909efcce91ce7b5e7e2e7f9e7b8e80ae9ebef97ef970000"
  },
  {
   "jp_offset": "0x2687",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……休想逃！！",
   "zh_hex": "150909e90ee7e6e8c2ef97ef970000"
  },
  {
   "jp_offset": "0x26b7",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……阿姆罗！？",
   "zh_hex": "150909e7d2e823e7ecef97050000"
  },
  {
   "jp_offset": "0x26e1",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "你就给我陪到最后吧、夏亚！！",
   "zh_hex": "15e7b8e7c5e839efccef42e7d7e8c5e7fee7d002ef37e7d6ef97ef970000"
  },
  {
   "jp_offset": "0x271f",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "布莱特舰长、阿姆罗大尉他！！",
   "zh_hex": "15e831e846e7cfe7d4ef3402e7d2e823e7ecbe86e80c0606000000000000"
  },
  {
   "jp_offset": "0x2749",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "唔……！",
   "zh_hex": "15e81d0909ef970000"
  },
  {
   "jp_offset": "0x2751",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "阿姆罗、你可千万别出事啊……！！",
   "zh_hex": "15e7d2e823e7ec02e7b8e7c4eafde9f8e7e5efbeefb8e7c30909ef97ef970000"
  },
  {
   "jp_offset": "0x2788",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "成功击破新吉翁军！！",
   "zh_hex": "15e837e9b1e7ccc7ef8ae7d9ee88e7e006060000000000"
  },
  {
   "jp_offset": "0x27b4",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "好！让陆战队朝阿克西斯进发！！",
   "zh_hex": "15e7c7ef97e7f9efdaef28e7c9eaade7d2e7d5e7f8e7c8e892e870ef97ef970000"
  },
  {
   "jp_offset": "0x27ca",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "从内部引爆、把阿克西斯炸断！",
   "zh_hex": "15e88ae99aef70e9d0ef8402e81be7d2e7d5e7f8e7c8e9c9e982ef970000"
  },
  {
   "jp_offset": "0x2802",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "爆破成功！{00}阿克西斯正在一点点断裂开来！！",
   "zh_hex": "15ef84c7e837e9b10600e7d2e7d5e7f8e7c8ef3bef2987e822e822e982ec3ae7fad906060000000000000000"
  },
  {
   "jp_offset": "0x2836",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "成功了吗……！？",
   "zh_hex": "15e837e9b1e7bae8020909ef97050000"
  },
  {
   "jp_offset": "0x288b",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "唔！请等一下！！",
   "zh_hex": "15e81def97e83ae826efb6ef4def97ef970000"
  },
  {
   "jp_offset": "0x289a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "这是……",
   "zh_hex": "15e7b9e7b609090000"
  },
  {
   "jp_offset": "0x28be",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "什么！？阿克西斯要朝地球坠落了！？",
   "zh_hex": "15e7dde7bdef9705e7d2e7d5e7f8e7c8ef2aeaadef63efd3eb53e92ae7baef97050000"
  },
  {
   "jp_offset": "0x28e9",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "呵呵呵呵……哈哈哈哈哈！！",
   "zh_hex": "15ef3def3def3def3d0909e7e8e7e8e7e8e7e8e7e8ef97ef970000"
  },
  {
   "jp_offset": "0x28fd",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "是我赢了、阿姆罗！！",
   "zh_hex": "15e7b6efcce9cbe7ba02e7d2e823e7ecef97ef970000"
  },
  {
   "jp_offset": "0x2926",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x2949",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "我刚才算过了……阿克西斯的后半部、会{00}被地球引力拉扯着坠落下去！",
   "zh_hex": "15efcce8bce836e889ef36e7ba0909e7d2e7d5e7f8e7c8e7b4e7feeadeef7002e7e200e7f1ef63efd3e9d0efb0e7c2ed62e86deb53e92aef4de7ebef970000"
  },
  {
   "jp_offset": "0x296e",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "都怪你们太拼命了啊！！",
   "zh_hex": "15e840ea07e7b8e7bbe86aea66e853e7bae7c3ef97ef970000"
  },
  {
   "jp_offset": "0x299a",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……别开玩笑了！！",
   "zh_hex": "150909e7e5e7fae970ea1ce7baef97ef970000"
  },
  {
   "jp_offset": "0x29a5",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "区区一块大石头、我就用高达把它给推出{00}去！！",
   "zh_hex": "15ef35ef3587ec10beef44e92e028be7c5d8e812ef2be81be978e839eaabaf00e7eb0606000000000000000000"
  },
  {
   "jp_offset": "0x29c3",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "『夏亚……』",
   "zh_hex": "150cef37e7d609090d0000"
  },
  {
   "jp_offset": "0x2a0b",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "『夏亚……』",
   "zh_hex": "150cef37e7d609090d0000"
  },
  {
   "jp_offset": "0x2a35",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "是在呼唤我……？",
   "zh_hex": "15e7b6ef29ea3cec0eefcc0909050000"
  },
  {
   "jp_offset": "0x2a6f",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "『夏亚……』",
   "zh_hex": "150cef37e7d609090d0000"
  },
  {
   "jp_offset": "0x2a8c",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "拉拉！？",
   "zh_hex": "15e7c2e7c206050000"
  },
  {
   "jp_offset": "0x2ac3",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "『夏亚……活下去』",
   "zh_hex": "150cef37e7d60909e8d4ef4de7eb0d0000"
  },
  {
   "jp_offset": "0x2ae3",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "可是、我……",
   "zh_hex": "15e7c4e7b602efcc09090000"
  },
  {
   "jp_offset": "0x8b36",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "……不好！{00}这艘舰要是被击沉、那就……！",
   "zh_hex": "150909e7b5e7c70600e7b9eb18e7d4ef2ae7b6e7f1e7cce98302e7b7e7c509090600000000"
  },
  {
   "jp_offset": "0x8eae",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "奎丝",
   "zh_hex": "15eb82e8a30000"
  },
  {
   "jp_offset": "0x8ebe",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "（懂吗、夏亚？）",
   "zh_hex": "15ef8ee8b0e80202ef37e7d605ef8f0000"
  },
  {
   "jp_offset": "0x8ecf",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "（又有一个女人、{00}为了你而死去了啊……）",
   "zh_hex": "150ae8f1e7cb87e828b0b40200e7c1e7bae7b8e89ca7e7ebe7bae7c309090b0000000000000000"
  },
  {
   "jp_offset": "0x8eef",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "（你这个人、就只会踏着别人的性命、去{00}改造这个世界吗……！）",
   "zh_hex": "15ef8ee7b8e7b9e828efb202e7c5ef32e7e2ed0be86de7e5efb2e7b4e951e85302e7eb00e9f0e93ee7b9e828e83ce8f5e8020909ef97ef8f0000"
  },
  {
   "jp_offset": "0x8f36",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "沉下去！",
   "zh_hex": "15e983ef4de7ebef970000"
  },
  {
   "jp_offset": "0x8f72",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "来了！",
   "zh_hex": "15efcfe7baef970000"
  },
  {
   "jp_offset": "0x8faa",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "什么！？我的动向、竟然被看穿了！？",
   "zh_hex": "15e7dde7bdef9705efcce7b4ef30efc102ef2ce7efe7f1e7f6ea7ee7baef97050000"
  },
  {
   "jp_offset": "0x8ff2",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "怎、怎么可能！",
   "zh_hex": "15e7f202e7f2e7bde7c4e7c6ef970000"
  },
  {
   "jp_offset": "0x9005",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "我、竟然会被正面直击……！？",
   "zh_hex": "15efcc02ef2ce7efe7e2e7f1ef3be862e875e7cc0909ef97050000"
  },
  {
   "jp_offset": "0x904a",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "踏着别人的性命去改造世界、这种事……{00}！！",
   "zh_hex": "15ed0be86de7e5efb2e7b4e951e853e7ebe9f0e93ee83ce8f502e7b9e7d1efb8090900ef97ef970000"
  },
  {
   "jp_offset": "0x908e",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "唔……！",
   "zh_hex": "15e81d0909ef970000"
  },
  {
   "jp_offset": "0x90a0",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "一个被愚民利用了才能的家伙、有什么资{00}格说我！！",
   "zh_hex": "1587e828e7f1e959ef38e82ed8e7bae836e7c6e7b4e7dfe7fd02e7cbe7dde7bdeba700e824e7ed8b060600000000000000"
  },
  {
   "jp_offset": "0x90ea",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "阿姆罗！要不是有你在、拉拉她就……！",
   "zh_hex": "15e7d2e823e7ecef97ef2ae7b5e7b6e7cbe7b8ef2902e7c2e7c2e88ee7c50909ef970000"
  },
  {
   "jp_offset": "0x910a",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "给我好好回想起、拉拉死去时的那份痛楚{00}吧！！",
   "zh_hex": "15e839efcce7c7e7c7ef52e7e6e84702e7c2e7c2ef6ae7ebef2de7b4e7b7ea22ea0bebd300e7d0ef97ef970000"
  },
  {
   "jp_offset": "0x9152",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "夏亚！你这可悲的家伙！！",
   "zh_hex": "15ef37e7d6ef97e7b8e7b9e7c4e9dfe7b4e7dfe7fdef97ef970000"
  },
  {
   "jp_offset": "0x918a",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "什么……！？",
   "zh_hex": "15e7dde7bd0909ef97050000"
  },
  {
   "jp_offset": "0x91c6",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "去吧！飞翼浮游炮！！",
   "zh_hex": "15e7ebe7d0ef97ea45ec35e813ea94e95aef97ef970000"
  },
  {
   "jp_offset": "0x9206",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "夏亚",
   "zh_hex": "15ef37e7d60000"
  },
  {
   "jp_offset": "0x9232",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "夏亚",
   "zh_hex": "15ef37e7d60000"
  },
  {
   "jp_offset": "0x925e",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "阿克西斯的坠落都已经开始了、你疯了吗{00}！？",
   "zh_hex": "15e7d2e7d5e7f8e7c8e7b4eb53e92ae840ef3ae8b7e7fae908e7ba02e7b8ee70e7bae80200ef97050000"
  },
  {
   "jp_offset": "0x92b2",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "我可没你那么心急、也没对人类那样绝望{00}过！",
   "zh_hex": "15efcce7c4e7d8e7b8e7b7e7bde82dea6202e7c0e7d8e7beefb2e841e7b7e7dae91ce96500ef36ef970000"
  },
  {
   "jp_offset": "0x92ee",
   "jp_len": 26,
   "kind": "script",
   "zh_hex": "152e3302000215e8fee812ef2b02e7c4e7b5e7b6eb02e7cbe8cfe9e7e7b4ef97ef970000"
  },
  {
   "jp_offset": "0x9336",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "我要用拉·凯拉姆、把阿克西斯硬推回去{00}！！",
   "zh_hex": "158bef2ad8e7c204e95fe7c2e82302e81be7d2e7d5e7f8e7c8eb97eaab8ce7eb0006060000000000000000"
  },
  {
   "jp_offset": "0x9368",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "太乱来了、舰长！",
   "zh_hex": "15e86ae976efcfe7ba02e7d4ef34ef970000"
  },
  {
   "jp_offset": "0x93bd",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……怎么了！？",
   "zh_hex": "150909e7f2e7bde7baef97050000"
  },
  {
   "jp_offset": "0x93e2",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "阿、阿克西斯上……！",
   "zh_hex": "15e7d202e7d2e7d5e7f8e7c8ef4c0909ef970000"
  },
  {
   "jp_offset": "0x93ed",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "阿克西斯上、有MS！！",
   "zh_hex": "15e7d2e7d5e7f8e7c8ef4c02e7cbefa7ef9eef97ef970000"
  },
  {
   "jp_offset": "0x9413",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x9432",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "怎么样、来得及吗？",
   "zh_hex": "15e7f2e7bde7da02efcfe80ae9cfe802050000"
  },
  {
   "jp_offset": "0x9459",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "一定会赶上的、你就瞧好吧！",
   "zh_hex": "15efb6e867e7e2ea04ef4ce7b402e7b8e7c5ead4e7c7e7d0ef970000"
  },
  {
   "jp_offset": "0x9482",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "推进剂只够单程、事后记得来接我啊！",
   "zh_hex": "15eaabe892edeaef32e920e918ea7d02a9e7fee996e80ad9b78be7c30600000000000000"
  },
  {
   "jp_offset": "0x94b6",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "真是抱歉啊！还劳烦你专程送我过来！！",
   "zh_hex": "15e820e7b6e922e927e7c306e7f7ec4ae95be7b8eb4bea7de9ba8bef36d906060000000000"
  },
  {
   "jp_offset": "0x94e7",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "道谢、等顺利拦住它之后再说吧、自然人{00}！",
   "zh_hex": "15e82ae8b202e826eab4e82eeb89e859e978e7cde7fee80be7ede7d002abe7efb400060000000000"
  },
  {
   "jp_offset": "0x951f",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "唯独这一次、得好好感谢调整者了……上{00}吧！",
   "zh_hex": "15ea89e8eee7b9efb6e86402e80ae7c7e7c7e87de8b2e95ce9feef6ee7ba0909ef4c00e7d0ef970000"
  },
  {
   "jp_offset": "0x9588",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "真是的……自然人、不是我们的敌人来着{00}吗？",
   "zh_hex": "15e820e7b6e7b40909efb5e7efefb202e7b5e7b6efcce7bbe7b4e7e3efb2efcfe86d00e802050000"
  },
  {
   "jp_offset": "0x95ba",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "在地球的危机面前、可分不出什么自然人{00}和调整者了",
   "zh_hex": "15ef29ef63efd3e7b4e935e7e4e862ef5102e7c4efaee7b5efbee7dde7bdefb5e7efefb200e7d3e95ce9feef6ee7ba0000"
  },
  {
   "jp_offset": "0x95f9",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "也是……",
   "zh_hex": "15e7c0e7b609090000"
  },
  {
   "jp_offset": "0x9602",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "望着那道光、还真会让人生出这种念头来",
   "zh_hex": "15e965e86de7b7e82ae83d02e7f7e820e7e2e7f9b4b6afe7b9e7d1ea27e92ed9000000000000"
  },
  {
   "jp_offset": "0x9636",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "舰长！阿克西斯它……！！",
   "zh_hex": "15e7d4ef34ef97e7d2e7d5e7f8e7c8e9780909ef97ef970000"
  },
  {
   "jp_offset": "0x965f",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "正远离地球……？",
   "zh_hex": "15ef3be94ce901ef63efd30909050000"
  },
  {
   "jp_offset": "0x9697",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "『夏亚……！』",
   "zh_hex": "150cef37e7d60909ef970d0000"
  },
  {
   "jp_offset": "0x96f2",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "『夏亚……！』",
   "zh_hex": "150cef37e7d60909ef970d0000"
  },
  {
   "jp_offset": "0x9717",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "拉拉！？不对……？",
   "zh_hex": "15e7c2e7c2ef9705e7b5e7be0909050000"
  },
  {
   "jp_offset": "0x9725",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "你是……",
   "zh_hex": "15e7b8e7b609090000"
  },
  {
   "jp_offset": "0x9785",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "夏亚！",
   "zh_hex": "15ef37e7d6060000"
  },
  {
   "jp_offset": "0x978d",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "我绝不会、让你就这样死去……",
   "zh_hex": "15efcce91ce7b5e7e202e7f9e7b8e7c5e7b9e7daef6ae7eb09090000"
  },
  {
   "jp_offset": "0x97c3",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "『夏亚……！』",
   "zh_hex": "150cef37e7d60909ef970d0000"
  },
  {
   "jp_offset": "0x981e",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "『夏亚……！』",
   "zh_hex": "150cef37e7d60909ef970d0000"
  },
  {
   "jp_offset": "0x9843",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "拉拉！？不对……？",
   "zh_hex": "15e7c2e7c2ef9705e7b5e7be0909050000"
  },
  {
   "jp_offset": "0x9851",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "你是……",
   "zh_hex": "15e7b8e7b609090000"
  },
  {
   "jp_offset": "0x98b1",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "夏亚！",
   "zh_hex": "15ef37e7d6060000"
  },
  {
   "jp_offset": "0x98b9",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "我绝不会、让你就这样死去……",
   "zh_hex": "15efcce91ce7b5e7e202e7f9e7b8e7c5e7b9e7daef6ae7eb09090000"
  },
  {
   "jp_offset": "0x98e2",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "唔……",
   "zh_hex": "15e81d09090000"
  },
  {
   "jp_offset": "0x990d",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "你醒了吗、夏亚",
   "zh_hex": "15e7b8eb20e7bae80202ef37e7d60000"
  },
  {
   "jp_offset": "0x9935",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……哈曼？",
   "zh_hex": "150909e7e8e874050000"
  },
  {
   "jp_offset": "0x993d",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "是你……把我、救下来的吗？",
   "zh_hex": "15e7b6e7b80909e81befcc02e8caef4defcfe7b4e802050000"
  },
  {
   "jp_offset": "0x9969",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "……连我自己、都觉得这么做很傻",
   "zh_hex": "150909e86eefccefb5e8c902e840e8aee80ae7b9e7bde81ce981ec0a0000"
  },
  {
   "jp_offset": "0x9978",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "但我、无论如何也无法对你的死、坐视不{00}管……",
   "zh_hex": "15e7dbefcc02e7dce8dce7f0efbce7c0e7dce84ee7bee7b8e7b4ef6a02ecc3e9d9e7b500e93b09090000"
  },
  {
   "jp_offset": "0x99b9",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "事到如今、还厚着脸皮活了下来、你又要{00}我去做什么……",
   "zh_hex": "15efb8e7d7e7f0efb902e7f7ecbce86deb69ebdde8d4e7baef4defcf02e7b8e8f1ef2a00efcce7ebe81ce7dde7bd09090000"
  },
  {
   "jp_offset": "0x99ed",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "犯下的过错、即便无法消除、却也是能够{00}偿还的、夏亚",
   "zh_hex": "15eb0eef4de7b4ef36e88502e855e8fae7dce84ee928e97402eadfe7c0e7b6e7c6e92000ec09e7f7e7b402ef37e7d60000"
  },
  {
   "jp_offset": "0x9a29",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "偿还……你是要我、去做这种事？",
   "zh_hex": "15ec09e7f70909e7b8e7b6ef2aefcc02e7ebe81ce7b9e7d1efb8050000"
  },
  {
   "jp_offset": "0x9a60",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "我只是、希望你能好好活着……仅此而已",
   "zh_hex": "15efccef32e7b602e87be965e7b8e7c6e7c7e7c7e8d4e86d0909eb7ae7cae89cef3a0000"
  },
  {
   "jp_offset": "0x9a7e",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "夏亚、你以前、应该对我说过的吧",
   "zh_hex": "15ef37e7d602e7b8e7f3ef5102e873e898e7beefcce7edef36e7b4e7d00000"
  },
  {
   "jp_offset": "0x9a96",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……说要和我重新来过",
   "zh_hex": "150909e7edef2ae7d3efcce8a1ef8aefcfef360000"
  },
  {
   "jp_offset": "0x9aa4",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "所以这一次、就轮到我、对你说同样的话",
   "zh_hex": "15e7fbe7f3e7b9efb6e86402e7c5ebf4e7d7efcc02e7bee7b8e7ede85de7dae7b4e81f0000"
  },
  {
   "jp_offset": "0x9ab9",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "重新来过吧、夏亚",
   "zh_hex": "15e8a1ef8aefcfef36e7d002ef37e7d60000"
  },
  {
   "jp_offset": "0x9ac6",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "偿还犯下的过错、然后……",
   "zh_hex": "15ec09e7f7eb0eef4de7b4ef36e88502e7efe7fe09090000"
  },
  {
   "jp_offset": "0x9ada",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "……这一次、就换我来支撑你、夏亚",
   "zh_hex": "150909e7b9efb6e86402e7c5ea78efccefcfe883ea29e7b802ef37e7d60000"
  },
  {
   "jp_offset": "0x9b09",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "哈曼",
   "zh_hex": "15e7e8e8740000"
  },
  {
   "jp_offset": "0x9b2a",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "唔……",
   "zh_hex": "15e81d09090000"
  },
  {
   "jp_offset": "0x9b55",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "没事吧、夏亚？",
   "zh_hex": "15e7d8efb8e7d002ef37e7d6050000"
  },
  {
   "jp_offset": "0x9b7e",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……哈曼？",
   "zh_hex": "150909e7e8e874050000"
  },
  {
   "jp_offset": "0x9b86",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "是你……把我、救下来的吗？",
   "zh_hex": "15e7b6e7b80909e81befcc02e8caef4defcfe7b4e802050000"
  },
  {
   "jp_offset": "0x9bb2",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯",
   "zh_hex": "150909e8650000"
  },
  {
   "jp_offset": "0x9bd4",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "为何",
   "zh_hex": "15e7c1efbc0000"
  },
  {
   "jp_offset": "0x9bf6",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "连我自己、都觉得是多管闲事了",
   "zh_hex": "15e86eefccefb5e8c902e840e8aee80ae7b6e7e9e93beebeefb8e7ba0000"
  },
  {
   "jp_offset": "0x9c13",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "可是、你就这样死去、我无论如何也忍受{00}不了……",
   "zh_hex": "15e7c4e7b602e7b8e7c5e7b9e7daef6ae7eb02efcce7dce8dce7f0efbce7c0eb59e8c800e7b5e7ba09090000"
  },
  {
   "jp_offset": "0x9c57",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "事到如今、还厚着脸皮活了下来、你又要{00}我去做什么……",
   "zh_hex": "15efb8e7d7e7f0efb902e7f7ecbce86deb69ebdde8d4e7baef4defcf02e7b8e8f1ef2a00efcce7ebe81ce7dde7bd09090000"
  },
  {
   "jp_offset": "0x9c8b",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "犯下的过错、即便无法消除、也是能够偿{00}还的、夏亚",
   "zh_hex": "15eb0eef4de7b4ef36e88502e855e8fae7dce84ee928e97402e7c0e7b6e7c6e920ec0900e7f7e7b402ef37e7d60000"
  },
  {
   "jp_offset": "0x9cc7",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "偿还……你是要我、去做这种事？",
   "zh_hex": "15ec09e7f70909e7b8e7b6ef2aefcc02e7ebe81ce7b9e7d1efb8050000"
  },
  {
   "jp_offset": "0x9cfe",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "我只是、希望你能好好活着……仅此而已",
   "zh_hex": "15efccef32e7b602e87be965e7b8e7c6e7c7e7c7e8d4e86d0909eb7ae7cae89cef3a0000"
  },
  {
   "jp_offset": "0x9d1d",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "你之前说过吧？",
   "zh_hex": "15e7b8e7cdef51e7edef36e7d0050000"
  },
  {
   "jp_offset": "0x9d2d",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "说要和我重新来过",
   "zh_hex": "15e7edef2ae7d3efcce8a1ef8aefcfef360000"
  },
  {
   "jp_offset": "0x9d3a",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "所以这一次、就换我、对你说同样的话",
   "zh_hex": "15e7fbe7f3e7b9efb6e86402e7c5ea78efcc02e7bee7b8e7ede85de7dae7b4e81f0000"
  },
  {
   "jp_offset": "0x9d51",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "重新来过吧、夏亚",
   "zh_hex": "15e8a1ef8aefcfef36e7d002ef37e7d60000"
  },
  {
   "jp_offset": "0x9d5e",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "偿还犯下的过错、然后……",
   "zh_hex": "15ec09e7f7eb0eef4de7b4ef36e88502e7efe7fe09090000"
  },
  {
   "jp_offset": "0x9d72",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "……这一次、就换我来支撑你",
   "zh_hex": "150909e7b9efb6e86402e7c5ea78efccefcfe883ea29e7b80000"
  },
  {
   "jp_offset": "0x9d82",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "所以、活下去吧……夏亚",
   "zh_hex": "15e7fbe7f302e8d4ef4de7ebe7d00909ef37e7d60000"
  },
  {
   "jp_offset": "0x9daa",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "哈曼",
   "zh_hex": "15e7e8e8740000"
  },
  {
   "jp_offset": "0x9dca",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "全机回收完毕",
   "zh_hex": "15efb4e7e4ef52e926e87eea2c0000"
  },
  {
   "jp_offset": "0x9df4",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……阿姆罗呢？",
   "zh_hex": "150909e7d2e823e7ece907050000"
  },
  {
   "jp_offset": "0x9e18",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "ν高达、确认已安全回收",
   "zh_hex": "15e8fee812ef2b02e88ce8a0ef3ae7fcefb4ef52e9260000"
  },
  {
   "jp_offset": "0x9e29",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "其他队员也全员平安、没有一人掉队失踪",
   "zh_hex": "15e8cfe80ce7c9e849e7c0efb4e849e887e7fc02e7d8e7cbefb6efb2e9d3e7c9e8a5ec970000"
  },
  {
   "jp_offset": "0x9e63",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "是吗",
   "zh_hex": "15e7b6e802000000"
  },
  {
   "jp_offset": "0x9e86",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "新吉翁那边、似乎也有大半的人获救或被{00}收容了",
   "zh_hex": "15ef8ae7d9ee88e7b7e89902e944e933e7c0e7cbbeeadee7b4b4e9d8e8cae905e7f100e926ed2fe7ba00000000"
  },
  {
   "jp_offset": "0x9ec0",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……连新吉翁也？",
   "zh_hex": "150909e86eef8ae7d9ee88e7c0050000"
  },
  {
   "jp_offset": "0x9ecc",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "经历了那样激烈的战斗……简直就像奇迹{00}一样",
   "zh_hex": "15e8b7e8fbe7bae7b7e7dae9b9eaece7b4ef28e7ff0909e9abe875e7c5e8e9e904ed0f00efb6e7da0000"
  },
  {
   "jp_offset": "0x9f11",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……是奇迹",
   "zh_hex": "150909e7b6e904ed0f0000"
  },
  {
   "jp_offset": "0x9f36",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "……是人心之光、所带来的",
   "zh_hex": "150909e7b6efb2e82de7cde83d02e7fbe937efcfe7b40000"
  },
  {
   "jp_offset": "0x9f6c",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "阿姆罗！？你果然平安无事啊！",
   "zh_hex": "15e7d2e823e7ecef9705e7b8e871e7efe887e7fce7dcefb8e7c3ef970000"
  },
  {
   "jp_offset": "0x9f98",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "……嗯、全靠大家伸手相助才得救的",
   "zh_hex": "150909e86502efb4e8c7efa5e7dfedd7ef66e8b1ea23e836e80ae8cae7b40000"
  },
  {
   "jp_offset": "0x9fd3",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "看来、这一次的事件、也终于全部落幕了",
   "zh_hex": "15e7f6efcf02e7b9efb6e864e7b4efb8e99102e7c0e8e2e879efb4ef70e92aec14e7ba0000"
  },
  {
   "jp_offset": "0x9fee",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "夏亚的作战已被阻止、新吉翁那边也……",
   "zh_hex": "15ef37e7d6e7b4ef2fef28ef3ae7f1e8efe86902ef8ae7d9ee88e7b7e899e7c009090000"
  },
  {
   "jp_offset": "0xa020",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "……见过那道光之后、谁都再提不起、想{00}要开战的念头了吧",
   "zh_hex": "150909e85cef36e7b7e82ae83de7cde7fe02e923e840e80be821e7b5e84702e7e600ef2ae7faef28e7b4ea27e92ee7bae7d00000"
  },
  {
   "jp_offset": "0xa05d",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "是精神感应框架的光吗……正是它、让奇{00}迹成为了可能",
   "zh_hex": "15e7b6e98de9aae87de873eef3e99de7b4e83de8020909ef3be7b6e97802e7f9e90400ed0fe837e7c1e7bae7c4e7c60000"
  },
  {
   "jp_offset": "0xa095",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "是ν高达……不、不只是ν高达",
   "zh_hex": "15e7b6e8fee812ef2b0909e7b502e7b5ef32e7b6e8fee812ef2b0000"
  },
  {
   "jp_offset": "0xa0b1",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "是那时、聚集到阿克西斯的高达们、让我{00}明白了……",
   "zh_hex": "15e7b6e7b7ef2d02ebe8ea98e7d7e7d2e7d5e7f8e7c8e7b4e812ef2be7bb02e7f98b00ef39e809e7ba0909000000"
  },
  {
   "jp_offset": "0xa0cf",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "人类还……远没有到无可救药的地步呢",
   "zh_hex": "15efb2e841e7f70909e94ce7d8e7cbe7d7e7dce7c4e8caebede7b4ef63ea93e9070000"
  },
  {
   "jp_offset": "0xa138",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "（对吧、拉拉？）",
   "zh_hex": "15ef8ee7bee7d002e7c2e7c205ef8f0000"
  },
  {
   "jp_offset": "0xb4de",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "大家……！？",
   "zh_hex": "15efa5e7df0909ef97050000"
  },
  {
   "jp_offset": "0xb502",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "地球、是生活在这片宇宙的所有人的原点{00}啊！",
   "zh_hex": "15ef63efd302e7b6ef8de8d4ef29e7b9ee5ee8bee8bfe7b4e7fbe7cbefb2e7b4e8e4e82200e7c3ef970000"
  },
  {
   "jp_offset": "0xb51d",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "我怎能眼睁睁、任由它被毁掉！",
   "zh_hex": "15efcce7f2e7c6e90bed90ed9002e89ae8a6e978e7f1e97ce9d3ef970000"
  },
  {
   "jp_offset": "0xb54b",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "……！住手！！",
   "zh_hex": "150909ef97e859ef66ef97ef970000"
  },
  {
   "jp_offset": "0xb558",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "你们没必要、陪着我一起干这种乱来的事{00}……",
   "zh_hex": "15e7b8e7bbe7d8e860ef2a02ef42e86defccefb6e847e8d3e7b9e7d1e976efcfe7b4efb80009090000"
  },
  {
   "jp_offset": "0xb58a",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "反正本来就是乱来！！",
   "zh_hex": "15e87cef3befa6efcfe7c5e7b6e976efcfef97ef970000"
  },
  {
   "jp_offset": "0xb596",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "所谓奇迹、要是不拼到这个份上、又怎么{00}可能发生！？",
   "zh_hex": "15e7fbe92be904ed0f02ef2ae7b6e7b5ea66e7d7e7b9e828ea22ef4c02e8f1e7f2e7bd00e7c4e7c6e870ef8def97050000"
  },
  {
   "jp_offset": "0xb5ca",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "蒂法！把你的力量、借给我！！",
   "zh_hex": "15e9f5e84e06e81be7b8e7b4dae85102eadce8398b060600000000000000"
  },
  {
   "jp_offset": "0xb5da",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "我要用卫星炮、把阿克西斯轰个粉碎！！",
   "zh_hex": "15efccef2aefb3e9b2ef69e95a02e81be7d2e7d5e7f8e7c8eefce828ee7debe0ef97ef970000"
  },
  {
   "jp_offset": "0xb60b",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "嗯……加洛德",
   "zh_hex": "15e8650909e854e94ae82c0000"
  },
  {
   "jp_offset": "0xb63a",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "你们……！",
   "zh_hex": "15e7b8e7bb0909060000"
  },
  {
   "jp_offset": "0xb65f",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "哪怕是背负罪业的∀高达、也一样能去救{00}助他人！！",
   "zh_hex": "15e8ffe958e7b6e9e4e92cea7feadae7b4effee812ef2b02e7c0efb6e7dae7c6e7ebe8ca00ea23e80cefb2ef97ef970000"
  },
  {
   "jp_offset": "0xb69a",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "相信高达的力量吧！阿姆罗先生！！",
   "zh_hex": "15e8b1e90fe812ef2be7b4dae851e7d006e7d2e823e7ecb8b606060000000000000000"
  },
  {
   "jp_offset": "0xb74c",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "这、这是……精神感应框架的共振！？",
   "zh_hex": "15e7b902e7b9e7b60909e98de9aae87de873eef3e99de7b4ea48eb5b0605000000"
  },
  {
   "jp_offset": "0xb7b4",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "……什么？竟然感觉不到一丝恐惧……？",
   "zh_hex": "150909e7dde7bd05ef2ce7efe87de8aee7b5e7d7efb6e8a3eb33ec6e0909050000"
  },
  {
   "jp_offset": "0xb7df",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "非但如此、反而让人感到温暖、安心……",
   "zh_hex": "15e8f0e7dbe7f0e7ca02e87ce89ce7f9b4e87de7d7e9c0ecc802e7fce82d0909000000"
  },
  {
   "jp_offset": "0xb85d",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "这就是、所谓人的温暖吗、夏亚！？",
   "zh_hex": "15e7b9e7c5e7b602e7fbe92bb4e7b4e9c0ecc8e80202ef37e7d6060500000000"
  },
  {
   "jp_offset": "0xb8a7",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "可就是怀着这份温暖的人类、却连地球都{00}要去毁灭！",
   "zh_hex": "15e7c4e7c5e7b6eb03e86de7b9ea22e9c0ecc8e7b4b4e84102eadfe86ebf95e84000ef2ae7ebe97ce8e106000000000000"
  },
  {
   "jp_offset": "0xb8c6",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "这一点、你要明白啊、阿姆罗！",
   "zh_hex": "15e7b9efb6e82202e7b8ef2aef39e809e7c302e7d2e823e7ecef970000"
  },
  {
   "jp_offset": "0xb941",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "所以、才更要让这世界、看见那人心之光{00}啊！！",
   "zh_hex": "15e7fbe7f302e836e952ef2ae7f9e7b9e83ce8f502e7f6e85ce7b7efb2e82de7cde83d00e7c3ef97ef970000"
  },
  {
   "jp_offset": "0xb994",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "哼！既然这么说、当初你对奎丝、可真是{00}冷淡得很！",
   "zh_hex": "15e8b3ef97e8c4e7efe7b9e7bde7ed02ef53eb4fe7b8e7beeb82e8a302e7c4e820e7b600eb4eee55e80ae981ef970000"
  },
  {
   "jp_offset": "0xb9e0",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我又不是机器！什么奎丝的代理父亲……",
   "zh_hex": "15efcce8f1e7b5e7b6e7e4e8c3ef97e7dde7bdeb82e8a3e7b4e8e7e872e888e89409090000"
  },
  {
   "jp_offset": "0xba12",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "唔！原来如此！！都怪你把奎丝当成机器{00}来对待！",
   "zh_hex": "15e81def97e8e4efcfe7f0e7caef97ef97e840ea07e7b8e81beb82e8a3ef53e837e7e4e8c300efcfe7beeaa8ef970000"
  },
  {
   "jp_offset": "0xba98",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "是吗……原来奎丝、一直在渴求着父爱",
   "zh_hex": "15e7b6e8020909e8e4efcfeb82e8a302efb6e875ef29ed84e93ae86de888e8d50000"
  },
  {
   "jp_offset": "0xbaae",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我却嫌那麻烦、把奎丝当成了机器……",
   "zh_hex": "15efcceadfee0be7b7ea36e95b02e81beb82e8a3ef53e837e7bae7e4e8c309090000"
  },
  {
   "jp_offset": "0xbb2c",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "堂堂你这样的男人、器量竟如此狭小！！",
   "zh_hex": "15eb2eeb2ee7b8e7b9e7dae7b4ea95b402e8c3e851ef2ce7f0e7caee62e83e06060000000000"
  },
  {
   "jp_offset": "0xbb70",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "拉拉·辛、本是有可能成为我母亲的女性{00}啊！！",
   "zh_hex": "15e7c2e7c204ea5802d2e7b6e7cbe7c4e7c6e837e7c18be9d5e894e7b4b0e95100e7c306060000000000000000"
  },
  {
   "jp_offset": "0xbb92",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "杀了那个拉拉的你、又有什么资格说我！{00}！",
   "zh_hex": "15e89be7bae7b7e828e7c2e7c2e7b4e7b802e8f1e7cbe7dde7bdeba7e824e7edefccef9700ef970000"
  },
  {
   "jp_offset": "0xbc1c",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "母亲？拉拉她……！？",
   "zh_hex": "15e9d5e89405e7c2e7c2e88e09090605000000"
  },
  {
   "jp_offset": "0xbc69",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "既是化生命为力量的高达、连奇迹也能{00}引发……",
   "zh_hex": "15e8c4e7b6e9a5b6e853e7c1dae851e7b4e812ef2b02e86ee904ed0fe7c0e7c600e9d0e87009090000000000000000"
  },
  {
   "jp_offset": "0xbc87",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "不！是一定能！！我们也来帮你、阿姆罗{00}先生！",
   "zh_hex": "15e7b5ef97e7b6efb6e867e7c6ef97ef97efcce7bbe7c0efcfe910e7b802e7d2e823e7ec00ef8bef8def970000"
  }
 ]
}
