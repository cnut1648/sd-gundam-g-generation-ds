{
 "file": "_STG00S.bin",
 "source_size": 26260,
 "built_size": 27719,
 "edits": [
  {
   "jp_offset": "0x11fb",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "竟然……是毒气……",
   "zh_hex": "15ef2ce7ef0909e7b6eb5fe8ed09090000"
  },
  {
   "jp_offset": "0x120c",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "上头那帮家伙、竟然这样骗了我们……",
   "zh_hex": "15ef4ce92ee7b7e910e7dfe7fd02ef2ce7efe7b9e7daeb49e7baefcce7bb09090000000000"
  },
  {
   "jp_offset": "0x1220",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "可恶！",
   "zh_hex": "15e7c4e7deef970000"
  },
  {
   "jp_offset": "0x1259",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "竟在殖民地里施放毒气、你们这群杀人凶{00}手！",
   "zh_hex": "15ef2cef29e8a9ef38ef63ef31eb8de86ceb5fe8ed02e7b8e7bbe7b9ecfae89befb2ecb200ef66ef97000000000000"
  },
  {
   "jp_offset": "0x1272",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "难道这就是你们所谓的战争吗！？",
   "zh_hex": "15e866e82ae7b9e7c5e7b6e7b8e7bbe7fbe92be7b4ef28e852e80206050000000000"
  },
  {
   "jp_offset": "0x12a0",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "啊……",
   "zh_hex": "15e7c309090000"
  },
  {
   "jp_offset": "0x12d5",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "队长！！您振作一点啊！",
   "zh_hex": "15e7c9ef34ef97ef97e835eb5bef2fefb6e822e7c3ef97000000"
  },
  {
   "jp_offset": "0x130a",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "再不应战可不行啊……！",
   "zh_hex": "15e80be7b5e873ef28e7c4e7b5efd6e7c30909ef970000"
  },
  {
   "jp_offset": "0x1342",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "再这样下去、我们会被干掉的！",
   "zh_hex": "15e80be7b9e7daef4de7eb02efcce7bbe7e2e7f1e8d3e9d3e7b4ef97000000"
  },
  {
   "jp_offset": "0x138c",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……抱歉",
   "zh_hex": "150909e922e927000000"
  },
  {
   "jp_offset": "0x1396",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "看来我刚才有点失态了",
   "zh_hex": "15e7f6efcfefcce8bce836e7cbe822e8a5e994e7ba000000"
  },
  {
   "jp_offset": "0x13c9",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……队长！",
   "zh_hex": "150909e7c9ef34ef970000"
  },
  {
   "jp_offset": "0x13fe",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "被他们蒙骗、被迫犯下杀人的勾当、到头{00}来",
   "zh_hex": "15e7f1e80ce7bbe942eb4902e7f1eb70eb0eef4de89befb2e7b4ecb7ef5302e7d7e92e00efcf000000000000"
  },
  {
   "jp_offset": "0x1417",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "要是就这么死在这种地方、可就太不甘心{00}了",
   "zh_hex": "15ef2ae7b6e7c5e7b9e7bdef6aef29e7b9e7d1ef63efb102e7c4e7c5e86ae7b5ecede82d00e7ba00000000000000"
  },
  {
   "jp_offset": "0x1430",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "小子们！都给我应战！",
   "zh_hex": "15e83ee886e7bbef97e840e839efcce873ef28ef97000000"
  },
  {
   "jp_offset": "0x145b",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "是、是！",
   "zh_hex": "15e7b602e7b606000000"
  },
  {
   "jp_offset": "0x1491",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "听好了、你们这帮家伙！我们一定要活下{00}去！",
   "zh_hex": "15e8d1e7c7e7ba02e7b8e7bbe7b9e910e7dfe7fdef97efcce7bbefb6e867ef2ae8d4ef4d00e7ebef970000000000"
  },
  {
   "jp_offset": "0x14aa",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "活下来、好好揍扁那些下达这种命令的家{00}伙！",
   "zh_hex": "15e8d4ef4defcf02e7c7e7c7ee33ee28e7b7e8a4ef4def2be7b9e7d1e853e94ee7b4e7df00e7fdef970000000000000000000000"
  },
  {
   "jp_offset": "0x14ce",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "在那之前、谁都不许给我死掉！",
   "zh_hex": "15ef29e7b7e7cdef5102e923e840e7b5e8a7e839efccef6ae9d3ef970000000000"
  },
  {
   "jp_offset": "0x1508",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "竟……竟然要死在这种地方……",
   "zh_hex": "15ef2c0909ef2ce7efef2aef6aef29e7b9e7d1ef63efb109090000000000"
  },
  {
   "jp_offset": "0x1520",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……可恶！",
   "zh_hex": "150909e7c4e7deef970000"
  },
  {
   "jp_offset": "0x155b",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "做到了……！",
   "zh_hex": "15e81ce7d7e7ba0909ef970000"
  },
  {
   "jp_offset": "0x1589",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯",
   "zh_hex": "150909e8650000"
  },
  {
   "jp_offset": "0x1590",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "看来总算是活下来了呢",
   "zh_hex": "15e7f6efcfe881e889e7b6e8d4ef4defcfe7bae9070000000000"
  },
  {
   "jp_offset": "0x15c4",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……队长？",
   "zh_hex": "150909e7c9ef34050000"
  },
  {
   "jp_offset": "0x15e7",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "……不、没什么",
   "zh_hex": "150909e7b502e7d8e7dde7bd000000"
  },
  {
   "jp_offset": "0x15f4",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "撤退！",
   "zh_hex": "15e90ae880ef970000"
  },
  {
   "jp_offset": "0x1622",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "呵呵……杀人凶手……吗",
   "zh_hex": "15ef3def3d0909e89befb2ecb2ef660909e80200000000"
  },
  {
   "jp_offset": "0x1630",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "我们……",
   "zh_hex": "15efcce7bb09090000"
  },
  {
   "jp_offset": "0x1650",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "啊、西玛大人！情况怎么样？",
   "zh_hex": "15e7c302e7f8e845efa5efb2ef97e88be8d0e7f2e7bde7da0500000000"
  },
  {
   "jp_offset": "0x167e",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "总之、会面已经结束了",
   "zh_hex": "15e881e7cd02e7e2e862ef3ae8b7e868e895e7ba0000"
  },
  {
   "jp_offset": "0x168b",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "接下来我们要载着一位客人、前往{00}SIDE6",
   "zh_hex": "15efceef4defcfefcce7bbef2aeb1de86defb6e834eccbefb202ef51e91100ef9eef62ef96ef9fe9cd00000000"
  },
  {
   "jp_offset": "0x16a5",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "听说是要把什么新人类、编入我们的战力",
   "zh_hex": "15e8d1e7ede7b6ef2ae81be7dde7bdef8aefb2e84102ec89e891efcce7bbe7b4ef28efb000000000"
  },
  {
   "jp_offset": "0x16d9",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "是吗……新人类啊……",
   "zh_hex": "15e7b6e8020909ef8ab4e841e7c309090000000000"
  },
  {
   "jp_offset": "0x1704",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "嘛、不管内情究竟如何……",
   "zh_hex": "15e93602e7b5e93be99ae88be906ef2ce7f0efbc09090000"
  },
  {
   "jp_offset": "0x1713",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "对干惯了脏活的我们来说、总算轮到一份{00}正经任务了",
   "zh_hex": "15e7bee8d3ecd6e7baedb0e8d4e7b4efcce7bbefcfe7ed02e881e889ebf4e7d7efb6ea2200ef3be8b7e89ae94fe7ba00000000"
  },
  {
   "jp_offset": "0x1734",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "正好趁这机会、给我们海兵队{00}洗刷污名……",
   "zh_hex": "15ef3be7c7e9eae7b9e7e4e7e202e8398be7bbe91bcee7c900ee50ede9ec26e8ac0909000000000000000000"
  },
  {
   "jp_offset": "0x1758",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "宇宙世纪0079、11月末",
   "zh_hex": "15e8bee8bfe83ceb99e998e998eb79eca402eff7eff7e850ec22000000"
  },
  {
   "jp_offset": "0x176b",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "地球、卫星轨道之上……",
   "zh_hex": "15bf9502e9b2b5e9cce82ae7cdb20909000000000000000000"
  },
  {
   "jp_offset": "0x1c67",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "唔……",
   "zh_hex": "15e81d09090000"
  },
  {
   "jp_offset": "0x1c6d",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "什么……？是梦……？",
   "zh_hex": "15e7dde7bd090905e7b6ea4009090500000000"
  },
  {
   "jp_offset": "0x1c7c",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "啧！尽让我看些恶心的东西……真是的！",
   "zh_hex": "15e9faef97e8f2e7f9efcce7f6e8a4e7dee82de7b4e8bae7f80909e820e7b6e7b4ef9700000000"
  },
  {
   "jp_offset": "0x1caf",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "……西玛大人？您这是怎么了？",
   "zh_hex": "150909e7f8e845efa5efb205e835e7b9e7b6e7f2e7bde7ba050000000000"
  },
  {
   "jp_offset": "0x1cde",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "嗯？不……没什么",
   "zh_hex": "15e86505e7b50909e7d8e7dde7bd000000"
  },
  {
   "jp_offset": "0x1cec",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "只不过是稍微睡了一小会儿罢了",
   "zh_hex": "15ef32e7b5ef36e7b6ead5eb58ebdee7baefb6e83ee7e2eb7ceaefe7ba0000000000000000"
  },
  {
   "jp_offset": "0x1d04",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "比起这个、出港的准备都办妥了吧？",
   "zh_hex": "15e825e847e7b9e82802afeb3be7b4e87ae877e840e8eaee05e7bae7d0050000000000000000"
  },
  {
   "jp_offset": "0x1d38",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "是！现在随时都能出港了",
   "zh_hex": "15e7b6ef97e82fef29e9a1ef2de840e7c6efbeeb3be7ba0000000000"
  },
  {
   "jp_offset": "0x1d67",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "好！莉莉·玛莲号、出航！",
   "zh_hex": "15e7c7ef97e81ee81eef4be845ecffe83302efbee9c1ef9700000000"
  },
  {
   "jp_offset": "0x1d93",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "收到！",
   "zh_hex": "15e926e7d7ef970000"
  },
  {
   "jp_offset": "0x4b7a",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "『宇宙世纪0079、1月3日』",
   "zh_hex": "150ce8bee8bfe83ceb99e998e998eb79eca402eff7e850ef60e98a0d000000"
  },
  {
   "jp_offset": "0x4b96",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "『SIDE2殖民地』",
   "zh_hex": "150cef9eef62ef96ef9fef5fe8a9ef38ef630d000000"
  },
  {
   "jp_offset": "0x4bbe",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "『队、队长！』",
   "zh_hex": "150ce7c902e7c9ef34ef970d000000"
  },
  {
   "jp_offset": "0x4bce",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "『殖民地它……』",
   "zh_hex": "150ce8a9ef38ef63e97809090d000000"
  },
  {
   "jp_offset": "0x4bde",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "『人……人全都死了……』",
   "zh_hex": "150cefb20909efb2efb4e840ef6ae7ba09090d00000000000000"
  },
  {
   "jp_offset": "0x4bf6",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "『……西玛队长！！』",
   "zh_hex": "150c0909e7f8e845e7c9ef34ef97ef970d000000"
  },
  {
   "jp_offset": "0x4c06",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "啊……怎、怎么会……",
   "zh_hex": "15e7c30909e7f202e7f2e7bde7e20909000000"
  },
  {
   "jp_offset": "0x4c1d",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "那明明说是刺激性气体……",
   "zh_hex": "15e7b7ef39ef39e7ede7b6ed26e9b9e951e8edef4f0909000000"
  },
  {
   "jp_offset": "0x4c37",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "我……",
   "zh_hex": "15efcc0909000000"
  },
  {
   "jp_offset": "0x4c49",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "是毒气……",
   "zh_hex": "15e7b6eb5fe8ed0909000000"
  },
  {
   "jp_offset": "0x4c62",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "我当时根本就不知道啊！！",
   "zh_hex": "158bc4ef2de9b8d2e7c5e7b5e85ae82ae7c30606000000000000000000"
  },
  {
   "jp_offset": "0x4d0e",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "原来如此！夏亚没能击沉木马吗！",
   "zh_hex": "15e8e4efcfe7f0e7caef97ef37e7d6e7d8e7c6e7cce983efa9e84fe802ef97000000"
  },
  {
   "jp_offset": "0x4d3f",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "木马似乎已朝SIDE6方向逃走了",
   "zh_hex": "15efa9e84fe944e933ef3aeaadef9eef62ef96ef9fe9cdefb1efc1e8c2e890e7ba0000000000"
  },
  {
   "jp_offset": "0x4d71",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "这可真是再凑巧不过了！",
   "zh_hex": "15e7b9e7c4e820e7b6e80becb1ec13e7b5ef36e7baef97000000"
  },
  {
   "jp_offset": "0x4d7c",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "好！立刻让舰队出击！",
   "zh_hex": "15e7c7ef97e86be91fe7f9e7d4e7c9efbee7ccef9700000000"
  },
  {
   "jp_offset": "0x4d90",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "就当着夏亚的面、把木马给击沉！",
   "zh_hex": "15e7c5ef53e86def37e7d6e7b4e86202e81befa9e84fe839e7cce983ef97000000000000"
  },
  {
   "jp_offset": "0x4e12",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "一路辛苦了",
   "zh_hex": "15efb6e8d2ea58e9e6e7ba0000"
  },
  {
   "jp_offset": "0x4e1f",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "感谢你将这条『宇宙世纪路线』一直玩到{00}了最后",
   "zh_hex": "15e87de8b2e7b8e84ae7b9e9d40ce8bee8bfe83ceb99e8d2e9160defb6e875e970e7d700e7bae8c5e7fe0000000000"
  },
  {
   "jp_offset": "0x4e3f",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "另外、隆德·贝尔队的战斗就在此暂告一{00}段落……",
   "zh_hex": "15e99be8f702ed16e82cef4be857e7e1e7c9e7b4ef28e7ffe7c5ef29e7cae9ffe8e5efb600ea6be92a0909000000"
  },
  {
   "jp_offset": "0x4e5e",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "游戏本身仍可继续、之后也希望你能尽情{00}玩下去",
   "zh_hex": "15ea94ea3eefa6e88deab9e7c4e9d6e9ad02e7cde7fee7c0e87be965e7b8e7c6e8f2e88b00e970ef4de7eb00000000"
  },
  {
   "jp_offset": "0x4e83",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "此外、为将本路线玩到最后的你、还准备{00}了特别关卡",
   "zh_hex": "15e7cae8f702e7c1e84aefa6e8d2e916e970e7d7e8c5e7fee7b4e7b802e7f7e87ae87700e7bae7cfe7e5e8bbe80100000000000000"
  },
  {
   "jp_offset": "0x4eaa",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "那是与我们分头作战的大天使队的特别演{00}习",
   "zh_hex": "15e7b7e7b6e832efcce7bbefaee92eef2fef28e7b4efa5e844e83fe7c9e7b4e7cfe7e5ea2f00eab60000000000"
  },
  {
   "jp_offset": "0x4ecb",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "与他们一战、检验一下你亲手培养的部队{00}实力、也不错",
   "zh_hex": "15e832e80ce7bbefb6ef2802ee40ea99efb6ef4de7b8e894ef66edfeec0be7b4ef70e7c900e87fefb002e7c0e7b5e88500000000000000000000"
  },
  {
   "jp_offset": "0x4ef0",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "在自由对战中选择『特殊演习』、即可与{00}他们交战",
   "zh_hex": "15ef29abe8a6e7beef28c0e966eaaa0ce7cfed7bea2feab60d02e855e7c4e83200e80ce7bbe861ef28000000000000000000"
  },
  {
   "jp_offset": "0x4f15",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "……那么、『SD高达G世代DS』",
