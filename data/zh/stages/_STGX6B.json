{
 "file": "_STGX6B.bin",
 "source_size": 43844,
 "built_size": 46236,
 "edits": [
  {
   "jp_offset": "0x150a",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "应战！动作快！！",
   "zh_hex": "15e873ef28ef97ef30ef2fe85fef97ef970000"
  },
  {
   "jp_offset": "0x15dd",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "2点钟方向出现新机影！",
   "zh_hex": "15ef5fe822ebf9efb1efc1efbee82fef8ae7e4ea8eef970000"
  },
  {
   "jp_offset": "0x1679",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "可恶！死亡军团怎么会出现在这种地方！",
   "zh_hex": "15e7c4e7de06a7ebb2e7e0ea5ee7f2e7bde7e2afe82fef29e7b9e7d1bfd0060000000000000000"
  },
  {
   "jp_offset": "0x16f2",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "光对付这些杂鱼没完没了！它们的本体到{00}底在哪！？",
   "zh_hex": "15e83de7bee97ee7b9e8a4eb38efdbe7d8e87ee7d8e7baef97e978e7bbe7b4efa6ef4fe7d700e9b4ef29e8ffef97050000"
  },
  {
   "jp_offset": "0x17a1",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "我马上追踪……",
   "zh_hex": "15efcce84fef4ce8ddec9709090000"
  },
  {
   "jp_offset": "0x17db",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "……找到了！是恶魔高达！！",
   "zh_hex": "150909e9d2e7d7e7baef97e7b6e7dee8d8e812ef2bef97ef970000"
  },
  {
   "jp_offset": "0x17eb",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "在殖民地里！恶魔高达就在殖民地内部！{00}！",
   "zh_hex": "15ef29e8a9ef38ef63ef31ef97e7dee8d8e812ef2be7c5ef29e8a9ef38ef63e99aef70ef9700ef970000"
  },
  {
   "jp_offset": "0x184b",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "击破恶魔高达！！全舰、突入殖民地内部{00}！",
   "zh_hex": "15e7ccef6de7dee8d8e812ef2bef97ef97efb4e7d402e8b6e891e8a9ef38ef63e99aef7000ef970000"
  },
  {
   "jp_offset": "0x1889",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "找到了！是恶魔高达！！",
   "zh_hex": "15e9d2e7d7e7baef97e7b6e7dee8d8e812ef2bef97ef970000"
  },
  {
   "jp_offset": "0x18bc",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "MS队即刻出击！前去击破恶魔高达！！",
   "zh_hex": "15efa7ef9ee7c9e855e91fefbee7ccef97ef51e7ebe7ccef6de7dee8d8e812ef2bef97ef970000"
  },
  {
   "jp_offset": "0x18fd",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "虽不知它为何出现在此、但这对我来说正{00}合心意！！",
   "zh_hex": "15e8b8e7b5e85ae978e7c1efbcefbee82fef29e7ca02e7dbe7b9e7beefccefcfe7edef3b00efc0e82def3cef97ef970000"
  },
  {
   "jp_offset": "0x191e",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "这一次、定要将你彻底击破！恶魔高达！{00}！",
   "zh_hex": "15e7b9efb6e86402e867ef2ae84ae7b8ebc5e9b4e7ccef6def97e7dee8d8e812ef2bef9700ef970000"
  },
  {
   "jp_offset": "0x195b",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "喂、那家伙到底是什么玩意儿！",
   "zh_hex": "15e8bd02e7b7e7dfe7fde7d7e9b4e7b6e7dde7bde970ef3ceb7cef970000"
  },
  {
   "jp_offset": "0x198a",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "从恶魔高达体内……钻出了好几台MS？",
   "zh_hex": "15e88ae7dee8d8e812ef2bbce99a0909edc1afe7bae7c7eaa5ea1613140500000000"
  },
  {
   "jp_offset": "0x19c4",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "机种和所属阵营、似乎都各不相同",
   "zh_hex": "15e7e4e7d1e7d3e7fbea24eb48ed0102e944e933e840e819e7b5e8b1e85d0000"
  },
  {
   "jp_offset": "0x19de",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "玲小姐、这究竟是……",
   "zh_hex": "15eee4e83ee92102e7b9e906ef2ce7b609090000"
  },
  {
   "jp_offset": "0x1a07",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "恐怕、是DG细胞制造出来的仿制品……",
   "zh_hex": "15eb33e95802e7b6ef96eed1eb9aefabe8dee93eefbeefcfe7b4efdfe8deeae109090000"
  },
  {
   "jp_offset": "0x1a1f",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "可是、没想到恶魔高达、竟连这种事都办{00}得到……",
   "zh_hex": "15e7c4e7b602e7d8e7e6e7d7e7dee8d8e812ef2b02ef2ce86ee7b9e7d1efb8e840e8ea00e80ae7d709090000"
  },
  {
   "jp_offset": "0x1a52",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "看来它也进化了吗……可恶！",
   "zh_hex": "15e7f6efcfe978e7c0e892e9a5e7bae8020909e7c4e7deef970000"
  },
  {
   "jp_offset": "0x1a8e",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "恶魔高达的再生力、变弱了？",
   "zh_hex": "15e7dee8d8e812ef2be7b4e80bef8defb002e955e9d1e7ba050000"
  },
  {
   "jp_offset": "0x1ac5",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……多蒙！！",
   "zh_hex": "150909e7e9e942ef97ef970000"
  },
  {
   "jp_offset": "0x1aef",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "哦！",
   "zh_hex": "15e919ef970000"
  },
  {
   "jp_offset": "0x1b1a",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "就此了结吧、恶魔高达……",
   "zh_hex": "15e7c5e7cae7bae868e7d002e7dee8d8e812ef2b09090000"
  },
  {
   "jp_offset": "0x1b63",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "且慢！！",
   "zh_hex": "15e999e979ef97ef970000"
  },
  {
   "jp_offset": "0x1b6c",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "不可摧毁恶魔高达！！",
   "zh_hex": "15e7b5e7c4efe5e97ce7dee8d8e812ef2bef97ef970000"
  },
  {
   "jp_offset": "0x1b7d",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "恶魔高达它……恶魔高达可是老夫的……",
   "zh_hex": "15e7dee8d8e812ef2be9780909e7dee8d8e812ef2be7c4e7b6e9cae830e7b409090000"
  },
  {
   "jp_offset": "0x1bf0",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "哦哦……！怎、怎会如此……！！",
   "zh_hex": "15e919e9190909ef97e7f202e7f2e7e2e7f0e7ca0909ef97ef970000"
  },
  {
   "jp_offset": "0x1c05",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "老夫的梦、老夫的希望……老夫的恶魔高{00}达啊……！！",
   "zh_hex": "15e9cae830e7b4ea4002e9cae830e7b4e87be9650909e9cae830e7b4e7dee8d8e81200ef2be7c30909ef97ef970000"
  },
  {
   "jp_offset": "0x1c46",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "……东方不败·亚洲尊者、你的野心、到{00}此为止了",
   "zh_hex": "150909e8bad0e7b5e88f04e7d6eacdeccdad02e7b8e7b4eb21e82d02e7d700e7cae7c1e869e7ba0000000000"
  },
  {
   "jp_offset": "0x1c94",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……野心？",
   "zh_hex": "150909eb21e82d050000"
  },
  {
   "jp_offset": "0x1c9c",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "你竟敢把老夫这远大的梦想、说成是野心{00}！",
   "zh_hex": "15e7b8ef2ce8cde81be9cae830e7b9e94cefa5e7b4ea40e7e602e7ede837e7b6eb21e82d00ef970000"
  },
  {
   "jp_offset": "0x1cce",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "你这蠢材！！",
   "zh_hex": "15e7b8e7b9e94bebcfef97ef970000"
  },
  {
   "jp_offset": "0x1d3a",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "明明一无所知、却摆出一副了然于胸的口{00}气！",
   "zh_hex": "15ef39ef3987e7dce7fbe85a02eadfeb8baf87ecb6e7bae7efe879ee8ce7b4eabd00e8ed06000000000000"
  },
  {
   "jp_offset": "0x1d51",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "你们、可是亲手粉碎了最后的希望啊！",
   "zh_hex": "15e7b8e7bb02e7c4e7b6e894ef66ee7debe0e7bae8c5e7fee7b4e87be965e7c3ef970000"
  },
  {
   "jp_offset": "0x1d90",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "什么！？东方不败、你这话是什么意思！{00}？",
   "zh_hex": "15e7dde7bdef9705e8baefb1e7b5e88f02e7b8e7b9e81fe7b6e7dde7bdef3cefcaef9700050000"
  },
  {
   "jp_offset": "0x1dda",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "对你这种蠢货、就算说了也是白费口舌！",
   "zh_hex": "15e7bee7b8e7b9e7d1e94beaf502e7c5e889e7ede7bae7c0e7b6e809e95deabdee2f06000000"
  },
  {
   "jp_offset": "0x1df5",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "不过、你若执意想知道的话……",
   "zh_hex": "15e7b5ef3602e7b8e7e7e9fcef3ce7e6e85ae82ae7b4e81f09090000"
  },
  {
   "jp_offset": "0x1e41",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "老夫便用胜负这两个字、来教教你们！",
   "zh_hex": "15e9cae830e8faefb3e8dbe92ce7b9e97de828e98002efcfeaaceaace7b8e7bbef970000"
  },
  {
   "jp_offset": "0x1e83",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "不好、快迎击！！",
   "zh_hex": "15e7b5e7c702e85fe931e7ccef97ef970000"
  },
  {
   "jp_offset": "0x1eac",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "等等、拉米亚斯舰长！！",
   "zh_hex": "15e826e82602e7c2e878e7d6e7c8e7d4ef34ef97ef970000"
  },
  {
   "jp_offset": "0x1ebc",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "那家伙、就交给我一个人来对付！",
   "zh_hex": "15e7b7e7dfe7fd02e7c5e861e839efccefb6e828efb2efcfe7bee97eef970000"
  },
  {
   "jp_offset": "0x1eec",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "多蒙……？",
   "zh_hex": "15e7e9e9420909050000"
  },
  {
   "jp_offset": "0x1f10",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "与东方不败的了断、我想不借任何人之手{00}、亲自完成",
   "zh_hex": "15e832e8baefb1e7b5e88fe7b4e7bae98202efcce7e6e7b5eadce89aefbcefb2e7cdef660002e894efb5e87ee8370000"
  },
  {
   "jp_offset": "0x1f4e",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……明白了",
   "zh_hex": "150909ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x1f59",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "与东方不败的这一战、就全权交给你了、{00}多蒙·卡修",
   "zh_hex": "15e832e8baefb1e7b5e88fe7b4e7b9efb6ef2802e7c5efb4eb39e861e839e7b8e7ba0200e7e9e942ef4be801e9b00000"
  },
  {
   "jp_offset": "0x1f74",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "不过、作为交换……",
   "zh_hex": "15e7b5ef3602ef2fe7c1e861ea7809090000"
  },
  {
   "jp_offset": "0x1f99",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "啊、我明白的……",
   "zh_hex": "15e7c302efccef39e809e7b409090000"
  },
  {
   "jp_offset": "0x1fcc",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "我……绝不会输！！",
   "zh_hex": "15efcc0909e91ce7b5e7e2e8b9ef97ef970000"
  },
  {
   "jp_offset": "0x1fff",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "全员后退！这一战、就交给多蒙了！",
   "zh_hex": "15efb4e849e7fee880ef97e7b9efb6ef2802e7c5e861e839e7e9e942e7baef970000"
  },
  {
   "jp_offset": "0x204b",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "碍事的家伙们都退下了吗……",
   "zh_hex": "15e8c6efb8e7b4e7dfe7fde7bbe840e880ef4de7bae80209090000"
  },
  {
   "jp_offset": "0x205b",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "这下、老夫便能毫无顾忌地与你一战了",
   "zh_hex": "15e7b9ef4d02e9cae830e8fae7c6ea0ae7dcea1fed5aef63e832e7b8efb6ef28e7ba0000"
  },
  {
   "jp_offset": "0x2095",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "求之不得、东方不败！",
   "zh_hex": "15e93ae7cde7b5e80a02e8baefb1e7b5e88fef970000"
  },
  {
   "jp_offset": "0x20c9",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "高达格斗——！！",
   "zh_hex": "15e812ef2be824e7ffebafebafef97ef970000"
  },
  {
   "jp_offset": "0x210f",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "预备——……",
   "zh_hex": "15ea5ae877ebafebaf09090000"
  },
  {
   "jp_offset": "0x2171",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "『开始——！！』",
   "zh_hex": "150ce7fae908ebafebafef97ef970d0000"
  },
  {
   "jp_offset": "0x21af",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "多蒙！！",
   "zh_hex": "15e7e9e942ef97ef970000"
  },
  {
   "jp_offset": "0x21d2",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "啊啊……我终于做到了、把恶魔高达……",
   "zh_hex": "15e7c3e7c30909efcce8e2e879e81ce7d7e7ba02e81be7dee8d8e812ef2b09090000"
  },
  {
   "jp_offset": "0x21e8",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "父亲、母亲……",
   "zh_hex": "15e888e89402e9d5e89409090000"
  },
  {
   "jp_offset": "0x2217",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "不好、快迎击！！",
   "zh_hex": "15e7b5e7c702e85fe931e7ccef97ef970000"
  },
  {
   "jp_offset": "0x224a",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "等等、拉米亚斯舰长！！",
   "zh_hex": "15e826e82602e7c2e878e7d6e7c8e7d4ef34ef97ef970000"
  },
  {
   "jp_offset": "0x225a",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "那家伙、就交给我一个人来对付！",
   "zh_hex": "15e7b7e7dfe7fd02e7c5e861e839efccefb6e828efb2efcfe7bee97eef970000"
  },
  {
   "jp_offset": "0x228a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "多蒙……？",
   "zh_hex": "15e7e9e9420909050000"
  },
  {
   "jp_offset": "0x22ae",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "与东方不败的了断、我想不借任何人之手{00}、亲自完成",
   "zh_hex": "15e832e8baefb1e7b5e88fe7b4e7bae98202efcce7e6e7b5eadce89aefbcefb2e7cdef660002e894efb5e87ee8370000"
  },
  {
   "jp_offset": "0x22ec",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……明白了",
   "zh_hex": "150909ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x22f7",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "与东方不败的这一战、就全权交给你了、{00}多蒙·卡修",
   "zh_hex": "15e832e8baefb1e7b5e88fe7b4e7b9efb6ef2802e7c5efb4eb39e861e839e7b8e7ba0200e7e9e942ef4be801e9b00000"
  },
  {
   "jp_offset": "0x2312",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "不过、作为交换……",
   "zh_hex": "15e7b5ef3602ef2fe7c1e861ea7809090000"
  },
  {
   "jp_offset": "0x2337",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "啊啊……我一定会赢！！",
   "zh_hex": "15e7c3e7c30909efccefb6e867e7e2e9cbef97ef970000"
  },
  {
   "jp_offset": "0x236c",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "唔哦哦！",
   "zh_hex": "15e81de919e919ef970000"
  },
  {
   "jp_offset": "0x2376",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "为何！为何、你就是不明白！？",
   "zh_hex": "15e7c1efbcef97e7c1efbc02e7b8e7c5e7b6e7b5ef39e809ef97050000"
  },
  {
   "jp_offset": "0x23a8",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……东方不败！？",
   "zh_hex": "150909e8baefb1e7b5e88fef97050000"
  },
  {
   "jp_offset": "0x23d9",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "你这蠢材……！！",
   "zh_hex": "15e7b8e7b9e94bebcf0909ef97ef970000"
  },
  {
   "jp_offset": "0x23e8",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "你那被蒙蔽的双眼、难道看不见地球苦苦{00}挣扎的惨状吗！？",
   "zh_hex": "15e7b8e7b7e7f1e942ed02e7b4eabce90b02e866e82ae7f6e7b5e85cbf95e9e6e9e600ebcae84be7b4ed5de98be80206050000000000"
  },
  {
   "jp_offset": "0x2428",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x244b",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "一会儿新人类一会儿旧人类……一会儿又{00}说调整者是敌人……",
   "zh_hex": "15efb6e7e2eb7cef8aefb2e841efb6e7e2eb7ceac8efb2e8410909efb6e7e2eb7ce8f100e7ede95ce9feef6ee7b6e7e3efb209090000"
  },
  {
   "jp_offset": "0x2466",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "就在世人沉溺于争斗之时、你以为地球变{00}成什么样了！？",
   "zh_hex": "15e7c5ef29e83cefb2e983ee58e879e852e7ffe7cdef2d02e7b8e7f3e7c1ef63efd3e95500e837e7dde7bde7dae7baef97050000"
  },
  {
   "jp_offset": "0x248c",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "那片日益沙漠化的达喀尔大地、你难道没{00}亲眼见过吗！？",
   "zh_hex": "15e7b7ee5ee98aed8ceb0ceceae9a5e7b4ef2be99ce7e1bebf02e7b8e866e82ae7d800e894e90be85cef36e80206050000000000"
  },
  {
   "jp_offset": "0x24a8",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "还有被独眼巨人化作荒野的、阿拉斯加那{00}惨不忍睹的模样呢！？",
   "zh_hex": "15e7f7e7cbe7f1e8eee90bea25efb2e9a5ef2fec38eb21e7b402e7d2e7c2e7c8e854e7b700ed5de7b5eb59ee74e7b4ea91e7dae907ef97050000"
  },
  {
   "jp_offset": "0x24c5",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "什么殖民地独立！！什么人类革新！",
   "zh_hex": "15e7dde7bde8a9ef38ef63e8eee86bef97ef97e7dde7bdefb2e841edc5ef8aef970000"
  },
  {
   "jp_offset": "0x24dd",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "连这点道理都不懂、却还一再挑起战争…{00}…！",
   "zh_hex": "15e86ee7b9e822e82ae872e840e7b5e8b002eadfe7f787e80beae7e847ef28e8520900090600000000"
  },
  {
   "jp_offset": "0x24f4",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "人类、是何等的愚蠢啊！！",
   "zh_hex": "15efb2e84102e7b6efbce826e7b4e959e94be7c3ef97ef970000"
  },
  {
   "jp_offset": "0x251f",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "东、东方不败……？你莫非是……！？",
   "zh_hex": "15e8ba02e8baefb1e7b5e88f090905e7b8eba0e8f0e7b60909ef97050000"
  },
  {
   "jp_offset": "0x2551",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "没错！万恶的根源、正是人类自身！！",
   "zh_hex": "15e7d8e885ef97e9f8e7dee7b4e9b8ebd602ef3be7b6efb2e841efb5e88def97ef970000"
  },
  {
   "jp_offset": "0x2567",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "那么、只要地球上没有了人类、自然便会{00}自行复苏！！",
   "zh_hex": "15e7b7e7bd02ef32ef2aef63efd3ef4ce7d8e7cbe7baefb2e84102efb5e7efe8fae7e200efb5efd6e9eeec8def97ef970000"
  },
  {
   "jp_offset": "0x2589",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "抹杀全人类、正是老夫的宏愿！！",
   "zh_hex": "15ecd9e89befb4efb2e84102ef3be7b6e9cae830e7b4ec5fe961ef97ef970000"
  },
  {
   "jp_offset": "0x259b",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "呼哈哈哈……对、就该如此！这样才是最{00}好的！！",
   "zh_hex": "15ea3ce7e8e7e8e7e80909e7be02e7c5e898e7f0e7caef97e7b9e7dae836e7b6e8c500e7c7e7b4ef97ef970000"
  },
  {
   "jp_offset": "0x25bb",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "只要能让地球重归绿色的星球、人类纵然{00}灭绝也无妨……！！",
   "zh_hex": "15ef32ef2ae7c6e7f9bf95e8a1e947ec88e89fe7b4b59502b4e841e8e6e7ef00e8e1e91ce7c0e7dce97f09090606000000000000000000"
  },
  {
   "jp_offset": "0x25fb",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "你、你这个人……！！",
   "zh_hex": "15e7b802e7b8e7b9e828efb20909ef97ef970000"
  },
  {
   "jp_offset": "0x262c",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "东方不败·亚洲尊者！",
   "zh_hex": "15e8bad0e7b5e88f04e7d6eacdeccdad06000000000000"
  },
  {
   "jp_offset": "0x2639",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "你错了！！",
   "zh_hex": "15e7b8e885e7baef97ef970000"
  },
  {
   "jp_offset": "0x2661",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x2669",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "你是说、老夫这寄托于地球再生的梦想、{00}是错的吗！！",
   "zh_hex": "15e7b8e7b6e7ed02e9cae830e7b9e803e7f4e879bf95e80bb6e7b4ea40e7e60200e7b6e885e7b4e802060600000000000000"
  },
  {
   "jp_offset": "0x26a5",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "啊啊、没错！",
   "zh_hex": "15e7c3e7c302e7d8e885ef970000"
  },
  {
   "jp_offset": "0x26af",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "你想做的、不过就是杀人罢了！！",
   "zh_hex": "15e7b8e7e6e81ce7b402e7b5ef36e7c5e7b6e89befb2eaefe7baef97ef970000"
  },
  {
   "jp_offset": "0x26d6",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "之所以这么说、东方不败……！！",
   "zh_hex": "15e7cde7fbe7f3e7b9e7bde7ed02e8baefb1e7b5e88f0909ef97ef970000"
  },
  {
   "jp_offset": "0x26e6",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "你想抹杀的人类、同样也是天然自然的生{00}灵……",
   "zh_hex": "15e7b8e7e6ecd9e89be7b4efb2e84102e85de7dae7c0e7b6e844e7efefb5e7efe7b4ef8d00eaeb09090000"
  },
  {
   "jp_offset": "0x2713",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "可以说、也是地球的一部分！！",
   "zh_hex": "15e7c4e7f3e7ed02e7c0e7b6ef63efd3e7b4efb6ef70efaeef97ef970000"
  },
  {
   "jp_offset": "0x2720",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "忘了这一点、还谈什么自然的……！地球{00}的再生……！！",
   "zh_hex": "15ea4de7bae7b9efb6e82202e7f7eaf4e7dde7bdefb5e7efe7b40909ef97ef63efd300e7b4e80bef8d0909ef97ef970000"
  },
  {
   "jp_offset": "0x273d",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "没错……！！",
   "zh_hex": "15e7d8e8850909ef97ef970000"
  },
  {
   "jp_offset": "0x2746",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "抹杀掉共同生存的人类、所换来的理想乡{00}……",
   "zh_hex": "15ecd9e89be9d3ea48e85def8de993e7b4efb2e84102e7fbea78efcfe7b4e872e7e6eb4c0009090000"
  },
  {
   "jp_offset": "0x27a5",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "简直愚不可及！！！",
   "zh_hex": "15e9abe875e959e7b5e7c4e9cfef97ef97ef970000"
  },
  {
   "jp_offset": "0x27ef",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "哦哦……！？",
   "zh_hex": "15e919e9190909ef97050000"
  },
  {
   "jp_offset": "0x27f8",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "什、什么！？多蒙的身影、看起来无比高{00}大……！？",
   "zh_hex": "15e7dd02e7dde7bd0605e7e9e942e7b4e88dea8e02e7f6e847d9e7dce825e81200be09090605000000000000"
  },
  {
   "jp_offset": "0x284f",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "东方不败·亚洲尊者！！你那抹杀人类的{00}野心……",
   "zh_hex": "15e8bad0e7b5e88f04e7d6eacdeccdad0606e7b8e7b7ecd9e89bb4e841e7b400eb21e82d09090000000000000000"
  },
  {
   "jp_offset": "0x286b",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "我便以红心之王之名、将它彻底粉碎！！",
   "zh_hex": "15efcce8fae7f3e9e3e82de7cde884e7cde8ac02e84ae978ebc5e9b4ee7debe0ef97ef970000"
  },
  {
   "jp_offset": "0x289e",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "唔哦……！",
   "zh_hex": "15e81de9190909ef970000"
  },
  {
   "jp_offset": "0x28a8",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "那么、究竟是老夫对、还是你对……",
   "zh_hex": "15e7b7e7bd02e906ef2ce7b6e9cae830e7be02e7f7e7b6e7b8e7be09090000"
  },
  {
   "jp_offset": "0x28c0",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "就用你我彼此的拳头、来分个高下吧！！",
   "zh_hex": "15e7c5efb3e7b8efccefc9e7cae7b4ea65e92e02efcfefaee828e812ef4de7d0ef97ef970000"
  },
  {
   "jp_offset": "0x28d9",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "上吧、多蒙！！",
   "zh_hex": "15ef4ce7d002e7e9e942ef97ef970000"
  },
  {
   "jp_offset": "0x290a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "唔……！！",
   "zh_hex": "15e81d0909ef97ef970000"
  },
  {
   "jp_offset": "0x295c",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "怎、怎么了、东方不败！？胜负还没分出{00}……",
   "zh_hex": "15e7f202e7f2e7bde7ba02e8baefb1e7b5e88fef9705e8dbe92ce7f7e7d8efaeefbe0009090000"
  },
  {
   "jp_offset": "0x2993",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "不、胜负已经分晓了",
   "zh_hex": "15e7b502e8dbe92cef3ae8b7efaeec73e7ba0000"
  },
  {
   "jp_offset": "0x29a1",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "如今地球再生之梦已碎、再打下去、不过{00}是迁怒罢了",
   "zh_hex": "15e7f0efb9ef63efd3e80bef8de7cdea40ef3aebe002e80be7f5ef4de7eb02e7b5ef3600e7b6eeb3ee1eeaefe7ba0000"
  },
  {
   "jp_offset": "0x29dc",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "东方、不败……！？",
   "zh_hex": "15e8baefb102e7b5e88f0909ef97050000"
  },
  {
   "jp_offset": "0x2a03",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……别了、多蒙",
   "zh_hex": "150909e7e5e7ba02e7e9e9420000"
  },
  {
   "jp_offset": "0x2a0f",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "我东方不败·亚洲尊者……今后绝不会再{00}出现在你面前",
   "zh_hex": "158be8bad0e7b5e88f04e7d6eacdeccdad0909a2e7fee91ce7b5e7e2e80b00afe82fef29e7b8e862ba000000000000000000"
  },
  {
   "jp_offset": "0x2a59",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "唔……！！",
   "zh_hex": "15e81d0909ef97ef970000"
  },
  {
   "jp_offset": "0x2a62",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "我、我……！！",
   "zh_hex": "15efcc02efcc0909ef97ef970000"
  },
  {
   "jp_offset": "0x2af3",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "唔……！？{00}怎么了、多蒙！？",
   "zh_hex": "15e81d0909060500e7f2e7bde7ba02e7e9e94206050000"
  },
  {
   "jp_offset": "0x2b06",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "为何不对老夫下最后一击！？",
   "zh_hex": "15e7c18ae7b5e7bee9cae83089e8c5e7fe87e7cc06050000"
  },
  {
   "jp_offset": "0x2b1d",
   "jp_len": 68,
   "kind": "dialogue",
   "zh_text": "ぬな、{00}{01}！{01}{00}M事ばな、{00}{01}！間{00}Mキねな、{00}{01}！や{00}M{00}ぬな、{00}{01}！{01}{00}！や{00}Mきぬな、{00}、ぁ东方不败·亚洲尊者……{00}不、师父",
   "zh_hex": "15353302000106010013a939330200010691001358363302000106430013003533020001060100064300131d353302000215e8bad0e7b5e88f04e7d6eacdeccdad090900e7b502e96ce8880000"
  },
  {
   "jp_offset": "0x2b61",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……这就是我的答案",
   "zh_hex": "150909e7b9e7c5e7b68be7b4ea96ee3f0000"
  },
  {
   "jp_offset": "0x2be6",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "的确、你是{00}企图抹杀人类的大恶人……",
   "zh_hex": "15e7b4e88c02e7b8e7b600ebdaeb2decd9e89bb4e841e7b4bee7deb409090000"
  },
  {
   "jp_offset": "0x2c1b",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "那份对地球深沉而悲伤的爱……",
   "zh_hex": "15e7b7ea22e7bebf95eb0de983e89ce9dfe8f9e7b4e8d509090000"
  },
  {
   "jp_offset": "0x2c31",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "我并没有足以裁决那份爱的拳头……！",
   "zh_hex": "158be957e7d8e7cbea1ee7f3ec39e8abe7b7ea22e8d5e7b4ea65e92e0909060000"
  },
  {
   "jp_offset": "0x2c6b",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "若在此放过老夫、{00}老夫或许还会再图抹杀人类、也无妨吗？",
   "zh_hex": "15e7e7ef29e7cae86cef36e9cae8300200e9cae830e905e8a7e7f7e7e2e80beb2decd9e89bb4e84102e7c0e7dce97fe802050000"
  },
  {
   "jp_offset": "0x2ca7",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "那到时候、{00}我就再把你打倒一次！",
   "zh_hex": "15e7b7e7d7ef2dea3902008be7c5e80be81be7b8e7f5e84887e864060000"
  },
  {
   "jp_offset": "0x2ce4",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "……你变强了啊、多蒙",
   "zh_hex": "150909e7b8e955e8ade7bae7c302e7e9e9420000"
  },
  {
   "jp_offset": "0x2d6c",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "呵呵……",
   "zh_hex": "15ef3def3d09090000"
  },
  {
   "jp_offset": "0x2d73",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "干得漂亮、多蒙……",
   "zh_hex": "15e8d3e80aead0eaa202e7e9e94209090000"
  },
  {
   "jp_offset": "0x2d7f",
   "jp_len": 36,
   "kind": "dialogue",
   "zh_text": "你的觉悟、老夫已用这副身躯、充分领会{00}了……",
   "zh_hex": "15e7b8e7b4e8aeea1902e9cae830ef3ad8e7b9ecb6e88dedbc02ea86cdea20e7e200e7ba090900000000"
  },
  {
   "jp_offset": "0x2dbe",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……师父！？",
   "zh_hex": "150909e96ce888ef97050000"
  },
  {
   "jp_offset": "0x2def",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "蠢货……！发出那种没出息的声音、成何{00}体统……！",
   "zh_hex": "15e94beaf50909ef97e870efbee7b7e7d1e7d8efbeec6ae7b4ea8aea7102e837efbc00ef4fe9290909ef970000"
  },
  {
   "jp_offset": "0x2e0b",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "给我扎稳马步、沉住腰劲！！",
   "zh_hex": "15e839efcce84beb3ee84fea9302e983e859ee8feb50ef97ef970000"
  },
  {
   "jp_offset": "0x2e20",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "就那副样子、{00}连老夫这一个恶人都打不倒！",
   "zh_hex": "15e7c5e7b7ecb6e7dae8860200e86ee9cae830e7b987e828e7deb4e840e7f5e7b5e848060000000000"
  },
  {
   "jp_offset": "0x2e57",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "师父……",
   "zh_hex": "15e96ce88809090000"
  },
  {
   "jp_offset": "0x2e86",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "来吧、多蒙！",
   "zh_hex": "15efcfe7d002e7e9e942ef970000"
  },
  {
   "jp_offset": "0x2e90",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "身为红心之王的使命、就漂亮地去完成给{00}老夫看！",
   "zh_hex": "15e88de7c1e9e3e82de7cde884e7b4e83fe85302e7c5ead0eaa2ef63e7ebe87ee837e83900e9cae830e7f6ef970000"
  },
  {
   "jp_offset": "0x2edd",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "哦哦哦！高达——！！",
   "zh_hex": "15e919e919e919ef97e812ef2bebafebafef97ef970000"
  },
  {
   "jp_offset": "0x2f13",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "师、师父啊！！",
   "zh_hex": "15e96c02e96ce888e7c3ef97ef970000"
  },
  {
   "jp_offset": "0x2f4e",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "东方不败·亚洲尊者……",
   "zh_hex": "15e8bad0e7b5e88f04e7d6eacdeccdad09090000000000"
  },
  {
   "jp_offset": "0x2f5c",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "曾经有过您这样一位伟大的人……",
   "zh_hex": "15ea2ae8b7e7cbef36e835e7b9e7daefb6e834ec47efa5e7b4efb209090000"
  },
  {
   "jp_offset": "0x2f77",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "我会将它永远铭刻在心……",
   "zh_hex": "15efcce7e2e84ae978e9bfe94cef13e91fef29e82d09090000"
  },
  {
   "jp_offset": "0x2fd5",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……结束了呢、多蒙",
   "zh_hex": "150909e868e895e7bae90702e7e9e9420000"
  },
  {
   "jp_offset": "0x2fe3",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "我们与恶魔高达的这场战斗、终于结束了",
   "zh_hex": "15efcce7bbe832e7dee8d8e812ef2be7b4e7b9e876ef28e7ff02e8e2e879e868e895e7ba0000"
  },
  {
   "jp_offset": "0x300e",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "嗯……",
   "zh_hex": "15e86509090000"
  },
  {
   "jp_offset": "0x3043",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "师父的事？",
   "zh_hex": "15e96ce888e7b4efb8050000"
  },
  {
   "jp_offset": "0x306a",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "我满脑子只想着和师父一决高下、却从未{00}想过去听他把话说完",
   "zh_hex": "15efcceb61eb67e886ef32e7e6e86de7d3e96ce888efb6e8abe812ef4d02eadfe88ae8b400e7e6ef36e7ebe8d1e80ce81be81fe7ede87e0000"
  },
  {
   "jp_offset": "0x308b",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "纵然手段是错的、可师父深爱着地球、这{00}本是不争的事实……",
   "zh_hex": "15e8e6e7efef66ea6be7b6e885e7b402e7c4e96ce888eb0de8d5e86def63efd302e7b900efa6e7b6e7b5e852e7b4efb8e87f09090000"
  },
  {
   "jp_offset": "0x30cc",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "……别露出那种表情嘛、多蒙",
   "zh_hex": "150909e7e5e858efbee7b7e7d1e9e7e88be93602e7e9e9420000"
  },
  {
   "jp_offset": "0x30dc",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "抬头挺胸、别垂头丧气……你做的、是正{00}确的事",
   "zh_hex": "15ee2ce92eeb5cee8c02e7e5ed41e92eefdce8ed0909e7b8e81ce7b402e7b6ef3b00e88ce7b4a9000000"
  },
  {
   "jp_offset": "0x3114",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "玲……？",
   "zh_hex": "15eee40909050000"
  },
  {
   "jp_offset": "0x3138",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "多蒙你的师父、或许确实是深爱着地球的",
   "zh_hex": "15e7e9e942e7b8e7b4e96ce88802e905e8a7e88ce87fe7b6eb0de8d5e86def63efd3e7b40000"
  },
  {
   "jp_offset": "0x3156",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "可是、说那种手段是错的、不正是多蒙你{00}自己吗？",
   "zh_hex": "15e7c4e7b602e7ede7b7e7d1ef66ea6be7b6e885e7b402e7b5ef3be7b6e7e9e942e7b800efb5e8c9e802050000"
  },
  {
   "jp_offset": "0x3191",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "说、说得也是……",
   "zh_hex": "15e7ed02e7ede80ae7c0e7b609090000"
  },
  {
   "jp_offset": "0x31b6",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "再说、你若一直这般消沉、我想师父他也{00}不会高兴的",
   "zh_hex": "15e80be7ed02e7b8e7e7efb6e875e7b9ea80e928e98302efcce7e6e96ce888e80ce7c000e7b5e7e2e812eabae7b40000"
  },
  {
   "jp_offset": "0x31d8",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "因为、今后我们的战斗、还要继续下去呢",
   "zh_hex": "15ef33e7c102efb9e7feefcce7bbe7b4ef28e7ff02e7f7ef2ae9d6e9adef4de7ebe9070000"
  },
  {
   "jp_offset": "0x320f",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "我们的战斗……",
   "zh_hex": "15efcce7bbe7b4ef28e7ff09090000"
  },
  {
   "jp_offset": "0x3235",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "让多蒙的师父所深爱的地球、重新找回和{00}平……",
   "zh_hex": "15e7f9e7e9e942e7b4e96ce888e7fbeb0de8d5e7b4bf9502e8a1ef8ae9d28ce7d300e88709090000000000"
  },
  {
   "jp_offset": "0x3250",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "那、就是打倒了恶魔高达的我们、新的战{00}斗",
   "zh_hex": "15e7b702e7c5e7b6e7f5e848e7bae7dee8d8e812ef2be7b4efcce7bb02ef8ae7b4ef2800e7ff0000"
  },
  {
   "jp_offset": "0x3286",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "说得对啊、玲",
   "zh_hex": "15e7ede80ae7bee7c302eee40000"
  },
  {
   "jp_offset": "0x3293",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "今后、艰难的战斗仍会继续……你愿意助{00}我一臂之力吗、玲？",
   "zh_hex": "15efb9e7fe02eb42e866e7b4ef28e7ffeab9e7e2e9d6e9ad0909e7b8e961ef3cea2300efccefb6ee92e7cdefb0e80202eee4050000"
  },
  {
   "jp_offset": "0x32d1",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "那当然、多蒙、毕竟我们、可是搭档呀",
   "zh_hex": "15e7b7ef53e7ef02e7e9e94202ea2cef2cefcce7bb02e7c4e7b6eb09ed78e9c60000"
  },
  {
   "jp_offset": "0x3302",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "谢谢你……玲",
   "zh_hex": "15e8b2e8b2e7b80909eee40000"
  },
  {
   "jp_offset": "0x3327",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "今后也请多关照哦……搭档先生",
   "zh_hex": "15a2e7fee7c0e83ae7e9e8bbea1ae9190909eb09ed78b8b6000000000000"
  },
  {
   "jp_offset": "0x3353",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "啊……！！",
   "zh_hex": "15e7c30909ef97ef970000"
  },
  {
   "jp_offset": "0x3373",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "希罗！！",
   "zh_hex": "15e87be7ecef97ef970000"
  },
  {
   "jp_offset": "0x3399",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "莉莉娜……！？",
   "zh_hex": "15e81ee81ee7ea0909ef97050000"
  },
  {
   "jp_offset": "0x33bd",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "是卡拉巴的人、把我带到这里来的",
   "zh_hex": "15e7b6e801e7c2e85be7b4efb202e81befcce937e7d7e7b9ef31efcfe7b40000"
  },
  {
   "jp_offset": "0x33df",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "你和我兄长……和米利亚尔特·匹斯克拉{00}福特交战了吧……希罗？",
   "zh_hex": "15e7b8e7d38bebb5ef340909e7d3e878e82ee7d6e7e1e7cf04ed2ae7c8e7d5e7c200ea7ce7cfe861ef28e7bae7d00909e87be7ec0500000000"
  },
  {
   "jp_offset": "0x3419",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯",
   "zh_hex": "150909e8650000"
  },
  {
   "jp_offset": "0x343b",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "好歹也是匹斯克拉福特家的人、竟会说出{00}要毁灭地球这种话……",
   "zh_hex": "15e7c7ee46e7c0e7b6ed2ae7c8e7d5e7c2ea7ce7cfe7dfe7b4efb202ef2ce7e2e7edefbe00ef2ae97ce8e1ef63efd3e7b9e7d1e81f09090000"
  },
  {
   "jp_offset": "0x345c",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "兄长在想什么呢……",
   "zh_hex": "15ebb5ef34ef29e7e6e7dde7bde90709090000"
  },
  {
   "jp_offset": "0x348b",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "……我也不清楚、零式系统什么都没告诉{00}我",
   "zh_hex": "150909efcce7c0e7b5e995ebd302eb74ea26e941e929e7dde7bde840e7d8e8e5ead600efcc0000"
  },
  {
   "jp_offset": "0x34a8",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "但他是真心要与地球为敌、唯独这一点是{00}事实",
   "zh_hex": "15e7dbe80ce7b6e820e82def2ae832ef63efd3e7c1e7e302ea89e8eee7b9efb6e822e7b600efb8e87f0000"
  },
  {
   "jp_offset": "0x3508",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "别想得太深、莉莉娜",
   "zh_hex": "15e7e5e7e6e80ae86aeb0d02e81ee81ee7ea0000"
  },
  {
   "jp_offset": "0x3519",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "你、只要去做唯有你才能做到的事就好",
   "zh_hex": "15e7b802ef32ef2ae7ebe81cea89e7cbe7b8e836e7c6e81ce7d7e7b4efb8e7c5e7c70000"
  },
  {
   "jp_offset": "0x354d",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "希罗……",
   "zh_hex": "15e87be7ec09090000"
  },
  {
   "jp_offset": "0x3575",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "与那家伙做个了断、是我的职责",
   "zh_hex": "15e832e7b7e7dfe7fde81ce828e7bae98202e7b6efcce7b4eda8eba60000"
  },
  {
   "jp_offset": "0x35eb",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "唯有我才能做到的事……",
   "zh_hex": "15ea89e7cbefcce836e7c6e81ce7d7e7b4efb809090000"
  },
  {
   "jp_offset": "0x3622",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "……是完全和平、对吧",
   "zh_hex": "150909e7b6e87eefb4e7d3e88702e7bee7d00000"
  },
  {
   "jp_offset": "0x3650",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "希罗先生想说的、想必正是……",
   "zh_hex": "15e87be7ecef8bef8de7e6e7ede7b402e7e6e860ef3be7b609090000"
  },
  {
   "jp_offset": "0x368d",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "您一直看着吗……？",
   "zh_hex": "15e835efb6e875e7f6e86de8020909050000"
  },
  {
   "jp_offset": "0x36b9",
   "jp_len": 41,
   "kind": "dialogue",
   "zh_text": "若是惹您不快、还请见谅、只是、贸然打{00}扰也不太好……",
   "zh_hex": "15e7e7e7b6ecd7e835e7b5e85f02e7f7e83ae85cec9502ef32e7b602ed08e7efe7f500ebc7e7c0e7b5e86ae7c709090000"
  },
  {
   "jp_offset": "0x36fd",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "不、我怎会因此见怪",
   "zh_hex": "15e7b502efcce7f2e7e2ef33e7cae85cea070000"
  },
  {
   "jp_offset": "0x370c",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "比起这个、两位刚才所说的那番话……",
   "zh_hex": "15e825e847e7b9e82802e97de834e8bce836e7fbe7ede7b4e7b7ee6de81f09090000"
  },
  {
   "jp_offset": "0x373f",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "对我而言、或许是种留恋吧",
   "zh_hex": "15e7beefcce89cefd702e905e8a7e7b6e7d1e98cee20e7d00000"
  },
  {
   "jp_offset": "0x376e",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……留恋？",
   "zh_hex": "150909e98cee20050000"
  },
  {
   "jp_offset": "0x3791",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "为了平息纷争、而亲手拿起枪……",
   "zh_hex": "15e7c1e7bae887ec6aecf8e85202e89ce894ef66e9a7e847eaae09090000"
  },
  {
   "jp_offset": "0x37ab",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我也只能采取这样的方法、别无他法",
   "zh_hex": "15efcce7c0ef32e7c6ec9ee987e7b9e7dae7b4efb1e84e02e7e5e7dce80ce84e0000"
  },
  {
   "jp_offset": "0x37e2",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "对我也是一样……",
   "zh_hex": "15e7beefcce7c0e7b6efb6e7da09090000"
  },
  {
   "jp_offset": "0x37f3",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "为阻止黑历史而来的我、却成了播下不和{00}种子的人",
   "zh_hex": "15e7c1e8efe869ef3ee8fbe925e89cefcfe7b4efcc02eadfe837e7baed70ef4de7b5e7d300e7d1e886e7b4efb20000"
  },
  {
   "jp_offset": "0x3815",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "但是、莉莉娜小姐……",
   "zh_hex": "15e7dbe7b602e81ee81ee7eae83ee92109090000"
  },
  {
   "jp_offset": "0x3821",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "您独自一人、一直坚守着完全和平这条道{00}路至今",
   "zh_hex": "15e835e8eeab87b40287e875eb80e8a8e86de87ebbe7d3e887e7b9e9d4e82a00e8d2e897a20000000000000000"
  },
  {
   "jp_offset": "0x3844",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "那是我们做不到的",
   "zh_hex": "15e7b7e7b6efcce7bbe81ce7b5e7d7e7b40000"
  },
  {
   "jp_offset": "0x3879",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "所以、我衷心希望您能将这条道路、贯彻{00}到最后……",
   "zh_hex": "15e7fbe7f3028bedb3e82de87be965e835e7c6e84ae7b9e9d4e82ae8d202ed07ebc500e7d7e8c5e7fe0909000000"
  },
  {
   "jp_offset": "0x38c5",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "通往完全和平之路……",
   "zh_hex": "15ef59e911e87eefb4e7d3e887e7cde8d209090000"
  },
  {
   "jp_offset": "0x38ed",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "我们未能实现的和平、就请让我们托付给{00}您吧、莉莉娜小姐",
   "zh_hex": "15efcce7bbe8b4e7c6e87fe82fe7b4e7d3e88702e7c5e83ae7f9efcce7bbe7f4e97ee83900e835e7d002e81ee81ee7eae83ee9210000"
  },
  {
   "jp_offset": "0x3936",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……是",
   "zh_hex": "150909e7b60000"
  },
  {
   "jp_offset": "0x39a6",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "咦……卡嘉莉小姐？",
   "zh_hex": "15ef490909e801e89ee81ee83ee921050000"
  },
  {
   "jp_offset": "0x39d7",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "……唔！是、是米莉亚莉亚啊……",
   "zh_hex": "150909e81def97e7b602e7b6e878e81ee7d6e81ee7d6e7c309090000"
  },
  {
   "jp_offset": "0x3a03",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "你在这种地方、做什么呢？",
   "zh_hex": "15e7b8ef29e7b9e7d1ef63efb102e81ce7dde7bde907050000"
  },
  {
   "jp_offset": "0x3a30",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "那、那个嘛……你看！……在那边！",
   "zh_hex": "15e7b702e7b7e828e9360909e7b8e7f6ef970909ef29e7b7e899ef970000"
  },
  {
   "jp_offset": "0x3a5e",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "啊……是拉克丝她们、正在和莉莉娜小姐{00}说话呢",
   "zh_hex": "15e7c30909e7b6e7c2e7d5e8a3e88ee7bb02ef3bef29e7d3e81ee81ee7eae83ee92100e7ede81fe9070000"
  },
  {
   "jp_offset": "0x3a9c",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "我、我也想……以奥布雄狮之女的身份、{00}向她进言几句",
   "zh_hex": "15efcc02efcce7c0e7e60909e7f3e82be831edc4ee63e7cdefade7b4e88dea220200efc1e88ee892efd7eaa5ebb90000"
  },
  {
   "jp_offset": "0x3ae4",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "可是、既然这样、你为何还躲在这种地方{00}偷看呢？",
   "zh_hex": "15e7c4e7b602e8c4e7efe7b9e7da02e7b8e7c1efbce7f7ea6fef29e7b9e7d1ef63efb100ebb4e7f6e907050000"
  },
  {
   "jp_offset": "0x3b19",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "这个嘛、怎么说呢、那个……那种场面、{00}我实在凑不进去……",
   "zh_hex": "15e7b9e828e93602e7f2e7bde7ede90702e7b7e8280909e7b7e7d1e876e8620200efcce87fef29ecb1e7b5e892e7eb09090000"
  },
  {
   "jp_offset": "0x3b56",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "那三个人确实是、该说与众不同呢、还是{00}怎么说……",
   "zh_hex": "15e7b7eaa0e828efb2e88ce87fe7b602e898e7ede832eafbe7b5e85de90702e7f7e7b600e7f2e7bde7ed09090000"
  },
  {
   "jp_offset": "0x3b6f",
   "jp_len": 42,
   "kind": "dialogue",
   "zh_text": "感觉是那种会客客气气互道『您好』之类{00}寒暄的人呢？",
   "zh_hex": "15e87de8aee7b6e7b7e7d1e7e2eccbeccbe8ede8ede9f9e82a0ce835e7c70de7cde84100ee0eee3de7b4b4e90705000000"
  },
  {
   "jp_offset": "0x3bd5",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "……嘛、这个就先不提了",
   "zh_hex": "150909e93602e7b9e828e7c5ef8be7b5e821e7ba0000"
  },
  {
   "jp_offset": "0x3be4",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "卡嘉莉小姐你不也是位公主吗？根本不必{00}怯场……",
   "zh_hex": "15e801e89ee81ee83ee921e7b8e7b5e7c0e7b6e834e9a4e954e80205e9b8efa6e7b5e86000ef54e87609090000"
  },
  {
   "jp_offset": "0x3c20",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "别、别叫我什么公主！怪难为情的……！",
   "zh_hex": "15e7e502e7e5e8c1efcce7dde7bde9a4e954ef97ea07e866e7c1e88be7b40909ef970000"
  },
  {
   "jp_offset": "0x3c53",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "老在意那种事、岂不是没法加入她们三人{00}之中了吗？",
   "zh_hex": "15e9caef29ef3ce7b7e7d1a902eac3e7b5e7b6e7d8e84ee854e891e88ee7bbeaa0b400e7cdc0e7bae802050000000000"
  },
  {
   "jp_offset": "0x3c79",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "那几位、对那种事、似乎压根就毫不在意{00}……",
   "zh_hex": "15e7b7eaa5e83402e7bee7b7e7d1efb802e944e933e992e9b8e7c5ea0ae7b5ef29ef3c0009090000"
  },
  {
   "jp_offset": "0x3cb3",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "是、是这样吗……？",
   "zh_hex": "15e7b602e7b6e7b9e7dae8020909050000"
  },
  {
   "jp_offset": "0x3cc0",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "唔……",
   "zh_hex": "15e81d09090000"
  },
  {
   "jp_offset": "0x912e",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "怎、怎么会在这里就败下阵来……",
   "zh_hex": "15e7f202e7f2e7bde7e2ef29e7b9ef31e7c5e88fef4deb48efcf09090000"
  },
  {
   "jp_offset": "0x9813",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "对……",
   "zh_hex": "15e7be09090000"
  },
  {
   "jp_offset": "0x9825",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "如今、你才是……真正的红心之王……",
   "zh_hex": "15e7f0efb902e7b8e836e7b60909e820ef3be7b4e9e3e82de7cde88409090000"
  },
  {
   "jp_offset": "0x985a",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "冯城",
   "zh_hex": "15ede5ed450000"
  },
  {
   "jp_offset": "0x9892",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "你们平安无事吗、拉米亚斯舰长！！",
   "zh_hex": "15e7b8e7bbe887e7fce7dcefb8e80202e7c2e878e7d6e7c8e7d4ef34ef97ef970000"
  },
  {
   "jp_offset": "0x98bd",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "隼人舰长！？",
   "zh_hex": "15ea35efb2e7d4ef34ef97050000"
  },
  {
   "jp_offset": "0x98e7",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "地球那边、不要紧吗……？",
   "zh_hex": "15ef63efd3e7b7e89902e7b5ef2aeaede8020909050000"
  },
  {
   "jp_offset": "0x991c",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "因为特列斯·克休里那达、已带着大半地{00}面战力上了宇宙",
   "zh_hex": "15ef33e7c1e7cfe8b5e7c8ef4be7d5e90eef31e7b7ef2b02ef3ae937e86defa5eadeef6300e862ef28efb0ef4ce7bae8bee8bf0000"
  },
  {
   "jp_offset": "0x9939",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "卡拉巴也突然没了交战的对手、正不知所{00}措呢",
   "zh_hex": "15e801e7c2e85be7c0e8b6e7efe7d8e7bae861ef28e7b4e7beef6602ef3be7b5e85ae7fb00ee31e9070000"
  },
  {
   "jp_offset": "0x9975",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "特列斯？你是说那位、特列斯·克休里那{00}达吗？",
   "zh_hex": "15e7cfe8b5e7c805e7b8e7b6e7ede7b7e83402e7cfe8b5e7c8ef4be7d5e90eef31e7b700ef2be802050000"
  },
  {
   "jp_offset": "0x99a6",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "您就是那位沙漠之虎……安德鲁·巴尔特{00}菲尔德吧",
   "zh_hex": "15e835e7c5e7b6e7b7e834eb0ceceae7cdec910909e7fce82ce8a2ef4be85be7e1e7cf00ea6ce7e1e82ce7d00000"
  },
  {
   "jp_offset": "0x99c0",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "能与您这样的人并肩作战、深感光荣、我{00}是卡拉巴的小林隼人",
   "zh_hex": "15e7c6e832e835e7b9e7dae7b4efb2e957eb16ef2fef2802eb0de87de83deb1902efcc00e7b6e801e7c2e85be7b4e83ee9b7ea35efb20000"
  },
  {
   "jp_offset": "0x99fb",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "彼此彼此、能得到一年战争的英雄这般评{00}价、我才真是光荣",
   "zh_hex": "15efc9e7caefc9e7ca02e7c6e80ae7d7efb6e909ef28e852e7b4eb6cedc4e7b9ea80ee9e00eb2502efcce836e820e7b6e83deb190000"
  },
  {
   "jp_offset": "0x9a1c",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "话说回来、要是连那个特列斯都上了宇宙{00}……",
   "zh_hex": "15e81fe7edef52efcf02ef2ae7b6e86ee7b7e828e7cfe8b5e7c8e840ef4ce7bae8bee8bf0009090000"
  },
  {
   "jp_offset": "0x9a3c",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "现在的宇宙、恐怕已经闹翻天了吧？",
   "zh_hex": "15e82fef29e7b4e8bee8bf02eb33e958ef3ae8b7ead8e808e844e7bae7d0050000"
  },
  {
   "jp_offset": "0x9a75",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯",
   "zh_hex": "150909e8650000"
  },
  {
   "jp_offset": "0x9a7c",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "其实我来见各位、本就是为了这件事",
   "zh_hex": "15e8cfe87fefccefcfe85ce819e83402efa6e7c5e7b6e7c1e7bae7b9e991efb80000"
  },
  {
   "jp_offset": "0x9ab6",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "你特意亲自前来、想必是出了相当重大的{00}事吧",
   "zh_hex": "15e7b8e7cfef3ce894efb5ef51efcf02e7e6e860e7b6efbee7bae8b1ef53e8a1efa5e7b400efb8e7d00000"
  },
  {
   "jp_offset": "0x9af3",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "特列斯派OZ、打算{00}对PLANT发动总攻",
   "zh_hex": "15e7cfe8b5e7c8e985ed1ceeda02e7f5e88900e7beeed4e81aea9ceed3eed6e870ef30e8819e000000"
  },
  {
   "jp_offset": "0x9b2c",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……！",
   "zh_hex": "150909ef970000"
  },
  {
   "jp_offset": "0x9b4e",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "特列斯·克休里那达、竟会做出这种事…{00}…",
   "zh_hex": "15e7cfe8b5e7c8ef4be7d5e90eef31e7b7ef2b02ef2ce7e2e81cefbee7b9e7d1efb80900090000"
  },
  {
   "jp_offset": "0x9b5f",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "可蓝色宇宙的穆尔塔·阿兹拉埃尔、绝不{00}会善罢甘休",
   "zh_hex": "15e7c4eaf1e89fe8bee8bfe7b4eb10e7e1e94504e7d2e856e7c2e96ae7e102e91ce7b500e7e2ed3aeaefecede90e000000"
  },
  {
   "jp_offset": "0x9b95",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "是的、蓝色宇宙派的OZ、正打算对此发{00}起攻击",
   "zh_hex": "15e7b6e7b402eaf1e89fe8bee8bfe985e7b4ed1ceeda02ef3be7f5e889e7bee7cae87000e8479ee7cc000000"
  },
  {
   "jp_offset": "0x9bd3",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "OZ居然内乱了……这对扎夫特来说、可{00}是求之不得的局面吧",
   "zh_hex": "15ed1ceedaea4ce7efe99ae976e7ba0909e7b9e7bee84be830e7cfefcfe7ed02e7c400e7b6e93ae7cde7b5e80ae7b4ea8ce862e7d00000"
  },
  {
   "jp_offset": "0x9c11",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "提坦斯也出现了附和他们的动向",
   "zh_hex": "15e821e843e7c8e7c0efbee82fe7baeaf8e7d3e80ce7bbe7b4ef30efc10000"
  },
  {
   "jp_offset": "0x9c28",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "这边、靠奥古和卡拉巴还勉强压得住、可{00}是……",
   "zh_hex": "15e7b9e89902e8c7e82be84de7d3e801e7c2e85be7f7eb2ae8ade992e80ae85902e7c400e7b609090000"
  },
  {
   "jp_offset": "0x9c61",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "问题就出在OZ和扎夫特啊",
   "zh_hex": "15e997ea12e7c5efbeef29ed1ceedae7d3e84be830e7cfe7c30000"
  },
  {
   "jp_offset": "0x9c8e",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "还有白色獠牙也是",
   "zh_hex": "15e7f7e7cbe809e89fececebd7e7c0e7b60000"
  },
  {
   "jp_offset": "0x9cc1",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "一旦扎夫特介入OZ的内乱、就可能演变{00}成地球与宇宙的全面战争",
   "zh_hex": "15efb6ebcde84be830e7cfea84e891ed1ceedae7b4e99ae97602e7c5e7c4e7c6ea2fe95500e837ef63efd3e832e8bee8bfe7b4efb4e862ef28e8520000"
  },
  {
   "jp_offset": "0x9d08",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "你是要我们去牵制那些势力？",
   "zh_hex": "15e7b8e7b6ef2aefcce7bbe7ebeb94e8dee7b7e8a4e8fdefb0050000"
  },
  {
   "jp_offset": "0x9d40",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "我知道这很难、可除了你们、再没有别的{00}能依靠的对象了",
   "zh_hex": "158be85ae82ae7b9e981e86602e7c4e974e7bae7b8e7bb02e80be7d8e7cbe7e5e7b400e7c6eafce8c7e7b4e7beebf2e7ba000000"
  },
  {
   "jp_offset": "0x9d7b",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……明白了",
   "zh_hex": "150909ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x9da1",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "拉米亚斯舰长！？",
   "zh_hex": "15e7c2e878e7d6e7c8e7d4ef34ef97050000"
  },
  {
   "jp_offset": "0x9dc5",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "我们的目的、就是让这场战争哪怕早一刻{00}结束",
   "zh_hex": "15efcce7bbe7b4efd4e7b402e7c5e7b6e7f9e7b9e876ef28e852e8ffe958e963efb6e91f00e868e8950000"
  },
  {
   "jp_offset": "0x9de5",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "我们没法坐视不管、对吧、克瓦特罗大尉{00}？",
   "zh_hex": "158be7bbe7d8e84eecc3e9d9e7b5e93b02e7bee7d002e7d5e99fe7cfe7ecbe8600050000000000"
  },
  {
   "jp_offset": "0x9e21",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "是啊、确实如你所言",
   "zh_hex": "15e7b6e7c302e88ce87fe7f0e7b8e7fbefd70000"
  },
  {
   "jp_offset": "0x9e51",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "隼人舰长、特列斯派的OZ、如今在哪里{00}？",
   "zh_hex": "15ea35efb2e7d4ef3402e7cfe8b5e7c8e985e7b4ed1ceeda02e7f0efb9ef29e8ffef3100050000"
  },
  {
   "jp_offset": "0x9e83",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "正在卫星轨道集结",
   "zh_hex": "15ef3bef29e9b2b5e9cce82aea98e868000000"
  },
  {
   "jp_offset": "0x9e90",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "据说阿兹拉埃尔也正赶往那边、若要开战",
   "zh_hex": "15e8cce7ede7d2e856e7c2e96ae7e1e7c0ef3bea04e911e7b7e89902e7e7ef2ae7faef280000"
  },
  {
   "jp_offset": "0x9eb0",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "应该就在那附近",
   "zh_hex": "15e873e898e7c5ef29e7b7eaf8efd80000"
  },
  {
   "jp_offset": "0x9ed5",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "这样啊……那么、我们也前往地球",
   "zh_hex": "15e7b9e7dae7c30909e7b7e7bd02efcce7bbe7c0ef51e911ef63efd30000"
  },
  {
   "jp_offset": "0x9eee",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "虽不知能做到哪一步、但我们会设法阻止{00}战火扩大",
   "zh_hex": "15e8b8e7b5e85ae7c6e81ce7d7e8ffefb6ea9302e7dbefcce7bbe7e2eb43e84ee8efe86900ef28e8daec1aefa50000"
  },
  {
   "jp_offset": "0x9f29",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "……就拜托你了、拉米亚斯舰长",
   "zh_hex": "150909e7c5e91ae7f4e7b8e7ba02e7c2e878e7d6e7c8e7d4ef340000"
  }
 ]
}
