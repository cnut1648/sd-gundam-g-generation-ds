  },
  {
   "jp_offset": "0x90f2",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "唔……无可奈何吗！",
   "zh_hex": "15e81d0909e7dce7c4eb2fefbce802ef970000"
  },
  {
   "jp_offset": "0x9100",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "全员、立刻进入战斗配置！迎击地球轨道{00}舰队！！",
