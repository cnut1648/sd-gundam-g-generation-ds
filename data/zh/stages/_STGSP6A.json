  },
  {
   "jp_offset": "0x959a",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "我这就救出贝尔纳黛特！",
   "zh_hex": "15efcce7b9e7c5e8caefbee857e7e1e882ea9ae7cfef970000"
