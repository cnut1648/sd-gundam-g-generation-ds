   "zh_hex": "15ef32e7c6ef28e7ba09090000"
  },
  {
   "jp_offset": "0x946d",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "全员、立刻进入战斗配置！迎击地球轨道{00}舰队！！",
   "zh_hex": "15bbe84902e86be91fe892e891ef28e7ffea34ea0e06e931e7ccbf95e9cce82a00e7d4e7c906060000000000000000"
