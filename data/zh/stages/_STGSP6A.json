  },
  {
   "jp_offset": "0x93e4",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "托比亚！？",
   "zh_hex": "15e7f4e825e7d60605000000"
  },
  {
   "jp_offset": "0x9407",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "再这么干等下去、我们可要被干掉了！！",
   "zh_hex": "15e80be7b9e7bde8d3e826ef4de7eb02efcce7bbe7c4ef2ae7f1e8d3e9d3e7baef97ef970000"
  },
  {
   "jp_offset": "0x9424",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "到那时候、还有谁能阻止木星帝国！！",
   "zh_hex": "15e7d7e7b7ef2dea3902e7f7e7cbe923e7c6e8efe869efa9ef69e8f8efc4ef97ef970000"
