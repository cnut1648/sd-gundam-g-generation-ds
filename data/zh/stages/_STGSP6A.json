   "zh_hex": "15e7c5e9eae82fef29060600e8caafe857e7e1e882ea9ae7cf04e831ef31ea31e7cf0600000000000000"
  },
  {
   "jp_offset": "0x9296",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "什么！？是拉·凯拉姆！？",
   "zh_hex": "15e7dde7bdef9705e7b6e7c2ef4be95fe7c2e823ef97050000"
  },
  {
   "jp_offset": "0x92a9",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "唔！可恶的大天使号！！",
   "zh_hex": "15e81def97e7c4e7dee7b4efa5e844e83fe833ef97ef970000"
  },
  {
   "jp_offset": "0x92b7",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "知道逃不掉、就索性豁出去了吗！！{00}全舰、转入攻击态势！！",
   "zh_hex": "15e85ae82ae8c2e7b5e9d302e7c5e93ce951eba5afe7ebe7bae802060600bbe7d402e9c2e8919ee7cce994e8fd0606000000000000000000"
  },
  {
   "jp_offset": "0x92fe",
