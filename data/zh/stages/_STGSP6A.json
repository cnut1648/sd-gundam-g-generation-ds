   "zh_hex": "15bf95e9cce82ae7d4e7c9e989e7fa1314060600ef3beaad8be7bbebf696060000000000000000000000"
  },
  {
   "jp_offset": "0x933c",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "怎么办、拉米亚斯舰长！！",
   "zh_hex": "15e7f2e7bde8ea02e7c2e878e7d6e7c8e7d4ef34ef97ef970000"
  },
  {
   "jp_offset": "0x934a",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "再这样下去、就要和正规军交战了！",
   "zh_hex": "15e80be7b9e7daef4de7eb02e7c5ef2ae7d3ef3bea42e7e0e861ef28e7baef970000"
