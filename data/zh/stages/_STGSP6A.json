{
 "file": "_STGSP6A.bin",
 "source_size": 39928,
 "built_size": 41661,
 "edits": [
  {
   "jp_offset": "0x1822",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "前进路线已清空！我们即将抵达地球轨道{00}！",
   "zh_hex": "15bae892e8d2e916ef3ae995e93f068be7bbe855e84ae96eef2bbf95e9cce82a00060000000000000000"
  },
  {
   "jp_offset": "0x1855",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "正规军那边怎么样？",
   "zh_hex": "15ef3bea42e7e0e7b7e899e7f2e7bde7da050000"
  },
  {
   "jp_offset": "0x187d",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "地球轨道舰队、似乎正前来迎接我们",
   "zh_hex": "15bf95e9cce82ae7d4e7c902e944e933ef3bbad9e931b78be7bb0000000000000000"
  },
  {
   "jp_offset": "0x18ae",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "好！各舰保持前进！！与地球轨道舰队会{00}合……",
   "zh_hex": "15e7c706e819e7d4ea47e9efbae8920606e832bf95e9cce82ae7d4e7c9e7e200a00909000000000000000000"
  },
  {
   "jp_offset": "0x18f2",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "炮击！？难道是木星帝国吗！？",
   "zh_hex": "15e95ae7cc0605e866e82ae7b6d4b5e8f8a1e802060500000000000000"
  },
  {
   "jp_offset": "0x1920",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "是来自正前方的远距离光束！发射源是…{00}…",
   "zh_hex": "15e7b6efcfefb5ef3bef51efb1e7b4e94cea0fe901e83de895ef97e870ef65ebd6e7b60900090000"
  },
  {
   "jp_offset": "0x1939",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……！！",
   "zh_hex": "150909ef97ef970000"
  },
  {
   "jp_offset": "0x195c",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "怎么了！？",
   "zh_hex": "15e7f2e7bde7baef97050000"
  },
  {
   "jp_offset": "0x197f",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "刚、刚才那次攻击……是来自地球轨道舰{00}队的！！",
   "zh_hex": "15e8bc02e8bce836e7b7e8649ee7cc0909e7b6d9abbf95e9cce82ae7d400e7c9e7b40606000000000000000000"
  },
  {
   "jp_offset": "0x19b6",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "你说什么！？",
   "zh_hex": "15e7b8e7ede7dde7bdef97050000"
  },
  {
   "jp_offset": "0x19e4",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "向隆德·贝尔队通告！立刻解除武装、向{00}我们投降！",
   "zh_hex": "15efc1ed16e82cef4be857e7e1e7c9ef59e8e5ef97e86be91fe89de974e8ece98f02efc100efcce7bbe948e943ef970000"
  },
  {
   "jp_offset": "0x1a21",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……请等等！",
   "zh_hex": "150909e83ae826e826ef970000"
  },
  {
   "jp_offset": "0x1a2f",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "为什么、我们非得遭你们炮击不可！？",
   "zh_hex": "15e7c1e7dde7bd02efcce7bbe8f0e80aeb1ee7b8e7bbe95ae7cce7b5e7c4ef97050000"
  },
  {
   "jp_offset": "0x1a6f",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "别装了！！",
   "zh_hex": "15e7e5e98fe7baef97ef970000"
  },
  {
   "jp_offset": "0x1a7c",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "你们勾结海盗、袭击了木星公社的运输船{00}！",
   "zh_hex": "15e7b8e7bbecb7e868e91be9f302e9aee7cce7baefa9ef69e9a4ed96e7b4e986e8b9ea0200ef970000"
  },
  {
   "jp_offset": "0x1ab9",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "唔！你、你们……！！",
   "zh_hex": "15e81def97e7b802e7b8e7bb0909ef97ef970000"
  },
  {
   "jp_offset": "0x1af1",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "认命吧、布莱特大佐",
   "zh_hex": "15e8a0e853e7d002e831e846e7cfbea300000000"
  },
  {
   "jp_offset": "0x1aff",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "贵队的越轨之举、木星公社早已通报过来",
   "zh_hex": "15e930e7c9e7b4ea57e9cce7cdea2102efa9ef69e9a4ed96e963ef3aef59e913ef36efcf0000"
  },
  {
   "jp_offset": "0x1b1e",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "攻击身为地球生命线的木星船队、等同于{00}背叛联邦",
   "zh_hex": "15ef67e7cce88de7c1ef63efd3ef8de853e916e7b4efa9ef69ea02e7c902e826e85de87900e9e4ef43ef2eefaa0000"
  },
  {
   "jp_offset": "0x1b45",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "立刻投降便罢！",
   "zh_hex": "15e86be91fe948e943e8faeaefef970000"
  },
  {
   "jp_offset": "0x1b57",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "否则、便视贵队为发动叛乱、立即发起攻{00}击！！",
   "zh_hex": "15e9bbea8702e8fae9d9e930e7c9e7c1e870ef30ef43e97602e86be855e870e847ef6700e7ccef97ef970000"
  },
  {
   "jp_offset": "0x1b9d",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "布莱特舰长……",
   "zh_hex": "15e831e846e7cfe7d4ef3409090000"
  },
  {
   "jp_offset": "0x1bc1",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "没想到、就连军方都已落入木星帝国的掌{00}控……",
   "zh_hex": "15e7d8e7e6e7d702e7c5e86ee7e0efb1e840ef3ae92ae891efa9ef69e8f8efc4e7b4eb3600ea3f09090000"
  },
  {
   "jp_offset": "0x1c0a",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "轨道舰队和木星帝国军、都已不见机影！",
   "zh_hex": "15e9cce82ae7d4e7c9e7d3d4b5e8f8a1e7e002e840ef3ae7b5e85ce7e4ea8e06000000000000"
  },
  {
   "jp_offset": "0x1c53",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "趁后续未到便撤退",
   "zh_hex": "15e9eae7fee9ade8b4e7d7e8fae90ae8800000"
  },
  {
   "jp_offset": "0x1c66",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "全舰、立刻撤退！！",
   "zh_hex": "15efb4e7d402e86be91fe90ae880ef97ef970000"
  },
  {
   "jp_offset": "0x4852",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "不妙！此舰若被击沉……！",
   "zh_hex": "15e7b5ecc7ef97e7cae7d4e7e7e7f1e7cce9830909ef970000"
  },
  {
   "jp_offset": "0x53b2",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "呵呵……",
   "zh_hex": "15ef3def3d09090000"
  },
  {
   "jp_offset": "0x53de",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……是扎比涅！？",
   "zh_hex": "150909e7b6e84be825eacf0605000000"
  },
  {
   "jp_offset": "0x540e",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "是地球轨道舰队的诸位吗？",
   "zh_hex": "15e7b6bf95e9cce82ae7d4e7c9e7b4ea56e834e8020500000000"
  },
  {
   "jp_offset": "0x5420",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我们奉杜加奇阁下之命、前来支援贵队！{00}！",
   "zh_hex": "158be7bbeac1e8cbe854e904e8d789e7cde85302bad9e883e863e930e7c90600060000000000000000"
  },
  {
   "jp_offset": "0x545d",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "哦哦、是木星的诸位啊！！多谢协助！",
   "zh_hex": "15e919e91902e7b6d4b5e7b4ea56e834e7c30606e7e9e8b2e8f6ea230600000000000000"
  },
  {
   "jp_offset": "0x54b7",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "（呵呵……扎比涅·夏尔……干得漂亮）",
   "zh_hex": "150aef3def3d0909e84be825eacf04ef37e7e10909e8d3e80aead0eaa20b0000000000"
  },
  {
   "jp_offset": "0x54cf",
   "jp_len": 37,
   "kind": "dialogue",
   "zh_text": "（这下、向地球圈派兵就更轻松了……）",
   "zh_hex": "150ae7b989029dbf95e9fbe985cee7c5e952e990e9e0e7ba09090b00000000000000"
  },
  {
   "jp_offset": "0x54f4",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "好！MS队、出击！！",
   "zh_hex": "15e7c7ef97efa7ef9ee7c902efbee7ccef97ef970000"
  },
  {
   "jp_offset": "0x5503",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "与联邦军联手、把那帮海盗一举击破！！",
   "zh_hex": "15e832ef2eefaae7e0ef2eef6602e81be7b7e910e91be9f3efb6ea21e7ccef6def97ef970000"
  },
  {
   "jp_offset": "0x5542",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x5551",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "难道是……贝尔纳黛特！？",
   "zh_hex": "15e866e82ae7b60909e857e7e1e882ea9ae7cf0605000000"
  },
  {
   "jp_offset": "0x5579",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "托比亚……！！",
   "zh_hex": "15e7f4e825e7d60909060600000000"
  },
  {
   "jp_offset": "0x559d",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "果然、是贝尔纳黛特！！",
   "zh_hex": "15e871e7ef02e7b6e857e7e1e882ea9ae7cfef97ef970000"
  },
  {
   "jp_offset": "0x55a9",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "你怎么会在这里……！？",
   "zh_hex": "15e7b8e7f2e7bde7e2ef29e7b9ef310909ef97050000"
  },
  {
   "jp_offset": "0x55cf",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "不行、托比亚！快逃！！",
   "zh_hex": "15e7b59f02e7f4e825e7d606e85fe8c20606000000000000"
  },
  {
   "jp_offset": "0x55fa",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "贝尔纳黛特！？",
   "zh_hex": "15e857e7e1e882ea9ae7cfef97050000"
  },
  {
   "jp_offset": "0x561e",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "不行啊！",
   "zh_hex": "15e7b5efd6e7c3ef970000"
  },
  {
   "jp_offset": "0x5626",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "操纵这机体的不是我、是电脑……！",
   "zh_hex": "15eac7e8e6e7b9e7e4ef4fe7b4e7b5e7b6efcc02e7b6ead3eb670909ef970000"
  },
  {
   "jp_offset": "0x563f",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "停不下了！托比亚快逃！",
   "zh_hex": "15e934e7b589e7ba06e7f4e825e7d6e85fe8c2060000000000"
  },
  {
   "jp_offset": "0x5674",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "可恶！杜加奇这混蛋！！竟对自己的女儿{00}下手！",
   "zh_hex": "15e7c4e7de06e8cbe854e904e7b9ea41ea6d0606ef2ce7beabe8c9e7b4b0eb7c0089ae0600000000000000000000"
  },
  {
   "jp_offset": "0x56a9",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "托比亚……！",
   "zh_hex": "15e7f4e825e7d6090906000000"
  },
  {
   "jp_offset": "0x56cc",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "没事的、贝尔纳黛特！！我马上……",
   "zh_hex": "15e7d8efb8e7b402e857e7e1e882ea9ae7cfef97ef97efcce84fef4c09090000"
  },
  {
   "jp_offset": "0x56e3",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "这就救你出来！",
   "zh_hex": "15e7b9e7c5e8cae7b8efbeefcfef970000"
  },
  {
   "jp_offset": "0x571a",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "什么！？那台MA……",
   "zh_hex": "15e7dde7bd0605e7b7ea1613ea9c09090000"
  },
  {
   "jp_offset": "0x572d",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "不是贝尔纳黛特、我感到了另一股气息！{00}！",
   "zh_hex": "15e7b5e7b6e857e7e1e882ea9ae7cf02efcce87de7d7e7bae99befb6edace8edec6aef9700ef970000"
  },
  {
   "jp_offset": "0x5746",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "是谁！是谁在里面！？",
   "zh_hex": "15e7b6e923ef97e7b6e923ef29ef31e862ef97050000"
  },
  {
   "jp_offset": "0x578b",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "哈哈哈哈哈哈！看穿了啊、小子！！",
   "zh_hex": "15e7e8e7e8e7e8e7e8e7e8e7e8ef97e7f6ea7ee7bae7c302e83ee886ef97ef970000"
  },
  {
   "jp_offset": "0x57c9",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "这声音！？是父亲大人！？",
   "zh_hex": "15e7b9ea8aea71ef9705e7b6e888e894efa5efb2ef97050000"
  },
  {
   "jp_offset": "0x57fb",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "格拉克斯·杜加奇……！！",
   "zh_hex": "15e824e7c2e7d5e7c804e8cbe854e904090906060000000000"
  },
  {
   "jp_offset": "0x5839",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "正是、小子",
   "zh_hex": "15ef3be7b602e83ee8860000"
  },
  {
   "jp_offset": "0x5846",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "操纵这台机体的、正是格拉克斯·杜加奇{00}……",
   "zh_hex": "15eac7e8e6e7b9ea16e7e4bce7b402ef3be7b6e824e7c2e7d5e7c804e8cbe854e90400090900000000"
  },
  {
   "jp_offset": "0x585e",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "是转写了他思维模式的生体头脑",
   "zh_hex": "15e7b6e9c2ede3e7bae80ca6ea54ea91ea26e7b4b6bce92eeb67000000"
  },
  {
   "jp_offset": "0x5872",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "可就算明白了、又能怎样呢、小子？",
   "zh_hex": "15e7c4e7c5e889ef39e809e7ba02e8f1e7c6e7f2e7dae90702e83ee886050000"
  },
  {
   "jp_offset": "0x58b1",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x58ed",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "你想救的那个女孩、就在我手中",
   "zh_hex": "15e7b8e7e6e8cae7b4e7b7e828efade95602e7c5ef29efccef66ef4e0000"
  },
  {
   "jp_offset": "0x5906",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "你还下得了手吗！？",
   "zh_hex": "15e7b8e7f7ef4de80ae7baef66e802ef97050000"
  },
  {
   "jp_offset": "0x5937",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "那可是你自己的女儿啊！！",
   "zh_hex": "15e7b7e7c4e7b6e7b8efb5e8c9e7b4efadeb7ce7c3ef97ef970000"
  },
  {
   "jp_offset": "0x5949",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "这是人说的话吗！你这家伙——！！",
   "zh_hex": "15e7b9e7b6efb2e7ede7b4e81fe802ef97e7b8e7b9e7dfe7fdebafebafef97ef970000"
  },
  {
   "jp_offset": "0x5993",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "哈哈哈、真是可笑！",
   "zh_hex": "15e7e8e7e8e7e802e820e7b6e7c4ea1cef970000"
  },
  {
   "jp_offset": "0x59a2",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "战斗本就不分光明与卑劣！这可是战争啊{00}！",
   "zh_hex": "15ef28e7ffefa6e7c5e7b5efaee83def39e832ec4bec0def97e7b9e7c4e7b6ef28e852e7c300ef970000"
  },
  {
   "jp_offset": "0x59e5",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "杜加奇……！！",
   "zh_hex": "15e8cbe854e9040909060600000000"
  },
  {
   "jp_offset": "0x5a16",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……就是现在！！",
   "zh_hex": "150909e7c5e7b6e82fef29ef97ef970000"
  },
  {
   "jp_offset": "0x5a42",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "贝尔纳黛特、就还给我吧！！",
   "zh_hex": "15e857e7e1e882ea9ae7cf02e7c5e7f7e839efcce7d0ef97ef970000"
  },
  {
   "jp_offset": "0x5a86",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "唔！这臭小子——！！",
   "zh_hex": "15e81def97e7b9ecfde83ee886ebafebafef97ef970000"
  },
  {
   "jp_offset": "0x5ac2",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "她可不是你的东西！",
   "zh_hex": "15e88ee7c4e7b5e7b6e7b8e7b4e8bae7f8ef970000"
  },
  {
   "jp_offset": "0x5b02",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "那么、就用海盗的方式……",
   "zh_hex": "15e7b7e7bd02e7c5efb3e91be9f3e7b4efb1ea2609090000"
