   "zh_hex": "15ef32e7c6e7f5e7bae7c306e831e846e7cfe7d4ef340600000000"
  },
  {
   "jp_offset": "0x9080",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "托比亚！？",
   "zh_hex": "15e7f4e825e7d60605000000"
  },
  {
   "jp_offset": "0x90a2",
   "jp_len": 29,
   "kind": "dialogue",
