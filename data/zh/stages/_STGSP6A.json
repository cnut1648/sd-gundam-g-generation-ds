   "jp_offset": "0x5b7e",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "托比亚！！",
   "zh_hex": "15e7f4e825e7d6060600000000"
  },
  {
   "jp_offset": "0x5baa",
   "jp_len": 20,
   "kind": "dialogue",
