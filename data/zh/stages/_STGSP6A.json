   "zh_hex": "15e819e7e402e95eefc1e7b7ea16efa7ea9cef970000"
  },
  {
   "jp_offset": "0x96bf",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "拦住它、救出被关在它内部的少女！",
   "zh_hex": "15eb89e859e97802e8caefbee7f1e8bbef29e978e99aef70e7b4efacefadef970000"
  },
  {
   "jp_offset": "0x96fe",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "就趁现在！……救出贝尔纳黛特！！",
   "zh_hex": "15e7c5e9eae82fef29ef970909e8caefbee857e7e1e882ea9ae7cfef97ef970000"
  },
  {
   "jp_offset": "0x9732",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "贝尔纳黛特……我现在就来！！",
   "zh_hex": "15e857e7e1e882ea9ae7cf0909efcce82fef29e7c5efcfef97ef970000"
  },
  {
   "jp_offset": "0x9a72",
   "jp_len": 11,
   "kind": "dialogue",
