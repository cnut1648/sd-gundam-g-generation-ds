  },
  {
   "jp_offset": "0x9142",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "六点钟方向、发现新舰影！！",
   "zh_hex": "15eddfe822ebf9efb1efc102e870e82fef8ae7d4ea8eef97ef970000"
  },
  {
   "jp_offset": "0x916c",
   "jp_len": 12,
   "kind": "dialogue",
