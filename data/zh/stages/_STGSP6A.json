   "zh_hex": "15e819e7e402e95eefc1e7b7ea16efa7ea9cef970000"
  },
  {
   "jp_offset": "0x9213",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "拦住它的行动、救出贝尔纳黛特·布里耶{00}特！",
   "zh_hex": "15eb89e859e978e7b4efd6ef3002e8caefbee857e7e1e882ea9ae7cfef4be831ef31ea3100e7cfef970000"
  },
  {
   "jp_offset": "0x9252",
   "jp_len": 21,
   "kind": "dialogue",
