   "zh_hex": "15e7dde7bd02e7b6ef8ae7beef66e802ef97050000"
  },
  {
   "jp_offset": "0x919e",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……是木星帝国！！",
   "zh_hex": "150909e7b6efa9ef69e8f8efc4ef97ef970000"
