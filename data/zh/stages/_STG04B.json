{
 "file": "_STG04B.bin",
 "source_size": 40960,
 "built_size": 43071,
 "edits": [
  {
   "jp_offset": "0x1395",
   "jp_len": 56,
   "kind": "dialogue",
   "zh_text": "あいうえおかダチッツテ{01}デ、トドナ{00}·{00}！言{01}Mうたな、{00}{01}！死{00}M中そな、{00}{01}ぁ敌舰队、突现于暗礁宙域！",
   "zh_hex": "15161718191a1b6566676869016a026b6c6d000400069b011358243302000106a7001300233302000115e7e3e7d4e7c902e8b6e82fe879ea6aee75e8bfeaa7ef970000"
  },
  {
   "jp_offset": "0x13e8",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "……来了吗、西玛中佐那边情况如何？",
   "zh_hex": "150909efcfe7bae80202e7f8e845ef4eefbae7b7e899e88be8d0e7f0efbc050000"
  },
  {
   "jp_offset": "0x1449",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "我们这边随时都能出击",
   "zh_hex": "15efcce7bbe7b9e899e9a1ef2de840e7c6efbee7cc0000"
  },
  {
   "jp_offset": "0x1472",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "好——！发起攻击！！",
   "zh_hex": "15e7c7ebafebafef97e870e847ef67e7ccef97ef970000"
  },
  {
   "jp_offset": "0x14a6",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "好！那我们也……",
   "zh_hex": "15e7c7ef97e7b7efcce7bbe7c009090000"
  },
  {
   "jp_offset": "0x14fc",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……是你！？",
   "zh_hex": "150909e7b6e7b8ef97050000"
  },
  {
   "jp_offset": "0x1520",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "我也来协助你",
   "zh_hex": "15efcce7c0efcfe8f6ea23e7b80000"
  },
  {
   "jp_offset": "0x1544",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "协助？怕不是来监视我的吧？",
   "zh_hex": "15e8f6ea2305e958e7b5e7b6efcfed8de9d9efcce7b4e7d0050000"
  },
  {
   "jp_offset": "0x155b",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "大尉您厌恶我们海兵队、这事我们可清楚{00}得很",
   "zh_hex": "15efa5efc6e835eb2be7deefcce7bbe91bef93e7c902e7b9efb8efcce7bbe7c4e995ebd300e80ae9810000"
  },
  {
   "jp_offset": "0x1596",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "那、中佐、就要看贵官您的诚意如何了",
   "zh_hex": "15e7b702ef4eefba02e7c5ef2ae7f6e930ef92e835e7b4ee9fef3ce7f0efbce7ba0000"
  },
  {
   "jp_offset": "0x15b0",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……告辞！",
   "zh_hex": "150909e8e5ec9aef970000"
  },
  {
   "jp_offset": "0x15e0",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "唔！竟是敌袭！？MS队、立刻迎击！！",
   "zh_hex": "15e81def97ef2ce7b6e7e3e9aeef9705efa7ef9ee7c902e86be91fe931e7ccef97ef970000"
  },
  {
   "jp_offset": "0x161c",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "可恶！这是要前后夹击吗！",
   "zh_hex": "15e7c4e7deef97e7b9e7b6ef2aef51e7feec5be7cce802ef970000"
  },
  {
   "jp_offset": "0x162f",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "净使这种卑劣的阴招！",
   "zh_hex": "15ecb0e83fe7b9e7d1ec4bec0de7b4eb22e97a06000000"
  },
  {
   "jp_offset": "0x165c",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "说明对手就是如此周密！别大意、蒙夏！",
   "zh_hex": "15e7edef39e7beef66e7c5e7b6e7f0e7caea5ce9bdef97e7e5efa5ef3c02e942ef37ef970000"
  },
  {
   "jp_offset": "0x169e",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "真是的！净是些难缠的不速之客啊！",
   "zh_hex": "15e820e7b6e7b4ef97ecb0e7b6e8a4e866ec34e7b4e7b5e9dae7cdeccbe7c3ef970000"
  },
  {
   "jp_offset": "0x16db",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "西玛大人！",
   "zh_hex": "15e7f8e845efa5efb2ef970000"
  },
  {
   "jp_offset": "0x16fe",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "卡多大尉的心思、暂且先放一边……开始{00}攻击！！",
   "zh_hex": "15e801e7e9efa5efc6e7b4e82defca02e9ffe999ef8be86cefb6e8990909e7fae90800ef67e7ccef97ef970000"
  },
  {
   "jp_offset": "0x1742",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "布拉德中佐！？",
   "zh_hex": "15e831e7c2e82cef4eefbaef97050000"
  },
  {
   "jp_offset": "0x1756",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "难得让我指挥一回……可恶！！",
   "zh_hex": "15e866e80ae7f9efcce8c0e949efb6ef520909e7c4e7deef97ef970000"
  },
  {
   "jp_offset": "0x179d",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "唔……看来总算是赶上了",
   "zh_hex": "15e81d0909e7f6efcfe881e889e7b6ea04ef4ce7ba0000"
  },
  {
   "jp_offset": "0x17ca",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "您是……松永大尉！！",
   "zh_hex": "15e835e7b60909e9e0e9bfefa5efc6ef97ef970000"
  },
  {
   "jp_offset": "0x17d8",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我听说您已被召回SIDE3了……",
   "zh_hex": "15efcce8d1e7ede835ef3ae7f1ecbdef52ef9eef62ef96ef9fef60e7ba09090000"
  },
  {
   "jp_offset": "0x1816",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "也正因如此、我才未能守住多兹鲁阁下…{00}…",
   "zh_hex": "15e7c0ef3bef33e7f0e7ca02efcce836e8b4e7c6e8a8e859e7e9e856e8a2e8d7ef4d0900090000"
  },
  {
   "jp_offset": "0x1832",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "至少要多歼灭一个敌人、为阁下雪此遗恨{00}、我才赶来此地",
   "zh_hex": "15e897efacef2ae7e9eaafe8e1efb6e828e7e3efb202e7c1e8d7ef4ded18e7caeba9e9be0002efcce836ea04efcfe7caef630000"
  },
  {
   "jp_offset": "0x187e",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "那么……请让我助贵军一臂之力！！",
   "zh_hex": "15e7b7e7bd0909e83ae7f9efccea23e930e7e0efb6ee92e7cdefb0ef97ef970000"
  },
  {
   "jp_offset": "0x18b5",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "这身手我有印象……你、是那个恩迪米翁{00}之鹰吧！",
   "zh_hex": "15e7b9e88dae8be7cbec4febf20909e7b802e7b6e7b7e828e7eeea11e878ee8800e7cde6b3e7d0060000000000"
  },
  {
   "jp_offset": "0x18f2",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "啧！是赤色闪电、强尼莱汀吗！",
   "zh_hex": "15e9fa06e7b6e9e9e89fea44ead302e8ade896e846ed7ce8020600000000"
  },
  {
   "jp_offset": "0x1907",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "碰上个难缠的家伙了！",
   "zh_hex": "15eb98ef4ce828e866ec34e7b4e7dfe7fde7baef970000"
  },
  {
   "jp_offset": "0x1939",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "什么！？你、刚才说什么来着！！",
   "zh_hex": "15e7dde7bdef9705e7b802e8bce836e7ede7dde7bdefcfe86def97ef970000"
  },
  {
   "jp_offset": "0x195a",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "85"
  },
  {
   "jp_offset": "0x195b",
   "jp_len": 33,
   "kind": "script",
   "zh_hex": "153302000106ce001358243302000106630013002333020001150909e7c3050000"
  },
  {
   "jp_offset": "0x1997",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "不、你看嘛！「难缠的家伙」之类的{00}……",
   "zh_hex": "15e7b502e7b8e7f6e93606e9c3e866ec34e7b4e7dfe7fde9c4e7cde841e7b40009090000000000"
  },
  {
   "jp_offset": "0x19ce",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "所以说……{00}你、莫非不是……赤色闪电吗？",
   "zh_hex": "15e7fbe7f3e7ed090900e7b802eba0e8f0e7b5e7b60909e9e9e89fea44ead3e802050000"
  },
  {
   "jp_offset": "0x1a18",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "是吗、是吗……",
   "zh_hex": "15e7b6e80202e7b6e80209090000"
  },
  {
   "jp_offset": "0x1a24",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "果然、识货的人、一看就懂啊……",
   "zh_hex": "15e871e7ef02e92feaf5e7b4efb202efb6e7f6e7c5e8b0e7c309090000"
  },
  {
   "jp_offset": "0x1a3a",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "你、从今往后就是我的好兄弟了！！",
   "zh_hex": "15e7b802e88aefb9e911e7fee7c5e7b6efcce7b4e7c7ebb5eb84e7baef97ef970000"
  },
  {
   "jp_offset": "0x1a69",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……哈？",
   "zh_hex": "150909e7e8050000"
  },
  {
   "jp_offset": "0x1a96",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "什么！？",
   "zh_hex": "15e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x1a9e",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "难道已经打到本队这里来了吗！？",
   "zh_hex": "15e866e82aef3ae8b7e7f5e7d7d2e7c9e7b9ef31d9e7bae80206050000000000"
  },
  {
   "jp_offset": "0x1ad0",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "这才是真正的机动战！",
   "zh_hex": "15e7b9e836e7b6e820ef3be7b4e7e4ef30ef28ef970000"
  },
  {
   "jp_offset": "0x1ae2",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "别小看了真红闪电的速度！",
   "zh_hex": "15e7e5e83ee7f6e7bae820e9e3ea44ead3e7b4e9dae96def970000"
  },
  {
   "jp_offset": "0x1b1a",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "那家伙、当年就在所罗门……！！",
   "zh_hex": "15e7b7e7dfe7fd02ef53e909e7c5ef29e7fbe7ece90c0909ef97ef970000"
  },
  {
   "jp_offset": "0x1b29",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "当心！敌方有那个所罗门的噩梦！！",
   "zh_hex": "15ef53e82def97e7e3efb1e7cbe7b7e828e7fbe7ece90ce7b4ed3fea40ef97ef970000"
  },
  {
   "jp_offset": "0x1b5b",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "哼……所罗门的噩梦吗、没想到联邦竟这{00}样称呼我……",
   "zh_hex": "15e8b30909e7fbe7ece90ce7b4ed3fea40e80202e7d8e7e6e7d7ef2eefaaef2ce7b900e7daea01ea3cefcc09090000"
  },
  {
   "jp_offset": "0x1b7c",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "那么、为不负我这异名、就让你们好好见{00}识见识噩梦！",
   "zh_hex": "15e7b7e7bd02e7c1e7b5e92cefcce7b9eb32e8ac02e7c5e7f9e7b8e7bbe7c7e7c7e85c00e92fe85ce92fed3fea40ef970000"
  },
  {
   "jp_offset": "0x1b9a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "尽情见识吧！！",
   "zh_hex": "15e8f2e88be85ce92fe7d0ef97ef970000"
  },
  {
   "jp_offset": "0x1bc8",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "我乃松永真！",
   "zh_hex": "15efccefdde9e0e9bfe820ef970000"
  },
  {
   "jp_offset": "0x1bd6",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "以所罗门白狼之名、多兹鲁阁下的遗恨…{00}…",
   "zh_hex": "15e7f3e7fbe7ece90ce809ec7be7cde8ac02e7e9e856e8a2e8d789e7b4eba9e9be090009000000"
  },
  {
   "jp_offset": "0x1bef",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "就让我来替他一雪此恨吧！！",
   "zh_hex": "15e7c5e7f9efccefcfea50e80cefb6ed18e7cae9bee7d0ef97ef970000"
  },
  {
   "jp_offset": "0x1c22",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "管你是红的白的、还是什么乱七八糟的颜{00}色……",
   "zh_hex": "15e93be7b8e7b6e9e3e7b4e809e7b402e7f7e7b6e7dde7bde976ec45ecafeeafe7b4ec4100e89f09090000"
  },
  {
   "jp_offset": "0x1c3e",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "老子可是联邦的王牌、蒙夏大爷！",
   "zh_hex": "15e9cae886e7c4e7b6ef2eefaae7b4e884ec2b02e942ef37efa5ed85ef970000"
  },
  {
   "jp_offset": "0x1c53",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "论本事、我可不会输给你们！！",
   "zh_hex": "15e8dcefa6efb802efcce7c4e7b5e7e2e8b9e839e7b8e7bbef97ef970000"
  },
  {
   "jp_offset": "0x1c8a",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "一转眼就被干掉一架……这家伙到底是什{00}么怪物！",
   "zh_hex": "15efb6e9c2e90be7c5e7f1e8d3e9d3efb6e99d0909e7b9e7dfe7fde7d7e9b4e7b6e7dd00e7bdea07e99eef970000"
  },
  {
   "jp_offset": "0x1c9f",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "那就是……吉翁的赤色彗星……",
   "zh_hex": "15e7b7e7c5e7b60909e7d9ee88e7b4e9e9e89fe9b6b50909000000"
  },
  {
   "jp_offset": "0x1cd6",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "拜托你听人把话说完啊……",
   "zh_hex": "15e91ae7f4e7b8e8d1efb2e81be81fe7ede87ee7c309090000"
  },
  {
   "jp_offset": "0x1d0b",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "划过战场的赤色闪电……我就是强尼莱汀{00}！！",
   "zh_hex": "15ea74ef36ef28e876e7b4e9e9e89fea44ead309098be7c5e7b6e8ade896e846ed7c0006060000000000"
  },
  {
   "jp_offset": "0x1d26",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "想找死的、就尽管放马过来！",
   "zh_hex": "15e7e6e9d2ef6ae7b402e7c5e8f2e93be86ce84fef36efcfef970000"
  },
  {
   "jp_offset": "0x1d5d",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "西玛·卡拉豪中佐……有一句话、我得对{00}贵官说清楚",
   "zh_hex": "15e7f8e845ef4be801e7c2eea2ef4eefba0909e7cbefb6ebb9e81f02efcce80ae7be00e930ef92e7ede995ebd30000"
  },
  {
   "jp_offset": "0x1d7c",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "贵官的实力、我确实也是认可的、可是…{00}…",
   "zh_hex": "15e930ef92e7b4e87fefb002efcce88ce87fe7c0e7b6e8a0e7c4e7b402e7c4e7b60900090000"
  },
  {
   "jp_offset": "0x1d95",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "纵是身经百战的名将、胸无大志者、也绝{00}不会有荣光降临",
   "zh_hex": "15e8e6e7b6e88de8b7ebdcef28e7b4e8ace84a02ee8ce7dcbeea18ad02e7c0e91c00e7b5e7e2e7cbeb19e83de943ed1e00000000"
  },
  {
   "jp_offset": "0x1dcf",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "哼……！你想说的、就是这些吗？",
   "zh_hex": "15e8b30909ef97e7b8e7e6e7ede7b402e7c5e7b6e7b9e8a4e802050000"
  },
  {
   "jp_offset": "0x1de8",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "都上战场了还来给我讲大道理、你倒真是{00}好大的架子啊？",
   "zh_hex": "15e840b2ef28e876e7bae7f7d9e8398beba2bee82ae87202e7b8e848e820e7b600e7c7bee7b4e99de886e7c30500000000000000"
  },
  {
   "jp_offset": "0x1e08",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "……竟还有闲心、大谈什么志向荣光",
   "zh_hex": "150909ef2ce7f7e7cbeebee82d02efa5eaf4e7dde7bdea18efc1eb19e83d0000"
  },
  {
   "jp_offset": "0x1e42",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "什么……！？",
   "zh_hex": "15e7dde7bd0909ef97050000"
  },
  {
   "jp_offset": "0x1e66",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "那些打从一开始、就没那份闲心去谈这些{00}的人、",
   "zh_hex": "15e7b7e8a4e7f5e88aefb6e7fae90802e7c5e7d8e7b7ea22eebee82de7ebeaf4e7b9e8a400e7b4efb2020000"
  },
  {
   "jp_offset": "0x1e86",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "你这种人、大概想都没想过吧……",
   "zh_hex": "15e7b8e7b9e7d1efb202efa5ec76e7e6e840e7d8e7e6ef36e7d009090000"
  },
  {
   "jp_offset": "0x1eb8",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "西玛中佐……？",
   "zh_hex": "15e7f8e845ef4eefba0909050000"
  },
  {
   "jp_offset": "0x1ee7",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "哎……总算收拾妥了",
   "zh_hex": "15e9dc0909e881e889e926eae6ee05e7ba0000"
  },
  {
   "jp_offset": "0x1f20",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "可恶、还有后续追兵吗！！",
   "zh_hex": "15e7c4e7de02e7f7e7cbe7fee9ade8ddef93e802ef97ef970000"
  },
  {
   "jp_offset": "0x1f2d",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……西玛中佐",
   "zh_hex": "150909e7f8e845ef4eefba0000"
  },
  {
   "jp_offset": "0x1f51",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "啊、是啊……",
   "zh_hex": "15e7c302e7b6e7c309090000"
  },
  {
   "jp_offset": "0x1f5d",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "……战斗就到此为止！全员、撤退！",
   "zh_hex": "150909ef28e7ffe7c5e7d7e7cae7c1e869ef97efb4e84902e90ae880ef970000"
  },
  {
   "jp_offset": "0x1f96",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x1f9e",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "你说什么蠢话！要丢下敌人逃走吗！？",
   "zh_hex": "15e7b8e7ede7dde7bde94be81fef97ef2aebb0ef4de7e3efb2e8c2e890e802ef97050000"
  },
  {
   "jp_offset": "0x1fd4",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "我们这边的战力早就见底了！连到了极限{00}都看不出来吗！？",
   "zh_hex": "15efcce7bbe7b9e899e7b4ef28efb0e963e7c5e85ce9b4e7baef97e86ee7d7e7baeacaeb2300e840e7f6e7b5efbeefcfe802ef97050000"
  },
  {
   "jp_offset": "0x2010",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "战况或许确实不利、可只要我们拼尽全力{00}去打……",
   "zh_hex": "15ef28e8d0e905e8a7e88ce87fe7b5e82e02e7c4ef32ef2a8be7bbea66e8f2bbda00e7ebe7f509090000000000"
  },
  {
   "jp_offset": "0x2058",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "你这蠢货！那种打法、根本就是自杀行为{00}！",
   "zh_hex": "15e7b8e7b9e94beaf5ef97e7b7e7d1e7f5e84e02e9b8efa6e7c5e7b6efb5e89befd6e7c100ef970000"
  },
  {
   "jp_offset": "0x2070",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "西玛中佐的判断才是妥当的、全员、撤退{00}！",
   "zh_hex": "15e7f8e845ef4eefbae7b4eb29e982e836e7b6ee05ef53e7b402efb4e84902e90ae88000ef970000"
  },
  {
   "jp_offset": "0x20a3",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "强尼莱汀少佐！如此惜命、又有什么意义{00}！",
   "zh_hex": "15e8ade896e846ed7cefacefbaef97e7f0e7cae9c8e85302e8f1e7cbe7dde7bdef3ce8ce00ef970000"
  },
  {
   "jp_offset": "0x20bf",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "此刻后退、只会助敌扬名……！",
   "zh_hex": "15e7cae91fe7fee88002ef32e7e2ea23e7e3ebc6e8ac0909ef970000"
  },
  {
   "jp_offset": "0x2103",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "区区虚名、要多少尽管让给他们便是",
   "zh_hex": "15ef35ef35ebefe8ac02ef2ae7e9eface8f2e93be7f9e839e80ce7bbe8fae7b60000"
  },
  {
   "jp_offset": "0x2131",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "连松永大尉您也……！？",
   "zh_hex": "15e86ee9e0e9bfefa5efc6e835e7c00909ef97050000"
  },
  {
   "jp_offset": "0x2157",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "我们的目的已经达成、再战下去已无必要",
   "zh_hex": "15efcce7bbe7b4efd4e7b4ef3ae8b7ef2be83702e80bef28ef4de7ebef3ae7dce860ef2a0000"
  },
  {
   "jp_offset": "0x216f",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "卡多大尉、莫要把性命葬送错了地方",
   "zh_hex": "15e801e7e9efa5efc602eba0ef2ae81be951e853ee96e9bae885e7baef63efb10000"
  },
  {
   "jp_offset": "0x21aa",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "干得好、强尼莱汀少佐",
   "zh_hex": "15e8d3e80ae7c702e8ade896e846ed7cefacefba0000"
  },
  {
   "jp_offset": "0x21bd",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "这样一来、联邦军的进攻也会稍稍放缓了{00}吧",
   "zh_hex": "15e7b9e7daefb6efcf02ef2eefaae7e0e7b4e892ef67e7c0e7e2ead5ead5e86ceda4e7ba00e7d00000"
  },
  {
   "jp_offset": "0x21ed",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "万分感谢、阁下",
   "zh_hex": "15e9f8efaee87de8b202e8d7ef4d0000"
  },
  {
   "jp_offset": "0x2215",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "突击机动军将在阿·巴瓦·库会合、迎击{00}来犯的联邦军",
   "zh_hex": "15e8b6e7cce7e4ef30e7e0e84aef29e7d2ef4be85be99fef4be9b3e7e2efc002e931e7cc00efcfeb0ee7b4ef2eefaae7e00000"
  },
  {
   "jp_offset": "0x2238",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "我也乘格瓦金随后赶去",
   "zh_hex": "158be7c0ebb1e824e99fe902e9a1e7feea04e7eb000000"
  },
  {
   "jp_offset": "0x2246",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "与夏亚协力、支援友军……就拜托你了",
   "zh_hex": "15e832ef37e7d6e8f6da02e883e863e960e7e00909e7c5e91ae7f4e7b8e7ba00000000"
  },
  {
   "jp_offset": "0x227b",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……阁下",
   "zh_hex": "150909e8d7ef4d0000"
  },
  {
   "jp_offset": "0x228d",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "9a"
  },
  {
   "jp_offset": "0x228e",
   "jp_len": 34,
   "kind": "script",
   "zh_hex": "153302000106f0001358243302000106bc001300233302000115e86502e7f2e7bdef52efb8050000"
  },
  {
   "jp_offset": "0x22bb",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "85"
  },
  {
   "jp_offset": "0x22bc",
   "jp_len": 40,
   "kind": "script",
   "zh_hex": "1533020001066b0013582433020001062e001300233302000115e7e7e835efb1e8fa02e83ae81be978e861e839e8d7ef4d0000"
  },
  {
   "jp_offset": "0x22ff",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "这是……奖章？独角兽？",
   "zh_hex": "15e7b9e7b60909ec5ced9d05e8eeeb1aed23050000"
  },
  {
   "jp_offset": "0x2329",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "就当是代我、请收下这个",
   "zh_hex": "15e7c5ef53e7b6e8e7efcc02e83ae926ef4de7b9e8280000"
  },
  {
   "jp_offset": "0x235b",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "有你在我身边、我也安心多了",
   "zh_hex": "15e7cbe7b8ef29efcce88de89902efcce7c0e7fce82de7e9e7ba0000"
  },
  {
   "jp_offset": "0x2375",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "那我就心怀感激地收下了",
   "zh_hex": "15e7b7efcce7c5e82deb03e87de9b9ef63e926ef4de7ba0000"
  },
  {
   "jp_offset": "0x23bf",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……你看到了吗？",
   "zh_hex": "150909e7b8e7f6e7d7e7bae802050000"
  },
  {
   "jp_offset": "0x23e5",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "只是碰巧路过罢了",
   "zh_hex": "15ef32e7b6eb98ec13e8d2ef36eaefe7ba0000"
  },
  {
   "jp_offset": "0x23f1",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "话说、你还真不简单啊",
   "zh_hex": "15e81fe7ed02e7b8e7f7e820e7b5e9abe918e7c30000"
  },
  {
   "jp_offset": "0x240c",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "嘛、只要跟着基西莉亚少将、总能尝到些{00}甜头就是了……",
   "zh_hex": "15e93602ef32ef2ae973e86de829e7f8e81ee7d6eface84a02e881e7c6eccfe7d7e8a400ee6ce92ee7c5e7b6e7ba09090000"
  },
  {
   "jp_offset": "0x244a",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "……不是那样的、我是因为信任那位大人{00}、才追随至今的",
   "zh_hex": "150909e7b5e7b6e7b7e7dae7b402efcce7b6ef33e7c1e90fe89ae7b7e834efa5efb20002e836e8dde9a1e897efb9e7b40000"
  },
  {
   "jp_offset": "0x2469",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "我相信那位大人、对故乡的那份思念……",
   "zh_hex": "15efcce8b1e90fe7b7e834efa5efb202e7beea09eb4ce7b4e7b7ea22efcaea2709090000"
  },
  {
   "jp_offset": "0x2499",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……啊？",
   "zh_hex": "150909e7c3050000"
  },
  {
   "jp_offset": "0x2504",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "『吉翁公国、是我们的故乡……是我深爱{00}的祖国……』",
   "zh_hex": "150ce7d9ee88e9a4a102e7b68be7bbe7b4ea09eb4c0909e7b68beb0de8d500e7b4ebe1a109090d000000000000"
  },
  {
   "jp_offset": "0x2521",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "『让我们彼此携手、守护这片深爱的祖国{00}吧』",
   "zh_hex": "150ce7f9efcce7bbefc9e7caec1def6602e8a8e8e0e7b9ee5eeb0de8d5e7b4ebe1efc400e7d00d0000"
  },
  {
   "jp_offset": "0x2560",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "『我深爱着SIDE3』——这是当年基{00}西莉亚阁下说过的话",
   "zh_hex": "150cefcceb0de8d5e86def9eef62ef96ef9fef600debafebafe7b9e7b6ef53e909e82900e7f8e81ee7d6e8d7ef4de7edef36e7b4e81f0000"
  },
  {
   "jp_offset": "0x2580",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "正因为懂得那份心意、我才决意守护那位{00}大人",
   "zh_hex": "15ef3bef33e7c1e8b0e80ae7b7ea22e82def3c02efcce836e8abef3ce8a8e8e0e7b7e83400efa5efb20000"
  },
  {
   "jp_offset": "0x25ba",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "守护故乡……是吗！真是、好大的一通漂{00}亮话啊",
   "zh_hex": "15e8a8e8e0ea09eb4c0909e7b6e802ef97e820e7b602e7c7efa5e7b4efb6ef59ead000eaa2e81fe7c30000"
  },
  {
   "jp_offset": "0x25d6",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "那位高高在上的基西莉亚大人、背地里又{00}在干些什么……",
   "zh_hex": "15e7b7e834e812e812ef29ef4ce7b4e829e7f8e81ee7d6efa5efb202e9e4ef63ef31e8f100ef29e8d3e8a4e7dde7bd09090000"
  },
  {
   "jp_offset": "0x25f1",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "你、难道不知道吗？",
   "zh_hex": "15e7b802e866e82ae7b5e85ae82ae802050000"
  },
  {
   "jp_offset": "0x263e",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我们也一样、被人骂作恶名在外的西玛舰{00}队、",
   "zh_hex": "15efcce7bbe7c0efb6e7da02e7f1efb2eeccef2fe7dee8acef29e8f7e7b4e7f8e845e7d400e7c9020000"
  },
  {
   "jp_offset": "0x2658",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "可那说到底、也不过是上头硬塞给我们的{00}任务罢了",
   "zh_hex": "15e7c4e7b7e7ede7d7e9b402e7c0e7b5ef36e7b6ef4ce92eeb97e950e839efcce7bbe7b400e89ae94feaefe7ba0000"
  },
  {
   "jp_offset": "0x2673",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "身为突击机动军之首的阁下、不可能会不{00}知情吧……",
   "zh_hex": "15e88de7c1e8b6e7cce7e4ef30e7e0e7cdef40e7b4e8d7ef4d02e7b5e7c4e7c6e7e2e7b500e85ae88be7d009090000"
  },
  {
   "jp_offset": "0x26b1",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……我的……",
   "zh_hex": "1509098be7b409090000"
  },
  {
   "jp_offset": "0x26b9",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "……我座机上、画着的那个独角兽标志…{00}…",
   "zh_hex": "150909efccebc4e7e4ef4c02ecefe86de7b4e7b7e828e8eeeb1aed23e96fea180900090000"
  },
  {
   "jp_offset": "0x26d3",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "你可知道、那东西究竟意味着什么？",
   "zh_hex": "15e7b8e7c4e85ae82a02e7b7e8bae7f8e906ef2cef3ced36e86de7dde7bd050000"
  },
  {
   "jp_offset": "0x2704",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……啊？",
   "zh_hex": "150909e7c3050000"
  },
  {
   "jp_offset": "0x2727",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "据说独角兽、只会向纯洁的少女、托付真{00}心",
   "zh_hex": "15e8cce7ede8eeeb1aed2302ef32e7e2efc1eb66ee4fe7b4efacefad02e7f4e97ee82000e82d0000"
  },
  {
   "jp_offset": "0x2745",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "可一旦它托付真心的对象、不再纯洁了…{00}…",
   "zh_hex": "15e7c4efb6ebcde978e7f4e97ee820e82de7b4e7beebf202e7b5e80beb66ee4fe7ba0900090000"
  },
  {
   "jp_offset": "0x2789",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "强尼莱汀……你这家伙……？",
   "zh_hex": "15e8ade896e846ed7c0909e7b8e7b9e7dfe7fd0909050000"
  },
  {
   "jp_offset": "0x281c",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "夏亚大佐、您能平安无事真是太好了！",
   "zh_hex": "15ef37e7d6efa5efba02e835e7c6e887e7fce7dcefb8e820e7b6e86ae7c7e7baef970000"
  },
  {
   "jp_offset": "0x284b",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "那么、战况究竟如何啊、夏亚大佐？",
   "zh_hex": "15e7b7e7bd02ef28e8d0e906ef2ce7f0efbce7c302ef37e7d6efa5efba050000"
  },
  {
   "jp_offset": "0x2895",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "……嗯、总算是把木马给击退了",
   "zh_hex": "150909e86502e881e889e7b6e81befa9e84fe839e7cce880e7ba0000"
  },
  {
   "jp_offset": "0x28a8",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "但是……",
   "zh_hex": "15e7dbe7b609090000"
  },
  {
   "jp_offset": "0x28ca",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "拉拉·辛少尉、被那台高达击坠了",
   "zh_hex": "15e7c2e7c2ef4bea58efacefc602e7f1e7b7ea16e812ef2be7cceb53e7ba0000"
  },
  {
   "jp_offset": "0x28fe",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "那……实在是太令人遗憾了",
   "zh_hex": "15e7b70909e87fef29e7b6e86ae94eefb2eba9ed61e7ba0000"
  },
  {
   "jp_offset": "0x2936",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "我们这边、好歹也算击退了敌方舰队",
   "zh_hex": "15efcce7bbe7b9e89902e7c7ee46e7c0e889e7cce880e7bae7e3efb1e7d4e7c90000"
  },
  {
   "jp_offset": "0x294b",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "多亏了强尼莱汀少佐的奇美拉队、表现实{00}在出色",
   "zh_hex": "15e7e9eab7e7bae8ade896e846ed7cb1a3e7b4e904e9f4e7c2e7c902e9e7e82fe87f00ef29afe89f0000000000"
  },
  {
   "jp_offset": "0x298e",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……是吗",
   "zh_hex": "150909e7b6e8020000"
  },
  {
   "jp_offset": "0x29ed",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……什么？",
   "zh_hex": "150909e7dde7bd050000"
  },
  {
   "jp_offset": "0x2a11",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "夏亚大佐！格拉纳达发来紧急通讯！！",
   "zh_hex": "15ef37e7d6efa5efbaef97e824e7c2e882ef2be870efcfeaedea62ef59eb1bef97ef970000"
  },
  {
   "jp_offset": "0x2a3f",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……你说核弹！？",
   "zh_hex": "150909e7b8e7ede8f3e946ef97050000"
  },
  {
   "jp_offset": "0x2a65",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……没错",
   "zh_hex": "150909e7d8e8850000"
  },
  {
   "jp_offset": "0x2a6d",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "参谋部的基林中佐、从格拉纳达带走了核{00}导弹",
   "zh_hex": "15ed1aea6ecce7b4e829e9b7c0a302e88ae824e7c2e882ef2be937e890e7bae8f300ea4be9460000000000"
  },
  {
   "jp_offset": "0x2a87",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "似乎是朝SIDE6方向去了",
   "zh_hex": "15e944e933e7b6eaadef9eef62ef96ef9fe9cdefb1efc1e7ebe7ba0000"
  },
  {
   "jp_offset": "0x2ab2",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "SIDE6？那家伙、究竟又是为了什么{00}……",
   "zh_hex": "15ef9eef62ef96ef9fe9cd05e7b7e7dfe7fd02e906ef2ce8f1e7b6e7c1e7bae7dde7bd0009090000"
  },
  {
   "jp_offset": "0x2ae3",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "联邦军似乎正在SIDE6、秘密研发一{00}台高达",
   "zh_hex": "15ef2eefaae7e0e944e933ef3bef29ef9eef62ef96ef9fe9cd02ecf5e9bdea0ce870efb600ea16e812ef2b0000"
  },
  {
   "jp_offset": "0x2b1e",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "对付一台高达居然用核弹？这是哪来的蠢{00}货干的好事？",
   "zh_hex": "15e7bee97eefb6ea16e812ef2bea4ce7efefb3e8f3e94605e7b9e7b6e8ffefcfe7b4e94b00eaf5e8d3e7b4e7c7efb8050000"
  },
  {
   "jp_offset": "0x2b56",
   "jp_len": 32,
   "kind": "dialogue",
   "zh_text": "向中立地带发动核打击、这可不像神志清{00}醒的军人会做的事",
   "zh_hex": "159dc0e86bbfe937e870ef30e8f3e7f5e7cc02e7b9e7c4e7b5e8e9e9aaea18e99500eb20e7b4e7e0b4e7e2e81ce7b4a900000000000000"
  },
  {
   "jp_offset": "0x2b91",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "基林中佐的鲁莽行径、无论如何都必须阻{00}止",
   "zh_hex": "15e829e9b7ef4eefbae7b4e8a2edb2efd6ecd302e7dce8dce7f0efbce840e860e9a2e8ef00e8690000"
  },
  {
   "jp_offset": "0x2bad",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "我们这就去追击基林中佐的舰队！",
   "zh_hex": "15efcce7bbe7b9e7c5e7ebe8dde7cce829e9b7ef4eefbae7b4e7d4e7c9ef970000"
  },
  {
   "jp_offset": "0x2bd7",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "再过不久、就要抵达阿·巴瓦·库了",
   "zh_hex": "15e80bef36e7b5e9db02e7c5ef2ae96eef2be7d2ef4be85be99fef4be9b3e7ba0000"
  },
  {
   "jp_offset": "0x2c38",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "拉拉少尉的事、那个……实在是太遗憾了{00}……",
   "zh_hex": "15e7c2e7c2efacefc6e7b4efb802e7b7e8280909e87fef29e7b6e86aeba9ed61e7ba0009090000"
  },
  {
   "jp_offset": "0x2c7b",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "拉拉之死……根源在于我的力量不足……",
   "zh_hex": "15e7c2e7c2e7cda70909e9b8ebd6ef29e8798be7b4dae851e7b5ea1e09090000000000"
  },
  {
   "jp_offset": "0x2cb4",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "阿·巴瓦·库一战、恐怕会演变成一场恶{00}战吧",
   "zh_hex": "15e7d2ef4be85be99fef4be9b3efb6ef2802eb33e958e7e2ea2fe955e837efb6e876e7de00ef28e7d00000"
  },
  {
   "jp_offset": "0x2cfa",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……中佐？",
   "zh_hex": "150909ef4eefba050000"
  },
  {
   "jp_offset": "0x2d1d",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "……可即便是恶战、也不愿有一人战死",
   "zh_hex": "150909e7c4e855e8fae7b6e7deef2802e7c0e7b5e961e7cbefb6efb2ef28ef6a0000"
  },
  {
   "jp_offset": "0x2d3c",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "我是这么想的",
   "zh_hex": "15efcce7b6e7b9e7bde7e6e7b40000"
  },
  {
   "jp_offset": "0x2d70",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "与其哀叹死者、莫如顾念活人……",
   "zh_hex": "15e832e8cfecbeedf1ef6aef6e02eba0e7f0ea1fea27e8d4efb209090000"
  },
  {
   "jp_offset": "0x2d93",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "抱歉、中佐、看来让你担心了",
   "zh_hex": "15e922e92702ef4eefba02e7f6efcfe7f9e7b8e9fde82de7ba0000"
  },
  {
   "jp_offset": "0x2dcd",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "是我多管闲事了吗？",
   "zh_hex": "15e7b6efcce7e9e93beebeefb8e7bae802050000"
  },
  {
   "jp_offset": "0x2dd8",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "不过、大佐您身为指挥官、还是得请您打{00}起精神来",
   "zh_hex": "15e7b5ef3602bea3e835e88de7c1e8c0e9498f02e7f7e7b6e80ae83ae835e7f500e847e98de9aad9000000000000"
  },
  {
   "jp_offset": "0x2e10",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "……是啊、先看向下一战吧",
   "zh_hex": "150909e7b6e7c302ef8be7f6efc1ef4defb6ef28e7d00000"
  },
  {
   "jp_offset": "0x2e2d",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "看向阿·巴瓦·库的那一战……！",
   "zh_hex": "15e7f69de7d204e85be99f04e9b3e7b4e7b787ef2809090600000000000000"
  },
  {
   "jp_offset": "0x7b3a",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "拉拉·辛、就这样死了吗……",
   "zh_hex": "15e7c2e7c2ef4bea5802e7c5e7b9e7daef6ae7bae80209090000"
  },
  {
   "jp_offset": "0x7b64",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "似乎是被一台名为高达的MS给击破的",
   "zh_hex": "15e944e933e7b6e7f1efb6ea16e8ace7c1e812ef2be7b4efa7ef9ee839e7ccef6de7b40000"
  },
  {
   "jp_offset": "0x7b9a",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……也罢、这也是无可奈何的事",
   "zh_hex": "150909e7c0eaef02e7b9e7c0e7b6e7dce7c4eb2fefbce7b4efb80000"
  },
  {
   "jp_offset": "0x7ba8",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "毕竟她可是个觉醒程度相当高的新人类啊",
   "zh_hex": "15ea2cef2ce88ee7c4e7b6e828e8aeeb20ea7de96de8b1ef53e812e7b4ef8aefb2e841e7c30000"
  },
  {
   "jp_offset": "0x7bc4",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "当然、拉拉·辛的数据、都保留下来了吧{00}？",
   "zh_hex": "15ef53e7ef02e7c2e7c2ef4bea58e7b4e914e8cc02e840ea47e98cef4defcfe7bae7d000050000"
  },
  {
   "jp_offset": "0x7bfb",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……是",
   "zh_hex": "150909e7b60000"
  },
  {
   "jp_offset": "0x7c1d",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "那就没问题了",
   "zh_hex": "15e7b7e7c5e7d8e997ea12e7ba0000"
  },
  {
   "jp_offset": "0x7c2c",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "趁现在、把数据导入那批试作品里",
   "zh_hex": "15e9eae82fef2902e81be914e8ccea4be891e7b7ed63e91def2feae1ef310000"
  },
  {
   "jp_offset": "0x7c63",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "要导入全部试作体吗？",
   "zh_hex": "15ef2aea4be891efb4ef70e91def2fef4fe802050000"
  },
  {
   "jp_offset": "0x7c8b",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "尽可能全部导入",
   "zh_hex": "15e8f2e7c4e7c6efb4ef70ea4be8910000"
  },
  {
   "jp_offset": "0x7c98",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "既然联邦的进攻已迫在眼前、就必须尽快{00}推进战力化",
   "zh_hex": "15e8c4e7efef2ed1e7b4e8929eef3aeb70ef29e90bba02e7c5e860e9a2e8f2e85f00eaabe892ef28dae9a5000000000000"
  },
  {
   "jp_offset": "0x7cd5",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "明白了",
   "zh_hex": "15ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x7cdc",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "我会着手推进A号到D号的再调整",
   "zh_hex": "158be7e2e86daeeaabe892ea9ce833e7d711e833e7b4e80be95ce9fe000000000000"
  },
  {
   "jp_offset": "0x7d0e",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "听说MS已经全部出动了、夏亚？",
   "zh_hex": "15e8d1e7edefa7ef9eef3ae8b7efb4ef70efbeef30e7ba02ef37e7d6050000"
  },
  {
   "jp_offset": "0x7d3f",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "是……",
   "zh_hex": "15e7b609090000"
  },
  {
   "jp_offset": "0x7d46",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我本想换装成新型的勇士……可是……",
   "zh_hex": "158bd2e7e6ea78e98fe837ef8ae977e7b4eadda50909e7c4e7b609090000000000"
  },
  {
   "jp_offset": "0x7d62",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "据说已全部配发完毕、没有能轮到我用的{00}了",
   "zh_hex": "15e8cce7edef3aefb4ef70ea34e870e87eea2c02e7d8e7cbe7c6ebf4e7d7efccefb3e7b400e7ba0000"
  },
  {
   "jp_offset": "0x7d9e",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "那、要不试试吉翁号？虽说似乎只完成了{00}八成……",
   "zh_hex": "15e7b702ef2ae7b5e91de91de7d9ee88e83305e8b8e7ede944e933ef32e87ee837e7ba00ecafe83709090000"
  },
  {
   "jp_offset": "0x7de0",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……吉翁号？",
   "zh_hex": "150909e7d9ee88e833050000"
  },
  {
   "jp_offset": "0x7e04",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "这是一台搭载了艾尔美斯精神感应装置的{00}MS、以你的本事、想必能运用自如",
   "zh_hex": "15e7b9e7b687ea16eb09eb1de7bae8d6e7e1e9f4e7c8e98de9aae87de873e98fea0ee7b400131402e7f3e7b8e7b4d2a902e7e6e860e7c6e986d8abe7f0000000000000000000"
  },
  {
   "jp_offset": "0x7e3b",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……明白了",
   "zh_hex": "150909ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x7f8a",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "这位便是身为指挥官的赤色彗星……夏亚{00}·阿兹纳布尔阁下吧",
   "zh_hex": "15e7b9e834e8fae7b6e88de7c1e8c0e9498fe7b4e9e9e89fe9b6b50909ef37e7d60004e7d2e856e882e831e7e1e8d789e7d0000000000000"
  },
  {
   "jp_offset": "0x7fa7",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "我乃松永真大尉、特来助贵军一臂之力！",
   "zh_hex": "15efccefdde9e0e9bfe820efa5efc602e7cfefcfea23e930e7e0efb6ee92e7cdefb0ef970000"
  },
  {
   "jp_offset": "0x7fda",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "哦！所罗门白狼的大名、我也是有所耳闻{00}的！",
   "zh_hex": "15e919ef97e7fbe7ece90ce809ec7be7b4efa5e8ac02efcce7c0e7b6e7cbe7fbee89ebac00e7b4ef970000"
  },
  {
   "jp_offset": "0x7ff4",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "有你来帮忙、那可真是如虎添翼啊……",
   "zh_hex": "15e7cbe7b8efcfe910ea0602e7b7e7c4e820e7b6e7f0ec91ebd5ec35e7c309090000"
  },
  {
   "jp_offset": "0x800f",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯？",
   "zh_hex": "150909e865050000"
  },
  {
   "jp_offset": "0x8016",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "喂、给我等一下！！",
   "zh_hex": "15e8bd02e839efcce826efb6ef4def97ef970000"
  },
  {
   "jp_offset": "0x803d",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "唔、您这是怎么了？赤色彗星？",
   "zh_hex": "15e81d02e835e7b9e7b6e7f2e7bde7ba05e9e9e89fe9b6b505000000"
  },
  {
   "jp_offset": "0x806b",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "不是彗星啊——！！",
   "zh_hex": "15e7b5e7b6e9b6ef69e7c3ebafebafef97ef970000"
  },
  {
   "jp_offset": "0x807a",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "是闪电、是闪电啊！！是真红闪电！",
   "zh_hex": "15e7b6ea44ead302e7b6ea44ead3e7c3ef97ef97e7b6e820e9e3ea44ead3ef970000"
  },
  {
   "jp_offset": "0x80a8",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "哦哦、原来如此！原来不是赤色彗星、而{00}是真红闪电啊",
   "zh_hex": "15e919e91902e8e4d9e7f0e7ca06e8e4d9e7b5e7b6e9e9e89fe9b6b502e89c00e7b6e820e9e3ea44ead3e7c3000000000000"
  },
  {
   "jp_offset": "0x80c6",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "失礼了、夏亚·阿兹纳布尔阁下",
   "zh_hex": "15e8a5eb65e7ba02ef37e7d6ef4be7d2e856e882e831e7e1e8d7ef4d0000"
  },
  {
   "jp_offset": "0x811e",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "没想到所罗门的白狼、竟肯特意赶来助阵{00}……",
   "zh_hex": "15e7d8e7e6e7d7e7fbe7ece90ce7b4e809ec7b02ef2ce93de7cfef3cea04efcfea23eb480009090000"
  },
  {
   "jp_offset": "0x8137",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我是奇美拉队的强尼莱汀少佐、多谢相助{00}！",
   "zh_hex": "15efcce7b6e904e9f4e7c2e7c9e7b4e8ade896e846ed7cefacefba02e7e9e8b2e8b1ea2300ef970000"
  },
  {
   "jp_offset": "0x81a6",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "准备都妥当了吗？",
   "zh_hex": "15e87ae877e840ee05ef53e7bae802050000"
  },
  {
   "jp_offset": "0x81ce",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "是、大德金号随时可以出港",
   "zh_hex": "15e7b602efa5e82ce902e833e9a1ef2de7c4e7f3efbeeb3b0000"
  },
  {
   "jp_offset": "0x81fe",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "嗯……那么、就拜托了",
   "zh_hex": "15e8650909e7b7e7bd02e7c5e91ae7f4e7ba0000"
  },
  {
   "jp_offset": "0x826b",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "大德金号、即将出港",
   "zh_hex": "15efa5e82ce902e83302e855e84aefbeeb3b0000"
  },
  {
   "jp_offset": "0x82df",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "基连……",
   "zh_hex": "15e829e86e09090000"
  },
  {
   "jp_offset": "0x82e6",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "你究竟想将吉翁公国、带往何方？",
   "zh_hex": "15e7b8e906ef2ce7e6e84ae7d9ee88e9a4a102e937e9118ad0050000000000"
  },
  {
   "jp_offset": "0x8300",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "战争再这样持续下去、吉翁公国本身都会{00}……",
   "zh_hex": "15ef28e852e80be7b9e7dae9efe9ad89e7eb02e7d9ee88e9a4a1d2e88de840e7e20009090000000000"
  },
  {
   "jp_offset": "0x833a",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "哼……是大德金号啊",
   "zh_hex": "15e8b30909e7b6efa5e82ce902e833e7c30000"
  },
  {
   "jp_offset": "0x8349",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "您也老了啊、父亲",
   "zh_hex": "15e835e7c0e9cae7bae7c302e888e8940000"
  },
  {
   "jp_offset": "0x8353",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "事到如今才来谈和、早已为时已晚了……",
   "zh_hex": "15efb8e7d7e7f0efb9e836efcfeaf4e7d302e963ef3ae7c1ef2def3aea69e7ba09090000"
  },
  {
   "jp_offset": "0x8389",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "怎么办、总帅？",
   "zh_hex": "15e7f2e7bde8ea02e881e9a6050000"
  },
  {
   "jp_offset": "0x83b3",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "太阳射线已经准备就绪……不必管他",
   "zh_hex": "15e86aeb72ace916ef3ae8b7e87ae877e7c5efee0909e7b5e860e93be80c00000000"
  },
  {
   "jp_offset": "0x83cd",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "比起那个、先稳住国内才是当务之急",
   "zh_hex": "15e825e847e7b7e82802b8eb3ee859a1e99ae836e7b6c4e94fe7cdea620000000000"
  },
  {
   "jp_offset": "0x83fd",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "是……属下会妥善处理",
   "zh_hex": "15e7b60909ea24ef4de7e2ee05ed3ae903e8720000"
  },
  {
   "jp_offset": "0x8426",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……松永真大尉",
   "zh_hex": "150909e9e0e9bfe820efa5efc60000"
  },
  {
   "jp_offset": "0x8432",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "还请您随我们同行一程",
   "zh_hex": "15e7f7e83ae835e9a1efcce7bbe85defd6efb6ea7d0000"
  },
  {
   "jp_offset": "0x845c",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……你们这些家伙、是什么人？",
   "zh_hex": "150909e7b8e7bbe7b9e8a4e7dfe7fd02e7b6e7dde7bdefb2050000"
  },
  {
   "jp_offset": "0x8485",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "基连总帅、应该早已向贵官下达了召回命{00}令",
   "zh_hex": "15e829e86ee881e9a602e873e898e963ef3aefc1e930ef92ef4def2be7baecbdef52e85300e94e0000"
  },
  {
   "jp_offset": "0x849f",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "只要乖乖随我们走、便不会伤你分毫",
   "zh_hex": "15ef32ef2ae9a3e9a3e9a1efcce7bbe89002e8fae7b5e7e2e8f9e7b8efaeea0a0000"
  },
  {
   "jp_offset": "0x84b6",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "来吧、松永大尉",
   "zh_hex": "15efcfe7d002e9e0e9bfefa5efc60000"
  },
  {
   "jp_offset": "0x9422",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "阿·巴瓦·库吗……这一仗、看来会是场{00}恶战",
   "zh_hex": "15e7d2ef4be85be99fef4be9b3e8020909e7b9efb6ea3702e7f6efcfe7e2e7b6e87600e7deef280000"
  },
  {
   "jp_offset": "0x9458",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "啊、是啊……",
   "zh_hex": "15e7c302e7b6e7c309090000"
  },
  {
   "jp_offset": "0x9488",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……怎么了、西格？",
   "zh_hex": "150909e7f2e7bde7ba02e7f8e824050000"
  },
  {
   "jp_offset": "0x94af",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……瑟拉",
   "zh_hex": "150909e8aae7c20000"
  },
  {
   "jp_offset": "0x94d1",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "怎么？这么一脸认真？",
   "zh_hex": "15e7f2e7bd05e7b9e7bdefb6eb69e8a0e820050000"
  },
  {
   "jp_offset": "0x950c",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "我是认真的、瑟拉",
   "zh_hex": "15efcce7b6e8a0e820e7b402e8aae7c20000"
  },
  {
   "jp_offset": "0x9518",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "啊……等下一仗打完之后……",
   "zh_hex": "15e7c30909e826ef4defb6ea37e7f5e87ee7cde7fe09090000"
  },
  {
   "jp_offset": "0x9548",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "之后……？",
   "zh_hex": "15e7cde7fe090905000000"
  },
  {
   "jp_offset": "0x956e",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "不、那个……",
   "zh_hex": "15e7b502e7b7e82809090000"
  },
  {
   "jp_offset": "0x957a",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……算了吧",
   "zh_hex": "150909e889e7bae7d0000000"
  },
  {
   "jp_offset": "0x95a8",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "真是怪家伙",
   "zh_hex": "15e820e7b6ea07e7dfe7fd0000"
  },
  {
   "jp_offset": "0x95fd",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "瑟拉……果然、你……",
   "zh_hex": "15e8aae7c20909e871e7ef02e7b809090000"
  },
  {
   "jp_offset": "0x9626",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "哼……哼哈哈哈……！",
   "zh_hex": "15e8b30909e8b3e7e8e7e8e7e80909ef970000"
  },
  {
   "jp_offset": "0x9633",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "终于完成了！我的孩子、格罗姆林！！",
   "zh_hex": "15e8e2e879e87ee837e7baef97efcce7b4e956e88602e824e7ece823e9b7ef97ef970000"
  },
  {
   "jp_offset": "0x9696",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "怎么了、爱娜？你不愿替我感到高兴吗？",
   "zh_hex": "15e7f2e7bde7ba02e8d5e7ea05e7b8e7b5e961ea50efcce87de7d7e812eabae802050000"
  },
  {
   "jp_offset": "0x96f9",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "哼……",
   "zh_hex": "15e8b309090000"
  },
  {
   "jp_offset": "0x9700",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "那个男人……好像是叫士郎来着……",
   "zh_hex": "15e7b7e828ea95efb20909e7c7e8e9e7b6e8c1ef64eb1fefcfe86d09090000"
  },
  {
   "jp_offset": "0x972f",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x9752",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "听士兵说、你俩似乎很亲密",
   "zh_hex": "15e8d1ef64ef93e7ed02e7b8eb7be944e933e981e894e9bd0000"
  },
  {
   "jp_offset": "0x976d",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "简直像个恋爱少女……",
   "zh_hex": "15e9abe875e8e9e828ee20e8d5efacefad09090000"
  },
  {
   "jp_offset": "0x979d",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我们……只是为了活下去、才彼此协作罢{00}了",
   "zh_hex": "15efcce7bb0909ef32e7b6e7c1e7bae8d4ef4de7eb02e836efc9e7cae8f6ef2feaef00e7ba0000"
  },
  {
   "jp_offset": "0x97d2",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "协作吗……和敌方的士兵？",
   "zh_hex": "15e8f6ef2fe8020909e7d3e7e3efb1e7b4ef64ef93050000"
  },
  {
   "jp_offset": "0x9806",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "纵然……",
   "zh_hex": "15e8e6e7ef09090000"
  },
  {
   "jp_offset": "0x9828",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯？",
   "zh_hex": "150909e865050000"
  },
  {
   "jp_offset": "0x984a",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "即便敌我两分、也会有好人！",
   "zh_hex": "15e855e8fae7e3efcce97defae02e7c0e7e2e7cbe7c7efb2ef970000"
  },
  {
   "jp_offset": "0x9868",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "甚至能彼此理解……！",
   "zh_hex": "15eceee897e7c6efc9e7cae872e89d0909ef970000"
  },
  {
   "jp_offset": "0x9892",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "呵……彼此理解？",
   "zh_hex": "15ef3d0909c9e7cae872e89d050000"
  },
  {
   "jp_offset": "0x98bc",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "哥哥难道您不懂吗！？那正是、这……",
   "zh_hex": "15e9bce9bce866e82ae835e7b5e8b0e8020605e7b7ef3be7b602e7b90909000000"
  },
  {
   "jp_offset": "0x98da",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "正是这场愚蠢战争中、唯一的一丝希望…{00}…",
   "zh_hex": "15ef3be7b6e7b9e876e959e94bef28e852ef4e02ea89efb6e7b4efb6e8a3e87be9650900090000"
  },
  {
   "jp_offset": "0x990c",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "哼……希望吗、真是无聊的废话",
   "zh_hex": "15e8b30909e87be965e80202e820e7b6e7dcec36e7b4eae5e81f0000"
  },
  {
   "jp_offset": "0x9981",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "哥哥……！？",
   "zh_hex": "15e9bce9bc0909ef97050000"
  },
  {
   "jp_offset": "0x9996",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "究竟从何时起……",
   "zh_hex": "15e906ef2ce88aefbcef2de84709090000"
  },
  {
   "jp_offset": "0x999f",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "我们究竟是从何时起、变得连话都说不通{00}了呢……",
   "zh_hex": "15efcce7bbe906ef2ce7b6e88aefbcef2de84702e955e80ae86ee81fe840e7ede7b5ef5900e7bae90709090000"
  }
 ]
}
