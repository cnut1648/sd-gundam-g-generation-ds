{
 "file": "_STG04A.bin",
 "source_size": 43612,
 "built_size": 45454,
 "edits": [
  {
   "jp_offset": "0x12a1",
   "jp_len": 54,
   "kind": "dialogue",
   "zh_text": "あいうえおかダチッツテ{01}デ、トドナ{00}·{00}！グ{00}M通せな、{00}{01}！せ{00}Mデずな、{00}{01}ぁ看见了……是木马！",
   "zh_hex": "15161718191a1b6566676869016a026b6c6d000400065b001330243302000106270013d8223302000115e7f6e85ce7ba0909e7b6efa9e84fef970000"
  },
  {
   "jp_offset": "0x12f2",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "看来其他部队也都一同随行了呢",
   "zh_hex": "15e7f6efcfe8cfe80cef70e7c9e7c0e840efb6e85de9a1efd6e7bae9070000"
  },
  {
   "jp_offset": "0x132b",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "首先、由我和拉拉率先突入、扰乱敌军阵{00}形",
   "zh_hex": "15ef40ef8b02e8a6efcce7d3e7c2e7c2e9e1ef8be8b6e89102ebc7e976e7e3e7e0eb4800ec670000"
  },
  {
   "jp_offset": "0x1345",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……上吧、拉拉",
   "zh_hex": "150909ef4ce7d002e7c2e7c20000"
  },
  {
   "jp_offset": "0x1375",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "是、大佐",
   "zh_hex": "15e7b602efa5efba0000"
  },
  {
   "jp_offset": "0x13a2",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……是敌人吗！！",
   "zh_hex": "150909e7b6e7e3efb2e802ef97ef970000"
  },
  {
   "jp_offset": "0x13ab",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "阿姆罗、拜托了！",
   "zh_hex": "15e7d2e823e7ec02e91ae7f4e7baef970000"
  },
  {
   "jp_offset": "0x13d0",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "好的、布莱特先生！",
   "zh_hex": "15e7c7e7b402e831e846e7cfb8b6060000000000"
  },
  {
   "jp_offset": "0x1400",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "高达……来了吗！！",
   "zh_hex": "15e812ef2b0909efcfe7bae802ef97ef970000"
  },
  {
   "jp_offset": "0x1425",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "先突破那家伙！跟上我、拉拉！！",
   "zh_hex": "15ef8be8b6ef6de7b7e7dfe7fdef97e973ef4cefcc02e7c2e7c2ef97ef970000"
  },
  {
   "jp_offset": "0x145b",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……是！",
   "zh_hex": "150909e7b6ef970000"
  },
  {
   "jp_offset": "0x1488",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "唔……！",
   "zh_hex": "15e81d0909ef970000"
  },
  {
   "jp_offset": "0x14b7",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……大佐！？",
   "zh_hex": "150909efa5efbaef97050000"
  },
  {
   "jp_offset": "0x14ef",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "啊啊……！不、不会、大佐他……",
   "zh_hex": "15e7c3e7c30909ef97e7b502e7b5e7e202efa5efbae80c09090000"
  },
  {
   "jp_offset": "0x1567",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "这种感觉……是拉拉吗！？",
   "zh_hex": "15e7b9e7d1e87de8ae0909e7b6e7c2e7c2e802ef97050000"
  },
  {
   "jp_offset": "0x15a4",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "拉拉！是你吗！？",
   "zh_hex": "15e7c2e7c2ef97e7b6e7b8e802ef97050000"
  },
  {
   "jp_offset": "0x15e0",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "你的力量、实在太强了……",
   "zh_hex": "15e7b8e7b4dae85102e87fef29e86ae8ade7ba0909000000"
  },
  {
   "jp_offset": "0x15fa",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "我若不打倒你……夏亚就会死！",
   "zh_hex": "15efcce7e7e7b5e7f5e848e7b80909ef37e7d6e7c5e7e2ef6aef970000"
  },
  {
   "jp_offset": "0x1632",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "夏亚他！？",
   "zh_hex": "15ef37e7d6e80cef97050000"
  },
  {
   "jp_offset": "0x1668",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "啊啊……！？",
   "zh_hex": "15e7c3e7c30909ef97050000"
  },
  {
   "jp_offset": "0x1696",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……拉拉！",
   "zh_hex": "150909e7c2e7c2ef970000"
  },
  {
   "jp_offset": "0x16da",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "大佐……我……看得见时间了……",
   "zh_hex": "15efa5efba0909efcc0909e7f6e80ae85cef2de8fce7ba09090000"
  },
  {
   "jp_offset": "0x1723",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "啊……拉、拉拉……？",
   "zh_hex": "15e7c30909e7c202e7c2e7c20909050000"
  },
  {
   "jp_offset": "0x1731",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "怎么会……",
   "zh_hex": "15e7f2e7bde7e209090000"
  },
  {
   "jp_offset": "0x175d",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "怎……怎会如此……",
   "zh_hex": "15e7f20909e7f2e7e2e7f0e7ca09090000"
  },
  {
   "jp_offset": "0x176d",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "拉拉她……",
   "zh_hex": "15e7c2e7c2e88e09090000"
  },
  {
   "jp_offset": "0x179a",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……阿姆罗少尉！",
   "zh_hex": "150909e7d2e823e7ecefacefc6ef970000"
  },
  {
   "jp_offset": "0x17c9",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "您把赤色彗星逼入了绝境！真不愧是新人{00}类！",
   "zh_hex": "15e835e81be9e9e89fe9b6b5ebf6e891e7bae91ceb8106e820e7b5ea08e7b6ef8ab400e84106000000000000"
  },
  {
   "jp_offset": "0x1800",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "啊……？",
   "zh_hex": "15e7c30909050000"
  },
  {
   "jp_offset": "0x1822",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "敌方舰队正逼近本队！",
   "zh_hex": "15e7e3efb1e7d4e7c9ef3bebf6efd8efa6e7c9ef970000"
  },
  {
   "jp_offset": "0x1834",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "余下的就交给我们、少尉去守住本队！！",
   "zh_hex": "15eb27ef4de7b4e7c5e861e839efcce7bb02efacefc6e7ebe8a8e859efa6e7c9ef97ef970000"
  },
  {
   "jp_offset": "0x1867",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "我、我知道了……",
   "zh_hex": "158b028be85ae82ae7ba090900000000"
  },
  {
   "jp_offset": "0x18b1",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "拉、拉拉……我……",
   "zh_hex": "15e7c202e7c2e7c20909efcc09090000"
  },
  {
   "jp_offset": "0x18bf",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "我到底该怎么办……",
   "zh_hex": "15efcce7d7e9b4e898e7f2e7bde8ea09090000"
  },
  {
   "jp_offset": "0x18f0",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "怎么回事？竟然毫无反应？",
   "zh_hex": "15e7f2e7bdef52efb805ef2ce7efea0ae7dce87ce873050000"
  },
  {
   "jp_offset": "0x191c",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "是驱动系统被打坏了吗、好、趁现在……",
   "zh_hex": "15e7b6ebffef30e941e929e7f1e7f5e9ede7bae80202e7c702e9eae82fef2909090000"
  },
  {
   "jp_offset": "0x195c",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……唔哦！？",
   "zh_hex": "150909e81de919ef97050000"
  },
  {
   "jp_offset": "0x19a6",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……大佐！",
   "zh_hex": "150909efa5efbaef970000"
  },
  {
   "jp_offset": "0x19c2",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x1a00",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "夏亚大佐！我是来救您的！！",
   "zh_hex": "15ef37e7d6bea3068be7b6d9e8cae835e7b406060000000000000000000000"
  },
  {
   "jp_offset": "0x1a26",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "（不对……！？不是拉拉……！？）",
   "zh_hex": "15ef8ee7b5e7be0909ef9705e7b5e7b6e7c2e7c20909ef9705ef8f0000"
  },
  {
   "jp_offset": "0x1a3e",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "你、你是……",
   "zh_hex": "15e7b802e7b8e7b609090000"
  },
  {
   "jp_offset": "0x1a7c",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "哈曼！我是哈曼·卡恩！",
   "zh_hex": "15e7e8e874ef97efcce7b6e7e8e874ef4be801e7eeef970000"
  },
  {
   "jp_offset": "0x1aa5",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "夏亚大佐！！",
   "zh_hex": "15ef37e7d6efa5efbaef97ef970000"
  },
  {
   "jp_offset": "0x1ac9",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "看来让你担心了……抱歉",
   "zh_hex": "15e7f6efcfe7f9e7b8e9fde82de7ba0909e922e9270000"
  },
  {
   "jp_offset": "0x1add",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "可是、拉拉她……",
   "zh_hex": "15e7c4e7b602e7c2e7c2e88e09090000"
  },
  {
   "jp_offset": "0x1b03",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……真是件憾事",
   "zh_hex": "150909e820e7b6e991ed61efb80000"
  },
  {
   "jp_offset": "0x1b0f",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "……话说回来、那台白色的MA是……",
   "zh_hex": "150909e81fe7ed8cd902e7b7ea16e809e89fe7b413ea9ce7b609090000000000"
  },
  {
   "jp_offset": "0x1b3e",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "她是哈曼·卡恩、马哈拉贾·卡恩提督的{00}千金",
   "zh_hex": "15e88ee7b6e7e8e874ef4be801e7ee02e84fe7e8e7c2e9e8ef4be801e7eee821ea1be7b400eafde9020000"
  },
  {
   "jp_offset": "0x1b59",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "在危急关头、是她救了我",
   "zh_hex": "15ef29e935ea62e8bbe92e02e7b6e88ee8cae7baefcc0000"
  },
  {
   "jp_offset": "0x1b6a",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "……哈曼·卡恩、我们接下来要与木马交{00}战",
   "zh_hex": "150909e7e8e874ef4be801e7ee02efcce7bbefceef4defcfef2ae832efa9e84fe86100ef280000"
  },
  {
   "jp_offset": "0x1b84",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "能帮个忙吗？",
   "zh_hex": "15e7c6e910e828ea06e802050000"
  },
  {
   "jp_offset": "0x1bb3",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "遵命、大佐！！",
   "zh_hex": "15ec40e85302efa5efbaef97ef970000"
  },
  {
   "jp_offset": "0x1bdb",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "好！全舰、进入攻击态势！",
   "zh_hex": "15e7c7ef97efb4e7d402e892e891ef67e7cce994e8fdef970000"
  },
  {
   "jp_offset": "0x1c15",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "不妙……！？",
   "zh_hex": "15e7b5ecc70909ef97050000"
  },
  {
   "jp_offset": "0x1c4f",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……趁现在！",
   "zh_hex": "150909e9eae82fef29ef970000"
  },
  {
   "jp_offset": "0x1cb0",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "我……",
   "zh_hex": "15efcc09090000"
  },
  {
   "jp_offset": "0x1cb8",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "我做了无法挽回的事……",
   "zh_hex": "15efcce81ce7bae7dce84eee2eef52e7b4efb809090000"
  },
  {
   "jp_offset": "0x1ccf",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "我……竟把拉拉……给杀了！！",
   "zh_hex": "15efcc0909ef2ce81be7c2e7c20909e839e89be7baef97ef970000"
  },
  {
   "jp_offset": "0x1d11",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "高达！",
   "zh_hex": "15e812ef2bef970000"
  },
  {
   "jp_offset": "0x1d35",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "是夏亚吗！？可是……！",
   "zh_hex": "15e7b6ef37e7d6e802ef9705e7c4e7b60909ef970000"
  },
  {
   "jp_offset": "0x1d69",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "卡斯巴尔哥哥！",
   "zh_hex": "15e801e7c8e85be7e1e9bce9bcef970000"
  },
  {
   "jp_offset": "0x1d8e",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "阿尔黛西亚！？",
   "zh_hex": "15e7d2e7e1ea9ae7f8e7d6ef97050000"
  },
  {
   "jp_offset": "0x1db0",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "哥哥、你已经着魔了！竟曲解了父亲的遗{00}愿……！",
   "zh_hex": "15e9bce9bc02e7b8ef3ae8b7e86de8d8e7baef97ef2cece2e89de7bae888e894e7b4eba900e9610909ef970000"
  },
  {
   "jp_offset": "0x1dd1",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "哪怕同归于尽、哥哥……我也要阻止你！",
   "zh_hex": "15e8ffe958e85de947e879e8f202e9bce9bc0909efcce7c0ef2ae8efe869e7b8ef970000"
  },
  {
   "jp_offset": "0x1e13",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "阿尔黛西亚……！你为何就是不肯理解我{00}！",
   "zh_hex": "15e7d2e7e1ea9ae7f8e7d60909ef97e7b8e7c1efbce7c5e7b6e7b5e93de872e89defcc00ef970000"
  },
  {
   "jp_offset": "0x1e44",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "哥哥你曾说过、要为新人类开创一个新世{00}界……",
   "zh_hex": "15e9bce9bce7b8ea2ae7edef3602ef2ae7c1ef8aefb2e841e7fae893efb6e828ef8ae83c00e8f509090000"
  },
  {
   "jp_offset": "0x1e62",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "可是、就在这场战争中、",
   "zh_hex": "15e7c4e7b602e7c5ef29e7b9e876ef28e852ef4e020000"
  },
  {
   "jp_offset": "0x1e6e",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "不、我看人类的革新、早在那之前就已经{00}开始了！",
   "zh_hex": "15e7b502efcce7f6efb2e841e7b4edc5ef8a02e963ef29e7b7e7cdef51e7c5ef3ae8b700e7fae908e7baef970000"
  },
  {
   "jp_offset": "0x1ea7",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "这世上、有能领悟之人、也有不能领悟之{00}人……",
   "zh_hex": "15e7b9e83cef4c02e7cbe7c6ea20ea19e7cdefb202e7c0e7cbe7b5e7c6ea20ea19e7cd00efb209090000"
  },
  {
   "jp_offset": "0x1ebf",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "所以、才必须将旧人类全部歼灭！",
   "zh_hex": "15e7fbe7f302e836e860e9a2e84aeac8efb2e841efb4ef70eaafe8e1ef970000"
  },
  {
   "jp_offset": "0x1eef",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "并非所有古老之物、都是邪恶的吧！",
   "zh_hex": "15e957e8f0e7fbe7cbe84de9cae7cde99e02e840e7b6ed12e7dee7b4e7d0ef970000"
  },
  {
   "jp_offset": "0x1f24",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "那种道理我也明白、我只是……",
   "zh_hex": "15e7b7e7d1e82ae8728be7c0ef39e809028bef32e7b6090900000000"
  },
  {
   "jp_offset": "0x1f55",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……那不过是野心与妄想罢了",
   "zh_hex": "150909e7b7e7b5ef36e7b6eb21e82de832ecc6e7e6eaefe7ba0000"
  },
  {
   "jp_offset": "0x1f9c",
   "jp_len": 38,
   "kind": "dialogue",
   "zh_text": "哥哥总觉得、自己必须服从命运之类的东{00}西……",
   "zh_hex": "15e9bce9bce881e8aee80a02efb5e8c9e860e9a2e9f1e88ae853e986e7cde841e7b4e8ba00e7f809090000"
  },
  {
   "jp_offset": "0x1fc2",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "哥哥就是不明白、那种想法本身就是错的{00}！",
   "zh_hex": "15e9bce9bce7c5e7b6e7b5ef39e80902e7b7e7d1e7e6e84eefa6e88de7c5e7b6e885e7b400ef970000"
  },
  {
   "jp_offset": "0x1ffe",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "阿尔黛西亚……！",
   "zh_hex": "15e7d2e7e1ea9ae7f8e7d60909ef970000"
  },
  {
   "jp_offset": "0x202b",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "夏亚大佐……",
   "zh_hex": "15ef37e7d6efa5efba09090000"
  },
  {
   "jp_offset": "0x204f",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……你是哈曼·卡恩？",
   "zh_hex": "150909e7b8e7b6e7e8e874ef4be801e7ee050000"
  },
  {
   "jp_offset": "0x2076",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "您还记得我吗？",
   "zh_hex": "15e835e7f7e996e80aefcce802050000"
  },
  {
   "jp_offset": "0x20a0",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯？",
   "zh_hex": "150909e865050000"
  },
  {
   "jp_offset": "0x20c2",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "我小时候……曾与您见过一面",
   "zh_hex": "15efcce83eef2dea390909ea2ae832e835e85cef36efb6e8620000"
  },
  {
   "jp_offset": "0x20e1",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "是随父亲一同……",
   "zh_hex": "15e7b6e9a1e888e894efb6e85d09090000"
  },
  {
   "jp_offset": "0x2107",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "原来如此……抱歉、那件事我已记不太清{00}了……",
   "zh_hex": "15e8e4efcfe7f0e7ca0909e922e92702e7b7e991efb8efccef3ae996e7b5e86ae99500e7ba09090000"
  },
  {
   "jp_offset": "0x213d",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "不、没关系……只是那时候、我心里这样{00}想过",
   "zh_hex": "15e7b502e7d8e8bbe9410909ef32e7b6e7b7ef2dea3902efcce82def31e7b9e7da00e7e6ef360000"
  },
  {
   "jp_offset": "0x215a",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "这人是多么温柔、又是多么哀伤的一个人{00}啊……",
   "zh_hex": "15e7b9efb2e7b6e7e9e7bde9c0ebd102e8f1e7b6e7e9e7bdecbee8f9e7b4efb6e828efb200e7c309090000"
  },
  {
   "jp_offset": "0x2196",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "哈曼·卡恩、你……",
   "zh_hex": "15e7e8e874ef4be801e7ee02e7b809090000"
  },
  {
   "jp_offset": "0x21c9",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "你就是阿姆罗·雷……那个欺负夏亚大佐{00}的坏人！",
   "zh_hex": "15e7b8e7c5e7b6e7d2e823e7ec04e8af0909e7b7e828ec78e92cef37e7d6bea300e7b4e9edb40600000000000000"
  },
  {
   "jp_offset": "0x21ff",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "你、你……？究竟想做什么……！？",
   "zh_hex": "15e7b802e7b8090905e906ef2ce7e6e81ce7dde7bd0909ef97050000"
  },
  {
   "jp_offset": "0x2237",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "再打下去也没胜算了！……全军后退！",
   "zh_hex": "15e80be7f5ef4de7ebe7c0e7d8e8dbe889e7baef970909efb4e7e0e7fee880ef970000"
  },
  {
   "jp_offset": "0x2278",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "还是让木马给逃掉了吗……",
   "zh_hex": "15e7f7e7b6e7f9efa9e84fe839e8c2e9d3e7bae80209090000"
  },
  {
   "jp_offset": "0x22c8",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "不、夏亚干得很好",
   "zh_hex": "15e7b502ef37e7d6e8d3e80ae981e7c70000"
  },
  {
   "jp_offset": "0x22f6",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "基西莉亚阁下……？",
   "zh_hex": "15e829e7f8e81ee7d6e8d7ef4d0909050000"
  },
  {
   "jp_offset": "0x231b",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "木马一撤退、联邦的进攻也会稍稍放缓",
   "zh_hex": "15efa9e84fefb6e90ae88002ef2eefaae7b4e892ef67e7c0e7e2ead5ead5e86ceda40000"
  },
  {
   "jp_offset": "0x2332",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "这样的战果已经足够了！全军、撤退！！",
   "zh_hex": "15e7b9e7dae7b4ef28e871ef3ae8b7ea1ee920e7baef97efb4e7e002e90ae880ef97ef970000"
  },
  {
   "jp_offset": "0x236e",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……夏亚大佐！",
   "zh_hex": "150909ef37e7d6efa5efbaef970000"
  },
  {
   "jp_offset": "0x2393",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "你是……哈曼·卡恩？",
   "zh_hex": "15e7b8e7b60909e7e8e874ef4be801e7ee050000"
  },
  {
   "jp_offset": "0x23bc",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "大佐！我从基西莉亚少将那里听说了！",
   "zh_hex": "15efa5efbaef97efcce88ae829e7f8e81ee7d6eface84ae7b7ef31e8d1e7ede7baef970000"
  },
  {
   "jp_offset": "0x23d2",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "您接下来就要出击了吧……请让我也来助{00}您一臂之力！",
   "zh_hex": "15e835efceef4defcfe7c5ef2aefbee7cce7bae7d00909e83ae7f9efcce7c0efcfea2300e835efb6ee92e7cdefb0ef970000"
  },
  {
   "jp_offset": "0x240b",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "你吗？可是、马哈拉贾提督那边……",
   "zh_hex": "15e7b8e80205e7c4e7b602e84fe7e8e7c2e9e8e821ea1be7b7e89909090000"
  },
  {
   "jp_offset": "0x2438",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "我已经向父亲报告过了",
   "zh_hex": "15efccef3ae8b7efc1e888e894e913e8e5ef36e7ba0000"
  },
  {
   "jp_offset": "0x2446",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "而且……",
   "zh_hex": "15e89ce99909090000"
  },
  {
   "jp_offset": "0x248a",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "弗拉纳冈机关那里……我实在……不太想{00}回去……",
   "zh_hex": "15e9b5e7c2e882eb7ee7e4e8bbe7b7ef310909efcce87fef290909e7b5e86ae7e600ef52e7eb09090000"
  },
  {
   "jp_offset": "0x24c0",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "哈曼·卡恩……？",
   "zh_hex": "15e7e8e874ef4be801e7ee0909050000"
  },
  {
   "jp_offset": "0x2505",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "不如就答应她吧？",
   "zh_hex": "15e7b5e7f0e7c5ea96e873e88ee7d0050000"
  },
  {
   "jp_offset": "0x253b",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "艾因·雷维！？",
   "zh_hex": "15e8d6ef3304e8afea54060500000000"
  },
  {
   "jp_offset": "0x2550",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "5d"
  },
  {
   "jp_offset": "0x2551",
   "jp_len": 52,
   "kind": "script",
   "zh_hex": "15330200010604001330243302000106020013d8223302000115e7e8e874e7b5e7e6ef52e7ebe7b4e82de88b02efcce7c0e7b6e7c6e872e89de7b40000"
  },
  {
   "jp_offset": "0x2585",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "在那种地方、新人类不过是实验用的小白{00}鼠罢了",
   "zh_hex": "15ef29e7b7e7d1ef63efb102ef8aefb2e841e7b5ef36e7b6e87fea99efb3e7b4e83ee80900eecfeaefe7ba0000"
  },
  {
   "jp_offset": "0x25bb",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x25de",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "以测试为名、全身上下被任意摆弄、反复{00}检查……",
   "zh_hex": "15e7f3eacee91de7c1e8ac02efb4e88def4cef4de7f1e89aef3ceb8beac402e87ce9ee00ee40eae909090000"
  },
  {
   "jp_offset": "0x2638",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "够了、别说了、艾因·雷维、我不想再听{00}下去了",
   "zh_hex": "15e920e7ba02e7e5e7ede7ba02e8d6ef3304e8afea54028be7b5e7e6e80be8d10089e7ebe7ba0000000000"
  },
  {
   "jp_offset": "0x2679",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "真是失礼了、呵呵……",
   "zh_hex": "15e820e7b6e8a5eb65e7ba02ef3def3d09090000"
  },
  {
   "jp_offset": "0x26cd",
   "jp_len": 1,
   "kind": "script",
   "zh_hex": "5d"
  },
  {
   "jp_offset": "0x26ce",
   "jp_len": 36,
   "kind": "script",
   "zh_hex": "1533020001065c001330243302000106270013d82233020001150909e7e8e874ef4be801e7ee0000"
  },
  {
   "jp_offset": "0x270d",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "是。",
   "zh_hex": "15e7b6030000"
  },
  {
   "jp_offset": "0x272f",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "若你愿意、我便准许你随部队同行",
   "zh_hex": "15e7e7e7b8e961ef3c02efcce8fae87ae8a7e7b8e9a1ef70e7c9e85defd60000"
  },
  {
   "jp_offset": "0x2749",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "不过、你必须做好战斗的觉悟、毕竟所谓{00}实战……",
   "zh_hex": "15e7b5ef3602e7b8e860e9a2e81ce7c7ef28e7ffe7b4e8aeea1902ea2cef2ce7fbe92b00e87fef2809090000"
  },
  {
   "jp_offset": "0x27e0",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "『……实战、可不像电视剧里那样帅气好{00}看』",
   "zh_hex": "150c0909e87fef2802e7c4e7b5e8e9ead3e9d9ecb5ef31e7b7e7dae9a6e8ede7c700e7f60d0000"
  },
  {
   "jp_offset": "0x2841",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "『……我明白……』",
   "zh_hex": "150c0909efccef39e80909090d0000"
  },
  {
   "jp_offset": "0x284e",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "『正因如此、大佐才会收留我这种女人吧{00}？』",
   "zh_hex": "150cef3bef33e7f0e7ca02efa5efbae836e7e2e926e98cefcce7b9e7d1efadefb2e7d000050d0000"
  },
  {
   "jp_offset": "0x28d2",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……夏亚大佐？",
   "zh_hex": "150909ef37e7d6efa5efba050000"
  },
  {
   "jp_offset": "0x28f7",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "啊、不……没什么",
   "zh_hex": "15e7c302e7b50909e7d8e7dde7bd0000"
  },
  {
   "jp_offset": "0x2904",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "总之、既然要随我同行、战斗便在所难免",
   "zh_hex": "15e881e7cd02e8c4e7efef2ae9a1efcce85defd602ef28e7ffe8faef29e7fbe866eb7d0000"
  },
  {
   "jp_offset": "0x291e",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "这一点、你务必要有觉悟、哈曼·卡恩",
   "zh_hex": "15e7b9efb6e82202e7b8e94fe860ef2ae7cbe8aeea1902e7e8e874ef4be801e7ee0000"
  },
  {
   "jp_offset": "0x2972",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "今后……请叫我哈曼就好……",
   "zh_hex": "15efb9e7fe0909e83ae8c1efcce7e8e874e7c5e7c709090000"
  },
  {
   "jp_offset": "0x29a4",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "今后？",
   "zh_hex": "15efb9e7fe050000"
  },
  {
   "jp_offset": "0x29c7",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "是、我已经下定决心了",
   "zh_hex": "15e7b602efccef3ae8b7ef4de867e8abe82de7ba0000"
  },
  {
   "jp_offset": "0x29d8",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "所以、夏亚大佐……",
   "zh_hex": "15e7fbe7f302ef37e7d6efa5efba09090000"
  },
  {
   "jp_offset": "0x29ff",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "是吗……那就拜托你了、哈曼",
   "zh_hex": "15e7b6e8020909e7b7e7c5e91ae7f4e7b8e7ba02e7e8e8740000"
  },
  {
   "jp_offset": "0x76fe",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "到、到此为止了吗……！",
   "zh_hex": "15e7d702e7d7e7cae7c1e869e7bae80209090600000000000000"
  },
  {
   "jp_offset": "0x773e",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "糟了！旗舰要是被击毁……",
   "zh_hex": "15eeafe7ba06eb0be7d4ef2ae7b6e7f1e7cce97c0909000000"
  },
  {
   "jp_offset": "0x7de2",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "阿姆罗……",
   "zh_hex": "15e7d2e823e7ec09090000"
  },
  {
   "jp_offset": "0x7e0e",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "拉拉！？",
   "zh_hex": "15e7c2e7c2ef97050000"
  },
  {
   "jp_offset": "0x7e46",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "你来得太迟了！",
   "zh_hex": "15e7b8d9e80ae86aea10e7ba0600000000"
  },
  {
   "jp_offset": "0x7e62",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "你为什么、偏偏到现在才出现！？",
   "zh_hex": "15e7b8e7c1e7dde7bd02eb4deb4de7d7e82fef29e836efbee82fef97050000"
  },
  {
   "jp_offset": "0x7ea6",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "太迟了！？",
   "zh_hex": "15e86aea10e7baef97050000"
  },
  {
   "jp_offset": "0x7ee2",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "你明明这么能打！……这究竟是为什么！{00}？",
   "zh_hex": "15e7b8ef39ef39e7b9e7bde7c6e7f5ef970909e7b9e906ef2ce7b6e7c1e7dde7bdef9700050000"
  },
  {
   "jp_offset": "0x7f06",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "明明你连一个该守护的人都没有……",
   "zh_hex": "15ef39ef39e7b8e86eefb6e828e898e8a8e8e0e7b4efb2e840e7d8e7cb09090000"
  },
  {
   "jp_offset": "0x7f45",
   "jp_len": 6,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x7f70",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "我能看得见啊……",
   "zh_hex": "15efcce7c6e7f6e80ae85ce7c309090000"
  },
  {
   "jp_offset": "0x7f86",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "你既没有故乡、也没有家人……",
   "zh_hex": "15e7b8e8c4e7d8e7cbea09eb4c02e7c0e7d8e7cbe7dfefb209090000"
  },
  {
   "jp_offset": "0x7fa6",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "……也不曾爱过任何人！",
   "zh_hex": "150909e7c0e7b5ea2ae8d5ef36e89aefbcefb2ef970000"
  },
  {
   "jp_offset": "0x7fe6",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "所以、就算如此……",
   "zh_hex": "15e7fbe7f302e7c5e889e7f0e7ca09090000"
  },
  {
   "jp_offset": "0x8022",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "那又怎么样啊！！",
   "zh_hex": "15e7b7e8f1e7f2e7bde7dae7c3ef97ef970000"
  },
  {
   "jp_offset": "0x808a",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "难道没有该守护之物、就不能战斗了吗！{00}？",
   "zh_hex": "15e866e82ae7d8e7cbe898e8a8e8e0e7cde99e02e7c5e7b5e7c6ef28e7ffe7bae802060005000000"
  },
  {
   "jp_offset": "0x80cf",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "那是不自然的啊……",
   "zh_hex": "15e7b7e7b6e7b5efb5e7efe7b4e7c309090000"
  },
  {
   "jp_offset": "0x80dc",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "我是在为救过我的人而战……",
   "zh_hex": "15efcce7b6ef29e7c1e8caef36efcce7b4efb2e89cef2809090000"
  },
  {
   "jp_offset": "0x8121",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "仅仅、只为了那种事……？",
   "zh_hex": "15eb7aeb7a02ef32e7c1e7bae7b7e7d1efb80909050000"
  },
  {
   "jp_offset": "0x8158",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "那是……是人活下去的真理啊……！",
   "zh_hex": "15e7b7e7b60909e7b6b4e8d489e7ebe7b4e820e872e7c309090600000000"
  },
  {
   "jp_offset": "0x8198",
   "jp_len": 25,
   "kind": "dialogue",
   "zh_text": "那么！我们之间这场相遇、又算是什么！{00}？",
   "zh_hex": "15e7b7e7bdef97efcce7bbe7cde8fce7b9e876e8b1ea4302e8f1e889e7b6e7dde7bdef9700050000"
  },
  {
   "jp_offset": "0x81f0",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "啊啊……！",
   "zh_hex": "15e7c3e7c30909060000"
  },
  {
   "jp_offset": "0x81fa",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "为什么——！？为什么偏偏这么晚才遇见{00}你……？",
   "zh_hex": "15e7c1e7dde7bdebafebafef9705e7c1e7dde7bdeb4deb4de7b9e7bdea69e836ea43e85c00e7b80909050000"
  },
  {
   "jp_offset": "0x8218",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "就算相遇了……也是一场无可奈何的相遇{00}啊！！",
   "zh_hex": "15e7c5e889e8b1ea43e7ba0909e7c0e7b6efb6e876e7dce7c4eb2fefbce7b4e8b1ea4300e7c3ef97ef970000"
  },
  {
   "jp_offset": "0x8255",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "若这就是命运、那也太过分了……太残酷{00}了",
   "zh_hex": "15e7e7e7b9e7c5e7b6e853e98602e7b7e7c0e86aef36efaee7ba0909e86ae97bebf700e7ba0000"
  },
  {
   "jp_offset": "0x8279",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "明明相遇就能彼此理解……为何偏偏只能{00}走到这一步……",
   "zh_hex": "15ef39ef39e8b1ea43e7c5e7c6efc9e7cae872e89d0909e7c1efbceb4deb4def32e7c600e890e7d7e7b9efb6ea9309090000"
  },
  {
   "jp_offset": "0x8296",
   "jp_len": 17,
   "kind": "dialogue",
   "zh_text": "你对我而言、来得太迟了……",
   "zh_hex": "15e7b8e7beefcce89cefd702efcfe80ae86aea10e7ba09090000"
  },
  {
   "jp_offset": "0x82b1",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "而你对我而言、来得太突然了……",
   "zh_hex": "15e89ce7b8e7beefcce89cefd702efcfe80ae86ae8b6e7efe7ba09090000"
  },
  {
   "jp_offset": "0x831a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……拉拉！！",
   "zh_hex": "150909e7c2e7c2ef97ef970000"
  },
  {
   "jp_offset": "0x834e",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "别再跟那家伙说这些废话了！！",
   "zh_hex": "15e7e5e80be973e7b7e7dfe7fde7ede7b9e8a4eae5e81fe7baef97ef970000"
  },
  {
   "jp_offset": "0x838e",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……夏亚！！",
   "zh_hex": "150909ef37e7d6ef97ef970000"
  },
  {
   "jp_offset": "0x83ca",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "可恶啊！！",
   "zh_hex": "15e7c4e7dee7c3ef97ef970000"
  },
  {
   "jp_offset": "0x8406",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……什么！？",
   "zh_hex": "150909e7dde7bdef97050000"
  },
  {
   "jp_offset": "0x8442",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "夏亚！受死吧！！",
   "zh_hex": "15ef37e7d6ef97e8c8ef6ae7d0ef97ef970000"
  },
  {
   "jp_offset": "0x847e",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "不行……！！",
   "zh_hex": "15e7b5efd60909ef97ef970000"
  },
  {
   "jp_offset": "0x84c7",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "拉拉！？",
   "zh_hex": "15e7c2e7c2ef97050000"
  },
  {
   "jp_offset": "0x84fe",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "拉拉·辛、就这样死了吗……",
   "zh_hex": "15e7c2e7c2ef4bea5802e7c5e7b9e7daef6ae7bae80209090000"
  },
  {
   "jp_offset": "0x8528",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "似乎是被一台名为高达的MS给击破的",
   "zh_hex": "15e944e933e7b6e7f1efb6ea16e8ace7c1e812ef2be7b4efa7ef9ee839e7ccef6de7b40000"
  },
  {
   "jp_offset": "0x855e",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……也罢、这也是无可奈何的事",
   "zh_hex": "150909e7c0eaef02e7b9e7c0e7b6e7dce7c4eb2fefbce7b4efb80000"
  },
  {
   "jp_offset": "0x856c",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "毕竟她可是个觉醒程度相当高的新人类啊",
   "zh_hex": "15ea2cef2ce88ee7c4e7b6e828e8aeeb20ea7de96de8b1ef53e812e7b4ef8aefb2e841e7c30000"
  },
  {
   "jp_offset": "0x8588",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "当然、拉拉·辛的数据、都保留下来了吧{00}？",
   "zh_hex": "15ef53e7ef02e7c2e7c2ef4bea58e7b4e914e8cc02e840ea47e98cef4defcfe7bae7d000050000"
  },
  {
   "jp_offset": "0x85bf",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……是",
   "zh_hex": "150909e7b60000"
  },
  {
   "jp_offset": "0x85e1",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "那就没问题了",
   "zh_hex": "15e7b7e7c5e7d8e997ea12e7ba0000"
  },
  {
   "jp_offset": "0x85f0",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "趁现在、把数据导入那批试作品里",
   "zh_hex": "15e9eae82fef2902e81be914e8ccea4be891e7b7ed63e91def2feae1ef310000"
  },
  {
   "jp_offset": "0x8627",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "要导入全部试作体吗？",
   "zh_hex": "15ef2aea4be891efb4ef70e91def2fef4fe802050000"
  },
  {
   "jp_offset": "0x864f",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "尽可能全部导入",
   "zh_hex": "15e8f2e7c4e7c6efb4ef70ea4be8910000"
  },
  {
   "jp_offset": "0x865c",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "既然联邦的进攻已迫在眼前、就必须尽快{00}推进战力化",
   "zh_hex": "15e8c4e7efef2ed1e7b4e8929eef3aeb70ef29e90bba02e7c5e860e9a2e8f2e85f00eaabe892ef28dae9a5000000000000"
  },
  {
   "jp_offset": "0x8699",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "明白了",
   "zh_hex": "15ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x86a0",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "我会着手推进A号到D号的再调整",
   "zh_hex": "158be7e2e86daeeaabe892ea9ce833e7d711e833e7b4e80be95ce9fe000000000000"
  },
  {
   "jp_offset": "0x86d2",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "夏亚大佐！格拉纳达发来紧急通讯！！",
   "zh_hex": "15ef37e7d6efa5efbaef97e824e7c2e882ef2be870efcfeaedea62ef59eb1bef97ef970000"
  },
  {
   "jp_offset": "0x8704",
   "jp_len": 10,
   "kind": "dialogue",
   "zh_text": "……你说什么？",
   "zh_hex": "150909e7b8e7ede7dde7bd050000"
  },
  {
   "jp_offset": "0x8726",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "……你说核弹！？",
   "zh_hex": "150909e7b8e7ede8f3e946ef97050000"
  },
  {
   "jp_offset": "0x874c",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……是的",
   "zh_hex": "150909e7b6e7b40000"
  },
  {
   "jp_offset": "0x8753",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "参谋部的基林中佐、射杀了鲁根斯基地司{00}令官",
   "zh_hex": "15ed1aea6ecce7b4e829e9b7c0a302ace89be7bae8a2e9b8e7c8e829bfeafe00e94e8f0000000000000000"
  },
  {
   "jp_offset": "0x876f",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "他带走了储备的核导弹、朝SIDE6而{00}去",
   "zh_hex": "15e80ce937e890e7baeddbe877e7b4e8f3ea4be94602eaadef9eef62ef96ef9fe9cde89c00e7eb0000"
  },
  {
   "jp_offset": "0x87a9",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "SIDE6？难道说、基林中佐他……",
   "zh_hex": "15ef9eef62ef96ef9fe9cd05e866e82ae7ed02e829e9b7ef4eefbae80c09090000"
  },
  {
   "jp_offset": "0x87d8",
   "jp_len": 40,
   "kind": "dialogue",
   "zh_text": "中佐早先就一直警告、SIDE6正研发{00}的新型高达极为危险",
   "zh_hex": "15ef4eefbae963ef8be7c5efb6e875eb6ee8e502ef9eef62ef96ef9fe9cdef3bea0ce87000e7b4ef8ae977e812ef2beacae7c1e935e9320000"
  },
  {
   "jp_offset": "0x8800",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "他带走核武器、恐怕也是为了摧毁那台高{00}达……",
   "zh_hex": "15e80ce937e890e8f3e8ece8c302eb33e958e7c0e7b6e7c1e7baefe5e97ce7b7ea16e81200ef2b09090000"
  },
  {
   "jp_offset": "0x8835",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "真是荒唐！中佐不懂政治吗！？",
   "zh_hex": "15e820e7b6ec38edf7ef97ef4eefbae7b5e8b0ea68ea79e802ef97050000"
  },
  {
   "jp_offset": "0x8856",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "值此时期、竟向中立地带动用核武器、对{00}吉翁而言无异于自杀！",
   "zh_hex": "15ec48e7caef2deac902ef2c9dc0e86bbfe937ef30d8e8f3e8ece8c302e7be00e7d9ee88e89c9be7dceb32e879abe89b06000000000000000000"
  },
  {
   "jp_offset": "0x8894",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……基西莉亚阁下",
   "zh_hex": "150909e829e7f8e81ee7d6e8d7ef4d0000"
  },
  {
   "jp_offset": "0x889d",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "基林中佐的鲁莽行径、无论如何都必须阻{00}止",
   "zh_hex": "15e829e9b7ef4eefbae7b4e8a2edb2efd6ecd302e7dce8dce7f0efbce840e860e9a2e8ef00e8690000"
  },
  {
   "jp_offset": "0x88d5",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "夏亚……你愿意去吗？",
   "zh_hex": "15ef37e7d60909e7b8e961ef3ce7ebe802050000"
  },
  {
   "jp_offset": "0x88ff",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……遵命",
   "zh_hex": "150909ec40e8530000"
  },
  {
   "jp_offset": "0x8906",
   "jp_len": 31,
   "kind": "dialogue",
   "zh_text": "视情况、或将与友军交火……",
   "zh_hex": "15e9d9e88be8d002e905e84ae832e960e7e0e861e8da0909000000"
  },
  {
   "jp_offset": "0x8940",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "无妨、务必给我阻止他",
   "zh_hex": "15e7dce97f02e94fe860e839efcce8efe869e80c0000"
  },
  {
   "jp_offset": "0x896a",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "……我们即将抵达阿·巴瓦·库",
   "zh_hex": "150909efcce7bbe855e84ae96eef2be7d2ef4be85be99fef4be9b30000"
  },
  {
   "jp_offset": "0x899a",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "嗯……是吗",
   "zh_hex": "15e8650909e7b6e8020000"
  },
  {
   "jp_offset": "0x89be",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "果然……联邦的进攻、已经近在眼前了吧",
   "zh_hex": "15e871e7ef0909ef2eefaae7b4e892ef6702ef3ae8b7efd8ef29e90bef51e7bae7d00000"
  },
  {
   "jp_offset": "0x89f0",
   "jp_len": 18,
   "kind": "dialogue",
   "zh_text": "啊、是布拉德中佐啊……是啊",
   "zh_hex": "15e7c302e7b6e831e7c2e82cef4eefbae7c30909e7b6e7c30000"
  },
  {
   "jp_offset": "0x8a02",
   "jp_len": 41,
   "kind": "dialogue",
   "zh_text": "联邦似乎想攻陷阿·巴瓦·库、一举剑指{00}吉翁本土",
   "zh_hex": "15ef2ed1e944e933e7e69eeaf9e7d204e85be99f04e9b30287ea21ecb3e8c000e7d9ee88d2ec560000000000000000"
  },
  {
   "jp_offset": "0x8a2b",
   "jp_len": 35,
   "kind": "dialogue",
   "zh_text": "上一战我们确实赢了、但那也不过是抓住{00}了一时的势头罢了",
   "zh_hex": "15ef4cefb6ef28efcce7bbe88ce87fe9cbe7ba02e7dbe7b7e7c0e7b5ef36e7b6e962e85900e7baefb6ef2de7b4e8fde92eeaefe7ba0000"
  },
  {
   "jp_offset": "0x8a4e",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "等联邦舰队一集结完毕、对阿·巴瓦·库{00}的进攻便会开始吧",
   "zh_hex": "15e826ef2ed1e7d4e7c987ea98e868e87eea2c02e7bee7d204e85be99f04e9b300e7b4e8929ee8fae7e2e7fae908e7d000000000000000"
  },
  {
   "jp_offset": "0x8a8a",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "将是一场恶战",
   "zh_hex": "15e84ae7b6efb6e876e7deef280000"
  },
  {
   "jp_offset": "0x8ab5",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "嗯、这几乎是错不了的",
   "zh_hex": "15e86502e7b9eaa5e933e7b6e885e7b5e7bae7b40000"
  },
  {
   "jp_offset": "0x8ade",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "哪怕能多一个人活下来也好……",
   "zh_hex": "15e8ffe958e7c6e7e987e828b4e8d489d9e7c0e7c70909000000000000000000"
  },
  {
   "jp_offset": "0x8b32",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "听说MS已经全部出动了、夏亚？",
   "zh_hex": "15e8d1e7edefa7ef9eef3ae8b7efb4ef70efbeef30e7ba02ef37e7d6050000"
  },
  {
   "jp_offset": "0x8b63",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "是……",
   "zh_hex": "15e7b609090000"
  },
  {
   "jp_offset": "0x8b6a",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "我本想换装成新型的勇士……可是……",
   "zh_hex": "158bd2e7e6ea78e98fe837ef8ae977e7b4eadda50909e7c4e7b609090000000000"
  },
  {
   "jp_offset": "0x8b86",
   "jp_len": 33,
   "kind": "dialogue",
   "zh_text": "据说已全部配发完毕、没有能轮到我用的{00}了",
   "zh_hex": "15e8cce7edef3aefb4ef70ea34e870e87eea2c02e7d8e7cbe7c6ebf4e7d7efccefb3e7b400e7ba0000"
  },
  {
   "jp_offset": "0x8bc2",
   "jp_len": 39,
   "kind": "dialogue",
   "zh_text": "那、要不试试吉翁号？虽说似乎只完成了{00}八成……",
   "zh_hex": "15e7b702ef2ae7b5e91de91de7d9ee88e83305e8b8e7ede944e933ef32e87ee837e7ba00ecafe83709090000"
  },
  {
   "jp_offset": "0x8c04",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "……吉翁号？",
   "zh_hex": "150909e7d9ee88e833050000"
  },
  {
   "jp_offset": "0x8c28",
   "jp_len": 28,
   "kind": "dialogue",
   "zh_text": "这是一台搭载了艾尔美斯精神感应装置的{00}MS、以你的本事、想必能运用自如",
   "zh_hex": "15e7b9e7b687ea16eb09eb1de7bae8d6e7e1e9f4e7c8e98de9aae87de873e98fea0ee7b400131402e7f3e7b8e7b4d2a902e7e6e860e7c6e986d8abe7f0000000000000000000"
  },
  {
   "jp_offset": "0x8c5f",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……明白了",
   "zh_hex": "150909ef39e809e7ba0000"
  },
  {
   "jp_offset": "0x8c82",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "阿·巴瓦·库吗……这一仗、看来会是场{00}恶战",
   "zh_hex": "15e7d2ef4be85be99fef4be9b3e8020909e7b9efb6ea3702e7f6efcfe7e2e7b6e87600e7deef280000"
  },
  {
   "jp_offset": "0x8cb8",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "啊、是啊……",
   "zh_hex": "15e7c302e7b6e7c309090000"
  },
  {
   "jp_offset": "0x8ce8",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……怎么了、西格？",
   "zh_hex": "150909e7f2e7bde7ba02e7f8e824050000"
  },
  {
   "jp_offset": "0x8d0f",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……瑟拉",
   "zh_hex": "150909e8aae7c20000"
  },
  {
   "jp_offset": "0x8d31",
   "jp_len": 22,
   "kind": "dialogue",
   "zh_text": "怎么？这么一脸认真？",
   "zh_hex": "15e7f2e7bd05e7b9e7bdefb6eb69e8a0e820050000"
  },
  {
   "jp_offset": "0x8d6c",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "我是认真的、瑟拉",
   "zh_hex": "15efcce7b6e8a0e820e7b402e8aae7c20000"
  },
  {
   "jp_offset": "0x8d78",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "啊……等下一仗打完之后……",
   "zh_hex": "15e7c30909e826ef4defb6ea37e7f5e87ee7cde7fe09090000"
  },
  {
   "jp_offset": "0x8da8",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "打完……？",
   "zh_hex": "15e7f5e87e090905000000"
  },
  {
   "jp_offset": "0x8dce",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "啊、不是……",
   "zh_hex": "15e7c302e7b5e7b609090000"
  },
  {
   "jp_offset": "0x8dda",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "……算了吧",
   "zh_hex": "150909e889e7bae7d0000000"
  },
  {
   "jp_offset": "0x8e08",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "真是怪家伙",
   "zh_hex": "15e820e7b6ea07e7dfe7fd0000"
  },
  {
   "jp_offset": "0x8e5d",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "瑟拉……果然、你……",
   "zh_hex": "15e8aae7c20909e871e7ef02e7b809090000"
  },
  {
   "jp_offset": "0x8e86",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "呵……呵哈哈哈……！",
   "zh_hex": "15ef3d0909ef3de7e8e7e8e7e8090906000000"
  },
  {
   "jp_offset": "0x8e93",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "终于完成了！我的孩子、格罗姆林！！",
   "zh_hex": "15e8e2e879e87ee837e7baef97efcce7b4e956e88602e824e7ece823e9b7ef97ef970000"
  },
  {
   "jp_offset": "0x8ef6",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "怎么了、爱娜？你不愿替我感到高兴吗？",
   "zh_hex": "15e7f2e7bde7ba02e8d5e7ea05e7b8e7b5e961ea50efcce87de7d7e812eabae802050000"
  },
  {
   "jp_offset": "0x8f59",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "哼……",
   "zh_hex": "15e8b309090000"
  },
  {
   "jp_offset": "0x8f60",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "那个男人……好像是叫士郎来着……",
   "zh_hex": "15e7b7e828ea95efb20909e7c7e8e9e7b6e8c1ef64eb1fefcfe86d09090000"
  },
  {
   "jp_offset": "0x8f8f",
   "jp_len": 8,
   "kind": "dialogue",
   "zh_text": "……！？",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x8fb2",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "听士兵说、你俩似乎很亲密",
   "zh_hex": "15e8d1ef64ef93e7ed02e7b8eb7be944e933e981e894e9bd0000"
  },
  {
   "jp_offset": "0x8fcd",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "简直像个恋爱少女……",
   "zh_hex": "15e9abe875e8e9e828ee20e8d5efacefad09090000"
  },
  {
   "jp_offset": "0x8ffd",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "我们……只是为了活下去、才彼此协作罢{00}了",
   "zh_hex": "15efcce7bb0909ef32e7b6e7c1e7bae8d4ef4de7eb02e836efc9e7cae8f6ef2feaef00e7ba0000"
  },
  {
   "jp_offset": "0x9032",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "协作吗……和敌方的士兵？",
   "zh_hex": "15e8f6ef2fe8020909e7d3e7e3efb1e7b4ef64ef93050000"
  },
  {
   "jp_offset": "0x9066",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "即便……",
   "zh_hex": "15e855e8fa09090000"
  },
  {
   "jp_offset": "0x9088",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "……嗯？",
   "zh_hex": "150909e865050000"
  },
  {
   "jp_offset": "0x90aa",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "即便敌我两分、也会有好人！",
   "zh_hex": "15e855e8fae7e3efcce97defae02e7c0e7e2e7cbe7c7efb2ef970000"
  },
  {
   "jp_offset": "0x90c8",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "甚至能彼此理解……！",
   "zh_hex": "15eceee897e7c6efc9e7cae872e89d0909ef970000"
  },
  {
   "jp_offset": "0x90f2",
   "jp_len": 15,
   "kind": "dialogue",
   "zh_text": "嚯、彼此理解？",
   "zh_hex": "15e9dd02c9e7cae872e89d05000000"
  },
  {
   "jp_offset": "0x911c",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "哥哥难道您不懂吗！？那正是、这……",
   "zh_hex": "15e9bce9bce866e82ae835e7b5e8b0e8020605e7b7ef3be7b602e7b90909000000"
  },
  {
   "jp_offset": "0x913a",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "正是这愚蠢战争中{00}唯一的一丝希望……",
   "zh_hex": "15ef3be7b6e7b9e959e94bef28e852c000ea8987e7b487e8a3e87be96509090000000000000000"
  },
  {
   "jp_offset": "0x916c",
   "jp_len": 20,
   "kind": "dialogue",
   "zh_text": "哼……希望吗、真是无聊的废话",
   "zh_hex": "15e8b30909e87be965e80202e820e7b6e7dcec36e7b4eae5e81f0000"
  },
  {
   "jp_offset": "0x91e1",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "哥哥……！？",
   "zh_hex": "15e9bce9bc0909ef97050000"
  },
  {
   "jp_offset": "0x91f6",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "究竟从何时起……",
   "zh_hex": "15e906ef2ce88aefbcef2de84709090000"
  },
  {
   "jp_offset": "0x91ff",
   "jp_len": 34,
   "kind": "dialogue",
   "zh_text": "我们究竟是从何时起、变得连话都说不通{00}了呢……",
   "zh_hex": "15efcce7bbe906ef2ce7b6e88aefbcef2de84702e955e80ae86ee81fe840e7ede7b5ef5900e7bae90709090000"
  },
  {
   "jp_offset": "0x9242",
   "jp_len": 21,
   "kind": "dialogue",
   "zh_text": "……总帅、大德金号已经出港了",
   "zh_hex": "150909e881e9a602efa5e82ce902e833ef3ae8b7efbeeb3be7ba0000"
  },
  {
   "jp_offset": "0x9272",
   "jp_len": 14,
   "kind": "dialogue",
   "zh_text": "……老了啊、父亲",
   "zh_hex": "150909e9cae7bae7c302e888e89400000000"
  },
  {
   "jp_offset": "0x9280",
   "jp_len": 27,
   "kind": "dialogue",
   "zh_text": "事到如今才来谈和、早已为时已晚了……",
   "zh_hex": "15efb8e7d7e7f0efb9e836efcfeaf4e7d302e963ef3ae7c1ef2def3aea69e7ba09090000"
  },
  {
   "jp_offset": "0x929b",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "太阳射线如何了？",
   "zh_hex": "15e86aeb72ef65e916e7f0efbce7ba050000"
  },
  {
   "jp_offset": "0x92c9",
   "jp_len": 11,
   "kind": "dialogue",
   "zh_text": "已经随时都可以发射",
   "zh_hex": "15ef3ae8b7e9a1ef2de840e7c4e7f3e870ef650000"
  },
  {
   "jp_offset": "0x92f9",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "现在传达最终目标、基本目标即盖尔·德{00}尔巴",
   "zh_hex": "15e82fef29ea38ef2be8c5e8e2efd4e96f02e829efa6efd4e96fe855ec7ee7e1ef4be82c00e7e1e85b0000"
  },
  {
   "jp_offset": "0x932e",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "是！遵命！！",
   "zh_hex": "15e7b6ef97ec40e853ef97ef970000"
  },
  {
   "jp_offset": "0x939e",
   "jp_len": 24,
   "kind": "dialogue",
   "zh_text": "德金陛下！我们即将与联邦舰队接触",
   "zh_hex": "15e82ce902eb24ef4def97efcce7bbe855e84ae832ef2eefaae7d4e7c9efceef480000"
  },
  {
   "jp_offset": "0x93d1",
   "jp_len": 9,
   "kind": "dialogue",
   "zh_text": "嗯……拜托了",
   "zh_hex": "15e8650909e91ae7f4e7ba0000"
  },
  {
   "jp_offset": "0x943f",
   "jp_len": 7,
   "kind": "dialogue",
   "zh_text": "基连……",
   "zh_hex": "15e829e86e09090000"
  },
  {
   "jp_offset": "0x9446",
   "jp_len": 26,
   "kind": "dialogue",
   "zh_text": "你究竟想将吉翁公国、带往何方？",
   "zh_hex": "15e7b8e906ef2ce7e6e84ae7d9ee88e9a4a102e937e9118ad0050000000000"
  },
  {
   "jp_offset": "0x9460",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "战争再这样持续下去、吉翁公国本身都会{00}……",
   "zh_hex": "15ef28e852e80be7b9e7dae9efe9ad89e7eb02e7d9ee88e9a4a1d2e88de840e7e20009090000000000"
  },
  {
   "jp_offset": "0xa40b",
   "jp_len": 29,
   "kind": "dialogue",
   "zh_text": "『人是会改变的、就像我们一样……』",
   "zh_hex": "150cefb2e7b6e7e2e9f0e955e7b402e7c5e8e9efcce7bbefb6e7da09090d0000"
  },
  {
   "jp_offset": "0xa467",
   "jp_len": 23,
   "kind": "dialogue",
   "zh_text": "『是啊……正如拉拉所说……』",
   "zh_hex": "150ce7b6e7c30909ef3be7f0e7c2e7c2e7fbe7ed09090d0000"
  },
  {
   "jp_offset": "0xa488",
   "jp_len": 19,
   "kind": "dialogue",
   "zh_text": "『我也终于和你这样相互理解了』",
   "zh_hex": "150cefcce7c0e8e2e879e7d3e7b8e7b9e7dae8b1e9f9e872e89de7ba0d0000"
  },
  {
   "jp_offset": "0xa4a5",
   "jp_len": 30,
   "kind": "dialogue",
   "zh_text": "『人终有一天……甚至能够支配时间……{00}』",
   "zh_hex": "150cefb2e8e2e7cbefb6e8440909eceee897e7c6e920e883ea34ef2de8fc0909000d0000"
  },
  {
   "jp_offset": "0xa502",
   "jp_len": 12,
   "kind": "dialogue",
   "zh_text": "『啊啊、阿姆罗……』",
   "zh_hex": "150ce7c3e7c302e7d2e823e7ec09090d0000"
  },
  {
   "jp_offset": "0xa518",
   "jp_len": 13,
   "kind": "dialogue",
   "zh_text": "『我看得见时间了……！』",
   "zh_hex": "150cefcce7f6e80ae85cef2de8fce7ba0909ef970d0000"
  }
 ]
}
