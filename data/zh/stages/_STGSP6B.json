   "jp_offset": "0x8317",
   "jp_len": 16,
   "kind": "dialogue",
   "zh_text": "今后也祝你武运长久",
   "zh_hex": "15efb9e7fee7c0ed97e7b8e8ece986ef34e9db000000"
  }
 ]
