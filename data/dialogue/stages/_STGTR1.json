   "zh_hex": "15e7b7e7bd02efceef4defcfe7b6ef67e7cce7b4efb1e84e090900000000000000"
  },
  {
   "jp_offset": "0x13ec",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "『近接』と『射撃』の違いについてだ！",
   "zh_text": "也就是『近接』和『射击』、这两者的区{00}别！",
   "jp_hex": "150cf0220d310cf01c0d37e0991734f0ab2f2b060000",
   "zh_hex": "15e7c0e7c5e7b60cefd8efce0de7d30cef65e7cc0d02e7b9e97def6ee7b4ef3500e7e5ef9700000000000000"
  },
  {
   "jp_offset": "0x1424",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "{01}{01}『近接』と『射撃』の違い",
   "zh_text": "{01}{01}近战射击区别",
   "jp_hex": "1501010cf0220d310cf01c0d37e099170000",
   "zh_hex": "150101efd8ef28ef65e7ccef35e7e5000000"
  },
  {
   "jp_offset": "0x1436",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『近接』は弾数がなく、命中率も高い{00}かわりに攻撃が遅くなります",
   "zh_text": "『近接』没有弹数限制、命中率也高、但{00}出手会慢一些",
