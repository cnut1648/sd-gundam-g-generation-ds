  },
  {
   "jp_offset": "0x1696",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "……と、こんな風に{00}『射撃』の方が先に当たるわけだ",
   "zh_text": "……就像这样、『射击』会先一步命中",
