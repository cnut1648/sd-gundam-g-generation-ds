  },
  {
   "jp_offset": "0x1574",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "そこだ！",
   "zh_text": "就是这里！上！",
   "jp_hex": "15f11b2b060000",
   "zh_hex": "15e7c5e7b6e7b9ef31ef97ef4cef9700000000"
  },
  {
   "jp_offset": "0x15d4",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "今、ザクが選んだのが『近接』",
   "zh_text": "刚才、扎古选的就是『近接』",
   "jp_hex": "15a202f4281ce39a4d2b371c0cf0220d0000",
   "zh_hex": "15e8bce83602e84be84de966e7b4e7c5e7b60cefd8efce0d0000000000"
  },
  {
   "jp_offset": "0x15f0",
   "jp_len": 35,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "命中率やクリティカル率が高く、{00}何土でも使えるのが特弔だ",
   "zh_text": "命中率和暴击率都高、而且能无限次使用{00}、这是它的特点",
