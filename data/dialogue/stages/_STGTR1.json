  },
  {
   "jp_offset": "0x1238",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "罗贝托·卡帕",
   "jp_text": "まずは「チーム」についてだ！",
   "zh_text": "首先、是关于『小队』！",
   "jp_hex": "15f15b38e00bf29de00c34f0ab2f2b060000",
   "zh_hex": "15ef40ef8b02e7b6e8bbe8790ce83ee7c90def9700000000000000"
  },
  {
   "jp_offset": "0x1276",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "罗贝托·卡帕",
   "jp_text": "こうやって、同じマスに複数の{00}ユニットがいる状態が『チーム』だ！",
