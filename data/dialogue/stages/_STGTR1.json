   "zh_hex": "15e7f8e845ef4eefba02e7b9e7da02e7c4e7f3e7d0050000000000"
  },
  {
   "jp_offset": "0x1f96",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "ああ、かまわないよ",
   "zh_text": "啊啊、没问题",
   "jp_hex": "15f05602f2774b3317450000",
   "zh_hex": "15e7c3e7c302e7d8e997ea120000000000"
  },
  {
   "jp_offset": "0x1fc7",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "玛利根",
   "jp_text": "シャア大佐！",
   "zh_text": "夏亚大佐！",
   "jp_hex": "15f023f05c060000",
   "zh_hex": "15ef37e7d6efa5efbaef970000000000"
  },
  {
   "jp_offset": "0x1fcf",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "玛利根",
   "jp_text": "シーマ中佐からそろそろ演習を{00}再開したいとの連乱がありました！",
   "zh_text": "西玛中佐传来联络、说差不多想重启演习{00}了！",
