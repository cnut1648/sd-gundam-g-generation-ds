   "zh_hex": "150909e7c5e8e9e7b9e7da020cef65e7cc0de7e2ef8befb6ea93e853ef4e000000000000000000"
  },
  {
   "jp_offset": "0x16e8",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "そうじゃないだろう！{00}もう一回、やり直しだ！！",
   "zh_text": "不是那样的！再给我重来一次！！",
   "jp_hex": "15f009244233172b4a180600f02af91a02f396232b06060000",
   "zh_hex": "15e7b5e7b6e7b7e7dae7b4ef97e80be839efcce8a1efcfefb6e864ef97ef97000000000000000000000000"
  },
  {
   "jp_offset": "0x1726",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "なるほど、基本のあたりは{00}きっちりとおさえてるようだねえ",
   "zh_text": "原来如此、看来基础部分、你们掌握得相{00}当扎实嘛",
   "jp_hex": "15f15802f57237f47a3800f5c8f59c2219f01df0072bf1b10000",
   "zh_hex": "15e8e4efcfe7f0e7ca02e7f6efcfe829eb96ef70efae02e7b8e7bbeb36eb37e80ae8b100ef53e84be87fe93600000000"
  },
  {
   "jp_offset": "0x1740",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "けど、戦いってのは楽に勝てるような{00}相手ばっかりじゃあないよ",
   "zh_text": "不过、战斗里、可不全是能让你轻松取胜{00}的对手哦",
   "jp_hex": "15f0f702b9172d2f3738e11334e2f9f01df0073300f05ff814f0cb3317450000",
   "zh_hex": "15e7b5ef3602ef28e7ffef3102e7c4e7b5efb4e7b6e7c6e7f9e7b8e990e9e0e987e8db00e7b4e7beef66e9190000000000"
  },
  {
   "jp_offset": "0x1785",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "たとえば、こいつはザクなんかより{00}装甲や火力は上……",
   "zh_text": "比方说、这家伙的装甲和火力、都在扎古{00}之上……",
   "jp_hex": "15f1c13902f1d638f428334d1bf02d00f31a43f4a338b209090000",
   "zh_hex": "15e825efb1e7ed02e7b9e7dfe7fde7b4e98febdbe7d3e8daefb002e840ef29e84be84d00e7cdef4c09090000000000"
  },
  {
   "jp_offset": "0x17a0",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "動かしてるのもAIなんかじゃなくて{00}海兵隊の腕離きさね",
   "zh_text": "而且、驾驶它的、也不是什么AI、而是{00}海兵队的好手",
   "jp_hex": "15f1e723f01d3741e01c12334df72f42f0432f00f3b837fec922360000",
   "zh_hex": "15e89ce99902e953e975e978e7b402e7c0e7b5e7b6e7dde7bdea9cef6202e89ce7b600e91bef93e7c9e7b4e7c7ef66000000000000"
  },
  {
   "jp_offset": "0x17bd",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "さて、こういうのを相手にどう戦う？",
   "zh_text": "那么、面对这样的对手、你们打算怎么打{00}？",
   "jp_hex": "15f2a002f46e374cf05f34f053b918050000",
   "zh_hex": "15e7b7e7bd02e862e7bee7b9e7dae7b4e7beef6602e7b8e7bbe7f5e889e7f2e7bde7f5000500000000"
  },
  {
   "jp_offset": "0x17f4",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "そういう相手には{00}『IDコマンド』が有効だな",
   "zh_text": "对付那样的对手、『ID指令』就很有效{00}了",
   "jp_hex": "15f0f6f05f3438000cf003f2010d1cf75a2b330000",
   "zh_hex": "15e7bee97ee7b7e7dae7b4e7beef66020cef62ef96e8c0e94e0de7c5e981e7cbea8f00e7ba000000000000"
  },
  {
   "jp_offset": "0x182b",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "{01}{01}{01}{01}『IDコマンド』",
   "zh_text": "{01}{01}{01}{01}ID指令",
   "jp_hex": "15010101010cf003f2010d0000",
   "zh_hex": "15010101011211e8c0e94e0000"
  },
  {
   "jp_offset": "0x1838",
   "jp_len": 34,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "各キャラクターは『IDコマンド』と{00}呼ばれる特殊能力を持っています",
   "zh_text": "每个角色、都拥有一种名为『ID指令』{00}的特殊能力",
   "jp_hex": "15e106f96a08380cf003f2010d3100e1fa394948f0a3f18d4ce29e2d2ff029250000",
   "zh_hex": "15ec25e828eb1ae89f02e840eb35e7cbefb6e7d1e8ace7c10cef62ef96e8c0e94e0d00e7b4e7cfed7be7c6efb0000000000000"
  },
  {
   "jp_offset": "0x185a",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "戦闘時には、この『IDコマンド』を{00}使用することで、",
   "zh_text": "在战斗中、通过使用这个『ID指令』、",
   "jp_hex": "15f04faa343802f0050cf003f2010d4c00f293f004f00230020000",
   "zh_hex": "15ef29ef28e7ffef4e02ef59ef36e83fefb3e7b9e8280cef62ef96e8c0e94e0d020000000000000000"
  },
  {
   "jp_offset": "0x1875",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "より多くのダメージを与えるなどの{00}効果を受けることができます",
   "zh_text": "就能获得诸如、造成更多伤害之类的效果",
   "jp_hex": "15f02df1c437f00b4cf1ea48f0393700f4e74cf0c248f0021cf017f0250000",
   "zh_hex": "15e7c5e7c6e9d8e80aea56e7f002e93ee837e952e7e9e8f9e988e7cde841e7b4ea8fe87100000000"
  },
  {
   "jp_offset": "0x18b9",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "ではアボリー、{00}手本を見せてやってくれ",
   "zh_text": "那么阿波利、就由你来示范给大家看看吧",
   "jp_hex": "15f00af3a70200f7ea4cf0da2f432d2ff0150000",
   "zh_hex": "15e7b7e7bde7d2e9a8e82e02e7c5e8a6e7b8efcfeab0ec8ee839efa5e7dfe7f6e7f6e7d000000000"
  },
  {
   "jp_offset": "0x18e8",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "了解です！",
   "zh_text": "明白！",
   "jp_hex": "15f0863025060000",
   "zh_hex": "15ef39e809ef97000000"
  },
  {
   "jp_offset": "0x1915",
   "jp_len": 19,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "俺が持ってる『IDコマンド』は……",
   "zh_text": "我所拥有的『ID指令』、有这么几个…{00}…",
   "jp_hex": "15881ce29e2df01d0cf003f2010d3809090000",
   "zh_hex": "15efcce7fbeb35e7cbe7b40cef62ef96e8c0e94e0d02e7cbe7b9e7bdeaa5e8280900090000000000"
  },
  {
   "jp_offset": "0x1946",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "……こんな感じだ！",
   "zh_text": "……就是这些！",
   "jp_hex": "150909f04af10b2b060000",
   "zh_hex": "150909e7c5e7b6e7b9e8a4ef97000000"
  },
  {
   "jp_offset": "0x1951",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "この内……",
   "zh_text": "其中……",
   "jp_hex": "15f005e49b09090000",
   "zh_hex": "15e8cfef4e09090000"
  },
  {
   "jp_offset": "0x195a",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "「……いけるか！？」には{00}ダメージと命中を増やす効果がある！",
   "zh_text": "这个『……能行吗！？』、有着提升伤害{00}和命中的效果！",
   "jp_hex": "15e00b0909f0b6481b0605e00c343800f00b31f5be4cf63425f4e71cf00f060000",
   "zh_hex": "15e7b9e8280c0909e7c6efd6e802ef97050d02e7cbe86de821ed2be8f9e98800e7d3e853ef4ee7b4ea8fe871ef970000000000000000000000"
  },
  {
   "jp_offset": "0x19a0",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "とりあえず、コイツを使って{00}あのMSを倒すぞ！",
   "zh_text": "总之、先用它、把那台MS给打倒吧！",
   "jp_hex": "15f24d02f1894ce27c2d2f00f01af02c4ce4732529060000",
   "zh_hex": "15e881e7cd02ef8befb3e97802e81be7b7ea16efa7ef9ee839e7f5e848e7d0ef97000000000000"
  },
  {
   "jp_offset": "0x19dd",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "武器選択画面で『IDコマンド』に{00}カーソルを合わせて決定すると…",
   "zh_text": "在武器选择画面上、把光标移到『ID指{00}令』并确定后……",
   "jp_hex": "15f08af3b0f82d300cf003f2010d3400f1a0e067824cf5652ff576f0f9090000",
   "zh_hex": "15ef29e8ece8c3e966eaaaecefe862ef4c02e81be83de96fec83e7d70cef62ef96e8c000e94e0de957e88ce867e7fe090900000000000000"
  },
  {
   "jp_offset": "0x19fd",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "この『IDコマンド選択画面』に来る",
   "zh_text": "就会进入这个『ID指令选择画面』",
   "jp_hex": "15f0050cf003f201f3b0f82d0d34f0bb0000",
   "zh_hex": "15e7c5e7e2e892e891e7b9e8280cef62ef96e8c0e94ee966eaaaecefe8620d000000"
  },
  {
   "jp_offset": "0x1a0f",
   "jp_len": 30,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "ここで使いたい『IDコマンド』を{00}選択して「決定」だ！",
   "zh_text": "在这里、选好想用的『ID指令』、再按{00}『确定』！",
   "jp_hex": "15f03e30f5042a170cf003f2010d4c00f3b0232fe00bf576e00c2b060000",
   "zh_hex": "15ef29e7b9ef3102e966e7c7e7e6efb3e7b40cef62ef96e8c0e94e0d02e80bea76000ce88ce8670def970000000000000000"
  },
  {
   "jp_offset": "0x1a44",
   "jp_len": 35,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "こんな風に『IDコマンド』を使えば{00}強敵との戦いも有離に進められる",
   "zh_text": "像这样活用『ID指令』、对上强敌、也{00}能把战局往有利的方向推进",
   "jp_hex": "15f04ae51a340cf003f2010d4ce27c193900fc7b3137b9f17ff61134f25c4649480000",
   "zh_hex": "15e8e9e7b9e7dae8d4efb30cef62ef96e8c0e94e0d02e7beef4ce8ade7e302e7c000e7c6e81bef28ea8ce911e7cbe82ee7b4efb1efc1eaabe892000000000000"
  },
  {
   "jp_offset": "0x1a67",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "ただし、ひとつ気をつけなくては{00}ならないことがある",
   "zh_text": "不过、有一点、是必须得注意的",
   "jp_hex": "15f3c602f22c934cf0c9f0432f380033463317f0021cf00f0000",
   "zh_hex": "15e7b5ef3602e7cbefb6e82202e7b6e860e9a2e80aeaccef3ce7b400000000000000"
  },
  {
   "jp_offset": "0x1a81",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "それは、『IDコマンド』の使用には{00}『SP』が必要ということだ",
   "zh_text": "那就是、使用『ID指令』、是需要消费{00}『SP』的",
   "jp_hex": "15f00838020cf003f2010d37f2933438000cf3f00d1cf0b5311718f0022b0000",
   "zh_hex": "15e7b7e7c5e7b602e83fefb30cef62ef96e8c0e94e0d02e7b6e92def2ae928e95d000cef9eeed40de7b4000000000000000000"
  },
  {
   "jp_offset": "0x1ac3",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "{01}{01}{01}{01}『SPについて』",
   "zh_text": "{01}{01}{01}{01}关于SP",
   "jp_hex": "15010101010cf3f034f0ab2f0d0000",
   "zh_hex": "1501010101e8bbe879ef9eeed40000"
  },
  {
   "jp_offset": "0x1ad2",
   "jp_len": 35,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "各キャラクターは精身力を表わす{00}『SP』という値を持っています",
   "zh_text": "每个角色、都拥有一个代表精神力的、名{00}为『SP』的数值",
   "jp_hex": "15e106f96a0838f3d4da4ce4fe4b25000cf3f00d311718e4104ce29e2d2ff029250000",
   "zh_hex": "15ec25e828eb1ae89f02e840eb35e7cbefb6e828e8e7e9e7e98de9aaefb0e7b402e8ac00e7c10cef9eeed40de7b4e914ec48000000000000"
  },
  {
   "jp_offset": "0x1af5",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『IDコマンド』を使用すると、",
   "zh_text": "每当使用『ID指令』时、",
   "jp_hex": "150cf003f2010d4cf293f0f9020000",
   "zh_hex": "15ec25ef53e83fefb30cef62ef96e8c0e94e0def2d0200000000"
  },
  {
   "jp_offset": "0x1b04",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "コマンドごとに決められた『SP』を{00}消費します",
   "zh_text": "就会消费掉、各个指令所规定的『SP』",
   "jp_hex": "15f201f1c534f2d846492a0cf3f00d4c00f8a8f012250000",
   "zh_hex": "15e7c5e7e2e928e95de9d302e819e828e8c0e94ee7fbea42e867e7b40cef9eeed40d00000000"
  },
  {
   "jp_offset": "0x1b1c",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "強力なコマンドほど消費する『SP』は{00}大きくなります",
   "zh_text": "指令越是强力、所消费的『SP』、也就{00}越多",
   "jp_hex": "15f35033f201f095f8a8f0040cf3f00d3800f33e1e3347f0250000",
   "zh_hex": "15e8c0e94eea57e7b6e8adefb002e7fbe928e95de7b40cef9eeed40d02e7c0e7c500ea57e7e9000000000000"
  },
  {
   "jp_offset": "0x1b37",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "{01}{01}{01}{01}{01}『SPの増減』",
   "zh_text": "{01}{01}{01}{01}{01}SP增减",
   "jp_hex": "1501010101010cf3f037e3bfe1f30d0000",
   "zh_hex": "150101010101ef9eeed4ea3ded24000000"
  },
  {
   "jp_offset": "0x1b48",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "各キャラクターは『緒期SP値』という{00}数値を持っていて、",
   "zh_text": "每个角色、都拥有一个名为『初始SP{00}值』的数值、",
   "jp_hex": "15e106f96a08380cf2c5f3f0e4100d31171800e353e4104ce29e2d2f172f020000",
   "zh_hex": "15ec25e828eb1ae89f02e840eb35e7cbefb6e828e8ace7c10ceb4fe908ef9eeed400ec480de7b4e914ec480200000000000000000000"
  },
  {
   "jp_offset": "0x1b69",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "これがステージ開始時に持っている{00}『SP』となります",
   "zh_text": "它就是关卡开始时、所持有的『SP』",
   "jp_hex": "15f00e1cf438f0b1aa34e29e2d2f1748000cf3f00df395f0250000",
   "zh_hex": "15e978e7c5e7b6e8bbe801e7fae908ef2d02e7fbe9efe7cbe7b40cef9eeed40d0000000000"
  },
  {
   "jp_offset": "0x1b84",
   "jp_len": 36,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "以後、『SP』はターンが経過するごと{00}に一定値ずつ上沼していきます",
   "zh_text": "在那之后、随着回合推进、『SP』每回{00}合都会上升一定的数值",
   "jp_hex": "15f6ba020cf3f00d38f06e1cfc87f004f1c50034fb72e410262ef842232f17f0d1250000",
   "zh_hex": "15ef29e7b7e7cde7fe02e9a1e86def52efc0eaabe892020cef9eeed40dec25ef5200efc0e840e7e2ef4ced2befb6e867e7b4e914ec4800000000000000000000000000"
  },
  {
   "jp_offset": "0x1ba8",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "また、敵を撃破したり特定のイベントを{00}起こすことでも上沼します",
   "zh_text": "此外、击破敌人、或是触发特定事件、也{00}会让它上升",
   "jp_hex": "15f09e02c34cf069232a47f9b637f2bf4c00f16a25f002f01bf842f012250000",
   "zh_hex": "15e7cae8f702e7ccef6de7e3efb202e905e7b6ef48e870e7cfe867efb8e99102e7c000e7e2e7f9e978ef4ced2b000000000000000000"
  },
  {
   "jp_offset": "0x1be6",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "ステージの始めは『SP』も少なくて{00}強力なコマンドは使えないが……",
   "zh_text": "关卡刚开始时、『SP』也少、用不了强{00}力的指令……",
   "jp_hex": "15f43837f1f8380cf3f00d41f3191e2f00f35033f20138e27c1933171c09090000",
   "zh_hex": "15e8bbe801e8bce7fae908ef2d020cef9eeed40de7c0efac02efb3e7b5e7bae8ad00efb0e7b4e8c0e94e0909000000000000000000"
  },
  {
   "jp_offset": "0x1c07",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "ターンの経過や、敵をたくさん鎮とす{00}ことで『SP』を{SLOT:1942}めれば、",
   "zh_text": "但只要靠回合推进、或多击坠敌人、把{00}『SP』积累起来、",
   "jp_hex": "15f06e37fc874302c34cf9ebe43d312500f002300cf3f00d4cfa774939020000",
   "zh_hex": "15e7dbef32ef2ae8c7ef52efc0eaabe89202e905e7e9e7cceb53e7e3efb202e81b000cef9eeed40ded99ec33e847efcf02000000000000"
  },
  {
   "jp_offset": "0x1c27",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "強力な『IDコマンド』を使うことが{00}できるようになる",
   "zh_text": "就能使用那些强力的『ID指令』了",
   "jp_hex": "15f350330cf003f2010d4ce27c18f0021c00f01748f0073433480000",
   "zh_hex": "15e7c5e7c6e83fefb3e7b7e8a4e8adefb0e7b40cef62ef96e8c0e94e0de7ba00000000000000"
  },
  {
   "jp_offset": "0x1c43",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "傷盤から効果の承さなコマンドを{00}こまめに使うか、",
   "zh_text": "是从开局就勤用那些效果小的指令、",
   "jp_hex": "15e2f4e4e21b46f4e737f3c7f2014c00213d4034e27cf0c8020000",
   "zh_hex": "15e7b6e88ae7faea8ce7c5ed29efb3e7b7e8a4ea8fe871e83ee7b4e8c0e94e02000000000000"
  },
  {
   "jp_offset": "0x1c5e",
   "jp_len": 35,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "あるいは時間をかけて『SP』を{SLOT:1942}め、{00}強力なコマンドで勝負を決めるか……",
   "zh_text": "还是花时间把『SP』积累起来、用强力{00}指令一举定胜负……",
   "jp_hex": "15f499f13f4cf0f02f0cf3f00d4cfa770200f35033f20130f2554cf2d8481b09090000",
   "zh_hex": "15e7f7e7b6eb9fef2de8fce81b0cef9eeed40ded99ec33e847efcf02efb3e8adefb000e8c0e94eefb6ea21e867e8dbe92c09090000000000"
  },
  {
   "jp_offset": "0x1c81",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "『SP』をどうコントロールするかは{00}戦闘の重要な要素だ",
   "zh_text": "如何调控『SP』、是战斗中、十分重要{00}的一环",
   "jp_hex": "150cf3f00d4cf053f49df0041b3800f04f37f53233fa762b0000",
   "zh_hex": "15e7f0efbce95cea3f0cef9eeed40d02e7b6ef28e7ffef4e02ea4aefaee8a1ef2a00e7b4efb6ef4700000000"
  },
  {
   "jp_offset": "0x1ca5",
   "jp_len": 35,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "では、この『IDコマンド』を使った{00}戦闘を実鈴してみることにしよう",
   "zh_text": "那么、就来实地演练一下、运用『ID指{00}令』的战斗吧",
   "jp_hex": "15f00a02f0050cf003f2010d4ce27c2d2a00f04f4cff5e232f3e48f0023423f0070000",
   "zh_hex": "15e7b7e7bd02e7c5efcfe87fef63ea2feb13efb6ef4d02e986efb30cef62ef96e8c000e94e0de7b4ef28e7ffe7d0000000000000000000"
  },
  {
   "jp_offset": "0x1ced",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "敵は強力なMSが2体……",
   "zh_text": "敌人、是两台强力的MS……",
   "jp_hex": "15c338f35033f02c1c0fbc09090000",
   "zh_hex": "15e7e3efb202e7b6e97dea16e8adefb0e7b4efa7ef9e0909000000"
  },
  {
   "jp_offset": "0x1cfc",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "これを『チーム』や『IDコマンド』を{00}活用して撃破する",
   "zh_text": "活用『小队』和『ID指令』、把它们击{00}破",
   "jp_hex": "15f00e4c0cf29d0d430cf003f2010d4c00fa19232ff069f0040000",
   "zh_hex": "15e8d4efb30ce83ee7c90de7d30cef62ef96e8c0e94e0d02e81be978e7bbe7cc00ef6d00000000000000"
  },
  {
   "jp_offset": "0x1d17",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "アボリー、ロベルト、シーマ中佐に{00}お前たちの腕を見せてやれ！",
   "zh_text": "阿波利、罗伯托、给西玛中佐、露一手你{00}们的本事！",
   "jp_hex": "15f3a702f3e002f08ff0a03400f021f00637e6094cf0da2f4349060000",
   "zh_hex": "15e7d2e9a8e82e02e7eceaa4e7f402e839e7f8e845ef4eefba02e858efb6ef66e7b800e7bbe7b4efa6efb8ef9700000000000000000000"
  },
  {
   "jp_offset": "0x1d59",
   "jp_len": 14,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "こいつは……いけるか！？",
   "zh_text": "这家伙……能行吗！？",
   "jp_hex": "15f1d6380909f0b6481b06050000",
   "zh_hex": "15e7b9e7dfe7fd0909e7c6efd6e802ef9705000000000000"
  },
  {
   "jp_offset": "0x1d8f",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "行けえっ！",
   "zh_text": "上啊——！",
   "jp_hex": "159f1fe04d2d060000",
   "zh_hex": "15ef4ce7c3ebafebafef9700000000"
  },
  {
   "jp_offset": "0x1dc0",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "む……どうした？{00}アボリー、ロベルト？",
   "zh_text": "唔……怎么了？阿波利、罗伯托？",
   "jp_hex": "153f0909f07f2a0500f3a702f3e0050000",
   "zh_hex": "15e81d0909e7f2e7bde7ba05e7d2e9a8e82e02e7eceaa4e7f405000000000000"
  },
  {
   "jp_offset": "0x1dec",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "す…すみません、大佐……",
   "zh_text": "对、对不起、大佐……",
   "jp_hex": "152509253e3d274d02f05c09090000",
   "zh_hex": "15e7be02e7bee7b5e84702efa5efba09090000000000"
  },
  {
   "jp_offset": "0x1e16",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "罗贝托·卡帕",
   "jp_text": "もう一土やらせてください！{00}今土こそは……",
   "zh_text": "请再让我们来一次！这一次、一定……",
   "jp_hex": "15f02af24e4346272ff083170600f15df0653809090000",
   "zh_hex": "15e83ae80be7f9efcce7bbefcfefb6e864ef97e7b9efb6e86402efb6e86709090000000000000000"
  },
  {
   "jp_offset": "0x1e48",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "ったく、しょうがないね……",
   "zh_text": "真是的、拿你们没办法……",
