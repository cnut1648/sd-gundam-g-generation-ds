  },
  {
   "jp_offset": "0x161d",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "ただし……",
   "zh_text": "不过……",
   "jp_hex": "15f3c609090000",
   "zh_hex": "15e7b5ef3609090000"
  },
  {
   "jp_offset": "0x164c",
   "jp_len": 34,
   "kind": "dialogue",
   "speaker": "阿波利",
   "jp_text": "相手が『射撃』を選んだ場合、{00}先に攻撃されるのが弱点だ！",
   "zh_text": "缺点是、一旦对方选了『射击』、就会被{00}对方抢先攻击！",
   "jp_hex": "15f05f1c0cf01c0d4ce39a4d2bf1af0200b834f01f224948371ce2bbe4632b060000",
