   "zh_hex": "15e825e847e7b9e82802afeb3be7b4e87ae877e840e8eaee05e7bae7d0050000000000000000"
  },
  {
   "jp_offset": "0x1d38",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "德托洛夫·科塞尔",
   "jp_text": "へい！{00}もういつでも出られますぜ",
   "zh_text": "是！现在随时都能出港了",
   "jp_hex": "153b170600f02af1b7f01baf4649f025e0530000",
   "zh_hex": "15e7b6ef97e82fef29e9a1ef2de840e7c6efbeeb3be7ba0000000000"
  },
  {
   "jp_offset": "0x1d67",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "よし！{00}リリーマルレーン、発進だよ！",
   "zh_text": "好！莉莉·玛莲号、出航！",
   "jp_hex": "15f0910600f770f87102f1012b45060000",
   "zh_hex": "15e7c7ef97e81ee81eef4be845ecffe83302efbee9c1ef9700000000"
  },
  {
   "jp_offset": "0x1d93",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "德托洛夫·科塞尔",
   "jp_text": "了解でさ！",
   "zh_text": "收到！",
   "jp_hex": "15f0863022060000",
   "zh_hex": "15e926e7d7ef970000"
  },
  {
   "jp_offset": "0x4b7a",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『宇宙世紀0079、1月3日』",
   "zh_text": "『宇宙世纪0079、1月3日』",
   "jp_hex": "150cf0a8f695fc07020ee1d610e4a40d0000",
   "zh_hex": "150ce8bee8bfe83ceb99e998e998eb79eca402eff7e850ef60e98a0d000000"
  },
  {
   "jp_offset": "0x4b96",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『サイド2コロニー』",
   "zh_text": "『SIDE2殖民地』",
   "jp_hex": "150cf1820ff09b0d0000",
   "zh_hex": "150cef9eef62ef96ef9fef5fe8a9ef38ef630d000000"
  },
  {
   "jp_offset": "0x4bbe",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『たっ、隊長！』",
   "zh_text": "『队、队长！』",
   "jp_hex": "150c2a2d02f104060d0000",
   "zh_hex": "150ce7c902e7c9ef34ef970d000000"
  },
  {
   "jp_offset": "0x4bce",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『コロニーが……』",
   "zh_text": "『殖民地它……』",
   "jp_hex": "150cf09b1c09090d0000",
   "zh_hex": "150ce8a9ef38ef63e97809090d000000"
  },
  {
   "jp_offset": "0x4bde",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『人が……{00}{01}人が死んで……』",
   "zh_text": "『人……人全都死了……』",
   "jp_hex": "150cb41c09090001b41ca74d3009090d0000",
   "zh_hex": "150cefb20909efb2efb4e840ef6ae7ba09090d00000000000000"
  },
  {
   "jp_offset": "0x4bf6",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "『……シーマ隊長！！』",
   "zh_text": "『……西玛队长！！』",
   "jp_hex": "150c0909f08ff10406060d0000",
   "zh_hex": "150c0909e7f8e845e7c9ef34ef97ef970d000000"
  },
  {
   "jp_offset": "0x4c06",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "あ……{00}そ、そんな……",
   "zh_text": "啊……怎、怎么会……",
   "jp_hex": "15160909002802f02609090000",
   "zh_hex": "15e7c30909e7f202e7f2e7bde7e20909000000"
  },
  {
   "jp_offset": "0x4c1d",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "あれは債{SLOT:1928}ガスだって……",
   "zh_text": "那明明说是刺激性气体……",
   "jp_hex": "15f03038e24ee6a8f6b8f05409090000",
   "zh_hex": "15e7b7ef39ef39e7ede7b6ed26e9b9e951e8edef4f0909000000"
  },
  {
   "jp_offset": "0x4c37",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "アタシは……",
   "zh_text": "我……",
   "jp_hex": "15f07b3809090000",
   "zh_hex": "15efcc0909000000"
  },
  {
   "jp_offset": "0x4c49",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "毒ガスだなんて……",
   "zh_text": "是毒气……",
   "jp_hex": "15e493f6b82bf06609090000",
   "zh_hex": "15e7b6eb5fe8ed0909000000"
  },
  {
   "jp_offset": "0x4c62",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "(narration)",
   "jp_text": "アタシは知らなかったんだよ！！",
   "zh_text": "我当时根本就不知道啊！！",
   "jp_hex": "15f07b38f149f0772d2a4d2b4506060000",
   "zh_hex": "158bc4ef2de9b8d2e7c5e7b5e85ae82ae7c30606000000000000000000"
  },
  {
   "jp_offset": "0x4d0e",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "康斯康",
   "jp_text": "なるほど！{00}シャアが木馬を撃ち損じたか！！",
   "zh_text": "原来如此！夏亚没能击沉木马吗！",
   "jp_hex": "15f1580600f0231cf2404c992ce3d524f03d06060000",
   "zh_hex": "15e8e4efcfe7f0e7caef97ef37e7d6e7d8e7c6e7cce983efa9e84fe802ef97000000"
  },
  {
   "jp_offset": "0x4d3f",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "吉恩士官",
   "jp_text": "木馬はサイド6方面へ{00}亜走したもようです",
   "zh_text": "木马似乎已朝SIDE6方向逃走了",
   "jp_hex": "15f24038f182e018f5103b00fb17232a41f00730250000",
   "zh_hex": "15efa9e84fe944e933ef3aeaadef9eef62ef96ef9fe9cdefb1efc1e8c2e890e7ba0000000000"
  },
  {
   "jp_offset": "0x4d71",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "康斯康",
   "jp_text": "なんとも好都合だな！",
   "zh_text": "这可真是再凑巧不过了！",
   "jp_hex": "15f12841f6172b33060000",
   "zh_hex": "15e7b9e7c4e820e7b6e80becb1ec13e7b5ef36e7baef97000000"
  },
  {
   "jp_offset": "0x4d7c",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "康斯康",
   "jp_text": "よし！{00}ただちに艦隊を発進させろ！",
   "zh_text": "好！立刻让舰队出击！",
   "jp_hex": "15f0910600f0442c34f0684cf101f02e4a060000",
   "zh_hex": "15e7c7ef97e86be91fe7f9e7d4e7c9efbee7ccef9700000000"
  },
  {
   "jp_offset": "0x4d90",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "康斯康",
   "jp_text": "シャアの見ている前で{00}木馬を討ち取ってくれる！！",
   "zh_text": "就当着夏亚的面、把木马给击沉！",
   "jp_hex": "15f023379a2f1748ba3000f2404ce4842ce2bd2d2ff0154806060000",
   "zh_hex": "15e7c5ef53e86def37e7d6e7b4e86202e81befa9e84fe839e7cce983ef97000000000000"
  },
  {
   "jp_offset": "0x4e12",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "これまでの戦い、ご苦漏",
   "zh_text": "一路辛苦了",
   "jp_hex": "15f00ef02b37b91702f6420000",
   "zh_hex": "15efb6e8d2ea58e9e6e7ba0000"
  },
  {
   "jp_offset": "0x4e1f",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "この「宇宙世紀ルート」を最後まで{00}遊んでくれて感射する",
   "zh_text": "感谢你将这条『宇宙世纪路线』一直玩到{00}了最后",
   "jp_hex": "15f005e00bf0a8f695fb35e00c4cf145f02b00e5ae4d30f0152ff288f0040000",
