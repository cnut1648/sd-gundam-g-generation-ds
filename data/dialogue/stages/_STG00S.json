   "zh_hex": "15ea94ea3eefa6e88deab9e7c4e9d6e9ad02e7cde7fee7c0e87be965e7b8e7c6e8f2e88b00e970ef4de7eb00000000"
  },
  {
   "jp_offset": "0x4e83",
   "jp_len": 39,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "また、本ルートを最後まで遊んでくれた{00}君には特別ステージも用意されている",
   "zh_text": "此外、为将本路线玩到最后的你、还准备{00}了特别关卡",
   "jp_hex": "15f09e02d2fb354cf145f02be5ae4d30f0152a00973438e490e534f43841f21622492f17480000",
   "zh_hex": "15e7cae8f702e7c1e84aefa6e8d2e916e970e7d7e8c5e7fee7b4e7b802e7f7e87ae87700e7bae7cfe7e5e8bbe80100000000000000"
  },
  {
   "jp_offset": "0x4eaa",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "我々とは別に戦いを続けていた{00}アークエンジェル隊との特別演習だ",
   "zh_text": "那是与我们分头作战的大天使队的特别演{00}习",
   "jp_hex": "15f0183138e53434b9174cf1302ff01300f093f09abd3137e490e534f4722b0000",
   "zh_hex": "15e7b7e7b6e832efcce7bbefaee92eef2fef28e7b4efa5e844e83fe7c9e7b4e7cfe7e5ea2f00eab60000000000"
  },
  {
   "jp_offset": "0x4ecb",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "彼らと戦い、君が育ててきた部隊の{00}強さを確かめてみるのも良いだろう",
   "zh_text": "与他们一战、检验一下你亲手培养的部队{00}实力、也不错",
