  },
  {
   "jp_offset": "0x4f39",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "この先も最後まで{00}じっくり楽しんでほしい",
   "zh_text": "今后也希望你能尽情地玩到最后",
   "jp_hex": "15f005b841f145f02b00fed0f5d64d30f238170000",
   "zh_hex": "15efb9e7fee7c0e87be965e7b8e7c6e8f2e88bef63e970e7d7e8c5e7fe000000"
  },
  {
   "jp_offset": "0x4fb2",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "玛琉",
   "jp_text": "ここまで私のような頼りない艦長に{00}付き合ってくれて、ありがとう",
   "zh_text": "谢谢你一路陪着我这个不太可靠的舰长",
   "jp_hex": "15f03ef02ba837f00733e5c0473317f0343400f3c92d2ff0152f02f1340000",
