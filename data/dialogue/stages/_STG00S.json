  },
  {
   "jp_offset": "0x4ef0",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "フリーバトルで「特殊演習」を{00}選ぶことで彼らと戦うことができる",
   "zh_text": "在自由对战中选择『特别演习』、即可与{00}他们交战",
   "jp_hex": "15f33071f3cd30e00bf0a3f472e00c4c00e39ae05af00230f0d531b918f0021cf017480000",
   "zh_hex": "15ef29abe8a6e7beef28c0e966eaaa0ce7cfe7e5ea2feab60d02e855e7c4e83200e80ce7bbe861ef28000000000000000000"
  },
  {
   "jp_offset": "0x4f15",
   "jp_len": 36,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "…では、「SDガンダム{00}{01}{01}{01}{01}{01}GジェネレーシユンDS」",
   "zh_text": "……那么、『SD高达G世代DS』",
   "jp_hex": "1509f00a02e00b1411f041f048000101010101e020f9786f83085fe073851114e00c0000",
