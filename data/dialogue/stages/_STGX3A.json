  },
  {
   "jp_offset": "0x1b3d",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "見捨てちまったら親覚めが悪いからな",
   "zh_text": "把你们丢下不管、我可睡不安稳",
   "jp_hex": "15f4d92c3d2d2a46e330e10c401ce082171b46330000",
   "zh_hex": "15e81be7b8e7bbebb0ef4de7b5e93b02efcce7c4ebdee7b5e7fceb3e0000000000"
  },
  {
   "jp_offset": "0x1b78",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "アンタたち……",
   "zh_text": "你们……",
   "jp_hex": "15f08cf00609090000",
   "zh_hex": "15e7b8e7bb09090000"
  },
  {
   "jp_offset": "0x1b9c",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "もうデラーズ中将の本隊が{00}コロニーに向かってる",
   "zh_text": "迪拉兹中将的本队、已经朝殖民地去了",
   "jp_hex": "15f02af0d8f41e37f2c91c00f09b34f0582df01d0000",
   "zh_hex": "15ea11e7c2e856ef4ee84ae7b4efa6e7c902ef3ae8b7eaade8a9ef38ef63e7ebe7ba000000000000"
  },
  {
   "jp_offset": "0x1bb2",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "これ以上の長巨は無用だ{00}とっとと敵を扁付けて後退するぞ！",
   "zh_text": "不必再久留了、赶紧把敌人收拾掉、撤退{00}！",
   "jp_hex": "15f0ee37fd0138f3f92b00312d3131c34cf4da2ff0d3f00429060000",
   "zh_hex": "15e7b5e860e80be9dbe98ce7ba02ea04eaede81be7e3efb2e926eae6e9d302e90ae88000ef9700000000"
  },
  {
   "jp_offset": "0x1bef",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "辛·松永",
   "jp_text": "……昇知！",
   "zh_text": "……明白！",
   "jp_hex": "150909f23d060000",
   "zh_hex": "150909ef39e809ef970000"
  },
  {
   "jp_offset": "0x1c1c",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "やれやれ……{00}なんとか扁付いたみたいだな",
   "zh_text": "哎呀哎呀……总算是收拾干净了",
   "jp_hex": "1543494349090900f1281bf6d5f0133e2a172b330000",
   "zh_hex": "15e9dce9c6e9dce9c60909e881e889e7b6e926eae6e8d3ecb0e7ba0000000000"
  },
  {
   "jp_offset": "0x1c32",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "いつ後続が来るかもわからない{00}こんな場所はとっとと離れようぜ",
   "zh_text": "也不知敌方后续何时会来、这种地方、还{00}是赶紧离开吧",
   "jp_hex": "15f1b7f6c11cf0bb1b41f02446331700f04af24538312d3131f21ef007e0530000",
   "zh_hex": "15e7c0e7b5e85ae7e3efb1e7fee9adefbcef2de7e2efcf02e7b9e7d1ef63efb102e7f700e7b6ea04eaede901e7fae7d000000000000000"
  },
  {
   "jp_offset": "0x1c78",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……ライデン中佐！",
   "zh_text": "……强尼莱汀中佐！",
   "jp_hex": "150909f19ff0a0060000",
   "zh_hex": "150909e8ade896e846ed7cef4eefbaef970000"
  },
  {
   "jp_offset": "0x1c9d",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "ん？{00}どうしたい、シーマ中佐？",
   "zh_text": "嗯？怎么了、西玛中佐？",
   "jp_hex": "154d0500f07f2a1702f08ff0a0050000",
   "zh_hex": "15e86505e7f2e7bde7ba02e7f8e845ef4eefba050000000000"
  },
  {
   "jp_offset": "0x1cc8",
   "jp_len": 6,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "あ……",
   "zh_text": "啊……",
   "jp_hex": "151609090000",
   "zh_hex": "15e7c309090000"
  },
  {
   "jp_offset": "0x1cce",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……いや{00}除けに来てくれて……ありがとう",
   "zh_text": "……不、谢谢你来救我们",
   "jp_hex": "150909f06000f0db34d92ff0152f0909f1340000",
   "zh_hex": "150909e7b502e8b2e8b2e7b8efcfe8caefcce7bb0000000000"
  },
  {
   "jp_offset": "0x1ce2",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "アンタたちには感射してる……",
   "zh_text": "我真的很感激你们……",
   "jp_hex": "15f08cf0063438f28823f01d09090000",
   "zh_hex": "15efcce820e7b4e981e87de9b9e7b8e7bb09090000000000"
  },
  {
   "jp_offset": "0x1d0d",
   "jp_len": 14,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "……戦友だろ、俺たちは",
   "zh_text": "……我们、是战友嘛",
   "jp_hex": "150909f6312b4a0288f006380000",
   "zh_hex": "150909efcce7bb02e7b6ef28e960e936000000"
  },
  {
   "jp_offset": "0x1d40",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "………………",
   "zh_text": "…………",
   "jp_hex": "150909090909090000",
   "zh_hex": "150909090900000000"
  },
  {
   "jp_offset": "0x1d6e",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "吉恩士官",
   "jp_text": "……本隊より入電！",
   "zh_text": "……本队来电！",
   "jp_hex": "150909f2c9f02df66c060000",
   "zh_hex": "150909efa6e7c9efcfead3ef9700000000"
  },
  {
   "jp_offset": "0x1d7a",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "吉恩士官",
   "jp_text": "デラーズ中将の本隊が{00}アイランド·ブレイドの確勉に成功！",
   "zh_text": "迪拉兹中将的本队、已成功夺取殖民地{00}布雷德岛！",
   "jp_hex": "15f0d8f41e37f2c91c00f6af0475f0a26c37f37c34f188060000",
   "zh_hex": "15ea11e7c2e856c0e84ae7b4d2e7c902ef3ae837e9b1ea17e987e8a9ef38bf00e831e8afe82cecd006000000000000000000"
  },
  {
   "jp_offset": "0x1d94",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "吉恩士官",
   "jp_text": "「星の{SLOT:1951}作戦」最終暖階が{00}発動されました！",
   "zh_text": "『星之屑作战』的最终阶段、已经发动！",
   "jp_hex": "15e00bb537f4f6e00cf18cf6991c00f5ba2249f0522a060000",
   "zh_hex": "150cef69e7cdeb31ef2fef280de7b4e8c5e8e2ebfbea6b02ef3ae8b7e870ef30ef97000000000000"
  },
  {
   "jp_offset": "0x1dc8",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "辛·松永",
   "jp_text": "こちらへの指示は？",
   "zh_text": "我们这边的指示呢？",
   "jp_hex": "15f07a3b37f4e838050000",
   "zh_hex": "15efcce7bbe7b9e899e7b4e8c0eab0e90705000000"
  },
  {
   "jp_offset": "0x1dee",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "吉恩士官",
   "jp_text": "至急本隊に合流するようにと",
   "zh_text": "速与本队会合",
   "jp_hex": "15fa33f2c934f1b9f004f00734310000",
   "zh_hex": "15e9dae832d2e7c9e7e2a00000000000"
  },
  {
   "jp_offset": "0x1e19",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "こっから駆けつけるとなると{00}到中は作戦開始のチユイ後ってとこか",
   "zh_text": "从这里赶过去的话、抵达大概会在作战开{00}始后一会儿吧",
   "jp_hex": "15212d1b46f568483133483100f3a538f0e4f0b13766e073509c2d2f31211b0000",
   "zh_hex": "15e88ae7b9ef31ea04ef36e7ebe7b4e81f02e96eef2befa5ec76e7e2ef29ef2fef28e7fa00e908e7feefb6e7e2eb7ce7d00000000000"
  },
  {
   "jp_offset": "0x1e55",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……すまないね",
   "zh_text": "……真是抱歉",
   "jp_hex": "150909253d3317360000",
   "zh_hex": "150909e820e7b6e922e927000000"
  },
  {
   "jp_offset": "0x1e5f",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "さっきの戦闘でリリーマルレーンも{00}結構な損召を受けちまったから",
   "zh_text": "刚才那一战、莉莉·玛莲号也受了不小的{00}损伤",
   "jp_hex": "15f1f337f04f30f770f8714100f52d33f3234cf0c22c3d2df03d460000",
   "zh_hex": "15e8bce836e7b7efb6ef2802e81ee81eef4be845ecffe833e7c0e8c8e7bae7b5e83ee7b400ea28e8f90000000000"
  },
  {
   "jp_offset": "0x1e97",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "なあに……遅れた分、{00}大忙れしてやればいいだけさ",
   "zh_text": "没事……迟到的份、大闹一场补回来就是{00}了",
   "jp_hex": "153316340909f25d2acd0200bee55b49232f43493917172b1f220000",
   "zh_hex": "15e7d8efb80909ea10e7d7e7b4ea2202efa5ead8efb6e876ea81ef52efcfe7c5e7b600e7ba0000000000000000"
  },
  {
   "jp_offset": "0x1eb3",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "ま…とにかく、{00}今は本隊との合流が先決だ",
   "zh_text": "嘛……总之、眼下先与本队会合要紧",
   "jp_hex": "153d09f1f60200a238f2c93137f1b91cf4ae2b0000",
   "zh_hex": "15e9360909e881e7cd02e90bef4def8be832efa6e7c9e7e2efc0ef2aeaed000000000000"
  },
  {
   "jp_offset": "0x1ec8",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "とっとと先を急ごうぜ",
   "zh_text": "我们赶紧赶路吧",
   "jp_hex": "15312d3131b84ce172e05118e0530000",
   "zh_hex": "15efcce7bbea04eaedea04e8d2e7d00000000000"
  },
  {
   "jp_offset": "0x1ef3",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "德托洛夫·科塞尔",
   "jp_text": "へい！{00}了解でさ！",
   "zh_text": "是！明白！",
   "jp_hex": "153b170600f0863022060000",
   "zh_hex": "15e7b6ef97ef39e809ef97000000"
  },
  {
   "jp_offset": "0x1f16",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "………………",
   "zh_text": "…………",
   "jp_hex": "150909090909090000",
   "zh_hex": "150909090900000000"
  },
  {
   "jp_offset": "0x1f3a",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "よう、どうしたいシーマ中佐？{00}いつになくしおらしい様子じゃないか",
   "zh_text": "哟、怎么了西玛中佐？难得见你这么没精{00}神啊",
   "jp_hex": "15f00702f07f2a17f08ff0a00500f1b734f043231a46f150f44e244233171b0000",
   "zh_hex": "15eb2c02e7f2e7bde7bae7f8e845c0a305e866e80ae85ce7b8e7b9e7bde7d8e98d00e9aae7c300000000000000000000"
  },
  {
   "jp_offset": "0x1f76",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……ああ、ライデン中佐か{00}少し…考え事をしててね",
   "zh_text": "……啊、是强尼莱汀中佐啊、我在想点事{00}……",
   "jp_hex": "150909f05602f19ff0a01b00f10609f092a94c232f2f360000",
   "zh_hex": "150909e7c302e7b6e8ade896e846ed7cef4eefbae7c302efccef29e7e6e822efb80009090000000000"
  },
  {
   "jp_offset": "0x1faa",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "まあ、指揮官ってのも大変だろうからな",
   "zh_text": "嘛、当指挥官也不轻松啊",
   "jp_hex": "15f10902f0ed8f2d2f3741fa5a2b4af0c846330000",
   "zh_hex": "15e93602ef53e8c0e949ef92e7c0e7b5e990e9e0e7c30000000000"
  },
  {
   "jp_offset": "0x1fda",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "そうじゃないんだ……",
   "zh_text": "不是那样……",
   "jp_hex": "15f009244233174d2b09090000",
   "zh_hex": "15e7b5e7b6e7b7e7da09090000"
  },
  {
   "jp_offset": "0x1ff1",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……ライデン中佐{00}カケロウ…ってのを知ってるかい？",
   "zh_text": "……强尼莱汀中佐、你知道蜉蝣……这种{00}东西吗？",
   "jp_hex": "150909f19ff0a000f3ca092d2f374ce4112df01df0f5050000",
   "zh_hex": "150909e8ade896e846ed7cc0a302e7b8e85ae82aebf0ebf10909e7b9e7d100e8bae7f8e80205000000000000"
  },
  {
   "jp_offset": "0x2025",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "カケロウ？{00}虫の名前だっけか……",
   "zh_text": "蜉蝣？好像是种虫子的名字吧……",
   "jp_hex": "15f3ca0500e42337f18e2b2d1f1b09090000",
   "zh_hex": "15ebf0ebf105e7c7e8e9e7b6e7d1eb6de886e7b4e8ace980e7d0090900000000"
  },
  {
   "jp_offset": "0x2052",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "なんでもカケロウってのは成虫になって{00}数日で死んでしまうんだそうだよ",
   "zh_text": "听说那蜉蝣、变成成虫之后、过个几天就{00}死了",
   "jp_hex": "15f2e0f3ca2d2f3738f8b534332d2f00f5ae30a74d30f012184d2bf0092b450000",
   "zh_hex": "15e8d1e7ede7b7ebf0ebf102e955e837e837eb6de7cde7fe02ef36e828eaa5e844e7c500ef6ae7ba00000000"
  },
  {
   "jp_offset": "0x208e",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "で、そいつがどうかしたのか？",
   "zh_text": "那它怎么了？",
   "jp_hex": "153002f2cc1cf129232a371b050000",
   "zh_hex": "15e7b7e978e7f2e7bde7ba05000000"
  },
  {
   "jp_offset": "0x20b8",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "前にアタシらを「カケロウのような」{00}って言ったやつがいてね",
   "zh_text": "以前有人说我们『就像蜉蝣一样』",
   "jp_hex": "15ba34f07b464ce00bf3ca37f00733e00c002d2f9b2d2af1a61c172f360000",
   "zh_hex": "15e7f3ef51e7cbefb2e7edefcce7bb0ce7c5e8e9ebf0ebf1efb6e7da0d0000"
  },
  {
   "jp_offset": "0x20d7",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "はかなく消えちまうカケロウと{00}アタシらシーマ艦隊をひき疲べてたのさ",
   "zh_text": "把转瞬即逝的蜉蝣、拿来跟我们西玛舰队{00}相提并论",
   "jp_hex": "15f4951ef1612c3d18f3ca3100f07b46f08ff0684ce0571df5832f2a37220000",
   "zh_hex": "15e81be9c2ebdfe855ec9de7b4ebf0ebf102e9a7efcfe973efcce7bbe7f8e845e7d4e7c900e8b1e821e957e8dc00000000"
  },
  {
   "jp_offset": "0x20f7",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "一年戦争からコッチ{00}たいがいの悪事に手を染め……",
   "zh_text": "从一年战争到现在、什么坏事都干过……",
   "jp_hex": "15f1b8f0701b46f41f002a171c1737e082a934ae4cf74e09090000",
   "zh_hex": "15e88aefb6e909ef28e852e7d7e82fef2902e7dde7bde9edefb8e840e8d3ef36090900000000000000"
  },
  {
   "jp_offset": "0x2112",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "悪名高めながら{00}意地汚く生きてきたアタシらとね",
   "zh_text": "背着恶名、苟且偷生至今的我们",
   "jp_hex": "15f7d8fca5331c4600f5a0e0c61ef0882ff074f07b4631360000",
   "zh_hex": "15e9e4e86de7dee8ac02ee94e999ebb4ef8de897efb9e7b4efcce7bb0000000000"
  },
  {
   "jp_offset": "0x212c",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "お障いだろ？{00}こんなアタシらがカケロウとはさ",
   "zh_text": "很可笑吧？我们这种人、竟也被比作蜉蝣",
   "jp_hex": "15fea12b4a0500f04af07b461cf3ca31f1840000",
   "zh_hex": "15e981e7c4ea1ce7d0058be7bbe7b9e7d1b402ef2ce7c0e7f1e825ef2febf0ebf100000000000000"
  },
  {
   "jp_offset": "0x215b",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "そうでもないんじゃないか？",
   "zh_text": "倒也不见得吧？",
   "jp_hex": "15f009f01b33174d244233171b050000",
   "zh_hex": "15e848e7c0e7b5e85ce80ae7d0050000"
  },
  {
   "jp_offset": "0x2186",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……え？",
   "zh_text": "……咦？",
   "jp_hex": "15090919050000",
   "zh_hex": "150909ef4905000000"
  },
  {
   "jp_offset": "0x21a8",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "カケロウってのは{SLOT:1924}虫のまま{00}何年も過ごしてようやく成虫になるのさ",
   "zh_text": "蜉蝣啊、要以幼虫之身、度过好几年、才{00}终于变成成虫",
   "jp_hex": "15f3ca2d2f3738fd3b37f20700f88b41fa12232ff2a9f8b534334837220000",
   "zh_hex": "15ebf0ebf1e7c302ef2ae7f3ec66eb6de7cde88d02e96def36e7c7eaa5e90902e83600e8e2e879e955e837e837eb6d00000000"
  },
  {
   "jp_offset": "0x21e2",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "ふふ……{00}あがき続けるアタシらそのものだね",
   "zh_text": "呵呵……那不就是一直挣扎着的我们本身{00}吗",
   "jp_hex": "153a3a090900f6561df13048f07b46f3fe2b360000",
   "zh_hex": "15ef3def3d0909e7b7e7b5e7c5e7b6efb6e875ebcae84be86de7b4efcce7bbefa6e88d00e8020000000000"
  },
  {
   "jp_offset": "0x21f7",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "{SLOT:1924}虫のまま見苦しく時だけ過ごして{00}いずれ、はかなく消えちまう……",
   "zh_text": "以幼虫之姿狼狈地混着日子、早晚有天、{00}转瞬即逝……",
   "jp_hex": "15fd3b37f207f7b51eaa2b1ffa12232f00f3c502f4951ef1612c3d1809090000",
   "zh_hex": "15e7f3ec66eb6de7cdebbeec7bee61ef63ea41e86de98ae88602e963ea69e7cbe8440200e9c2ebdfe855ec9d090900000000"
  },
  {
   "jp_offset": "0x2232",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "……そうじゃない",
   "zh_text": "……不是这样的",
   "jp_hex": "150909f009244233170000",
   "zh_hex": "150909e7b5e7b6e7b9e7dae7b40000"
  },
  {
   "jp_offset": "0x223d",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "ほんの数日でも成虫になれるから{00}カケロウは待ち続けられるのさ",
   "zh_text": "正因为哪怕只有几天能化为成虫、蜉蝣才{00}能一直等下去",
   "jp_hex": "15fd58f5aef01bf8b5343349481b4600f3ca38e3e22cf13046494837220000",
   "zh_hex": "15ef3bef33e7c1e8ffe958ef32e7cbeaa5e844e7c6e9a5e7c1e837eb6d02ebf0ebf1e83600e7c6efb6e875e826ef4de7eb00000000"
  },
  {
   "jp_offset": "0x225c",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "本人にしてみりゃあ{00}どう思われようが関係ねえ",
   "zh_text": "对它自己来说、别人怎么看根本无所谓",
   "jp_hex": "15f4d434232f3e47421600f053a64b49f0071cf52b36e04d0000",
   "zh_hex": "15e7bee978efb5e8c9efcfe7ed02e7e5efb2e7f2e7bde7f6e9b8efa6e7dce7fbe92b0000000000"
  },
  {
   "jp_offset": "0x2276",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "必ず空に{SLOT:2001}ばたいてやるって覚悟で{00}何年も過ごしてるんじゃないか？",
   "zh_text": "正是怀着定要飞向天空的觉悟、才挺过那{00}些年的、不是吗？",
   "jp_hex": "15f1a1e1af34e6f1392a172f43482d2ff1773000f88b41fa1223f01d4d244233171b050000",
   "zh_hex": "15ef3be7b6eb03e86de867ef2aea45efc1e844e93fe7b4e8aeea1902e836eb5cef36e7b700e8a4e909e7b402e7b5e7b6e8020500000000"
  },
  {
   "jp_offset": "0x22b6",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "ライデン中佐……",
   "zh_text": "强尼莱汀中佐……",
   "jp_hex": "15f19ff0a009090000",
   "zh_hex": "15e8ade896e846ed7cef4eefba09090000"
  },
  {
   "jp_offset": "0x22bf",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "アンタ……{00}見かけによらず学があるんだねえ",
   "zh_text": "你这人……真是看不出来、还挺有学问啊",
   "jp_hex": "15f08c090900fb3c34454626e1111cf00f4d2b36e04d0000",
   "zh_hex": "15e7b8e7b9efb20909e820e7b6e7f6e7b5efbeefcf02e7f7eb5ce7cbeb55e997e7c3000000"
  },
  {
   "jp_offset": "0x22ff",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "……って、おい！",
   "zh_text": "……喂、我说你啊！",
   "jp_hex": "1509092d2f02f0e6060000",
   "zh_hex": "150909e8bd02efcce7ede7b8e7c3ef97000000"
  },
  {
   "jp_offset": "0x230a",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "せっかく良い話で{00}まとめようとしたのにオチはそれかよ！",
   "zh_text": "难得想用段漂亮话来收尾、你最后却给我{00}来这么一句！",
   "jp_hex": "15f436e5df17e6053000f3ebf007f0e52a3734556638f0081b45060000",
   "zh_hex": "15e866e80ae7e6efb3ea6bead0eaa2e81fefcfe926ebc002e7b8e8c5e7feeadfe839efcc00efcfe7b9e7bdefb6ebb9ef97000000000000"
  },
  {
   "jp_offset": "0x2327",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "こう見えてもジオンじゃあそれなりな{00}家平の出なんだがなぁ……",
   "zh_text": "别看我这样、在吉翁也算是出身名门的呢{00}……",
   "jp_hex": "15f087f1c82f41f00cf0cbf00833473300f98537af334df027331509090000",
   "zh_hex": "15e7e5e7f68be7b9e7da02ef29e7d9ee88e7c0e889e7b6afe88de8ace90ce7b4e907000909000000000000"
  },
  {
   "jp_offset": "0x2361",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……ま、なんにせよ{00}ありがたい話だったよ、ライデン中佐",
   "zh_text": "……嘛、不管怎样、你这番话我很受用、{00}强尼莱汀中佐",
   "jp_hex": "1509093d02334d34f0a700f36217e6052b2d2a4502f19ff0a00000",
   "zh_hex": "150909e93602e7b5e93be7f2e7da02e7b8e7b9ee6de81fefcce981e8c8efb30200e8ade896e846ed7cef4eefba0000000000"
  },
  {
   "jp_offset": "0x237c",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "少しは脅の内も軽くなったってもんさ",
   "zh_text": "心里头、多少也轻松了一些",
   "jp_hex": "15f10638e19437e49b41e1ca1e332d2a2d2f414d220000",
   "zh_hex": "15e82def31e92e02e7e9eface7c0e990e9e0e7baefb6e8a400000000000000"
  },
  {
   "jp_offset": "0x23ae",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "……そりゃどうも",
   "zh_text": "……那真是多谢了",
   "jp_hex": "150909284742f3a60000",
   "zh_hex": "150909e7b7e820e7b6e7e9e8b2e7ba000000"
  },
  {
   "jp_offset": "0x23bb",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "ーー同時刻",
   "zh_text": "……同一时刻",
   "jp_hex": "15e004e004f30ee2360000",
   "zh_hex": "150909e85defb6ef2de91f000000"
  },
  {
   "jp_offset": "0x23c6",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "コンベイトウー地球間航路",
   "zh_text": "金平糖·地球间航路",
   "jp_hex": "15f59ef903e004f01091e22ee5f90000",
   "zh_hex": "15e902e887eefa04bf95e8fce9c1e8d200000000"
  },
  {
   "jp_offset": "0x23d6",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "约翰尼·莱汀",
   "jp_text": "アクシズ先軒艦隊",
   "zh_text": "阿克西斯先遣舰队",
   "jp_hex": "15f0e1fac20000",
   "zh_hex": "15e7d2e7d5e7f8e7c8ef8bedc0e7d4e7c9000000"
  },
  {
   "jp_offset": "0x5ed2",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "迪拉兹军官",
   "jp_text": "これは……！！",
   "zh_text": "这是……！！",
   "jp_hex": "15f00e38090906060000",
   "zh_hex": "15e7b9e7b60909ef97ef970000"
  },
  {
   "jp_offset": "0x5ef7",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "新吉恩士官",
   "jp_text": "我がアクシズで開発されたMA、{00}ノイエ·ジールです",
   "zh_text": "这是我们阿克西斯开发的MA、诺耶·吉{00}尔",
   "jp_hex": "15f114f0e130f11e22492af29f0200fbf004fd5b30250000",
   "zh_hex": "15e7b9e7b68be7bbe7d2e7d5e7f8e7c8e7fae870e7b413ea9c02e972ea3104e7d900e7e10000000000000000000000"
  },
  {
   "jp_offset": "0x5f2a",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "迪拉兹军官",
   "jp_text": "素晴らしい！！",
   "zh_text": "了不起！！",
   "jp_hex": "15f7731706060000",
   "zh_hex": "15e7bae7b5e847ef97ef970000"
  },
  {
   "jp_offset": "0x5f32",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "迪拉兹军官",
   "jp_text": "まるでジオンの精身が{00}径となったようだ！",
   "zh_text": "简直就像吉翁的精神、化作了实体一般！",
   "jp_hex": "15f3fbf00c37f3d41c00e1bf31332d2af0072b060000",
   "zh_hex": "15e9abe875e7c5e8e9e7d9ee88e7b4e98de9aa02e9a5ef2fe7bae87fbc87ea80060000000000000000"
  },
  {
   "jp_offset": "0x5f6d",
   "jp_len": 36,
   "kind": "dialogue",
   "speaker": "新吉恩士官",
   "jp_text": "連邦との非戦を蒸件に{00}地球圏への泰在を許された我々には…",
   "zh_text": "我们是以不与联邦交战为条件、才获准滞{00}留地球圈的……",
   "jp_hex": "15f01e3137e4f1b94cf4ca3400f010e1db3b37e3e7e2604ce18122492af0183438090000",
   "zh_hex": "158be7bbe7b6e7f3e7b5e832ef2ed1e861ef28e7c1e9d4e99102e836e9d8e87aeef800e98cbf95e9fbe7b40909000000000000000000000000"
  },
  {
   "jp_offset": "0x5f91",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "新吉恩士官",
   "jp_text": "この程土の援除しかできませんが……",
   "zh_text": "因此也只能提供这种程度的援助了……",
   "jp_hex": "15f005f19737f88af06ff0173d274d1c09090000",
   "zh_hex": "15ef33e7cae7c0ef32e7c6e821eca9e7b9e7d1ea7de96de7b4e863ea23e7ba0909000000"
  },
  {
   "jp_offset": "0x5fc0",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "迪拉兹军官",
   "jp_text": "いや、これで従分というもの",
   "zh_text": "不、这就足够了",
   "jp_hex": "15f06002f00e30f551311718f0190000",
   "zh_hex": "15e7b502e7b9e7c5ea1ee920e7ba0000"
  },
  {
   "jp_offset": "0x5fd0",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "迪拉兹军官",
   "jp_text": "アクシズ艦隊がいることで{00}我らは後雇の憂いなく戦えるのだ",
   "zh_text": "正因为有阿克西斯舰队在、我们才能毫无{00}后顾之忧地作战",
   "jp_hex": "15f0e1f0681c1748f0023000f0b438ff4937fbe7f043b91948372b0000",
   "zh_hex": "15ef3bef33e7c1e7cbe7d2e7d5e7f8e7c8e7d4e7c9ef2902efcce7bbe836e7c6ea0ae7dc00e7feea1fe7cdee1def63ef2fef280000000000"
  },
  {
   "jp_offset": "0x6008",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "新吉恩士官",
   "jp_text": "ガトー少佐……",
   "zh_text": "卡多少佐……",
   "jp_hex": "15f0b0f0c309090000",
   "zh_hex": "15e801e7e9efacefba090900000000"
  },
  {
   "jp_offset": "0x602c",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "迪拉兹军官",
   "jp_text": "事が成った暁の兵の回収はぜひ……！",
   "zh_text": "大功告成之日、士兵的回收{00}就拜托了……！",
   "jp_hex": "15a91ce3612d2ae19b37ce37f3e3f81ee0570909060000",
   "zh_hex": "15bee9b1e8e5e837e7cde98a02a5cee7b48ce92600e7c5e91ae7f4e7ba0909060000000000000000000000"
  },
  {
   "jp_offset": "0x605e",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "新吉恩士官",
   "jp_text": "……はっ{00}ガトー少佐……どうかご武運を",
   "zh_text": "……是、卡多少佐……祝您武运长久",
   "jp_hex": "150909382d00f0b0f0c30909f129e051fd1b4c0000",
   "zh_hex": "150909e7b602e801e7e9b1a30909ed97e835e8ece986ef34e9db00000000000000000000"
  },
  {
   "jp_offset": "0x6094",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "迪拉兹军官",
   "jp_text": "……ジオンの栄光のために！",
   "zh_text": "……为了吉翁的荣光！",
   "jp_hex": "150909f00c37f41437f03c34060000",
   "zh_hex": "150909e7c1e7bae7d9ee88e7b4eb19e83d0600000000"
  },
  {
   "jp_offset": "0x6106",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "これまでの戦い、ご苦漏",
   "zh_text": "一路辛苦了",
   "jp_hex": "15f00ef02b37b91702f6420000",
   "zh_hex": "15efb6e8d2ea58e9e6e7ba0000"
  },
  {
   "jp_offset": "0x6113",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "この「宇宙世紀ルート」を最後まで{00}遊んでくれて感射する",
   "zh_text": "感谢你、将这条『宇宙世纪路线』一直玩{00}到了最后",
   "jp_hex": "15f005e00bf0a8f695fb35e00c4cf145f02b00e5ae4d30f0152ff288f0040000",
   "zh_hex": "15e87de8b2e7b802e84ae7b9e9d40ce8bee8bfe83ceb99e8d2e9160defb6e875e97000e7d7e7bae8c5e7fe0000000000000000"
  },
  {
   "jp_offset": "0x6133",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "なお、ロンド·ベル隊の戦いは{00}ここでひとまず終了するが……",
   "zh_text": "另外、隆德·贝尔队的战斗、就先在此告{00}一段落了……",
   "jp_hex": "15f29002f17a04f0f4bd37b9173800f03e30f9fcf15bf3aef0041c09090000",
   "zh_hex": "15e99be8f702ed16e82cef4be857e7e1e7c9e7b4ef28e7ff02e7c5ef8bef29e7cae8e500efb6ea6be92ae7ba0909000000"
  },
  {
   "jp_offset": "0x6152",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "ケーム自体はまだ続けることが可能だ{00}この後も引き続きを楽しんで雷しい",
   "zh_text": "游戏本身仍然可以继续、今后也请你继续{00}尽情享受",
   "jp_hex": "15f763f702f0ea2bf13048f0021cf1692b00f0059c41f429e3d01d4cf5d64d30f252170000",
   "zh_hex": "15ea94ea3eefa6e88deab9e7efe7c4e7f3e9d6e9ad02efb9e7fee7c0e83ae7b8e9d6e9ad00e8f2e88bec06e8c80000000000"
  },
  {
   "jp_offset": "0x6177",
   "jp_len": 39,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "また、本ルートを最後まで遊んでくれた{00}君には特別ステージも用意されている",
   "zh_text": "另外、为将本路线一直玩到最后的你、还{00}准备了特别关卡",
   "jp_hex": "15f09e02d2fb354cf145f02be5ae4d30f0152a00973438e490e534f43841f21622492f17480000",
   "zh_hex": "15e99be8f702e7c1e84aefa6e8d2e916efb6e875e970e7d7e8c5e7fee7b4e7b802e7f700e87ae877e7bae7cfe7e5e8bbe80100000000000000"
  },
  {
   "jp_offset": "0x619e",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "我々とは別に戦いを続けていた{00}アークエンジェル隊との特別演習だ",
   "zh_text": "那是与我们分头、一直另行作战的大天使{00}队的特别演习",
   "jp_hex": "15f0183138e53434b9174cf1302ff01300f093f09abd3137e490e534f4722b0000",
   "zh_hex": "15e7b7e7b6e832efcce7bbefaee92e02efb6e875e99befd6ef2fef28e7b4efa5e844e83f00e7c9e7b4e7cfe7e5ea2feab6000000000000"
  },
  {
   "jp_offset": "0x61bf",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "彼らと戦い、君が育ててきた部隊の{00}強さを確かめてみるのも良いだろう",
   "zh_text": "与他们一战、亲自检验一下你培养至今的{00}部队实力、也不错",
   "jp_hex": "15f0d531b91702971cfb702ff074f0643700e18c224cf4972f3e483741e5df172b4a180000",
   "zh_hex": "15e832e80ce7bbefb6ef2802e894efb5ee40ea99efb6ef4de7b8edfeec0be897efb9e7b400ef70e7c9e87fefb002e7c0e7b5e8850000000000"
  },
  {
   "jp_offset": "0x61e4",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "フリーバトルで「特殊演習」を{00}選ぶことで彼らと戦うことができる",
