   "jp_offset": "0x63a9",
   "jp_len": 36,
   "kind": "dialogue",
   "speaker": "玛琉",
   "jp_text": "…では、「SDガンダム{00}{01}{01}{01}{01}{01}GジェネレーシユンDS」",
