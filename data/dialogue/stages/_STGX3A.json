  },
  {
   "jp_offset": "0x6209",
   "jp_len": 36,
   "kind": "dialogue",
   "speaker": "布莱特·诺亚",
   "jp_text": "…では、「SDガンダム{00}{01}{01}{01}{01}{01}GジェネレーシユンDS」",
