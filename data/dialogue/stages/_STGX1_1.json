  },
  {
   "jp_offset": "0x1ac2",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "阿纳贝尔·卡托",
   "jp_text": "あの、ソロモンでのようなことは{00}もう匂土と……",
   "zh_text": "所罗门那样的惨剧、绝不能再重演……",
   "jp_hex": "15f01a02f1763037f00733f0023800f02af3e83109090000",
   "zh_hex": "15e7fbe7ece90ce7b7e7dae7b4ed5decb502e91ce7b5e7c6e80be8a1ea2f0909000000"
  },
  {
   "jp_offset": "0x1af5",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "……いいだろう{00}では、ガトー大尉に同行を頼む",
