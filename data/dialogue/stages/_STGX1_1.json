   "jp_hex": "15090917172b4a1800f00a02f0b0f05d34f1ef4ce5c03f0000",
   "zh_hex": "150909e7c7e7d002e7b7e7c5e91ae7f4e801e7e9efa5efc6e85defd6e7ba000000000000"
  },
  {
   "jp_offset": "0x1b29",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "阿纳贝尔·卡托",
   "jp_text": "……はっ！",
   "zh_text": "……是！",
   "jp_hex": "150909382d060000",
   "zh_hex": "150909e7b6ef970000"
  },
  {
   "jp_offset": "0x1b71",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "ったく……！{00}みんなして甘っちょろいことを……",
