  {
   "jp_offset": "0x1bb8",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "アタシとデトローフに忍せてくれれば{00}きっちり送り届けてやるさ",
