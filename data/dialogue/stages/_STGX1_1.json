  },
  {
   "jp_offset": "0x192f",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "玛利根",
   "jp_text": "では、サイド6に{00}向かう部隊の編成を……",
   "zh_text": "那么、我这就编组前往SIDE6的部队{00}……",
