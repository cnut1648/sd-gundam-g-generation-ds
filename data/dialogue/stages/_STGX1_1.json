   "jp_hex": "15f00a02f00dc03400a841f3392ff016f0441f3d274d1b050000",
   "zh_hex": "15e7b7e7bd02e7c6e9bbe7c0e7f9efcce854e891e8cfef4e0500000000"
  },
  {
   "jp_offset": "0x1a60",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "……ガトー大尉？",
   "zh_text": "……卡多大尉？",
   "jp_hex": "150909f0b0f05d050000",
   "zh_hex": "150909e801e7e9efa5efc6050000"
  },
  {
   "jp_offset": "0x1a85",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "阿纳贝尔·卡托",
   "jp_text": "少数での行動ならば{00}私もソロモンで経験済みです",
   "zh_text": "少数人的行动、我在所罗门也有过经验",
   "jp_hex": "15f5aa3037f0e333463900a841f17630f42cfa2c30250000",
   "zh_hex": "15eface914efb2e7b4efd6ef3002efccef29e7fbe7ece90ce7c0e7cbef36e8b7ea9900000000000000"
