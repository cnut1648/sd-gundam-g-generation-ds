   "zh_hex": "15e7b502e7b5e86002ef9eef62ef96ef9fe9cde8a6efcce894efb5ef51e911000000000000"
  },
  {
   "jp_offset": "0x1998",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "布拉德·法伦",
   "jp_text": "大佐自らが……でありますか？",
   "zh_text": "要大佐您亲自前去……吗？",
