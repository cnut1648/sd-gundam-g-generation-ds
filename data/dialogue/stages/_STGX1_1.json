   "zh_hex": "15e820e7b6e7b40909ef97e840e7b9e7bde844e8200909000000"
  },
  {
   "jp_offset": "0x1b8b",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "……ま{00}そういうのも悪かぁないけどね",
