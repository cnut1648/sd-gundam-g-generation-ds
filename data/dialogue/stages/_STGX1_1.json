   "zh_hex": "15e7f3eface914ef93efb0eb3ce891ef9eef62ef96ef9fe9cd02e832e8eee90bea25efb200e83ee7c9e987e80aef2eeb14000000"
  },
  {
   "jp_offset": "0x18f2",
   "jp_len": 34,
   "kind": "dialogue",
   "speaker": "夏亚",
   "jp_text": "核攻撃がなくなったことさえ伝えれば{00}彼らも早まった紳似はすまい",
   "zh_text": "只要告知他们核攻击已取消、他们就不会{00}再做出鲁莽之举",
   "jp_hex": "15f3ed1cf043332d2af0022219f30d493900f0d541e3b03d2d2af2f73825f1190000",
