  },
  {
   "jp_offset": "0x1cfe",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "米莎",
   "jp_text": "……ですな",
   "zh_text": "……是啊",
   "jp_hex": "1509093025330000",
   "zh_hex": "150909e7b6e7c3000000"
  },
  {
   "jp_offset": "0x1d37",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "施泰纳",
   "jp_text": "ここは、いいところだな{00}ミーシャ",
   "zh_text": "这地方真不错啊、米莎",
   "jp_hex": "15f03e380217f2574a2b3300f59a0000",
   "zh_hex": "15e7b9ef63efb1e820e7b5e885e7c302e878ef7c0000000000"
  },
  {
   "jp_offset": "0x1d6f",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "米莎",
   "jp_text": "……ですな",
   "zh_text": "……是啊",
   "jp_hex": "1509093025330000",
   "zh_hex": "150909e7b6e7c3000000"
  },
  {
   "jp_offset": "0x1d77",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "米莎",
   "jp_text": "こんなご時世じゃなけりゃ{00}巨中いちまいたいくらいですよ",
