  },
  {
   "jp_offset": "0x1cc9",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "施泰纳",
   "jp_text": "ジオンは……敗けるな",
   "zh_text": "吉翁……要败了啊……",
