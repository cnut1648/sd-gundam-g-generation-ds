   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "ん？{01}なんだ？",
   "zh_text": "嗯？怎么回事？",
   "jp_hex": "154d0501334d2b050000",
   "zh_hex": "15e86505e7f2e7bdef52efb8050000"
  },
  {
   "jp_offset": "0x17de",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "芙蕾·阿尔斯特",
   "jp_text": "軍本部から通信です",
   "zh_text": "军本部发来了通信",
   "jp_hex": "15f4ba1b46f1b430250000",
   "zh_hex": "15e7e0efa6ef70e870efcfe7baef59e90f0000"
  },
  {
   "jp_offset": "0x17e9",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "芙蕾·阿尔斯特",
   "jp_text": "地球軌道艦隊と合流するように{00}とのことです",
   "zh_text": "命令我们与地球轨道舰队会合",
   "jp_hex": "15f010f1a7f06831f1b9f004f00734003137f00230250000",
   "zh_hex": "15e853e94eefcce7bbe832ef63efd3e9cce82ae7d4e7c9e7e2efc00000"
  },
  {
   "jp_offset": "0x181c",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "早速、軍が動いたのか",
   "zh_text": "军方动作还真快啊",
   "jp_hex": "15fced02981cc6f013371b0000",
   "zh_hex": "15e7e0efb1ef30ef2fe7f7e820e85fe7c30000"
  },
  {
   "jp_offset": "0x1829",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "よし、進路、地球へ！！{00}軌道艦隊と合流する！",
   "zh_text": "好、航向地球！与轨道舰队会合！",
   "jp_hex": "15f09102f23e02f0103b060600f1a7f06831f1b9f004060000",
   "zh_hex": "15e7c702e9c1efc1ef63efd3ef97e832e9cce82ae7d4e7c9e7e2efc0ef970000"
  },
  {
   "jp_offset": "0x1859",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "こちらドミニオン隊{00}ナタル·バジルール中佐であります",
   "zh_text": "这里是主天使队、娜塔尔·巴基露露中佐",
   "jp_hex": "15f07af165bd00f19404f15af0a030f046f0250000",
   "zh_hex": "15e7b9ef31e7b6e954e844e83fe7c902e7eae945e7e1ef4be85be829e858e858ef4eefba0000"
  },
  {
   "jp_offset": "0x1889",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "地球軌道艦隊司令だ",
   "zh_text": "我是地球轨道舰队司令",
   "jp_hex": "15f010f1a7f068f4192b0000",
   "zh_hex": "15efcce7b6ef63efd3e9cce82ae7d4e7c9eafee94e0000"
  },
  {
   "jp_offset": "0x1895",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "海賊の追討、ご苦漏だったな{00}バジルール中佐",
   "zh_text": "追讨海盗、辛苦了啊、巴基露露中佐",
   "jp_hex": "15f14e37fe6c02f6422b2d2a3300f15af0a00000",
   "zh_hex": "15e8dde9f7e91be9f302ea58e9e6e7bae7c302e85be829e858e858ef4eefba0000"
  },
  {
   "jp_offset": "0x18ce",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "そちらがだ捕したという{00}海賊の旗艦かね？",
   "zh_text": "那就是你们俘获的海盗旗舰吧？",
   "jp_hex": "15f2351c2bcf232a31171800f14e37f3a0f160050000",
   "zh_hex": "15e7b7e7c5e7b6e7b8e7bbeadbe9d8e7b4e91be9f3eb0be7d4e7d0050000"
  },
  {
   "jp_offset": "0x18e4",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "早速だが、引渡してもらおうか",
   "zh_text": "事不宜迟、立刻把它移交给我们吧",
   "jp_hex": "15fcedf02702e0a5fe712ff0401af0c80000",
   "zh_hex": "15efb8e7b5ecc9ea1002e86be91fe81be978ec83e861e839efcce7bbe7d00000"
  },
  {
   "jp_offset": "0x1911",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "……は？",
   "zh_text": "……什么？",
   "jp_hex": "15090938050000",
   "zh_hex": "150909e7dde7bd050000"
  },
  {
   "jp_offset": "0x1918",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "ま、待ってください！{00}何か誤解しておられるのでは！？",
   "zh_text": "请、请等一下！你们是不是有什么误会！{00}？",
   "jp_hex": "153d02e3e22d2ff0831706008a1bfca1232f1a46494837f00a06050000",
   "zh_hex": "15e83a02e83ae826efb6ef4def97e7b8e7bbe7b6e7b5e7b6e7cbe7dde7bdea33e7e2ef9700050000"
  },
  {
   "jp_offset": "0x1935",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "彼らは我々の叫力者で……",
   "zh_text": "他们是我们的合作者……",
   "jp_hex": "15f0d538f01837f13aad3009090000",
   "zh_hex": "15e80ce7bbe7b6efcce7bbe7b4efc0ef2fef6e09090000"
  },
  {
   "jp_offset": "0x1969",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "用用用",
   "jp_text": "……違いますな",
   "zh_text": "……并非如此",
   "jp_hex": "150909e099f02925330000",
   "zh_hex": "150909e957e8f0e7f0e7ca0000"
  },
  {
   "jp_offset": "0x1999",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "木",
   "jp_text": "あの者たちは{00}クロスボーン·バンガード",
   "zh_text": "那些人、是十字先锋",
   "jp_hex": "15f01aadf0063800f179f17c04f19c0000",
   "zh_hex": "15e7b7e8a4efb202e7b6ea4ae980ef8be9670000"
  },
  {
   "jp_offset": "0x19aa",
   "jp_len": 30,
   "kind": "dialogue",
   "speaker": "木",
   "jp_text": "以前より我ら木星公社の諭送船鍛を{00}週っていた海賊です",
   "zh_text": "是一直袭击我们木星公社运输船团的海盗",
   "jp_hex": "15f291f02df0b4f037f4a537f44cf5334c00e2d12d2ff013f14e30250000",
   "zh_hex": "15e7b6efb6e875e9aee7ccefcce7bbefa9ef69e9a4ed96e986e8b9ea02ea5ee7b4e91be9f30000"
  },
  {
   "jp_offset": "0x19ed",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "……木星{SLOT:1900}国！？",
   "zh_text": "……木星帝国！？",
   "jp_hex": "150909f037f05b06050000",
   "zh_hex": "150909efa9ef69e8f8efc4ef97050000"
  },
  {
   "jp_offset": "0x1a19",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ベラさん……！",
   "zh_text": "贝拉小姐……！",
   "jp_hex": "15f0e7f04b0909060000",
   "zh_hex": "15e857e7c2e83ee9210909ef970000"
  },
  {
   "jp_offset": "0x1a48",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "……司令！！",
   "zh_text": "……司令！！",
   "jp_hex": "150909f41906060000",
   "zh_hex": "150909eafee94eef97ef970000"
  },
  {
   "jp_offset": "0x1a6c",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "君らドミニオン隊は政府の要請で{00}海賊の討伐に向かい、だ捕に成功した",
   "zh_text": "你们主天使队奉政府之命前去讨伐海盗、{00}并成功将其俘获",
   "jp_hex": "159746f165bd38f3a337f2ed3000f14e37f8c334f05817022bcf34f188232a0000",
   "zh_hex": "15e7b8e7bbe954e844e83fe7c9eac1ea68ea60e7cde853ef51e7ebe9f7eb26e91be9f30200e957e837e9b1e84ae8cfeadbe9d80000"
  },
  {
   "jp_offset": "0x1a8d",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "……そういうことなのだろう？{00}バジルール中佐",
   "zh_text": "……是这么回事吧？巴基露露中佐",
   "jp_hex": "150909f0f6f00233372b4a180500f15af0a00000",
   "zh_hex": "150909e7b6e7b9e7bdef52efb8e7d005e85be829e858e858ef4eefba0000"
  },
  {
   "jp_offset": "0x1aa1",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "でなければ海賊に荷ーした者として{00}君らも撃たねばならん",
   "zh_text": "否则、连你们也会被当成海盗同伙、一并{00}击毁",
   "jp_hex": "15f422f14e34fc5d232aadf02800974641992a363933464d0000",
   "zh_hex": "15e9bbea8702e86ee7b8e7bbe7c0e7e2e7f1ef53e837e91be9f3e85de7fd02efb6e95700e7cce97c0000"
  },
  {
   "jp_offset": "0x1ad6",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "わ、我々より{00}木星の者叩を信用すると！？",
   "zh_text": "你们、竟然比起我们更相信木星那些人！{00}？",
   "jp_hex": "154b02f018f02d00f03737fa364cf32cf0f906050000",
   "zh_hex": "15e7b8e7bb02ef2ce7efe825e847efcce7bbe952e8b1e90fefa9ef69e7b7e8a4efb2ef9700050000"
  },
  {
   "jp_offset": "0x1b07",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "……当然だろう！",
   "zh_text": "……那是当然！",
   "jp_hex": "150909f4912b4a18060000",
   "zh_hex": "150909e7b7e7b6ef53e7efef970000"
  },
  {
   "jp_offset": "0x1b12",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "クロスボーン·バンガードは{00}連邦と戦ったこともあるのだぞ！！",
   "zh_text": "十字先锋、可是和联邦交过战的！！",
   "jp_hex": "15f179f17c04f19c3800f01e31b92d2af00241f00f372b2906060000",
   "zh_hex": "15ea4ae980ef8be96702e7c4e7b6e7d3ef2eefaae861ef36ef28e7b4ef97ef970000"
  },
  {
   "jp_offset": "0x1b2e",
   "jp_len": 39,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "これまで連邦と叫力関係を続けていた{00}木星公社とは信用の土合いが違う！",
   "zh_text": "和长期与联邦合作的木星公社、信用度天{00}差地别！",
   "jp_hex": "15f00ef02bf01e31f13af52b4cf1302ff01300f037f4a53138f32c37e46fa0171ce09918060000",
   "zh_hex": "15e7d3ef34eac9e832ef2eefaaefc0ef2fe7b4efa9ef69e9a4ed9602e90fefb3e96de84400e9c7ef63e7e5ef970000"
  },
  {
   "jp_offset": "0x1b55",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "さあ、バジルール中佐！{00}海賊どもを引き渡したまえ！！",
   "zh_text": "来吧、巴基露露中佐！把那帮海盗交出来{00}！！",
   "jp_hex": "15f0fb02f15af0a00600f14ef0cd4cf6a523f1021906060000",
   "zh_hex": "15efcfe7d002e85be829e858e858ef4eefbaef97e81be7b7e910e91be9f3e861efbeefcf00ef97ef970000"
  },
  {
   "jp_offset": "0x1b93",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "く……！",
   "zh_text": "唔……！",
   "jp_hex": "151e0909060000",
   "zh_hex": "15e81d0909ef970000"
  },
  {
   "jp_offset": "0x1bb5",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "バジルール中佐！！",
   "zh_text": "巴基露露中佐！！",
   "jp_hex": "15f15af0a006060000",
   "zh_hex": "15e85be829e858e858ef4eefbaef97ef970000"
  },
  {
   "jp_offset": "0x1be3",
   "jp_len": 19,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "……その命令には従いかねます！",
   "zh_text": "此令恕难从命！",
   "jp_hex": "150909f00df1523438e2da17f160f025060000",
   "zh_hex": "15e7cae94eeb04e866e88ae853060000"
  },
  {
   "jp_offset": "0x1c11",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "なにっ、キサマ！？",
   "zh_text": "什么！？",
   "jp_hex": "15f04d2d02f0d606050000",
   "zh_hex": "15e7dde7bd06050000"
  },
  {
   "jp_offset": "0x1c41",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "……バジルール艦長！",
   "zh_text": "……巴基露露舰长！",
   "jp_hex": "150909f15af034060000",
   "zh_hex": "150909e85be829e858e858e7d4ef34ef970000"
  },
  {
   "jp_offset": "0x1c6c",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "安心しろ{00}君叩を引き渡すようなことはしない",
   "zh_text": "放心、我绝不会把你们交出去",
   "jp_hex": "15f359f0b700faed4cf6a525f00733f00238f057170000",
   "zh_hex": "15e86ce82d02efcce91ce7b5e7e2e81be7b8e7bbe861efbee7eb0000"
  },
  {
   "jp_offset": "0x1ca8",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "どういうことだ、中佐！？",
   "zh_text": "你这是什么意思、中佐！？",
   "jp_hex": "15f17df0022b02f0a006050000",
   "zh_hex": "15e7b8e7b9e7b6e7dde7bdef3cefca02ef4eefbaef97050000"
  },
  {
   "jp_offset": "0x1cdd",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "私は以前、ある人物から学びました",
   "zh_text": "我曾从某人身上学到",
   "jp_hex": "15a838f29102f00ff2f81b46e111e058f0522a0000",
   "zh_hex": "15efccea2ae88aeae8efb2e88def4ceb55e7d70000"
  },
  {
   "jp_offset": "0x1cf2",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "軍人として行動する前に、{00}まず、人として正しき行いをすべきと！",
   "zh_text": "在作为军人行动之前、首先得作为一个人{00}、做正确的事！",
   "jp_hex": "15f2d6f028f0e3f004ba340200f15b02b4f028f1931d9f174c25e05c1d31060000",
   "zh_hex": "15ef29ef2fe7c1e7e0efb2efd6ef30e7cdef5102ef40ef8be80aef2fe7c1efb6e828efb20002e81cef3be88ce7b4efb8ef970000"
  },
  {
   "jp_offset": "0x1d38",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "ここは私が尽い止める！！{00}行け、ベラ·ロナ！",
   "zh_text": "这里由我来挡住！快走、贝拉·罗纳！",
   "jp_hex": "15f03e38a81cf47e480606009f1f02f0e704f222060000",
   "zh_hex": "15e7b9ef31e8a6efccefcfea77e859ef97e85fe89002e857e7c2ef4be7ece882ef970000"
  },
  {
   "jp_offset": "0x1d6a",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "は、はい！！",
   "zh_text": "是、是的！！",
   "jp_hex": "153802f01606060000",
   "zh_hex": "15e7b602e7b6e7b4ef97ef970000"
  },
  {
   "jp_offset": "0x1d98",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "海賊め、亜がすか！！",
   "zh_text": "可恶的海盗、休想逃！！",
   "jp_hex": "15f14e4002f296251b06060000",
   "zh_hex": "15e7c4e7dee7b4e91be9f302e90ee7e6e8c2ef97ef970000"
  },
  {
   "jp_offset": "0x1dc0",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "待ち伏せ……！？",
   "zh_text": "是埋伏……！？",
   "jp_hex": "15e3e22cf8cf090906050000",
   "zh_hex": "15e7b6ed44edd60909ef97050000"
  },
  {
   "jp_offset": "0x1df1",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "くそっ！",
   "zh_text": "可恶！",
   "jp_hex": "151e282d060000",
   "zh_hex": "15e7c4e7deef970000"
  },
  {
   "jp_offset": "0x1e1d",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "だめよ、トビア！！",
   "zh_text": "不行、托比亚！！",
   "jp_hex": "152b404502f13606060000",
   "zh_hex": "15e7b5efd602e7f4e825e7d6ef97ef970000"
  },
  {
   "jp_offset": "0x1e28",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "連邦軍と戦うことはできないわ！",
   "zh_text": "我们不能和联邦军交战！",
   "jp_hex": "15f01e9831b918f00238f01733174b060000",
   "zh_hex": "15efcce7bbe7b5e7c6e7d3ef2eefaae7e0e861ef28ef970000"
  },
  {
   "jp_offset": "0x1e5b",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "で、でも、ベラさん！{00}このままじゃ……",
   "zh_text": "可、可是、贝拉小姐！再这样下去……",
   "jp_hex": "153002f01b02f0e7f04b0600f080244209090000",
   "zh_hex": "15e7c402e7c4e7b602e857e7c2e83ee921ef97e80be7b9e7daef4de7eb09090000"
  },
  {
   "jp_offset": "0x1e7a",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x1e7b",
   "jp_len": 51,
   "kind": "script",
   "jp_hex": "1533020001060c02137812330200010622001320113302000106190006220013f91133020002150909f5f501f0092bf1360000",
   "zh_hex": "1833020001060c021330153302000106220013d8133302000106190006220013b11433020002150909ef3def3d02e7d8e88502e7f4e825e7d60000"
  },
  {
   "jp_offset": "0x1f0b",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "扎比涅·夏鲁",
   "jp_text": "困るのだよ……戦ってもらわねばね！",
   "zh_text": "这可让人为难啊……非得让你们打一场不{00}可！",
   "jp_hex": "15e24048372b450909b92d2ff0404b363936060000",
   "zh_hex": "15e7b9e7c4e7f9efb2e7c1e866e7c30909e8f0e80ae7f9e7b8e7bbe7f5efb6e876e7b500e7c4ef970000"
  },
  {
   "jp_offset": "0x1f45",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "ザビーネ！？",
   "zh_text": "萨比尼！？",
   "jp_hex": "15f1c006050000",
   "zh_hex": "15e83be825e896ef97050000"
  },
  {
   "jp_offset": "0x1f71",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "扎比涅·夏鲁",
   "jp_text": "フ{01}フフフ……",
   "zh_text": "呵呵呵呵……",
   "jp_hex": "157401f5f57409090000",
   "zh_hex": "15ef3def3def3def3d09090000"
  },
  {
   "jp_offset": "0x1fa0",
   "jp_len": 14,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "おのれ、海賊どもめ！！",
   "zh_text": "可恶、该死的海盗们！！",
   "jp_hex": "151a374902f14ef0cd4006060000",
   "zh_hex": "15e7c4e7de02e898ef6ae7b4e91be9f3e7bbef97ef970000"
  },
  {
   "jp_offset": "0x1fd3",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "司令っ！！",
   "zh_text": "司令！！",
   "jp_hex": "15f4192d06060000",
   "zh_hex": "15eafee94eef97ef970000"
  },
  {
   "jp_offset": "0x1ff6",
   "jp_len": 34,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "貴様たちはそこを動くな！{00}動いたら貴様らも海賊の忠間とみなす！",
   "zh_text": "你们都给我待在原地别动！敢动就把你们{00}也当海盗同伙！",
   "jp_hex": "15f011f00638f11b4cc61e330600c6f01346f0114641f14e37f215f914f4e1060000",
   "zh_hex": "15e7b8e7bbe840e839efcceaa8ef29e8e4ef63e7e5ef30ef97e8cdef30e7c5e81be7b8e7bb00e7c0ef53e91be9f3e85de7fdef970000"
  },
  {
   "jp_offset": "0x2033",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "そのようなこと今さら……！",
   "zh_text": "事到如今、还说这种话……！",
   "jp_hex": "15f23733f002f19a0909060000",
   "zh_hex": "15efb8e7d7e7f0efb902e7f7e7ede7b9e7d1e81f0909ef970000"
  },
  {
   "jp_offset": "0x2065",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "バジルール中佐、キサマ！？",
   "zh_text": "巴基露露中佐、你这家伙！？",
   "jp_hex": "15f15af0a002f0d606050000",
   "zh_hex": "15e85be829e858e858ef4eefba02e7b8e7b9e7dfe7fdef97050000"
  },
  {
   "jp_offset": "0x208c",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "木星{SLOT:1900}国の危険を理解していない{00}貴官の勘告には従えない",
   "zh_text": "你根本不懂木星帝国的危险、你的劝告、{00}我不会听从",
   "jp_hex": "15f037f05b37f1134cf2fb232f17331700f18b37f6fa3438e2da1933170000",
   "zh_hex": "15e7b8e9b8efa6e7b5e8b0efa9ef69e8f8efc4e7b4e935e93202e7b8e7b4ebb6e8e50200efcce7b5e7e2e8d1e88a0000"
  },
  {
   "jp_offset": "0x20ab",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "我々ドミニオン隊は{00}マザーバンガードを支援する！",
   "zh_text": "我们主天使队、将支援先锋女王号！",
   "jp_hex": "15f018f165bd3800f21b4cf1bcf004060000",
   "zh_hex": "15efcce7bbe954e844e83fe7c902e84ae883e863ef8be967efade884e833ef970000"
  },
  {
   "jp_offset": "0x20ca",
   "jp_len": 34,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "各艦はただちに戦闘態勢へ！{00}ベラ艦長を支援し母囲を突破する！！",
   "zh_text": "各舰立刻进入战斗态势！掩护贝拉舰长突{00}破包围！！",
   "jp_hex": "15f2d438f0442c34f04ff4443b0600f0e7f0344cf1bc23f6d74cf24ff00406060000",
   "zh_hex": "15e819e7d4e86be91fe892e891ef28e7ffe994e8fdef97ec72e8e0e857e7c2e7d4ef34e8b600ef6deabbe9deef97ef970000"
  },
  {
   "jp_offset": "0x2111",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "よし！{01}今のうちだ！{00}全艦、ただちに後退せよ！！",
   "zh_text": "好！趁现在！全舰、立刻后退！！",
   "jp_hex": "15f0910601a2f2602c2b0600f11a02f0442c34f0d3f0a706060000",
   "zh_hex": "15e7c7ef97e9eae82fef29ef97efb4e7d402e86be91fe7fee880ef97ef970000"
  },
  {
   "jp_offset": "0x2151",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "巴尔特菲尔德",
   "jp_text": "どうやら、木星{SLOT:1900}国はかなりの部隊を{00}地球圏に入り込ませているようだな",
   "zh_text": "看来、木星帝国已经往地球圈派进了相当{00}多的部队",
   "jp_hex": "15f13c02f037f05bf4954737f0644c00f010e1db34e4a547e23e3d272f1748f0072b330000",
   "zh_hex": "15e7f6efcf02efa9ef69e8f8efc4ef3ae8b7e911ef63efd3e9fbe985e892e7bae8b1ef5300e7e9e7b4ef70e7c90000"
  },
  {
   "jp_offset": "0x2176",
   "jp_len": 30,
   "kind": "dialogue",
   "speaker": "巴尔特菲尔德",
   "jp_text": "海賊討伐に叫力するという名目で{00}各地に部隊を破軒している",
   "zh_text": "打着协助讨伐海盗的名义、在各地驻扎部{00}队",
   "jp_hex": "15f14ef8c334f13af0f91718fb263000f54934f0644cf36e232f17480000",
   "zh_hex": "15e7f5e86de8f6ea23e9f7eb26e91be9f3e7b4e8ace8ce02ef29e819ef63eca2e84bef7000e7c90000"
  },
  {
   "jp_offset": "0x21af",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "すみません、私たちのせいで……",
   "zh_text": "对不起、都是因为我们……",
   "jp_hex": "15253e3d274d02a8f00637f25a3009090000",
   "zh_hex": "15e7bee7b5e84702e840e7b6ef33e7c1efcce7bb09090000"
  },
  {
   "jp_offset": "0x21dc",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "いや、君らのせいではない{00}離用されたのだ、木星{SLOT:1900}国に",
   "zh_text": "不、不怪你们、是被木星帝国利用了",
   "jp_hex": "15f06002974637f25af00a331700f21d22492a372b02f037f05b340000",
   "zh_hex": "15e7b502e7b5ea07e7b8e7bb02e7b6e7f1efa9ef69e8f8efc4e82eefb3e7ba0000"
  },
  {
   "jp_offset": "0x2214",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "木星{SLOT:1900}国のやつら、今じゃ大手を審って{00}地球圏を通行してる",
   "zh_text": "木星帝国那帮家伙、如今在地球圈大摇大{00}摆地横行",
   "jp_hex": "15f037f05b37f1a64602a22442beae4ce3342d2f00f010e1db4cff9d23f01d0000",
   "zh_hex": "15efa9ef69e8f8efc4e7b7e910e7dfe7fd02e7f0efb9ef29ef63efd3e9fbefa5ebccefa500eb8bef63ec77efd60000"
  },
  {
   "jp_offset": "0x2235",
   "jp_len": 22,
   "kind": "dialogue",
   "speaker": "西玛·加拉霍",
   "jp_text": "やつらが行動に移るのもそう遠くないね",
   "zh_text": "离他们动手也不远了",
   "jp_hex": "15f1a6461cf0e334e097483741f009f82a3317360000",
   "zh_hex": "15e901e80ce7bbef30ef66e7c0e7b5e94ce7ba0000"
  },
  {
   "jp_offset": "0x226c",
   "jp_len": 27,
   "kind": "dialogue",
   "speaker": "拉克丝·克莱因",
   "jp_text": "地球連邦は木星{SLOT:1900}国の悪意に{00}気付いてはおりません",
   "zh_text": "地球联邦、还没察觉到木星帝国的恶意",
   "jp_hex": "15f010f01e38f037f05b37f7383400f3ac172f381a473d274d0000",
   "zh_hex": "15ef63efd3ef2eefaa02e7f7e7d8ea8be8aee7d7efa9ef69e8f8efc4e7b4e7deef3c0000"
  },
  {
   "jp_offset": "0x2287",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "拉克丝·克莱因",
   "jp_text": "このまま木星{SLOT:1900}国が{00}攻撃を開始したら……",
   "zh_text": "一旦木星帝国就这样发动进攻……",
   "jp_hex": "15f080f037f05b1c00f01f4cf0b1232a4609090000",
   "zh_hex": "15efb6ebcdefa9ef69e8f8efc4e7c5e7b9e7dae870ef30e892ef6709090000"
  },
  {
   "jp_offset": "0x22bd",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "巴尔特菲尔德",
   "jp_text": "連邦軍はひとたまりもあるまい",
   "zh_text": "联邦军恐怕一下就撑不住了",
   "jp_hex": "15f01e9838f9fcf1024741f00ff1190000",
   "zh_hex": "15ef2eefaae7e0eb33e958efb6ef4de7c5ea29e7b5e859e7ba0000"
  },
  {
   "jp_offset": "0x22fc",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "……父は",
   "zh_text": "……我父亲他",
   "jp_hex": "150909e510380000",
   "zh_hex": "150909efcce888e894e80c0000"
  },
  {
   "jp_offset": "0x2304",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "父は地球など必要ないと、{00}そう言っていました",
   "zh_text": "我父亲曾说过、地球这种东西、他根本不{00}需要",
   "jp_hex": "15e51038f010f039f0b53317310200f0099b2d2ff029232a0000",
   "zh_hex": "15efcce888e894ea2ae7edef3602ef63efd3e7b9e7d1e8bae7f802e80ce9b8efa6e7b500e92def2a0000"
  },
  {
   "jp_offset": "0x2339",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "それは……木星{SLOT:1900}国は地球そのものをも{00}攻撃対城にするということか？",
   "zh_text": "那意思是……木星帝国连地球本身都要当{00}成攻击目标吗？",
   "jp_hex": "15f008380909f037f05b38f010f3fe4c4100f01ff7f634f0f91718f0021b050000",
   "zh_hex": "15e7b7ef3cefcae7b60909efa9ef69e8f8efc4e86eef63efd3efa6e88de840ef2aef5300e837ef67e7ccefd4e96fe802050000"
  },
  {
   "jp_offset": "0x2375",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "理由はわかりませんけど、{00}父は……地球を憎んでいました",
   "zh_text": "我不知道原因、但父亲他……一直憎恨着{00}地球",
   "jp_hex": "15f28338f024473d274df0f70200e510380909f0104ce3c04d30f029232a0000",
   "zh_hex": "15efcce7b5e85ae82ae8e4ef3302e7dbe888e894e80c0909efb6e875eb34e9bee86d00ef63efd30000"
  },
  {
   "jp_offset": "0x2395",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "父がそんなことをするとは{00}思いたくないですけど……",
   "zh_text": "尽管我不愿相信父亲会做出那种事……",
   "jp_hex": "15e5101cf026f0024cf0f93800a6f71d33173025f0f709090000",
   "zh_hex": "15e8f2e93befcce7b5e961e8b1e90fe888e894e7e2e81cefbee7b7e7d1efb809090000"
  },
  {
   "jp_offset": "0x23ca",
   "jp_len": 35,
   "kind": "dialogue",
   "speaker": "拉克丝·克莱因",
   "jp_text": "撃たれるいわれなき人々の上に{00}再び戦火の{SLOT:1851}が舞い降りれば……",
   "zh_text": "若战火之雨、再次落在无辜的人们头上…{00}…",
   "jp_hex": "15992a4948174b49331df29437b23400f2f4f60737e65b1ce51817f32a493909090000",
   "zh_hex": "15e7e7ef28e8dae7cdebad02e80be864e92aef29e7dced0de7b4efb2e7bbe92eef4c0900090000"
  },
  {
   "jp_offset": "0x23ed",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "拉克丝·克莱因",
   "jp_text": "それはまた、かつての争いのように{00}多くの悲劇を生むでしょう",
   "zh_text": "那必将如昔日的纷争一般、催生出无数悲{00}剧",
   "jp_hex": "15f008f0ea2a02f24c37e3b31737f0073400f1c437f5bb4cb63f302344180000",
   "zh_hex": "15e7b7e860e84ae7f0ec55e98ae7b4ecf8e852efb6ea8002ed22ef8defbee7dce914e9df00ecb50000"
  },
  {
   "jp_offset": "0x240d",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "拉克丝·克莱因",
   "jp_text": "それだけは組止しなくてはなりません",
   "zh_text": "唯独这一点、必须阻止才行",
   "jp_hex": "15f1b038f178f0571e2ff03a473d274d0000",
   "zh_hex": "15ea89e8eee7b9efb6e82202e860e9a2e8efe869e836efd60000"
  },
  {
   "jp_offset": "0x2440",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "止めるしかないな……我々の手で",
   "zh_text": "只能阻止它了……靠我们自己的手",
   "jp_hex": "15f0ca48f06f3317330909f01837ae300000",
   "zh_hex": "15ef32e7c6e8efe869e978e7ba0909e8c7efcce7bbefb5e8c9e7b4ef660000"
  },
  {
   "jp_offset": "0x245d",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x245e",
   "jp_len": 56,
   "kind": "script",
   "jp_hex": "153302000106c000137812330200010658001320113302000115f2204cf4534d30f0122d2af0073000f02afc271ff0463d274d1c09090000",
   "zh_hex": "183302000106c0001330153302000106580013d8133302000115e81be819e834ecbae7bae892d90200e820e7b6e922e92709090000"
  },
  {
   "jp_offset": "0x24b1",
   "jp_len": 30,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "かまわぬさ、我々はやるべきと{00}信じたことを行うまでだ",
   "zh_text": "无妨、我们只做认定该做的事",
   "jp_hex": "15f2774b352202f018f1fd48e05c1d3100f1032af0024c9ff298302b0000",
   "zh_hex": "15e7dce97f028be7bbef32e81ce8a0e867e898e81ce7b4a90000"
  },
  {
   "jp_offset": "0x24f0",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "巴尔特菲尔德",
   "jp_text": "勝算はまあ……低いが{00}やるしかなかろう",
   "zh_text": "胜算虽低、只能干了",
   "jp_hex": "15fa40f0ea160909e446171c004348f06ff0774a180000",
   "zh_hex": "15e8dbe889e8b8ec0802ef32e7c6e8d3e7ba0000"
  },
  {
   "jp_offset": "0x2512",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x2513",
   "jp_len": 53,
   "kind": "script",
   "jp_hex": "1533020001068f00137812330200010642001320113302000115f06002f037f05b1cf0104ce39e183117f0634600fa40f084480000",
   "zh_hex": "1833020001068f001330153302000106420013d8133302000115e7b502e7e7efa9ef69e8f8efc4ef3ceb2de7beef63efd3efbeef66e7b7efcce7bbe7c500e7cbe8dbe8890000"
  },
  {
   "jp_offset": "0x2563",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "トビア·アロナクス？",
   "zh_text": "托比亚",
   "jp_hex": "15f13604f64f050000",
   "zh_hex": "15e7f4e825e7d60000"
  },
  {
   "jp_offset": "0x2587",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ドゥガチが{00}地球を憎んでいるというなら……",
   "zh_text": "德卡契若恨地球……",
   "jp_hex": "15f0af1c00f0104ce3c04d3017483117f0634609090000",
   "zh_hex": "15e82ce801eee2e7e7e9bebf9509090000"
  },
  {
   "jp_offset": "0x259e",
   "jp_len": 32,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "あの男は自分自身の手で{00}地球へ一撃を与えようとするはずだ",
   "zh_text": "那个男人、一定会想亲手给地球来上致命{00}一击",
   "jp_hex": "15f01ae40e38f07ef30b37ae3000f0103bf3164cf1eaf00731f004f0552b0000",
   "zh_hex": "15e7b7e828ea95efb202efb6e867e7e2e7e6e894ef66e839ef63efd3efcfef4cea32e85300efb6e7cc0000"
  },
  {
   "jp_offset": "0x25be",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "そこをつけば……！",
   "zh_text": "只要抓住这一点……！",
   "jp_hex": "15f11b4cf0c9390909060000",
   "zh_hex": "15ef32ef2ae962e859e7b9efb6e8220909ef970000"
  },
  {
   "jp_offset": "0x25e5",
   "jp_len": 30,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "木星{SLOT:1900}国はクラックス·ドゥガチに{00}よって厳しく騰制された国家……",
   "zh_text": "木星帝国受德卡契严密管制……",
   "jp_hex": "15f037f05b38f1ee04f0af3400452d2ff3e51ef4f022492af50309090000",
   "zh_hex": "15d4b5e8f8a1e8c8e82ce801eee2eaa1e9bde93be8de09090000"
  },
  {
   "jp_offset": "0x261e",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ドゥガチさえ倒せば{SLOT:1900}国は終わる！",
   "zh_text": "打倒德卡契即可",
   "jp_hex": "15f0af2219e4732739f05b38f06a48060000",
   "zh_hex": "15e7f5e848e82ce801eee2e855e7c40000"
  },
  {
   "jp_offset": "0x264b",
   "jp_len": 33,
   "kind": "dialogue",
   "speaker": "拉克丝·克莱因",
   "jp_text": "……やりましょう、バジルール艦長！{00}これ以上の悲劇を生み出さぬためにも！",
   "zh_text": "干吧、舰长！为了不再生悲剧！",
   "jp_hex": "1509094347f052441802f15af0340600f0ee37f5bb4cf3322235f03c3441060000",
   "zh_hex": "15e8d3e7d002e7d4ef3406e7c1e7bae7b5e80bb6e9dfecb5060000"
  },
  {
   "jp_offset": "0x268d",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "無和、そのつもりだ！",
   "zh_text": "正有此意",
   "jp_hex": "15f37102f00df08b2b060000",
   "zh_hex": "15ef3be7cbe7caef3c0000"
  },
  {
   "jp_offset": "0x26a4",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x26a5",
   "jp_len": 44,
   "kind": "script",
   "jp_hex": "1533020001069c00137812330200010646001320113302000115f2d4f0b902f0442c34f11037f0ff4c060000",
   "zh_hex": "1833020001069c001330153302000106460013d8133302000115e819e7d4e86be855e87ae877efbee7cc0000"
  },
  {
   "jp_offset": "0x26d1",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "これより我々は木星{SLOT:1900}国軍に対し{00}決戦を挑む！！",
   "zh_text": "从现在起、我们就向木星帝国军发起决战{00}！！",
   "jp_hex": "15f00ef02df01838f037f05b9834e3df2300f2544ce42e3f06060000",
   "zh_hex": "15e88ae82fef29e84702efcce7bbe7c5efc1efa9ef69e8f8efc4e7e0e870e847e8abef2800ef97ef970000"
  },
  {
   "jp_offset": "0x70aa",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "くっ……！{00}こんなところで……！！",
   "zh_text": "唔……！竟要栽在这种地方……！！",
   "jp_hex": "151e2d09090600f04af138090906060000",
   "zh_hex": "15e81d0909ef97ef2cef2aec5def29e7b9e7d1ef63efb10909ef97ef970000"
  },
  {
   "jp_offset": "0x732e",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "木星军高级士官",
   "jp_text": "地球軌道艦隊の皆さまですな？",
   "zh_text": "诸位、是地球轨道舰队的吧？",
   "jp_hex": "15f010f1a7f06837e0fcf038302533050000",
   "zh_hex": "15ea56e83402e7b6ef63efd3e9cce82ae7d4e7c9e7b4e7d0050000"
  },
  {
   "jp_offset": "0x7340",
   "jp_len": 28,
   "kind": "dialogue",
   "speaker": "木星军高级士官",
   "jp_text": "我々はドゥガチ覚下より{00}貴隊の応援に破軒されました！！",
   "zh_text": "我们奉德卡契阁下之命、特来支援贵队！{00}！",
   "jp_hex": "15f01838f0aff09ff02d00f62937f2f334f36e2249f0522a06060000",
   "zh_hex": "15efcce7bbeac1e82ce801eee2e8d7ef4de7cde85302e7cfefcfe883e863e930e7c9ef9700ef970000"
  },
  {
   "jp_offset": "0x737d",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "联邦士官",
   "jp_text": "おお、木星の方々か！！{00}叫力感射します！",
   "zh_text": "哦哦、是木星的诸位啊！！多谢相助！",
   "jp_hex": "15f23302f03737f2eb1b060600f13af288f01225060000",
   "zh_hex": "15e919e91902e7b6efa9ef69e7b4ea56e834e7c3ef97ef97e7e9e8b2e8b1ea23ef970000"
  },
  {
   "jp_offset": "0x73d7",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "木星军高级士官",
   "jp_text": "（ふふ……{00}{01}ザビーネ·シャル……良い仕事だ）",
   "zh_text": "（呵呵……萨比尼·夏尔……干得漂亮）",
   "jp_hex": "150a3a3a09090001f1c004f7650909e5df17f3d02b0b0000",
   "zh_hex": "15ef8eef3def3d0909e83be825e896ef4bef37e7e10909e8d3e80aead0eaa2ef8f0000"
  },
  {
   "jp_offset": "0x73ef",
   "jp_len": 37,
   "kind": "dialogue",
   "speaker": "木星军高级士官",
   "jp_text": "（これで地球圏に軍を向かわせることが{00}{01}いっそうたやすくなった……）",
   "zh_text": "（这下、要让大军开进地球圈、就更容易{00}了……）",
   "jp_hex": "150af00e30f010e1db34984cf0584b2748f0021c0001172df009fbeb1e332d2a09090b0000",
   "zh_hex": "15ef8ee7b9ef4d02ef2ae7f9efa5e7e0e7fae892ef63efd3e9fb02e7c5e952ed2fe96400e7ba0909ef8f0000"
  },
  {
   "jp_offset": "0x7414",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "木星军高级士官",
   "jp_text": "よし！{00}モビルスーツ隊、発進！！",
   "zh_text": "好！MS队、出击！！",
   "jp_hex": "15f0910600f081bd02f10106060000",
   "zh_hex": "15e7c7ef97efa7ef9ee7c902efbee7ccef97ef970000"
  },
  {
   "jp_offset": "0x7423",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "木星军高级士官",
   "jp_text": "連邦軍と叫力して{00}海賊どもを撃破するのだ！！",
   "zh_text": "与联邦军联手、把那帮海盗一举击溃！！",
   "jp_hex": "15f01e9831f13a232f00f14ef0cd4cf069f004372b06060000",
   "zh_hex": "15e832ef2eefaae7e0ef2eef6602e81be7b7e910e91be9f3efb6ea21e7ccec79ef97ef970000"
  },
  {
   "jp_offset": "0x7462",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "……っ！？",
   "zh_text": "……！？",
   "jp_hex": "1509092d06050000",
   "zh_hex": "150909ef97050000"
  },
  {
   "jp_offset": "0x7471",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "まさか……ベルナデット！？",
   "zh_text": "难道是……贝尔纳黛特！？",
   "jp_hex": "15f06b0909f0f4f1a206050000",
   "zh_hex": "15e866e82ae7b60909e857e7e1e882ea9ae7cfef97050000"
  },
  {
   "jp_offset": "0x7499",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "トビア……！！",
   "zh_text": "托比亚……！！",
   "jp_hex": "15f136090906060000",
   "zh_hex": "15e7f4e825e7d60909ef97ef970000"
  },
  {
   "jp_offset": "0x74bd",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "やはり、ベルナデット！！",
   "zh_text": "果然是你、贝尔纳黛特！！",
   "jp_hex": "15f11d02f0f4f1a206060000",
   "zh_hex": "15e871e7efe7b6e7b802e857e7e1e882ea9ae7cfef97ef970000"
  },
  {
   "jp_offset": "0x74c9",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "どうして君が……！？",
   "zh_text": "你怎么会在这里……！？",
   "jp_hex": "15f094971c090906050000",
   "zh_hex": "15e7b8e7f2e7bde7e2ef29e7b9ef310909ef97050000"
  },
  {
   "jp_offset": "0x74ef",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "ダメっ、トビア！{00}亜げて！！",
   "zh_text": "不行、托比亚！快逃！！",
   "jp_hex": "15f12f2d02f1360600f1182f06060000",
   "zh_hex": "15e7b5efd602e7f4e825e7d6ef97e85fe8c2ef97ef970000"
  },
  {
   "jp_offset": "0x751a",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ベルナデット！？",
   "zh_text": "贝尔纳黛特！？",
   "jp_hex": "15f0f4f1a206050000",
   "zh_hex": "15e857e7e1e882ea9ae7cfef97050000"
  },
  {
   "jp_offset": "0x753e",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "ダメなの！",
   "zh_text": "不行啊！",
   "jp_hex": "15f12f3337060000",
   "zh_hex": "15e7b5efd6e7c3ef970000"
  },
  {
   "jp_offset": "0x7546",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "この機体は私じゃなくて{00}コンビューターが動かして……！",
   "zh_text": "这台机体不是我在开、是电脑在操控它…{00}…！",
   "jp_hex": "15f005f06d38a82442f0432f00fee61cf1e7232f0909060000",
   "zh_hex": "15e7b9ea16e7e4ef4fe7b5e7b6efccef29e7fa02e7b6ead3eb67ef29eac7ea3fe978090009ef970000"
  },
  {
   "jp_offset": "0x755f",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "私じゃ止められないの！{00}だから、亜げて、トビア！！",
   "zh_text": "我根本拦不住它！所以快逃啊、托比亚！{00}！",
   "jp_hex": "15a82442f0ca46493317370600f04702f1182f02f13606060000",
   "zh_hex": "15efcce9b8efa6eb89e7b5e859e978ef97e7fbe7f3e85fe8c2e7c302e7f4e825e7d6ef9700ef970000"
  },
  {
   "jp_offset": "0x7594",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "くそっ！{01}ドゥガチめ！！{00}自分の娘になんてことを！",
   "zh_text": "可恶！德卡契！！竟然对亲生女儿做出这{00}种事！",
   "jp_hex": "151e282d0601f0af40060600f07e37e58134f066f0024c060000",
   "zh_hex": "15e7c4e7deef97e82ce801eee2ef97ef97ef2ce7efe7bee894ef8defadeb7ce81cefbee7b900e7d1efb8ef970000"
  },
  {
   "jp_offset": "0x75c9",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "トビア……！",
   "zh_text": "托比亚……！",
   "jp_hex": "15f1360909060000",
   "zh_hex": "15e7f4e825e7d60909ef970000"
  },
  {
   "jp_offset": "0x75ec",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "だいじょうぶだ、ベルナデット！！{00}すぐに……",
   "zh_text": "别怕、贝尔纳黛特！！我马上……",
   "jp_hex": "152bf1954418e05a2b02f0f4f1a2060600f2ef09090000",
   "zh_hex": "15e7e5e95802e857e7e1e882ea9ae7cfef97ef97efcce84fef4c09090000"
  },
  {
   "jp_offset": "0x7603",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "すぐにそこから除け出してやる！！",
   "zh_text": "立刻把你从那里面救出来！！",
   "jp_hex": "15f2eff11b1b46f4f7232f434806060000",
   "zh_hex": "15e86be91fe81be7b8e88ae7b7ef31e862e8caefbeefcfef97ef970000"
  },
  {
   "jp_offset": "0x763a",
   "jp_len": 19,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "なんだ……！？{00}あのモビルアーマー……",
   "zh_text": "那是什么……！？那台机动装甲……",
   "jp_hex": "15334d2b0909060500f01af1b5f2b509090000",
   "zh_hex": "15e7b7e7b6e7dde7bd0909ef9705e7b7ea16e7e4ef30e98febdb09090000"
  },
  {
   "jp_offset": "0x764d",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ベルナデットじゃない、{00}もっと別な気を感じる！！",
   "zh_text": "里面不是贝尔纳黛特、我感觉到了另一股{00}气息！！",
   "jp_hex": "15f0f4f1a2244233170200f311e53433934cf10b4806060000",
   "zh_hex": "15ef31e862e7b5e7b6e857e7e1e882ea9ae7cf02efcce87de8aee7d7e7bae99befb6edac00e8edec6aef97ef970000"
  },
  {
   "jp_offset": "0x7666",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "誰だ！{00}誰がそこにいる！？",
   "zh_text": "是谁！是谁在那里面！？",
   "jp_hex": "15e3fc2b0600e3fc1cf11b34174806050000",
   "zh_hex": "15e7b6e923ef97e7b6e923ef29e7b7ef31e862ef97050000"
  },
  {
   "jp_offset": "0x76ab",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "フ{01}フハハハハハ！{00}よくわかったな、承僧！！",
   "zh_text": "呼哈哈哈哈！好眼力啊、臭小子！！",
   "jp_hex": "157401f5d1f1e5f1e50600f0def0242d2a3302f2b906060000",
   "zh_hex": "15ea3ce7e8e7e8e7e8e7e8ef97e7c7e90befb0e7c302ecfde83ee886ef97ef970000"
  },
  {
   "jp_offset": "0x76cf",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x76d0",
   "jp_len": 42,
   "kind": "script",
   "jp_hex": "1533020001064f0113781233020001068d001320113302000115f005e36a0605011ae510f03806050000",
   "zh_hex": "1833020001064f0113301533020001068d0013d8133302000115e7b9ea8aea71ef9705e7b6e888e894efa5efb2ef97050000"
  },
  {
   "jp_offset": "0x771b",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "クラックス·ドゥガチ……！！",
   "zh_text": "德卡契！",
   "jp_hex": "15f1ee04f0af090906060000",
   "zh_hex": "15e82ce801eee2060000"
  },
  {
   "jp_offset": "0x7732",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x7733",
   "jp_len": 51,
   "kind": "script",
   "jp_hex": "1533020001063c011378123302000106800013201133020001060300068000133d1133020002150909f00df0f82b02f2b90000",
   "zh_hex": "1833020001063c011330153302000106800013d8133302000106030006800013f5133302000215ef3be7b602e83ee8860000"
  },
  {
   "jp_offset": "0x7766",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "この機体を動かしているのは{00}クラックス·ドゥガチ……",
   "zh_text": "操控它的是德卡契……",
   "jp_hex": "15f005f06d4cf1e7232f1748373800f1ee04f0af09090000",
   "zh_hex": "15eac7ea3fe978e7b4e7b6e82ce801eee209090000"
  },
  {
   "jp_offset": "0x777e",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "その思考パターンを転{SLOT:2053}した{00}生体頭脳よ",
   "zh_text": "是把他的思维模式转写而成的生体头脑",
   "jp_hex": "15f00dfcb7fdbf4cf9b1232a00f5dcf93c450000",
   "zh_hex": "15e7b6e81be80ce7b4efcaea54ea91ea26e9c2ede3e89ce837e7b4ef8def4fe92eeb670000"
  },
  {
   "jp_offset": "0x7792",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "だが、わかったところで{00}どうなるというのだ、承僧？",
   "zh_text": "可就算你看穿了、又能怎样呢、臭小子？",
   "jp_hex": "15f02702f0242d2af13800f0533348311718372b02f2b9050000",
   "zh_hex": "15e7c4e7c5e889e7b8e7f6ea7ee7ba02e8f1e7c6e7f2e7dae90702ecfde83ee886050000"
  },
  {
   "jp_offset": "0x77b7",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x77b8",
   "jp_len": 35,
   "kind": "script",
   "jp_hex": "1533020001068f001378123302000106420013201133020001150909f04d2d06050000",
   "zh_hex": "1833020001068f001330153302000106420013d813330200011509e7dde7bd06050000"
  },
  {
   "jp_offset": "0x77e6",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x77e7",
   "jp_len": 63,
   "kind": "script",
   "jp_hex": "1533020001063c011378123302000106800013201133020001060300068000133d113302000215f02137f0dbf007f0281748e5813800f114ae37e49b2b0000",
   "zh_hex": "1833020001063c011330153302000106800013d8133302000106030006800013f5133302000215e7b8e7e6e8cae7b4b0e95602e7c500ef298be7b4aec00000"
  },
  {
   "jp_offset": "0x7826",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "攻撃できるかね！？",
   "zh_text": "你还下得了手吗！？",
   "jp_hex": "15f01ff01748f16006050000",
   "zh_hex": "15e7b8e7f7ef4de80ae7baef66e802ef97050000"
  },
  {
   "jp_offset": "0x783d",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x783e",
   "jp_len": 43,
   "kind": "script",
   "jp_hex": "1533020001068f00137812330200010642001320113302000115f07e37e58137f002244233171b06060000",
   "zh_hex": "1833020001068f001330153302000106420013d8133302000115e7b7e7c4e7b6e7b8e7b4e894ef8defadeb7ce7c3ef97ef970000"
  },
  {
   "jp_offset": "0x7869",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "それが人間の言うことか！{00}きさまーーっ！！",
   "zh_text": "这是人说得出口的话吗！你这混蛋——！{00}！",
   "jp_hex": "15f0081cf075379b18f0021b06001df038f1752d06060000",
   "zh_hex": "15e7b9e7b6efb2e7ede80aefbeeabde7b4e81fe802ef97e7b8e7b9ea41ea6debafebafef9700ef970000"
  },
  {
   "jp_offset": "0x788c",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x788d",
   "jp_len": 53,
   "kind": "script",
   "jp_hex": "1533020001063c011378123302000106800013201133020001060300068000133d1133020002153838383802e3124b274833060000",
   "zh_hex": "1833020001063c011330153302000106800013d8133302000106030006800013f5133302000215e7e8e7e8e7e8e7e802e7c4ea1ce897eacaef970000"
  },
  {
   "jp_offset": "0x78c2",
   "jp_len": 30,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "戦いに汚い{SLOT:2185}烈などありはせん！{00}これは戦争なのだよ！",
   "zh_text": "战斗哪分什么卑劣与高尚！这可是战争啊{00}！",
   "jp_hex": "15b91734e0c617ffe2f039f04638274d0600f00e38f07033372b45060000",
   "zh_hex": "15ef28e7ffe8ffefaee7dde7bdec4bec0de832e812ecceef97e7b9e7c4e7b6ef28e852e7c300ef970000"
  },
  {
   "jp_offset": "0x78eb",
   "jp_len": 1,
   "kind": "script",
   "jp_hex": "c9",
   "zh_hex": "81"
  },
  {
   "jp_offset": "0x78ec",
   "jp_len": 34,
   "kind": "script",
   "jp_hex": "1533020001068f00137812330200010642001320113302000115f0af090906060000",
   "zh_hex": "1833020001068f001330153302000106420013d8133302000115e82ce801eee20909ef97ef970000"
  },
  {
   "jp_offset": "0x7936",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "戦争だと……！？",
   "zh_text": "战争……！？",
   "jp_hex": "15f0702b31090906050000",
   "zh_hex": "15ef28e8520909ef97050000"
  },
  {
   "jp_offset": "0x794b",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "クラックス·ドゥガチ！{00}あんたがどう思ってようと……",
   "zh_text": "格拉克斯·德卡契！不管你怎么想……",
   "jp_hex": "15f1ee04f0af0600164d2a1cf053a62d2ff0073109090000",
   "zh_hex": "15e824e7c2e7d5e7c8ef4be82ce801eee2ef97e7b5e93be7b8e7f2e7bde7e609090000"
  },
  {
   "jp_offset": "0x796d",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "俺の方は戦争をやっている{00}つもりなどないっ！！",
   "zh_text": "我可不是在跟你打什么战争！！",
   "jp_hex": "158837d038f0704c432d2f174800f08bf03933172d06060000",
   "zh_hex": "15efcce7c4e7b5e7b6ef29e973e7b8e7f5e7dde7bdef28e852ef97ef970000"
  },
  {
   "jp_offset": "0x7986",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ベルナデットは返してもらうぞ！",
   "zh_text": "贝尔纳黛特、我要夺回来！",
   "jp_hex": "15f0f4f1a238e53b232ff0401829060000",
   "zh_hex": "15e857e7e1e882ea9ae7cf02efccef2aea17ef52efcfef970000"
  },
  {
   "jp_offset": "0x79be",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "……今だ！！",
   "zh_text": "……就是现在！！",
   "jp_hex": "150909a22b06060000",
   "zh_hex": "150909e7c5e7b6e82fef29ef97ef970000"
  },
  {
   "jp_offset": "0x79ea",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ベルナデットは返してもらうぞ！！",
   "zh_text": "我一定要把贝尔纳黛特夺回来！！",
   "jp_hex": "15f0f4f1a238e53b232ff040182906060000",
   "zh_hex": "15efccefb6e867ef2ae81be857e7e1e882ea9ae7cfea17ef52efcfef97ef970000"
  },
  {
   "jp_offset": "0x7a2e",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "っ！{01}承僧がぁっ！！",
   "zh_text": "唔！这臭小子！！",
   "jp_hex": "152d0601f2b91c152d06060000",
   "zh_hex": "15e81def97e7b9ecfde83ee886ef97ef970000"
  },
  {
   "jp_offset": "0x7a6a",
   "jp_len": 16,
   "kind": "dialogue",
   "speaker": "克拉克斯·杜加奇",
   "jp_text": "キサマのものではあるまいっ！",
   "zh_text": "她可不是属于你的东西！",
   "jp_hex": "15f0d637f019f00af00ff1192d060000",
   "zh_hex": "15e88ee7c4e7b5e7b6ea24e879e7b8e7b4e8bae7f8ef970000"
  },
  {
   "jp_offset": "0x7aaa",
   "jp_len": 14,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ならば、海賊らしく……",
   "zh_text": "那么、就照我们海盗的作风……",
   "jp_hex": "1533463902f14e46231e09090000",
   "zh_hex": "15e7b7e7bd02e7c5ea1aefcce7bbe91be9f3e7b4ef2feb7509090000"
  },
  {
   "jp_offset": "0x7aea",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "いただいてゆくっ！！",
   "zh_text": "我就把她笑纳了！！",
   "jp_hex": "15f125172fe0601e2d06060000",
   "zh_hex": "15efcce7c5e81be88eea1ce882e7baef97ef970000"
  },
  {
   "jp_offset": "0x7b26",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "トビア！！",
   "zh_text": "托比亚！！",
   "jp_hex": "15f13606060000",
   "zh_hex": "15e7f4e825e7d6ef97ef970000"
  },
  {
   "jp_offset": "0x7b52",
   "jp_len": 20,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "もうだいじょうぶだ、ベルナデット……",
   "zh_text": "已经没事了、贝尔纳黛特……",
   "jp_hex": "15f02a2bf1954418e05a2b02f0f4f1a209090000",
   "zh_hex": "15ef3ae8b7e7d8efb8e7ba02e857e7e1e882ea9ae7cf09090000"
  },
  {
   "jp_offset": "0x7b87",
   "jp_len": 12,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "うん！……うん！！",
   "zh_text": "嗯！……嗯！！",
   "jp_hex": "15184d060909184d06060000",
   "zh_hex": "15e865ef970909e865ef97ef970000"
  },
  {
   "jp_offset": "0x7bde",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "トビア……",
   "zh_text": "托比亚……",
   "jp_hex": "15f13609090000",
   "zh_hex": "15e7f4e825e7d609090000"
  },
  {
   "jp_offset": "0x7c00",
   "jp_len": 23,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "どうしたんだ、ベルナデット？{00}民れないのか？",
   "zh_text": "怎么了、贝尔纳黛特？睡不着吗？",
   "jp_hex": "15f07f2a4d2b02f0f4f1a20500e57d493317371b050000",
   "zh_hex": "15e7f2e7bde7ba02e857e7e1e882ea9ae7cf05ebdee7b5e86de802050000"
  },
  {
   "jp_offset": "0x7c32",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "少し、考えごとしてて……",
   "zh_text": "我在想一些事情……",
   "jp_hex": "15f10602f092f1c5232f2f09090000",
   "zh_hex": "15efccef29e7e6efb6e8a4efb8e88b09090000"
  },
  {
   "jp_offset": "0x7c65",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "……ベルナデット？",
   "zh_text": "……贝尔纳黛特？",
   "jp_hex": "150909f0f4f1a2050000",
   "zh_hex": "150909e857e7e1e882ea9ae7cf050000"
  },
  {
   "jp_offset": "0x7c8a",
   "jp_len": 8,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "父さんは……",
   "zh_text": "我父亲他……",
   "jp_hex": "15f46d3809090000",
   "zh_hex": "15efcce888e894e80c09090000"
  },
  {
   "jp_offset": "0x7c92",
   "jp_len": 29,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "……父さんはもう、{00}死んじゃってるんじゃないかって思うの",
   "zh_text": "……我总觉得、父亲他、其实早就已经死{00}了",
   "jp_hex": "150909f46d38f02a0200a74d24422df01d4d24423317f3b6a618370000",
   "zh_hex": "150909efcce881e8aee80a02e888e894e80c02e8cfe87fe963e7c5ef3ae8b7ef6a00e7ba0000"
  },
  {
   "jp_offset": "0x7caf",
   "jp_len": 31,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "だから今、木星軍に命令してるのは{00}父さんのコビー人径なんだわ！",
   "zh_text": "所以如今对木星军下令的、是父亲的复制{00}人偶！",
   "jp_hex": "15f047a202f0379834f15223f01d373800f46d37fea7f3a2334d2b4b060000",
   "zh_hex": "15e7fbe7f3e7f0efb9e7beefa9ef69e7e0ef4de94ee7b402e7b6e888e894e7b4e9eee8de00efb2ea85ef970000"
  },
  {
   "jp_offset": "0x7cce",
   "jp_len": 24,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "でなければあんなひどいこと{00}するわけないもの……！",
   "zh_text": "否则、他绝不会做出那么残忍的事……！",
   "jp_hex": "15f422f1f2f81f17f00200f004f05033f17f370909060000",
   "zh_hex": "15e9bbea8702e80ce91ce7b5e7e2e81cefbee7b7e7bde97beb59e7b4efb80909ef970000"
  },
  {
   "jp_offset": "0x7d01",
   "jp_len": 9,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ベルナデット……",
   "zh_text": "贝尔纳黛特……",
   "jp_hex": "15f0f4f1a209090000",
   "zh_hex": "15e857e7e1e882ea9ae7cf09090000"
  },
  {
   "jp_offset": "0x7d25",
   "jp_len": 21,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "ねえ、トビアーー！{00}だから、だから……",
   "zh_text": "听我说、托比亚！所以……所以……",
   "jp_hex": "15f1b102f136e004e0040600f04702f04709090000",
   "zh_hex": "15e8d1efcce7ed02e7f4e825e7d6ef97e7fbe7f30909e7fbe7f309090000"
  },
  {
   "jp_offset": "0x7d3a",
   "jp_len": 18,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "だから止めて！{00}止めてあげて！！",
   "zh_text": "所以快阻止他！求你阻止他吧！！",
   "jp_hex": "15f047f0ca2f0600f0ca2ff2b62f06060000",
   "zh_hex": "15e7fbe7f3e85fe8efe869e80cef97e93ae7b8e8efe869e80ce7d0ef97ef970000"
  },
  {
   "jp_offset": "0x7d4c",
   "jp_len": 25,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "父の煙念にこれ以上{00}ひどいことをさせないで！！",
   "zh_text": "别再让父亲的怨念、做出更残忍的事了！{00}！",
   "jp_hex": "15e51037fae334f0ee00f81f17f0024cf02e33173006060000",
   "zh_hex": "15e7e5e80be7f9e888e894e7b4ec19ea2702e81cefbee952e97beb59e7b4efb8e7baef9700ef970000"
  },
  {
   "jp_offset": "0x7d80",
   "jp_len": 19,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "……だいじょうぶだよ、ベルナデット",
   "zh_text": "……放心吧、贝尔纳黛特",
   "jp_hex": "1509092bf1954418e05a2b4502f0f4f1a20000",
   "zh_hex": "150909e86ce82de7d002e857e7e1e882ea9ae7cf0000"
  },
  {
   "jp_offset": "0x7d93",
   "jp_len": 13,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ボクが、きっと……！！",
   "zh_text": "我、我一定会……！！",
   "jp_hex": "15f0591c02f310090906060000",
   "zh_hex": "15efcc02efccefb6e867e7e20909ef97ef970000"
  },
  {
   "jp_offset": "0x7dbb",
   "jp_len": 7,
   "kind": "dialogue",
   "speaker": "ベルナデット",
   "jp_text": "……うん",
   "zh_text": "……嗯",
   "jp_hex": "150909184d0000",
   "zh_hex": "150909e8650000"
  },
  {
   "jp_offset": "0x7dda",
   "jp_len": 10,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "……バジルール艦長！",
   "zh_text": "……巴基露露舰长！",
   "jp_hex": "150909f15af034060000",
   "zh_hex": "150909e85be829e858e858e7d4ef34ef970000"
  },
  {
   "jp_offset": "0x7dff",
   "jp_len": 11,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "ああ、了解した！",
   "zh_text": "啊、明白了！",
   "jp_hex": "15f05602f086232a060000",
   "zh_hex": "15e7c302ef39e809e7baef970000"
  },
  {
   "jp_offset": "0x7e0a",
   "jp_len": 17,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "各機、あのモビルアーマーへ向かえ！",
   "zh_text": "各机、都冲向那台机动装甲！",
   "jp_hex": "15f20302f01af1b5f2b53bf05819060000",
   "zh_hex": "15e819e7e402e840e95eefc1e7b7ea16e7e4ef30e98febdbef970000"
  },
  {
   "jp_offset": "0x7e1b",
   "jp_len": 26,
   "kind": "dialogue",
   "speaker": "娜塔尔·巴吉路",
   "jp_text": "足を止めて内部に{SLOT:1812}われている{00}少女を救出する！",
   "zh_text": "拦下它、把困在它内部的那名少女救出来{00}！",
   "jp_hex": "15e3ca4cf0ca2ff26534f46c2f174800f29a4cf368f004060000",
   "zh_hex": "15eb89ef4de97802e81beaffef29e978e99aef70e7b4e7b7e8acefacefade8caefbeefcf00ef970000"
  },
  {
   "jp_offset": "0x7e5a",
   "jp_len": 15,
   "kind": "dialogue",
   "speaker": "贝拉·罗纳",
   "jp_text": "今よ！……ベルナデットを！！",
   "zh_text": "就趁现在！……救出贝尔纳黛特！！",
   "jp_hex": "15a245060909f0f4f1a24c06060000",
   "zh_hex": "15e7c5e9eae82fef29ef970909e8caefbee857e7e1e882ea9ae7cfef97ef970000"
  },
  {
   "jp_offset": "0x7e8e",
   "jp_len": 14,
   "kind": "dialogue",
   "speaker": "托比亚",
   "jp_text": "ベルナデット……今行く！！",
   "zh_text": "我这就来！",
   "jp_hex": "15f0f4f1a20909f8391e06060000",
   "zh_hex": "158be7b9e7c5d9060000"
  }
 ]
}
