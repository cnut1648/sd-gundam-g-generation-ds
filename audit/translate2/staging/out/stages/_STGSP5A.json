 ],
 "title_zh": "扎比涅的叛乱",
 "briefing": [],
 "blocks": [
  {
   "off": "0x629A",
   "zh": "呵呵呵……"
  },
  {
   "off": "0x62CA",
   "zh": "你就是十字先锋的扎比涅·夏尔吧？"
  },
  {
   "off": "0x62DE",
   "zh": "……联络我们已经收到了"
  },
  {
   "off": "0x631E",
   "zh": "那么、投降的条件也……"
  },
  {
   "off": "0x6351",
   "zh": "我们会保障你和贝拉·罗纳舰长的安全"
  },
  {
   "off": "0x6382",
   "zh": "可恶！就没什么办法了吗！？"
  },
  {
   "off": "0x63B0",
   "zh": "先锋母舰上可还有布莱特舰长在啊！"
  },
  {
   "off": "0x63C4",
   "zh": "要是我们轻举妄动的话……"
  },
  {
   "off": "0x63FA",
   "zh": "……没错、你们最好别乱动"
  },
  {
   "off": "0x640C",
   "zh": "先锋母舰的主炮、可正对准着你们呢"
  },
  {
   "off": "0x6424",
   "zh": "要是轻举妄动、呵呵……"
  },
  {
   "off": "0x645A",
   "zh": "唔哦！？"
  },
  {
   "off": "0x6497",
   "zh": "扎比涅！你这混蛋！！"
  },
  {
   "off": "0x64B8",
   "zh": "啧！是金凯度吗！！"
  },
  {
   "off": "0x64EA",
   "zh": "可恶！是海盗一伙吗！！全员、进入战斗配置……"
  },
  {
   "off": "0x6538",
   "zh": "……等等！"
  },
  {
   "off": "0x6566",
   "zh": "唔！？"
  },
  {
   "off": "0x659E",
   "zh": "放走那家伙是我的失职……那就由我负起责任收拾他"
  },
  {
   "off": "0x65DF",
   "zh": "唔……好、好吧"
  },
  {
   "off": "0x6612",
   "zh": "……就是这么回事、金凯度"
  },
  {
   "off": "0x6620",
   "zh": "毕竟我想不容旁人插手、与你做个了断啊、呵呵……"
  },
  {
   "off": "0x6670",
   "zh": "扎比涅、你这家伙？"
  },
  {
   "off": "0x669E",
   "zh": "……来吧、尽管放马过来、金凯度"
  },
  {
   "off": "0x66AD",
   "zh": "若你能打倒我、我答应释放贝拉大人也无妨哦？"
  },
  {
   "off": "0x66CD",
   "zh": "哈、哈哈、哈！！"
  },
  {
   "off": "0x670B",
   "zh": "啧、扎比涅……！"
  },
  {
   "off": "0x674B",
   "zh": "……好吧"
  },
  {
   "off": "0x6755",
   "zh": "你的诡计……我就奉陪到底！！"
  },
  {
   "off": "0x677C",
   "zh": "哈、哈哈哈、哈哈！！这才像话！金凯度！！"
  },
  {
   "off": "0x67AE",
   "zh": "呵呵呵、我就知道你会答应"
  },
  {
   "off": "0x67F3",
   "zh": "…………"
  },
  {
   "off": "0x6821",
   "zh": "毕竟、你我二人……"
  },
  {
   "off": "0x6830",
   "zh": "似乎正是非得一决雌雄不可的关系啊！金凯度！！"
  },
  {
   "off": "0x6887",
   "zh": "打倒你、救出贝拉……"
  },
  {
   "off": "0x6899",
   "zh": "……觉悟吧！扎比涅！！"
  },
  {
   "off": "0x60D2",
   "zh": "……不好！这艘舰要是被击毁……！"
  },
  {
   "off": "0x8982",
   "zh": "啊啊！？"
  },
  {
   "off": "0x6AE6",
   "zh": "金凯度！？"
  },
  {
   "off": "0x6B12",
   "zh": "贝、贝拉……对不……"
  },
  {
   "off": "0x6B4E",
   "zh": "啊哈哈哈！啊哈哈哈哈哈！！永别了！金凯度！"
  },
  {
   "off": "0x6B96",
   "zh": "金凯度……！！"
  },
  {
   "off": "0x6BCF",
   "zh": "可恶！金凯度先生他！？"
  },
  {
   "off": "0x6C06",
   "zh": "托比亚……！"
  },
  {
   "off": "0x6C36",
   "zh": "先锋母舰被占领、这次连金凯度先生也……！"
  },
  {
   "off": "0x6C4E",
   "zh": "……可恶！！"
  },
  {
   "off": "0x6C8D",
   "zh": "啊、托比亚！？"
  },
  {
   "off": "0x6CAE",
   "zh": "…………"
  },
  {
   "off": "0x6CD2",
   "zh": "唔……是托比亚吗！？"
  },
  {
   "off": "0x6CF8",
   "zh": "你们这帮混蛋……！"
  },
  {
   "off": "0x6D0D",
   "zh": "别给我开玩笑了啊啊！！"
  },
  {
   "off": "0x6D4A",
   "zh": "……就是现在！先锋母舰、快后退！！"
  },
  {
   "off": "0x6D97",
   "zh": "啊……我、我……金凯度他……"
  },
  {
   "off": "0x6DC4",
   "zh": "快让舰后退、贝拉·罗纳！！"
  },
  {
   "off": "0x6E00",
   "zh": "啊……"
  },
  {
   "off": "0x6E06",
   "zh": "先、先锋母舰……后退……"
  },
  {
   "off": "0x6E3A",
   "zh": "啧！可恶的海盗！！"
  },
  {
   "off": "0x14AA",
   "zh": "布莱特舰长！！"
  },
  {
   "off": "0x14CE",
   "zh": "这边不用担心！托比亚！你去迎击敌方部队！！"
  },
  {
   "off": "0x1503",
   "zh": "明白！"
  },
  {
   "off": "0x152E",
   "zh": "各舰、立即进入战斗态势！！击退木星帝国！"
  },
  {
   "off": "0x157C",
   "zh": "啊……"
  },
  {
   "off": "0x159D",
   "zh": "贝拉·罗纳！？"
  },
  {
   "off": "0x15CF",
   "zh": "早知道……早知道会变成这样……"
  },
  {
   "off": "0x15E2",
   "zh": "我……当初什么都不做就好了……"
  },
  {
   "off": "0x1613",
   "zh": "贝拉·罗纳！振作起来！！你这个样子怎么行！"
  },
  {
   "off": "0x1659",
   "zh": "可、可是、我……都是因为我挑起了这场战争"
  },
  {
   "off": "0x1674",
   "zh": "那个人他……金凯度他……！！"
  },
  {
   "off": "0x16AA",
   "zh": "不对、贝拉小姐！！金凯度先生才没有死！"
  },
  {
   "off": "0x16C6",
   "zh": "那个人怎么可能那么轻易就死！！我相信、他一定还活着！！"
  },
  {
   "off": "0x1713",
   "zh": "托比亚……"
  },
  {
   "off": "0x173F",
   "zh": "贝拉·罗纳、你打算沉浸在悲伤里到什么时候？"
  },
  {
   "off": "0x177E",
   "zh": "…………"
  },
  {
   "off": "0x17A2",
   "zh": "指挥官这条路、应该是你自己选择的"
  },
  {
   "off": "0x17B7",
   "zh": "若你在此抛下一切、那就不只是金凯度……"
  },
  {
   "off": "0x17D0",
   "zh": "更是等于背弃了所有信任着你的人啊"
  },
  {
   "off": "0x1817",
   "zh": "布莱特舰长……"
  },
  {
   "off": "0x183B",
   "zh": "来、执掌先锋母舰的指挥吧、贝拉·罗纳！！"
  },
  {
   "off": "0x187C",
   "zh": "我……"
  },
  {
   "off": "0x18A0",
   "zh": "我会去做的！！"
  },
  {
   "off": "0x6E6E",
   "zh": "先锋母舰！全舰、进入攻击态势！！"
  },
  {
   "off": "0x6E7F",
   "zh": "我们要击破木星帝国军！！"
  },
  {
   "off": "0x6EB6",
   "zh": "好！其他各舰、跟上先锋母舰！！"
  },
  {
   "off": "0x6EC9",
   "zh": "隆德·贝尔队！现在开始、转入反击！！"
  },
  {
   "off": "0x68D2",
   "zh": "……啧！"
  },
  {
   "off": "0x6902",
   "zh": "结束了！扎比涅！！"
  },
  {
   "off": "0x6936",
   "zh": "呵、呵呵呵呵！当真如此吗、金凯度！！"
  },
  {
   "off": "0x6976",
   "zh": "什么、你这家伙！？"
  },
  {
   "off": "0x699A",
   "zh": "可恶！没能给他最后一击吗！！"
  },
  {
   "off": "0x69E2",
   "zh": "金凯度……！"
  },
  {
   "off": "0x69F4",
   "zh": "只要没有你、只要没有你的话……！"
  },
  {
   "off": "0x6A12",
   "zh": "若非贝拉大人对你倾心、她也不会舍弃贵族主义！"
  },
  {
   "off": "0x6A6A",
   "zh": "用死来赎罪吧！！金凯度！"
  },
  {
   "off": "0x6AAE",
   "zh": "糟了！？"
  },
  {
   "off": "0x18D0",
   "zh": "敌方部队的反应、完全消失！"
  },
  {
   "off": "0x6F06",
   "zh": "看来你已经重新振作起来了、贝拉·罗纳"
  },
  {
   "off": "0x6F36",
   "zh": "……好的"
  },
  {
   "off": "0x6F3D",
   "zh": "如果只顾悲伤、那个人的所作所为、就都白费了……"
  },
  {
   "off": "0x6F5D",
   "zh": "胸中的伤痛虽无法抹去……但我们不能停下脚步"
  },
  {
   "off": "0x6F82",
   "zh": "所以、我要……"
  },
  {
   "off": "0x6FB2",
   "zh": "可恶、又来了新的敌人……！？"
  },
  {
   "off": "0x6FE6",
   "zh": "……布莱特舰长！"
  },
  {
   "off": "0x700B",
   "zh": "不妙啊、我们的战力在方才一战中消耗严重……"
  },
  {
   "off": "0x704E",
   "zh": "全舰、准备攻击！"
  },
  {
   "off": "0x7059",
   "zh": "对胆敢违抗德卡契总统的海盗们、降下制裁的铁锤！"
  },
  {
   "off": "0x709E",
   "zh": "都给我住手！！"
  },
  {
   "off": "0x70CE",
   "zh": "贝尔纳黛特！？"
  },
  {
   "off": "0x70FE",
   "zh": "不许对这些人出手！！"
  },
  {
   "off": "0x7130",
   "zh": "你、你是什么人！？"
  },
  {
   "off": "0x7159",
   "zh": "我是提提妮丝·德卡契"
  },
  {
   "off": "0x7163",
   "zh": "总统格拉克斯德卡契的女儿"
  },
  {
   "off": "0x718D",
   "zh": "怎、怎么会……贝尔纳黛特？"
  },
  {
   "off": "0x71B6",
   "zh": "那孩子、是德卡契的……？"
  },
  {
   "off": "0x71EA",
   "zh": "司、司令……那张脸确实是提提妮丝大人的……"
  },
  {
   "off": "0x721F",
   "zh": "唔、唔唔……"
  },
  {
   "off": "0x7252",
   "zh": "父亲德卡契应该正在寻找我的下落……"
  },
  {
   "off": "0x726B",
   "zh": "如果你们放过他们、我就和你们一起回到父亲身边"
  },
  {
   "off": "0x72AA",
   "zh": "这话……当真？"
  },
  {
   "off": "0x72D1",
   "zh": "总统之女、绝无戏言"
  },
  {
   "off": "0x7308",
   "zh": "……那好吧"
  },
  {
   "off": "0x7314",
   "zh": "那么、作为收容您的交换、便放过那些人吧"
  },
  {
   "off": "0x735A",
   "zh": "司令……！？"
  },
  {
   "off": "0x737E",
   "zh": "无妨！提提妮丝大人的安危优先！！"
  },
  {
   "off": "0x73B1",
   "zh": "可是……"
  },
  {
   "off": "0x73D3",
   "zh": "反正只是支濒死的部队、放着不管也翻不起什么风浪"
  },
  {
   "off": "0x73F3",
   "zh": "何况、就算我们不特意动手、反正那帮家伙也……"
  },
  {
   "off": "0x744F",
   "zh": "快去收容提提妮丝大人！！"
  },
  {
   "off": "0x7486",
   "zh": "……贝尔纳黛特！！"
  },
  {
   "off": "0x74AC",
   "zh": "别担心、托比亚"
  },
  {
   "off": "0x74B8",
   "zh": "我会去见父亲大人、试着说服他停止这场战争"
  },
  {
   "off": "0x74F1",
   "zh": "请吧……提提妮丝大人"
  },
  {
   "off": "0x7516",
   "zh": "……好的"
  },
  {
   "off": "0x7542",
   "zh": "可恶……贝尔纳黛特！！"
  },
  {
   "off": "0x1904",
   "zh": "各舰的修理、均已完成"
  },
  {
   "off": "0x192F",
   "zh": "……是吗"
  },
  {
   "off": "0x1937",
   "zh": "虽然耽搁了不少时间、但这下总算能返回地球了"
  },
  {
   "off": "0x1977",
   "zh": "木星帝国已经将那样一支大部队、送进了地球圈……"
  },
  {
   "off": "0x1998",
   "zh": "而他们露出獠牙、恐怕只是时间问题了"
  },
  {
   "off": "0x19CF",
   "zh": "拦得住吗？……凭我们这双手"
  },
  {
   "off": "0x19FB",
   "zh": "……不"
  },
  {
   "off": "0x1A02",
   "zh": "单凭我们隆德·贝尔来应对、这事态未免太过重大"
  },
  {
   "off": "0x1A1F",
   "zh": "联络军本部、请求增援吧"
  },
  {
   "off": "0x1A4B",
   "zh": "若木星帝国意在地球、那便一刻也不容耽搁了"
  },
  {
   "off": "0x1A6D",
   "zh": "必须尽快与正规军的各位会合、防备侵攻才行呢"
  },
  {
   "off": "0x1AAC",
   "zh": "那么、各舰迅速出发！"
  },
  {
   "off": "0x1ABD",
   "zh": "托雷斯、联络军本部！"
  },
  {
   "off": "0x1ACA",
   "zh": "与正规军会合后、着手阻止木星帝国军的侵攻！！"
  },
  {
   "off": "0x7576",
   "zh": "…………"
  },
  {
   "off": "0x759A",
   "zh": "……贝拉小姐"
  },
  {
   "off": "0x75BE",
   "zh": "啊……托比亚？"
  },
  {
   "off": "0x75E2",
   "zh": "那个……金凯度先生的事……"
  },
  {
   "off": "0x760C",
   "zh": "你是在担心我吗？谢谢你、托比亚"
  },
  {
   "off": "0x761F",
   "zh": "不过、我没事的哦"
  },
  {
   "off": "0x7630",
   "zh": "托比亚你不也在为她的事难受吗、我也不能一直哭哭啼啼的呢"
  },
  {
   "off": "0x7670",
   "zh": "金、金凯度先生他！金凯度先生才没有死！"
  },
  {
   "off": "0x768A",
   "zh": "就那种程度、他怎么可能会死！！"
  },
  {
   "off": "0x76C1",
   "zh": "……没关系的、托比亚"
  },
  {
   "off": "0x76CD",
   "zh": "人不管怎样、该死的时候……终究还是会死的"
  },
  {
   "off": "0x7702",
   "zh": "…………"
  },
  {
   "off": "0x7726",
   "zh": "以前……啊"
  },
  {
   "off": "0x7749",
   "zh": "贝拉小姐……？"
  },
  {
   "off": "0x776E",
   "zh": "在我决意与木星帝国作战的那一天……"
  },
  {
   "off": "0x7788",
   "zh": "那个人选择舍弃旧名、改称金凯度"
  },
  {
   "off": "0x77C1",
   "zh": "旧名……他舍弃了西布克·阿诺这个名字……"
  },
  {
   "off": "0x77F7",
   "zh": "……嗯"
  },
  {
   "off": "0x77FE",
   "zh": "我不明白那是为什么、问了、他也不肯回答"
  },
  {
   "off": "0x7820",
   "zh": "而我、因为他一直陪在身边……总以为彼此的心意是相通的"
  },
  {
   "off": "0x7848",
   "zh": "便没有再追问下去"
  },
  {
   "off": "0x785B",
   "zh": "但是、也许从那个时候起……"
  },
  {
   "off": "0x786E",
   "zh": "我或许并没有像自己以为的那样、真正抓住他的心呢"
  },
  {
   "off": "0x78AD",
   "zh": "……是这样吗"
  },
  {
   "off": "0x78D4",
   "zh": "咦……？"
  },
  {
   "off": "0x78F6",
   "zh": "贝拉小姐你以前、不也自称塞西莉·菲亚查德吗？"
  },
  {
