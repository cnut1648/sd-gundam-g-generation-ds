 "title_zh": "拉克丝出击",
 "briefing": [
  {
   "off": "0x19DFEA",
   "zh": "根据方才截获的通信……"
  },
  {
   "off": "0x19DFFB",
   "zh": "现已查明、PLANT的拉克丝正遭到扎夫特的追捕"
  },
  {
   "off": "0x19E01B",
   "zh": "拉克丝与我们一样、也是为阻止战争而奔走的一员"
  },
  {
   "off": "0x19E042",
   "zh": "我们绝不能让她命丧扎夫特之手"
  },
  {
   "off": "0x19E05C",
   "zh": "接下来我们大天使号将直航PLANT、"
  },
  {
   "off": "0x19E075",
   "zh": "前去营救拉克丝！"
  },
  {
   "off": "0x19E0AF",
   "zh": "多亏迪安娜女王的协助……"
  },
  {
   "off": "0x19E0BE",
   "zh": "迪安娜回归军的舰队、已经在替我们扰乱扎夫特了"
  },
  {
   "off": "0x19E0DF",
   "zh": "我们大天使号将趁此空隙进入PLANT领域、"
  },
  {
   "off": "0x19E0FD",
   "zh": "预定在那里与拉克丝会合"
  },
  {
   "off": "0x19E13C",
   "zh": "既然有阿斯兰·萨拉与拉克丝同行……"
  },
  {
   "off": "0x19E156",
   "zh": "很难想象敌人只会派普通战力进行追击"
  },
  {
   "off": "0x19E174",
   "zh": "扎夫特的新型机恐怕也会出动、请各位务必谨慎应战"
  }
 ],
 "blocks": [
  {
   "off": "0x1696",
   "zh": "叛逆者拉克丝！停止抵抗、乖乖投降！"
  },
  {
   "off": "0x16D6",
   "zh": "前后被夹击了吗……这下可难办了啊"
  },
  {
   "off": "0x170A",
   "zh": "请打开全频段的通信线路"
  },
  {
   "off": "0x173B",
   "zh": "……拉克丝！？"
  },
  {
   "off": "0x1770",
   "zh": "我是拉克丝"
  },
  {
   "off": "0x177C",
   "zh": "虽说因所期望的未来不同、我们与萨拉议长已成敌对、"
  },
  {
   "off": "0x17A5",
   "zh": "但我并不希望与各位交战"
  },
  {
   "off": "0x17B8",
   "zh": "请放这艘船过去吧、然后、也请各位再一次……"
  },
  {
   "off": "0x17D3",
   "zh": "请大家想一想、我们真正必须与之战斗的、究竟是什么"
  },
  {
   "off": "0x181B",
   "zh": "队、队长……！？"
  },
  {
   "off": "0x1848",
   "zh": "唔……"
  },
  {
   "off": "0x1880",
   "zh": "……不可以！"
  },
  {
   "off": "0x18B0",
   "zh": "哦哦、那是！！"
  },
  {
   "off": "0x18D6",
   "zh": "绝不能放那艘舰离开！"
  },
  {
   "off": "0x18E8",
   "zh": "那艘舰上有搭载了中子干扰消除器的MS！"
  },
  {
   "off": "0x1929",
   "zh": "中子干扰消除器！？"
  },
  {
   "off": "0x1953",
   "zh": "怎么可能！拉克丝大人可是被誉为PLANT歌姬的人啊！？"
  },
  {
   "off": "0x1971",
   "zh": "那位大人怎么会做出背叛我们的事……"
  },
  {
   "off": "0x19AB",
   "zh": "可是、蕾蒂·安小姐是真心期盼与PLANT和平相处的啊！？"
  },
  {
   "off": "0x19CD",
   "zh": "无法想象、那位大人会说谎！"
  },
  {
   "off": "0x1A0B",
   "zh": "那东西一旦落入蓝色宇宙之手、"
  },
  {
   "off": "0x1A1E",
   "zh": "昔日的悲剧、就会在地球与PLANT之间重演"
  },
  {
   "off": "0x1A3C",
   "zh": "如果大家真心期盼和平、就绝不能容许那艘舰存在！"
  },
  {
   "off": "0x1A84",
   "zh": "……真有她的。这样一来、我们完全成了坏人"
  },
  {
   "off": "0x1A9F",
   "zh": "那么、您打算怎么办？"
  },
  {
   "off": "0x1AC4",
   "zh": "……突破过去吧"
  },
  {
   "off": "0x1AD0",
   "zh": "因为我们、决不能在这里停下脚步"
  },
  {
   "off": "0x1B01",
   "zh": "嘛……看来也只能拼了"
  },
  {
   "off": "0x1B33",
   "zh": "……我也出击！"
  },
  {
   "off": "0x1B63",
   "zh": "尽量避开驾驶舱哦、阿斯兰"
  },
  {
   "off": "0x1B96",
   "zh": "……我尽力而为"
  },
  {
   "off": "0x9FB2",
   "zh": "居、居然会在这里结束……"
  },
  {
   "off": "0x1BC6",
   "zh": "难道是我太鲁莽了吗……"
  },
  {
   "off": "0x1C07",
   "zh": "阿斯兰！！"
  },
  {
   "off": "0x1C30",
   "zh": "基拉！？"
  },
  {
   "off": "0x1C5C",
   "zh": "哟、少年！你是来救我们的吗！！"
  },
  {
   "off": "0x1C92",
   "zh": "巴尔特菲尔德……先生？"
  },
  {
   "off": "0x1CC3",
   "zh": "这里是大天使号、我是玛琉！"
  },
  {
   "off": "0x1CD6",
   "zh": "是拉克丝对吧、我们是来救援的！"
  },
  {
   "off": "0x1D0F",
   "zh": "这里是永恒号、我是拉克丝"
  },
  {
   "off": "0x1D1F",
   "zh": "十分感谢各位前来救援"
  },
  {
   "off": "0x1D47",
   "zh": "我们正被MS团团围住、进退两难呢！"
  },
  {
   "off": "0x1D61",
   "zh": "你们要是能帮忙突围、那就太感谢了！"
  },
  {
   "off": "0x1D9B",
   "zh": "明白了！"
  },
  {
   "off": "0x1DAD",
   "zh": "MS部队立刻出击！前去救援永恒号！！"
  },
  {
   "off": "0x1F87",
   "zh": "啊……？"
  },
  {
   "off": "0x1F98",
   "zh": "我、我这是……"
  },
  {
   "off": "0x2556",
   "zh": "杰克斯……你到底在想什么？"
  },
  {
   "off": "0x2589",
   "zh": "正如我方才所说、希罗·尤尔"
  },
  {
   "off": "0x259C",
   "zh": "我们的目的、是清除一切与殖民地为敌之物……"
  },
  {
   "off": "0x25B3",
   "zh": "也就是说、地球本身就是敌人！"
  },
  {
   "off": "0x25DC",
   "zh": "……什么！？"
  },
  {
   "off": "0x2600",
   "zh": "只要阻碍这个目的、无论是谁都将被排除！！"
  },
  {
   "off": "0x2620",
   "zh": "接招吧、希罗！！"
  },
  {
   "off": "0x2650",
   "zh": "杰克斯！这到底是怎么回事……！？"
  },
  {
   "off": "0x2662",
   "zh": "您到底想要做什么？"
  },
  {
   "off": "0x2697",
   "zh": "我没打算向你解释"
  },
  {
   "off": "0x26BA",
   "zh": "……杰克斯！"
  },
  {
   "off": "0x26E3",
   "zh": "让开、诺茵！就算是你、挡路的话我也照打不误！！"
  },
  {
   "off": "0x2715",
   "zh": "杰、杰克斯……！"
  },
  {
   "off": "0x2745",
   "zh": "住手吧！！"
  },
  {
   "off": "0x274F",
   "zh": "我们只是想离开这里而已！！"
  },
  {
   "off": "0x2784",
   "zh": "……离开之后又如何？"
  },
  {
   "off": "0x27AD",
   "zh": "什么……？"
  },
  {
   "off": "0x27D0",
   "zh": "把拉克丝带出PLANT之后、你们又打算怎么做？"
  },
  {
   "off": "0x27EF",
   "zh": "她的存在本身、就会为世界播撒争乱的火种！"
  },
  {
   "off": "0x2810",
   "zh": "既然如此、赶在那之前将她在此讨灭、便是这世界的必然！"
  },
  {
   "off": "0x2851",
   "zh": "你这家伙……想对拉克丝！？"
  },
  {
   "off": "0x285D",
   "zh": "我绝不会让你得逞！！"
  },
  {
   "off": "0x2892",
   "zh": "身为匹斯克拉福特王族的您、为何要与扎夫特为伍？"
  },
  {
   "off": "0x28CD",
   "zh": "因为他们与地球为敌！这个理由足以让我助阵"
  },
  {
   "off": "0x2909",
   "zh": "您是打算毁灭地球本身吗？"
  },
  {
   "off": "0x291F",
   "zh": "毁灭之后、您又打算做什么呢？"
  },
  {
   "off": "0x294E",
   "zh": "只要争乱的元凶地球消失、就再没有什么必须做的……！"
  },
  {
   "off": "0x2971",
   "zh": "此刻我们该做的、并不是选择和平这种折中之道！"
  },
  {
   "off": "0x2997",
   "zh": "唯有正本清源之举、才是必要的！"
  },
  {
   "off": "0x29C7",
   "zh": "您这个人……"
  },
  {
   "off": "0x29EA",
   "zh": "你追求和平的行为、对我们白色獠牙而言是个障碍……"
  },
  {
   "off": "0x2A0B",
   "zh": "我与你无冤无仇、但你必须在这里消失！拉克丝！"
  },
  {
   "off": "0x2C76",
   "zh": "怎么了！？"
  },
  {
   "off": "0x2CA1",
   "zh": "这下有点不妙啊、主引擎它……"
  },
  {
   "off": "0x2CDC",
   "zh": "好机会！"
  },
  {
   "off": "0x2CE2",
   "zh": "拿下你了、拉克丝！"
  },
  {
   "off": "0x2D16",
   "zh": "……杰克斯！"
  },
  {
   "off": "0x2D43",
   "zh": "请住手、杰克斯！"
  },
  {
   "off": "0x2D7F",
   "zh": "什么、是诺茵！？"
  },
  {
   "off": "0x2D96",
   "zh": "可恶！快让开、诺茵！！"
  },
  {
   "off": "0x2DCD",
   "zh": "不！我不会让开！！"
  },
  {
   "off": "0x2E00",
   "zh": "不要妨碍我！"
  },
  {
   "off": "0x2E16",
   "zh": "你再不让开、我就连你也当作障碍一并排除！"
  },
  {
   "off": "0x2E62",
   "zh": "那样也没关系……杰克斯"
  },
  {
   "off": "0x2E98",
   "zh": "诺茵！？"
  },
  {
   "off": "0x2EC4",
   "zh": "只是在那之前、请回答我！您为什么要这么做！？"
  },
  {
   "off": "0x2EEC",
   "zh": "身为匹斯克拉福特王族的您、竟亲手做出扩大战乱之举……"
  },
  {
   "off": "0x2F19",
   "zh": "您有没有想过、莉莉娜大人会有多么悲伤！？"
  },
  {
   "off": "0x2F5F",
   "zh": "…………"
  },
  {
   "off": "0x2F8D",
   "zh": "……杰克斯！！"
  },
  {
   "off": "0x2FC5",
   "zh": "没有必要跟你说！！"
  },
  {
   "off": "0x3004",
   "zh": "……杰克斯！？"
  },
  {
   "off": "0x303C",
   "zh": "杰克斯、您这是……"
  },
  {
   "off": "0x3076",
   "zh": "…………"
  },
  {
   "off": "0x307F",
   "zh": "（原谅我、诺茵……）"
  },
  {
   "off": "0x30B1",
   "zh": "唔……！？"
  },
  {
   "off": "0x30EB",
   "zh": "……最后只问你一件事"
  },
  {
   "off": "0x30FA",
   "zh": "杰克斯、你那是认真的吗？"
  },
  {
   "off": "0x3129",
   "zh": "事到如今还说什么……！"
  },
  {
   "off": "0x3134",
   "zh": "我正是为了与地球为敌、才站在这里"
  },
  {
   "off": "0x3169",
   "zh": "即便那样会散播新的战乱、您也在所不惜吗？"
  },
  {
   "off": "0x31A2",
   "zh": "这一切我早有觉悟！！"
  },
  {
   "off": "0x31C9",
   "zh": "……那就是你的真意吗"
  },
  {
   "off": "0x31D7",
   "zh": "那么杰克斯、我就……"
  },
  {
   "off": "0x320E",
   "zh": "……杀了你！"
  },
  {
   "off": "0x3243",
   "zh": "不！我可不能栽在你的手上！"
  },
  {
   "off": "0x3281",
   "zh": "……杰克斯！！"
  },
  {
   "off": "0x32B9",
   "zh": "……太慢了！！"
  },
  {
   "off": "0x32F3",
   "zh": "可恶……！"
  },
  {
   "off": "0x3305",
   "zh": "这动作……是零式系统！？"
  },
  {
   "off": "0x333A",
   "zh": "没错！"
  },
  {
   "off": "0x334B",
   "zh": "我已将零式系统的力量化为己有、希罗·尤尔！"
  },
  {
   "off": "0x3398",
   "zh": "杰克斯！！"
  },
  {
   "off": "0x33C5",
   "zh": "就算是艾比安、也无法再战下去了……"
  },
  {
   "off": "0x33D7",
   "zh": "胜负改日再分、希罗·尤尔！"
  },
  {
   "off": "0x340D",
   "zh": "杰克斯……"
  },
  {
   "off": "0x3414",
   "zh": "杰克斯……！"
  },
  {
   "off": "0x3441",
   "zh": "到此为止了、杰克斯"
  },
  {
   "off": "0x3450",
   "zh": "你成不了地球的敌人"
  },
  {
   "off": "0x3464",
   "zh": "就在这里、由我们……杀了你"
  },
  {
   "off": "0x3491",
   "zh": "很遗憾、我可不会让你们如愿！"
  },
  {
   "off": "0x34C6",
   "zh": "……杰克斯！？"
  },
  {
   "off": "0x34F4",
   "zh": "胜负改日再分、大天使号！还有、希罗·尤尔！"
  },
  {
   "off": "0x3534",
   "zh": "杰克斯、您这是……"
  },
  {
   "off": "0x353F",
   "zh": "…………"
  },
  {
   "off": "0x2A4D",
   "zh": "米利亚尔特·匹斯克拉福特……"
  },
  {
   "off": "0x2A5B",
   "zh": "舍弃杰克斯这个假面之后、你得出的结论就是这个吗？"
  },
  {
   "off": "0x2A94",
   "zh": "你应该能够理解……那些压迫宇宙居民的地球人有多愚蠢"
  },
  {
   "off": "0x2AB8",
   "zh": "我要纠正这一切！"
  },
  {
   "off": "0x2AE1",
   "zh": "荒唐！"
  },
  {
   "off": "0x2AE8",
   "zh": "那和当年的扎比家、还有OZ企图做的事不是一样吗！"
  },
  {
   "off": "0x2B27",
   "zh": "现在不是计较手段的时候"
  },
  {
   "off": "0x2B3B",
   "zh": "地球已经……不、整个世界已经被逼到了绝境"
  },
  {
   "off": "0x2B56",
   "zh": "你应该也早已察觉到了吧！？夏亚！"
  },
  {
   "off": "0x2B8C",
   "zh": "……但即便如此、我依然无法认同你想做的事"
  },
  {
   "off": "0x2BCC",
   "zh": "……要与我为敌也无妨。但你给我记住、夏亚"
  },
  {
   "off": "0x2BEF",
   "zh": "总有一天、你也一定会承认我此举是正确的！"
  },
  {
   "off": "0x2C38",
   "zh": "…………"
  },
  {
   "off": "0x2C41",
   "zh": "我、会认同他的行为……？"
  },
  {
   "off": "0x1DED",
   "zh": "不妙啊……再这样下去、会被那些家伙逃掉的"
  },
  {
   "off": "0x1E2C",
   "zh": "……由我来？"
  },
  {
   "off": "0x1E4F",
   "zh": "是的、蕾蒂·安特佐"
  },
  {
   "off": "0x1E5E",
   "zh": "若您在此亲自出击、扎夫特对我们的信任也会提高"
  },
  {
   "off": "0x1E99",
   "zh": "可是、我……"
  },
  {
   "off": "0x1EBE",
   "zh": "这可是个机会啊、特佐"
  },
  {
   "off": "0x1ECD",
   "zh": "要打倒阿兹拉埃尔、救出特列斯阁下、就只有这样……"
  },
  {
   "off": "0x1F07",
   "zh": "为了特列斯大人……"
  },
  {
   "off": "0x1F28",
   "zh": "……我明白了"
  },
