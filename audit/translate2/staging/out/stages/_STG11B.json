  {
   "off": "0x1691",
   "zh": "哈利中尉！"
  },
  {
   "off": "0x16BE",
   "zh": "我不要紧"
  },
  {
   "off": "0x16CB",
   "zh": "比起这个、你那台白色的MS还能战斗吗？"
