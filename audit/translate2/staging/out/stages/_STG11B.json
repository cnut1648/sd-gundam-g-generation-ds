 "title_zh": "琪耶尔与迪安娜",
 "briefing": [
  {
   "off": "0x19CF03",
   "zh": "根据方才接收到的求救信号……"
  },
  {
   "off": "0x19CF1A",
   "zh": "已经确认卡拉巴的友好组织米利西亚目前正处于交战之中"
  },
  {
   "off": "0x19CF40",
   "zh": "据通信所说、情况已经相当紧迫、"
  },
  {
   "off": "0x19CF5B",
   "zh": "我们大天使号将立刻前去救援米利西亚"
  },
  {
   "off": "0x19CFA5",
   "zh": "据情报显示、米利西亚正遭受迪安娜反击队的攻击"
  },
  {
   "off": "0x19CFCA",
   "zh": "虽然内情不明、但我们既然接受了卡拉巴的支援……"
  },
  {
   "off": "0x19CFED",
   "zh": "就不能对米利西亚坐视不管"
  },
  {
   "off": "0x19D004",
   "zh": "对手将是月之民的高性能MS、"
  },
  {
   "off": "0x19D01D",
   "zh": "请各员做好相应觉悟、推进战斗准备"
  },
  {
   "off": "0x19D05E",
   "zh": "据说月之民还拥有装备I力场的MS"
  },
  {
   "off": "0x19D078",
   "zh": "若抱着对付提坦斯或扎夫特的心态作战、恐将遭到惨痛的反击"
  },
  {
   "off": "0x19D09A",
   "zh": "各员、千万不可掉以轻心"
  }
 ],
 "blocks": [
  {
   "off": "0x13FF",
   "zh": "可恶！威尔盖姆、快进入对空战斗！"
  },
  {
   "off": "0x142E",
   "zh": "公子请您坐在那里就好！指挥由我来执行！！"
  },
  {
   "off": "0x1468",
   "zh": "唔……"
  },
  {
   "off": "0x1489",
   "zh": "莫非是迪安娜反击队的追兵、已然逼近了吗？"
  },
  {
   "off": "0x14C1",
   "zh": "请不必担心、迪安娜女王"
  },
  {
   "off": "0x14CF",
   "zh": "您的人身安全、就由我们米利西亚来保证"
  },
  {
   "off": "0x1505",
   "zh": "…………"
  },
  {
   "off": "0x1525",
   "zh": "好了、你们这些地球人！乖乖把迪安娜大人交出来！"
  },
  {
   "off": "0x153E",
   "zh": "否则那艘叫威尔盖姆的战舰、可就要被击落了！"
  },
  {
   "off": "0x1577",
   "zh": "明明谋害着迪安娜大人的性命、如今还叫我们交人、真是无耻！"
  },
  {
   "off": "0x15B3",
   "zh": "啧、哈利·奥德！亲卫队竟要和地球人这帮蛮族沆瀣一气吗！？"
  },
  {
   "off": "0x15ED",
   "zh": "菲尔想取迪安娜大人而代之的鬼胎、我岂会看不透！"
  },
  {
   "off": "0x160C",
   "zh": "绝不容你们碰迪安娜大人玉体分毫！"
  },
  {
   "off": "0x163E",
   "zh": "可恶、既然如此、那就打倒你再接走陛下便是！"
