   "off": "0x71F2",
   "zh": "…………"
  },
  {
   "off": "0x68F2",
   "zh": "……且慢"
  },
  {
   "off": "0x6925",
   "zh": "夏亚大佐？"
  },
  {
   "off": "0x6948",
   "zh": "不许海兵队同行、这是什么道理？"
  },
  {
   "off": "0x697C",
   "zh": "啊……夏、夏亚大佐……"
  },
  {
   "off": "0x698C",
   "zh": "正如大佐方才所闻、因为他们逾越了军纪……"
  },
  {
   "off": "0x69C5",
   "zh": "那是基西莉亚少将下的命令"
  },
  {
   "off": "0x69D8",
   "zh": "要追究责任也该找基西莉亚少将、而少将如今也已战死"
  },
  {
   "off": "0x69F9",
   "zh": "服从命令的海兵队没有罪"
  },
  {
   "off": "0x6A26",
   "zh": "可、可是……"
  },
  {
   "off": "0x6A4A",
   "zh": "难道我的担保还不够吗？"
  },
  {
   "off": "0x6A75",
   "zh": "啊、不……绝、绝无此意！"
  },
  {
   "off": "0x6AA5",
   "zh": "那么、就没有任何问题了吧？"
  },
  {
   "off": "0x6AB5",
   "zh": "西玛中佐、让莉莉·玛莲加入船团吧"
  },
  {
   "off": "0x6ACE",
   "zh": "我们马上就要出发前往阿克西斯"
  },
  {
   "off": "0x6AFA",
   "zh": "夏、夏亚大佐……！"
  },
  {
   "off": "0x71FE",
   "zh": "而后、时光流逝……"
  },
  {
   "off": "0x720A",
   "zh": "……宇宙世纪0080年初"
  },
  {
   "off": "0x721D",
   "zh": "小行星带、小行星阿克西斯……"
  },
  {
   "off": "0x7229",
   "zh": "这颗曾是吉翁公国资源开采卫星的小行星"
  },
  {
   "off": "0x7243",
   "zh": "如今成了脱离地球圈的旧吉翁军人们的基地"
  },
  {
   "off": "0x727E",
   "zh": "感觉如何？已经习惯阿克西斯的生活了吗？"
