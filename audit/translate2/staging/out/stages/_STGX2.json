   "off": "0x8692",
   "zh": "…………"
  },
  {
   "off": "0x869B",
   "zh": "重启独立战争……吗"
  },
  {
   "off": "0x86A8",
   "zh": "的确、不打倒联邦的旧体制、宇宙居民的独立就无从谈起"
  },
