 ],
 "title_zh": "背叛的宇宙",
 "briefing": [],
 "blocks": [
  {
   "off": "0x111E",
   "zh": "看来总算是甩掉追兵了"
  },
  {
   "off": "0x1149",
   "zh": "队长他们呢？"
  },
  {
   "off": "0x116D",
   "zh": "不知道、乱战中走散之后就再也没见着了"
  },
  {
   "off": "0x1183",
   "zh": "嘛、有艾因跟着、应该是不用担心……"
  },
  {
   "off": "0x11BB",
   "zh": "……艾因、是吗"
  },
  {
   "off": "0x11DF",
   "zh": "怎么了？"
  },
  {
   "off": "0x1201",
   "zh": "不……没什么"
  },
  {
   "off": "0x1227",
   "zh": "那就赶往会合点吧、队长他们若平安、应该能在那碰头"
  },
  {
   "off": "0x1264",
   "zh": "…………"
  },
  {
   "off": "0x1284",
   "zh": "…………"
  },
  {
   "off": "0x12A8",
   "zh": "艾因？你没事吗？"
  },
  {
   "off": "0x12D1",
   "zh": "布拉德队长也平安吗！？"
  },
  {
   "off": "0x12F9",
   "zh": "布拉德中佐？啊啊、那个人的话……"
  },
  {
   "off": "0x1331",
   "zh": "……！？"
  },
  {
   "off": "0x135E",
   "zh": "西格！瑟拉！！快离开那家伙！！"
  },
  {
   "off": "0x138F",
   "zh": "……队长？"
  },
  {
   "off": "0x13BC",
   "zh": "唔……！"
  },
  {
   "off": "0x13F3",
   "zh": "啊啊……您居然还活着呢、中佐"
  },
  {
   "off": "0x1407",
   "zh": "都伤成那副破烂样子了、竟然还活着……"
  },
  {
   "off": "0x141F",
   "zh": "真是……命够硬的呢"
  },
  {
   "off": "0x1447",
   "zh": "……艾因？"
  },
  {
   "off": "0x1474",
   "zh": "……队长！！"
  },
  {
   "off": "0x14AA",
   "zh": "艾、艾因……你……"
  },
  {
   "off": "0x14D3",
   "zh": "好了、这下就能好好聊聊了、瑟拉……"
  },
  {
   "off": "0x1502",
   "zh": "艾因！你这家伙！！"
  },
  {
   "off": "0x152F",
   "zh": "你知不知道、自己究竟做了什么！？"
  },
  {
   "off": "0x156E",
   "zh": "……我也是没办法啊、谁叫中佐他非要碍事"
  },
  {
   "off": "0x15A8",
   "zh": "你这家伙……！？"
  },
  {
   "off": "0x15D6",
   "zh": "瑟拉……我是来接你的"
  },
  {
   "off": "0x1605",
   "zh": "接我……？你在说什么啊、艾因！？"
  },
  {
   "off": "0x1636",
   "zh": "……这场战争、马上就要结束了"
  },
  {
   "off": "0x1647",
   "zh": "吉翁公国、还有弗拉纳冈机关、都将不复存在"
  },
  {
   "off": "0x165C",
   "zh": "所以、瑟拉……"
  },
  {
   "off": "0x1666",
   "zh": "你也已经、没必要再待在那种男人身边了"
  },
  {
   "off": "0x1681",
   "zh": "来吧、跟我走、瑟拉"
  },
  {
   "off": "0x16B5",
   "zh": "联邦军……！？"
  },
  {
   "off": "0x16EB",
   "zh": "他们会为我们、提供一个新的归宿"
  },
  {
   "off": "0x1704",
   "zh": "再也不用在设施里当研究对象、也不用服从军队那些蛮横的命令了"
  },
  {
   "off": "0x172D",
   "zh": "来吧、走吧……瑟拉、和我一起……"
  },
  {
   "off": "0x1768",
   "zh": "艾因……"
  },
  {
   "off": "0x176F",
   "zh": "你……就为了那么点事、竟把队长……"
  },
  {
   "off": "0x1784",
   "zh": "……你这个、大笨蛋！！"
  },
  {
   "off": "0x17B5",
   "zh": "瑟拉……？"
  },
  {
   "off": "0x17E2",
   "zh": "我什么时候、求过你做那种事了！？"
  },
  {
   "off": "0x17FB",
   "zh": "可你竟然……！"
  },
  {
   "off": "0x1808",
   "zh": "出卖同伴、连布拉德队长都下了毒手！！"
  },
  {
   "off": "0x183B",
   "zh": "这全都是为了你啊、瑟拉"
  },
  {
   "off": "0x186A",
   "zh": "为了我？……别开玩笑了！！"
  },
  {
   "off": "0x187B",
   "zh": "无论是被当成研究对象、还是被军令投入激战……"
  },
  {
   "off": "0x189D",
   "zh": "那些事、对我来说根本无所谓！"
  },
  {
   "off": "0x18B5",
   "zh": "我只要那家伙、能待在我身边就够了……"
  },
  {
   "off": "0x18F1",
   "zh": "瑟拉……"
  },
  {
   "off": "0x191D",
   "zh": "……艾因"
  },
  {
   "off": "0x1924",
   "zh": "看在多年交情上……我就饶你这一回、不在这里把你打趴下"
  },
  {
   "off": "0x1963",
   "zh": "……瑟拉？"
  },
  {
   "off": "0x1986",
   "zh": "快给我从眼前滚开！！"
  },
  {
   "off": "0x19BE",
   "zh": "瑟拉……"
  },
  {
   "off": "0x19D9",
   "zh": "果然……果然是这样啊、瑟拉"
  },
  {
   "off": "0x19EC",
   "zh": "你要的不是我、而是那家伙……"
  },
  {
   "off": "0x19FA",
   "zh": "竟对区区一个旧人类……动了真心……"
  },
  {
   "off": "0x1A34",
   "zh": "呵呵……啊哈哈哈哈！！"
  },
  {
   "off": "0x1A44",
   "zh": "果然、你就是个残次品……瑟蕾因！！"
  },
  {
   "off": "0x1A81",
   "zh": "……艾因·雷维"
  },
  {
   "off": "0x1AA6",
   "zh": "已经够了、要杀要抓、随你们便"
  },
  {
   "off": "0x1AEC",
   "zh": "……艾因！！"
  },
  {
   "off": "0x1B1A",
   "zh": "等等、瑟拉！现在先杀出这里要紧！"
  },
  {
   "off": "0x1B50",
   "zh": "西格……"
  },
  {
   "off": "0x1B72",
   "zh": "我们不是约好了吗……？两个人一起活下去"
  },
  {
   "off": "0x1BA4",
   "zh": "……嗯。说得也是"
  },
  {
   "off": "0x1BB2",
   "zh": "收拾艾因的事先放一放、现在全力活下去要紧"
  },
  {
   "off": "0x1BD4",
   "zh": "这样可以吧、西格"
  },
  {
   "off": "0x1BFD",
   "zh": "……就是这么回事"
  },
  {
   "off": "0x1C07",
   "zh": "上吧、瑟拉！"
  },
  {
   "off": "0x1C36",
   "zh": "唔……！瑟拉……对不起……！！"
  },
  {
   "off": "0x1C79",
   "zh": "……西格！？"
  },
  {
   "off": "0x1C8D",
   "zh": "竟然先我一步走了……你这个、大笨蛋……！"
  },
  {
   "off": "0x1CD3",
   "zh": "……啊啊！？"
  },
  {
   "off": "0x1D0C",
   "zh": "……瑟拉！？"
  },
  {
   "off": "0x1D1F",
   "zh": "瑟拉啊啊啊啊！"
  },
  {
   "off": "0x1D59",
   "zh": "……西格"
  },
  {
   "off": "0x1D81",
   "zh": "啊啊、看来总算是活下来了……"
  },
  {
   "off": "0x1DBA",
   "zh": "唔！？"
  },
  {
   "off": "0x1DF1",
   "zh": "……果然啊、我就猜到会变成这样"
  },
  {
   "off": "0x1E36",
   "zh": "……艾因！！"
  },
  {
   "off": "0x1E6B",
   "zh": "不过、这样反倒正中下怀了呢？西格·韦德纳中尉……"
  },
  {
   "off": "0x1EAA",
   "zh": "因为这样一来、就能由我亲手了结你了！！"
  },
  {
   "off": "0x1EF6",
   "zh": "唔……！艾因、你这家伙……！！"
  },
  {
   "off": "0x1F37",
   "zh": "这是自作自受、西格·韦德纳中尉……一切、都怪你"
  },
  {
   "off": "0x1F5D",
   "zh": "都怪你……只要没有你……！！"
  },
  {
   "off": "0x1FA2",
   "zh": "都怪你一个人独占了瑟拉、才会变成这样啊啊！！"
  },
  {
   "off": "0x1FF2",
   "zh": "西格……！！"
  },
  {
   "off": "0x7A8A",
   "zh": "……瑟拉！？"
  },
  {
   "off": "0x7AA2",
   "zh": "西格……"
  },
  {
   "off": "0x7AB3",
   "zh": "约定……我没能守住……"
  },
  {
   "off": "0x7ACB",
   "zh": "对不起……"
  },
  {
   "off": "0x7AF6",
   "zh": "瑟拉啊啊啊啊！！"
  },
  {
   "off": "0x202A",
   "zh": "瑟拉……你竟对那家伙、用情至此……"
  },
  {
   "off": "0x203E",
   "zh": "……！！"
  },
  {
   "off": "0x206B",
   "zh": "……艾因·雷维"
  },
  {
   "off": "0x2090",
   "zh": "啊啊……是你们啊"
  },
  {
   "off": "0x209C",
   "zh": "抱歉、她……瑟拉、她已经死了"
  },
  {
   "off": "0x20D2",
   "zh": "那个男人呢？"
  },
  {
   "off": "0x20F6",
   "zh": "那只是个旧人类、对你们没有任何用处"
  },
  {
   "off": "0x212D",
   "zh": "……是吗。那就处理掉"
  },
  {
   "off": "0x2162",
   "zh": "…………"
  },
  {
   "off": "0x216B",
   "zh": "瑟拉……我……"
  },
  {
   "off": "0x219C",
   "zh": "…………"
  },
  {
   "off": "0x21E7",
   "zh": "……小妹妹、你在这种地方做什么呢？"
  },
  {
   "off": "0x2214",
   "zh": "…………"
  },
  {
   "off": "0x2231",
   "zh": "这里是军港、像你这样的小孩子待着可危险啊"
  },
  {
   "off": "0x2260",
   "zh": "…………"
  },
  {
   "off": "0x2269",
   "zh": "我……在等着呢"
  },
  {
   "off": "0x228A",
   "zh": "小妹妹……？"
  },
  {
   "off": "0x22A9",
   "zh": "大家……都会回来的……"
  },
  {
   "off": "0x22BE",
   "zh": "我……就在这里等着"
  },
  {
   "off": "0x22E2",
   "zh": "…………"
  },
  {
   "off": "0x22EB",
   "zh": "……是吗"
  },
  {
   "off": "0x235A",
   "zh": "…………"
  },
  {
   "off": "0x2363",
   "zh": "西格……爸爸……"
  },
  {
   "off": "0x236D",
   "zh": "……大家都不会有事的、对吧？"
  },
  {
   "off": "0x6386",
   "zh": "宇宙世纪0079年、12月31日"
  },
  {
   "off": "0x6398",
   "zh": "随着宇宙要塞阿·巴瓦·库的陷落、吉翁公国迎来了崩溃的时刻"
  },
  {
   "off": "0x63BA",
   "zh": "翌年、宇宙世纪0080年1月1日"
  },
  {
   "off": "0x63D1",
   "zh": "两国在月面城市格拉纳达签订了终战协定……"
  },
  {
   "off": "0x63ED",
   "zh": "吉翁公国、更名为吉翁共和国"
  },
  {
   "off": "0x640A",
   "zh": "……与此同时"
  },
  {
   "off": "0x6415",
   "zh": "因战败而被迫离开公国的吉翁军将兵们、"
  },
  {
   "off": "0x6437",
   "zh": "为逃往地球圈外、正在卡拉玛集结点集结"
  },
  {
   "off": "0x675E",
   "zh": "请问这是为什么！？"
  },
  {
   "off": "0x676A",
   "zh": "难道说我们连撤往阿克西斯的权利、都没有吗！！"
  },
  {
   "off": "0x67A2",
   "zh": "你们海兵队太过逾越军纪！玷污光荣吉翁之罪、罪责深重！"
  },
  {
   "off": "0x67E3",
   "zh": "什……逾越！？我们的任务、全都是奉本国的命令……"
  },
  {
   "off": "0x681B",
   "zh": "那或许是战死的基西莉亚大人的独断、总之就是累赘！"
  },
  {
   "off": "0x6838",
   "zh": "自己的烂摊子、自己去收拾！"
  },
  {
   "off": "0x6866",
   "zh": "可、可是……"
  },
  {
   "off": "0x688A",
   "zh": "…………"
  },
  {
   "off": "0x6893",
   "zh": "西玛中佐……"
  },
  {
   "off": "0x68A9",
   "zh": "『为西玛说情』{00}『……自己无能为力』"
  },
  {
   "off": "0x6B25",
   "zh": "…………"
  },
  {
   "off": "0x6B2E",
   "zh": "（凭我一人之力、无法推翻他们的决定……）"
  },
  {
   "off": "0x6B4B",
   "zh": "（……对不住、西玛中佐）"
  },
  {
   "off": "0x6B7F",
   "zh": "可恶！凭什么我们要受这种……！！"
  },
  {
   "off": "0x6BAE",
   "zh": "西玛大人！回去吧、回我们的故乡去！"
  },
  {
   "off": "0x6BEF",
   "zh": "德托洛夫……！？"
  },
  {
   "off": "0x6C13",
   "zh": "这种舰队、老子再也不管了！就算被逮捕也无所谓！"
  },
  {
   "off": "0x6C33",
   "zh": "回马哈尔去吧！回我们的故乡去！"
  },
  {
   "off": "0x6C9E",
   "zh": "……啊、说得也是"
  },
  {
   "off": "0x6CAA",
   "zh": "呵呵……去也是地狱、不去也是地狱……"
  },
  {
   "off": "0x6CC0",
   "zh": "那阿克西斯那种边陲之地、不去也罢……出发！！"
  },
  {
   "off": "0x6CF5",
   "zh": "好嘞、西玛大人！！"
  },
  {
   "off": "0x6D06",
   "zh": "而后、时光流逝……"
  },
  {
   "off": "0x6D12",
   "zh": "宇宙世纪0083年"
  },
  {
   "off": "0x6D22",
   "zh": "暗礁宙域、荆棘之园"
  },
  {
   "off": "0x6D33",
   "zh": "不愿逃往阿克西斯、而选择留在地球圈的吉翁士兵们、"
  },
  {
   "off": "0x6D58",
   "zh": "在艾裘·迪拉兹准将的指挥之下……"
  },
  {
   "off": "0x6D68",
   "zh": "为对地球联邦实施「星之屑作战」、正稳步推进着准备……"
  },
  {
   "off": "0x6DAA",
   "zh": "卡多少佐、现已归队"
  },
  {
   "off": "0x6DD5",
   "zh": "……嗯"
  },
  {
   "off": "0x6DDC",
   "zh": "夺取高达的报告我已听闻、干得漂亮、卡多少佐"
  },
  {
   "off": "0x6DF9",
   "zh": "只要有高达2号机和核弹、我等的「星之屑」必将成就"
  },
  {
   "off": "0x6E3C",
   "zh": "非常感谢"
  },
  {
   "off": "0x6E46",
   "zh": "但是、迪拉兹阁下……听说我不在的期间、出了些不好的传闻"
  },
  {
   "off": "0x6E81",
   "zh": "是指西玛舰队参与作战之事吗？"
  },
  {
   "off": "0x6EAD",
   "zh": "……是的、还请告知我其中的理由……"
  },
  {
   "off": "0x6F25",
   "zh": "……迪拉兹阁下的「星之屑」作战"
  },
  {
   "off": "0x6F4A",
   "zh": "我们想着、好歹也来助上一份力呢"
  },
  {
   "off": "0x6F9B",
   "zh": "唔……西玛中佐"
  },
  {
   "off": "0x6FC0",
   "zh": "自阿·巴瓦·库一别了吧、所罗门的噩梦先生"
  },
  {
   "off": "0x6FF3",
   "zh": "哼……该是终战以来才对"
  },
  {
   "off": "0x701B",
   "zh": "嘛、既然我们来了、之后就让你轻松轻松吧、少佐"
  },
  {
   "off": "0x703D",
   "zh": "你就好好把高达擦亮些吧、呵呵呵……"
  },
  {
   "off": "0x70CF",
   "zh": "…………"
  },
  {
   "off": "0x70FD",
   "zh": "趁你不在时让西玛入伙、是我不对"
  },
  {
   "off": "0x7115",
   "zh": "不过、你若在场、想必会反对吧"
  },
  {
   "off": "0x7140",
   "zh": "……是的、那女人一肚子黑水……！"
  },
  {
   "off": "0x7159",
   "zh": "他日必成光荣吉翁的祸患！"
  },
  {
   "off": "0x718D",
   "zh": "……卡多啊"
  },
  {
   "off": "0x7195",
   "zh": "欲成大义者、不可拘泥于小节"
  },
  {
   "off": "0x71B2",
   "zh": "星之屑作战要成功、就必须充实我方舰队的战力"
  },
  {
   "off": "0x71E9",
   "zh": "迪拉兹阁下……"
