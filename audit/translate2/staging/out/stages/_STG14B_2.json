   "zh": "难道我的理念……实现完全和平终究只是一场梦吗？"
  },
  {
   "off": "0x7936",
   "zh": "我一定会保护好莉莉娜大人……"
  },
  {
   "off": "0x7948",
   "zh": "……杰克斯！我以与你的约定起誓……！"
  },
  {
   "off": "0x57BA",
   "zh": "难、难道就到此为止了……"
  },
  {
   "off": "0x7EBE",
   "zh": "唔……！难道我就到此为止了吗！！"
  },
  {
   "off": "0x7E7E",
   "zh": "可恶……任务、失败了吗！"
  },
  {
   "off": "0x7986",
   "zh": "可恶……！对不起、杰克斯……！！"
  },
  {
   "off": "0xCCB6",
   "zh": "哼！区区一台机体能成什么事！！"
  },
  {
   "off": "0xCCC9",
   "zh": "派出后续部队！连那台MS带王城一起给我抹掉！"
  },
  {
   "off": "0xCD0E",
   "zh": "哼……想凭区区一台机体反抗我们吗"
  },
  {
   "off": "0xCD25",
   "zh": "派出后续部队！连王城一口气碾个粉碎！！"
