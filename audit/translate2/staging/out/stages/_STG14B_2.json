 "briefing": [
  {
   "off": "0x19D96B",
   "zh": "方才接到友军的联络、"
  },
  {
   "off": "0x19D97B",
   "zh": "已经确认、桑古王国正遭受提坦斯的进攻！"
  },
  {
   "off": "0x19D997",
   "zh": "希罗·尤尔已驾驶艾比安出击、正赶往桑古王国"
  },
  {
   "off": "0x19D9B5",
   "zh": "我们将追随他火速赶往桑古王国……"
  },
  {
   "off": "0x19D9CA",
   "zh": "与当地部队协力、保卫桑古王国！"
  },
  {
   "off": "0x19D9FD",
   "zh": "另外、关于入侵桑古王国的提坦斯部队……"
  },
  {
   "off": "0x19DA15",
   "zh": "据卡拉巴的情报、NT研究所似乎也派出了战力"
  },
  {
   "off": "0x19DA56",
   "zh": "敌方部队中极有可能存在新人类"
  },
  {
   "off": "0x19DA70",
   "zh": "我方若不以相应战力应对、苦战在所难免"
  },
  {
   "off": "0x19DA8B",
   "zh": "万一桑古王国陷落、提坦斯自不必说……"
  },
  {
   "off": "0x19DAA5",
   "zh": "与提坦斯合作的OZ、想必也会进一步扩张势力"
  },
  {
   "off": "0x19DACA",
   "zh": "唯有这一点、无论如何都要阻止！"
  },
  {
   "off": "0x19DADF",
   "zh": "拜托了、各位！"
  }
 ],
 "blocks": [
  {
   "off": "0x7692",
   "zh": "莉莉娜女王！！请您退下！这里太危险了！"
