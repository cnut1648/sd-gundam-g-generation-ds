 "title_zh": "悲剧就此落幕",
 "briefing": [
  {
   "off": "0x19C263",
   "zh": "……托雷斯"
  },
  {
   "off": "0x19C26A",
   "zh": "关于正在接近的MA、收到什么情报了吗？"
  },
  {
   "off": "0x19C2A0",
   "zh": "啊、是……这是刚才摄像机拍到的影像"
  },
  {
   "off": "0x19C2B7",
   "zh": "那架叫迪斯帕达的MS、似乎正与那台MA同行"
  },
  {
   "off": "0x19C2F3",
   "zh": "这么说、那是提坦斯的MA吗！"
  },
  {
   "off": "0x19C321",
   "zh": "艾因……！！"
  },
  {
   "off": "0x19C345",
   "zh": "另外似乎还有疑似护卫的MS随行……"
  },
  {
   "off": "0x19C365",
   "zh": "不过这边的好像都是无人机"
  },
  {
   "off": "0x19C392",
   "zh": "能确认到的战力就只有这些吗？"
  },
  {
   "off": "0x19C3BC",
   "zh": "……是的"
  },
  {
   "off": "0x19C3DE",
   "zh": "一台MA加上迪斯帕达……其余全是无人机吗……"
  },
  {
   "off": "0x19C3F7",
   "zh": "要说是冲着我们来的、这编队也太古怪了"
  },
  {
   "off": "0x19C40F",
   "zh": "看来还是多加小心为好"
  },
  {
   "off": "0x19C43E",
   "zh": "…………"
  }
 ],
 "blocks": [
  {
   "off": "0x13FA",
   "zh": "MA仍在继续接近！距离已不足两千！"
  },
  {
   "off": "0x142E",
   "zh": "是想发起突击吗！？全体人员、准备迎击……"
  },
  {
   "off": "0x14AF",
   "zh": "唔！！什、什么……！？"
  },
  {
   "off": "0x14E0",
   "zh": "哈哈哈、对、就是这样！！继续唱啊、瑟蕾因！"
  },
  {
   "off": "0x14FB",
   "zh": "唱出塞壬的破灭之歌！！"
  },
  {
   "off": "0x1559",
   "zh": "唔……什、什么！？"
  },
  {
   "off": "0x158F",
   "zh": "呜哦！头……我的头像要裂开了！！"
  },
  {
   "off": "0x15CF",
   "zh": "这、这是……精神感应装置的波动！？"
  },
  {
   "off": "0x15E3",
   "zh": "难道说是利用精神波的心理兵器！？"
  },
  {
   "off": "0x1617",
   "zh": "啊哈哈哈哈！瞧你们这副德性！！"
  },
  {
   "off": "0x1652",
   "zh": "这声音……是艾因！？"
  },
  {
   "off": "0x167A",
   "zh": "是泰拉·斯欧诺的塞壬系统啊！"
  },
  {
   "off": "0x168B",
   "zh": "精神感应装置的波动、会让你们的心智陷入疯狂……！"
  },
  {
   "off": "0x16A7",
   "zh": "你们就在那里束手无策、在歌声中挣扎打滚着死去吧！"
  },
  {
   "off": "0x16C6",
   "zh": "谁让你们敢愚弄我！！啊哈哈哈哈！"
  },
  {
   "off": "0x1712",
   "zh": "不好！再这样下去、船员们会……！！"
  },
  {
   "off": "0x174E",
   "zh": "后……后退……！"
  },
  {
   "off": "0x1774",
   "zh": "……呜唔！！"
  },
  {
   "off": "0x17B8",
   "zh": "西格中尉！？"
  },
  {
   "off": "0x17DC",
   "zh": "布莱特舰长！"
  },
  {
   "off": "0x17E4",
   "zh": "这里交给我、阿伽玛去雅金·杜威吧！"
  },
  {
   "off": "0x1822",
   "zh": "胡来！就凭你一个人能做什么！？"
  },
  {
   "off": "0x1851",
   "zh": "反正照这种状态、你们根本没法战斗！"
  },
  {
   "off": "0x1865",
   "zh": "我没有受到系统的影响、我还能战斗！"
  },
  {
   "off": "0x18B0",
   "zh": "西格·韦德纳！"
  },
  {
   "off": "0x18B9",
   "zh": "你还想重犯以前那样的过错吗！？"
  },
  {
   "off": "0x18E7",
   "zh": "……不是那样"
  },
  {
   "off": "0x1910",
   "zh": "克瓦特罗大尉……不、夏亚大佐"
  },
  {
   "off": "0x1920",
   "zh": "一年战争时、是你教会了我怎么战斗"
  },
  {
   "off": "0x195E",
   "zh": "莱汀少佐……"
  },
  {
   "off": "0x198B",
   "zh": "若没有你那句话、我恐怕还在独自一人战斗吧"
  },
  {
   "off": "0x19F1",
   "zh": "蜜安则让我懂得了珍贵的东西"
  },
  {
   "off": "0x1A04",
   "zh": "……不仅如此"
  },
  {
   "off": "0x1A34",
   "zh": "正因为与队友们并肩作战、我才没有丢失人的心"
  },
  {
   "off": "0x1A54",
   "zh": "所以、这次轮到我报恩了"
  },
  {
   "off": "0x1AA8",
   "zh": "西格中尉……"
  },
  {
   "off": "0x1ACC",
   "zh": "我可没打算轻抛性命"
  },
  {
   "off": "0x1ADD",
   "zh": "我会在这里和那家伙做个了断、然后一定赶回你们身边"
  },
  {
   "off": "0x1B15",
   "zh": "是吗……那么西格中尉、这里就交给你了"
  },
  {
   "off": "0x1B48",
   "zh": "克瓦特罗大尉！？"
  },
  {
   "off": "0x1B6C",
   "zh": "他的决心是真的。那么、我们也该回应这份决心"
  },
  {
   "off": "0x1BA9",
   "zh": "再说、急着去送死的家伙、可说不出那种台词"
  },
  {
   "off": "0x1BE5",
   "zh": "……不错。那是值得信赖的男儿之言"
  },
  {
   "off": "0x1C1C",
   "zh": "…………"
  },
  {
   "off": "0x1C25",
   "zh": "好吧、西格中尉！这里就交给你了！"
  },
  {
   "off": "0x1C58",
   "zh": "布莱特舰长……！！"
  },
  {
   "off": "0x1C7E",
   "zh": "一定要回来……明白吗？"
  },
  {
   "off": "0x1CAB",
   "zh": "……是！西格·韦德纳、明白！"
  },
  {
   "off": "0x1CE6",
   "zh": "好、全舰后退！！"
  },
  {
   "off": "0x1D17",
   "zh": "想逃！？我可不会让……"
  },
  {
   "off": "0x1D4C",
   "zh": "……唔！"
  },
  {
   "off": "0x1D74",
   "zh": "我不会让你去妨碍布莱特舰长他们！"
  },
  {
   "off": "0x1D89",
   "zh": "你的对手是我、艾因！！"
  },
  {
   "off": "0x1DBD",
   "zh": "又是你来碍事吗！！"
  },
  {
   "off": "0x1DCD",
   "zh": "那好啊！我就先从你杀起！！"
  },
  {
   "off": "0x1E0B",
   "zh": "……西格！"
  },
  {
   "off": "0x1E38",
   "zh": "……蜜安！？"
  },
  {
   "off": "0x1E5C",
   "zh": "西格、我也要一起战斗！"
  },
  {
   "off": "0x1E85",
   "zh": "蜜安、你怎么会……"
  },
  {
   "off": "0x1EAC",
   "zh": "西格你会打倒艾因、然后回到阿伽玛大家身边、对吧？"
  },
  {
   "off": "0x1EE5",
   "zh": "蜜安……"
  },
  {
   "off": "0x1F07",
   "zh": "这场战斗……也让我见证到最后"
  },
  {
   "off": "0x1F33",
   "zh": "……会很危险的"
  },
  {
   "off": "0x1F57",
   "zh": "我也能替西格你守住背后哦"
  },
  {
   "off": "0x1F84",
   "zh": "……说得也是"
  },
  {
   "off": "0x1F8D",
   "zh": "身为布拉德队长的女儿、蜜安也有和那家伙战斗的权利吗……"
  },
  {
   "off": "0x1FC7",
   "zh": "不是那样的、西格"
  },
  {
   "off": "0x1FD4",
   "zh": "我们战斗、不是为了死去的人和已经发生的事"
  },
  {
   "off": "0x1FF5",
   "zh": "而是为了继续向前走而战哦。我是、西格你也是"
  },
  {
   "off": "0x202C",
   "zh": "呵……"
  },
  {
   "off": "0x2033",
   "zh": "真是说不过你啊、蜜安"
  },
  {
   "off": "0x2063",
   "zh": "那么、上吧"
  },
  {
   "off": "0x208D",
   "zh": "走吧、西格！"
  },
  {
   "off": "0x928A",
   "zh": "……不好！这艘舰要是被击毁的话……！"
  },
  {
   "off": "0x20BC",
   "zh": "糟了、被直击了！？"
  },
  {
   "off": "0x20F7",
   "zh": "西格！！"
  },
  {
   "off": "0x212E",
   "zh": "呀啊啊！！"
  },
  {
   "off": "0x2167",
   "zh": "蜜安！！"
  },
  {
   "off": "0x2922",
   "zh": "……阿伽玛！？"
  },
  {
   "off": "0x292B",
   "zh": "怎么会！你们不是先走了吗……"
  },
  {
   "off": "0x2959",
   "zh": "哪能把伙伴扔下不管啊？"
  },
  {
   "off": "0x298C",
   "zh": "要去雅金·杜威的话、你也一起来、西格·韦德纳"
  },
  {
   "off": "0x29CC",
   "zh": "你们这些人……"
  },
  {
   "off": "0x29F9",
   "zh": "……布莱特舰长！"
  },
  {
   "off": "0x2A1E",
   "zh": "明白！MS部队、立即出击！"
  },
  {
   "off": "0x2A31",
   "zh": "各机、去掩护西格中尉！！"
  },
  {
   "off": "0x2A5E",
   "zh": "小心精神波的辐射！这里可待不了太久！"
  },
  {
   "off": "0x2AA2",
   "zh": "周围的机体由我们来对付！！上吧、西格中尉！！"
  },
  {
   "off": "0x2AD8",
   "zh": "……好！"
  },
  {
   "off": "0x2AE0",
   "zh": "好、上了、蜜安！！"
  },
  {
   "off": "0x2B0E",
   "zh": "……嗯！"
  },
  {
   "off": "0x221F",
   "zh": "到此为止了、艾因"
  },
  {
   "off": "0x224F",
   "zh": "…………"
  },
  {
   "off": "0x2258",
   "zh": "为什么……！"
  },
  {
   "off": "0x2260",
   "zh": "为什么会是你……！！"
  },
  {
   "off": "0x2287",
   "zh": "……艾因？"
  },
  {
   "off": "0x22AA",
   "zh": "为什么被选中的是你！？"
  },
  {
   "off": "0x22BD",
   "zh": "为什么瑟拉选中的、是你这种平凡的人类！？"
  },
  {
   "off": "0x22DC",
   "zh": "明明本该被她选中的、是我才对！？"
  },
  {
   "off": "0x2314",
   "zh": "……什么！？"
  },
  {
   "off": "0x233A",
   "zh": "吉翁制造人造新人类的技术、当时还未完成……"
  },
  {
   "off": "0x235A",
   "zh": "她需要一个能引导她不稳定精神的搭档！"
  },
  {
   "off": "0x2376",
   "zh": "而且不是普通人、必须是真正的新人类！！"
  },
  {
   "off": "0x2391",
   "zh": "可是为什么、瑟拉不选我、却选了你！？"
  },
  {
   "off": "0x23B0",
   "zh": "……到底为什么啊！？"
  },
  {
   "off": "0x23BB",
   "zh": "为什么谁都不肯认可我！！"
  },
  {
   "off": "0x23EA",
   "zh": "……理所当然"
  },
  {
   "off": "0x240D",
   "zh": "……你说什么！？"
  },
  {
   "off": "0x2434",
   "zh": "我是说、你不被认可是理所当然的"
  },
  {
   "off": "0x244D",
   "zh": "你除了哭喊着没被选中、自己又做过什么！？"
  },
  {
   "off": "0x246C",
   "zh": "只因得不到认可就撒泼哭嚎……除了迁怒于人什么都不会"
  },
  {
   "off": "0x248D",
   "zh": "你只是个孩子！！"
  },
  {
   "off": "0x249C",
   "zh": "一个因为得不到想要的东西、就哭闹不休的孩子！！"
  },
  {
   "off": "0x24D8",
   "zh": "……可恶！你敢这么说！！"
  },
  {
   "off": "0x2502",
   "zh": "啊、多少遍我都说给你听！！"
  },
  {
   "off": "0x2514",
   "zh": "你就是个耍赖撒泼的孩子！！"
  },
  {
   "off": "0x2528",
   "zh": "就凭你这种心性、绝不可能被任何人认可！！"
  },
  {
   "off": "0x2562",
   "zh": "……！！"
  },
  {
   "off": "0x2571",
   "zh": "你啊啊啊！！"
  },
  {
   "off": "0x99D2",
   "zh": "你竟敢羞辱我！"
  },
  {
   "off": "0x99ED",
   "zh": "区区一个旧人类！一个毫无力量的普通人啊啊！！"
  },
  {
   "off": "0x9A3E",
   "zh": "……西格！"
  },
  {
   "off": "0x9A6B",
   "zh": "没事、交给我吧！！"
  },
  {
   "off": "0x9AAE",
   "zh": "没用的！！"
  },
  {
   "off": "0x9AEA",
   "zh": "上啊啊！！"
  },
  {
   "off": "0x9B26",
   "zh": "什……！？"
  },
  {
   "off": "0x9B65",
   "zh": "西格！"
  },
  {
   "off": "0x9B91",
   "zh": "喔！！"
  },
  {
   "off": "0x9BCA",
   "zh": "结束了、艾因·雷维！"
  },
  {
   "off": "0x9C0A",
   "zh": "为、为什么！？"
  },
  {
   "off": "0x9C1E",
   "zh": "为什么我会……！！"
  },
  {
   "off": "0x9C4F",
   "zh": "无论拥有多么优秀的力量……"
  },
  {
   "off": "0x9C6E",
   "zh": "使用者若被愤怒支配、连一半力量都发挥不出来"
  },
  {
   "off": "0x9C98",
   "zh": "你的败因、就是你自己内心的软弱！"
  },
  {
   "off": "0x9CD5",
   "zh": "……！！"
  },
  {
   "off": "0x25A6",
   "zh": "……可恶！？"
  },
  {
   "off": "0x25CA",
   "zh": "死心吧、艾因"
  },
  {
   "off": "0x25F2",
   "zh": "怎、怎么会……"
  },
  {
   "off": "0x25FB",
   "zh": "这样的结局……"
  },
  {
   "off": "0x2606",
   "zh": "我怎么可能承认啊啊！！"
  },
  {
   "off": "0x263C",
   "zh": "……什么！？"
  },
  {
   "off": "0x2661",
   "zh": "西格！那个……！！"
  },
  {
   "off": "0x2693",
   "zh": "…………"
  },
  {
   "off": "0x269C",
   "zh": "接收到主人的最终命令……确认"
  },
  {
   "off": "0x26D0",
   "zh": "呵……哈哈、哈……"
  },
  {
   "off": "0x26DB",
   "zh": "啊哈哈哈哈……！"
  },
  {
   "off": "0x26E6",
   "zh": "你们已经完了！"
  },
  {
   "off": "0x2712",
   "zh": "艾因……你这家伙！？"
  },
  {
   "off": "0x2738",
   "zh": "我怎么可能一个人去死！！"
  },
  {
   "off": "0x2749",
   "zh": "要死也要拉上你们和瑟拉一起！"
  },
  {
   "off": "0x275C",
   "zh": "一旦变成那样、就再没人能阻止泰拉·斯欧诺了……"
  },
  {
   "off": "0x277E",
   "zh": "精神波的最大输出……你们承受不……"
  },
  {
   "off": "0x2799",
   "zh": "……啊！"
  },
  {
   "off": "0x27C5",
   "zh": "唔！这、这是……"
  },
  {
   "off": "0x27EF",
   "zh": "……西格！！"
  },
  {
   "off": "0x2813",
   "zh": "必须阻止泰拉·斯欧诺……阻止瑟拉才行……唔！！"
  },
  {
   "off": "0x2849",
   "zh": "可、可是要怎么做！？"
  },
  {
   "off": "0x2873",
   "zh": "……不知道。但也只能试试看了！"
  },
  {
   "off": "0x28AF",
   "zh": "…………"
  },
  {
   "off": "0x28E4",
   "zh": "…………"
  },
  {
   "off": "0x28ED",
   "zh": "瑟拉……"
  },
  {
   "off": "0x28F4",
   "zh": "我这就来……！"
  },
  {
   "off": "0x2BA3",
   "zh": "……！"
  },
  {
   "off": "0x2BCF",
   "zh": "…………"
