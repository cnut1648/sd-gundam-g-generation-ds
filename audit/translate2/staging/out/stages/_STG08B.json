 "title_zh": "分道扬镳",
 "briefing": [
  {
   "off": "0x19A3DC",
   "zh": "联邦远征舰队正逼近阿克西斯的情报、想必诸君也已知晓"
  },
  {
   "off": "0x19A403",
   "zh": "联邦的进攻连内应都利用上了、计划性极强……"
  },
  {
   "off": "0x19A422",
   "zh": "他们的目的、显然就是完全占领这座阿克西斯"
  },
  {
   "off": "0x19A440",
   "zh": "望诸君立即出击、担负起迎击联邦舰队的任务"
  },
  {
   "off": "0x19A488",
   "zh": "……关于敌方部队、容我补充几句"
  },
  {
   "off": "0x19A498",
   "zh": "敌军主力是此前遭遇过的吉姆型……"
  },
  {
   "off": "0x19A4AF",
   "zh": "其中也确认到部分性能强化型和支援型机体"
  },
  {
   "off": "0x19A4F5",
   "zh": "毕竟是主力部队、战力与以往对手不在一个档次"
  },
  {
   "off": "0x19A512",
   "zh": "务必千万小心作战"
  }
 ],
 "blocks": [
  {
   "off": "0x14C6",
   "zh": "那是……联邦军！？"
  },
  {
   "off": "0x14EE",
   "zh": "好庞大的数量……他们是真想踏平这里吗！？"
  },
  {
   "off": "0x152E",
   "zh": "……怎么样了？"
  },
  {
   "off": "0x1552",
   "zh": "……是。各项部署均已就绪"
  },
  {
   "off": "0x158E",
   "zh": "阿萨尔姆还没做好出港准备吗！？快派迎击的MS出击！"
  },
  {
   "off": "0x15CA",
   "zh": "是！目前正在全力加紧……"
  },
  {
   "off": "0x15FF",
   "zh": "……怎么回事！？"
  },
  {
   "off": "0x1624",
   "zh": "居住区发生爆炸！"
  },
  {
   "off": "0x1631",
   "zh": "……！？这、这是……！！"
  },
  {
   "off": "0x1669",
   "zh": "你、你们……想干什么！？"
  },
  {
   "off": "0x1693",
   "zh": "呜哇！！"
  },
  {
   "off": "0x16E6",
   "zh": "如今的阿克西斯、岂能交给那帮信不过的高层！"
  },
  {
   "off": "0x1724",
   "zh": "要用我们的手夺回来！夺回真正的吉翁！！"
  },
  {
   "off": "0x1754",
   "zh": "是年轻军官们叛乱了！！"
  },
  {
   "off": "0x177F",
   "zh": "多么愚蠢的行径……！！"
  },
  {
   "off": "0x178D",
   "zh": "这样只会白白便宜了联邦！！"
  },
  {
   "off": "0x17A7",
   "zh": "可恶……夏亚大佐他们怎么样了！？"
  },
  {
   "off": "0x17D6",
   "zh": "无法取得联络！恐怕是被卷入了这场叛乱……"
  },
  {
   "off": "0x180F",
   "zh": "可恶……难道大势已去了吗！！"
  },
  {
   "off": "0x1870",
   "zh": "把无能的高层统统扫清！！"
  },
  {
   "off": "0x18CF",
   "zh": "没错！我们才是真正的吉翁！！"
  },
  {
   "off": "0x9AD8",
   "zh": "『大家、住手啊！！』"
  },
  {
   "off": "0x9AFA",
   "zh": "……哈曼大人！？"
  },
  {
   "off": "0x9B20",
   "zh": "是、是内部广播！哈曼大人她……"
  },
  {
   "off": "0x9B8C",
   "zh": "同为吉翁的同胞、为什么非要自相残杀！？"
  },
  {
   "off": "0x9BAA",
   "zh": "难道我们离开地球圈、就是为了做这种事吗！？"
  },
  {
   "off": "0x9BC7",
   "zh": "我的父亲大人和瑟娜大人、拼上性命想要守护的阿克西斯、"
  },
  {
   "off": "0x9BE7",
   "zh": "眼看就要遭到联邦军的攻击、大家为什么还不站出来！？"
  },
  {
   "off": "0x9C0E",
   "zh": "我不要！我不要这座阿克西斯就此消失！"
  },
  {
   "off": "0x9C27",
   "zh": "如果谁都不肯战斗的话……"
  },
  {
   "off": "0x9C39",
   "zh": "我一个人也要战斗！！"
  },
  {
   "off": "0x1947",
   "zh": "喂！！那是哈曼大人的MS！！"
  },
  {
   "off": "0x197D",
   "zh": "这么说、哈曼大人她真的是独自一人……"
  },
  {
   "off": "0x19B6",
   "zh": "哈曼大人说得对！！"
  },
  {
   "off": "0x19C7",
   "zh": "现在不是自己人窝里斗的时候！！"
  },
  {
   "off": "0x1A04",
   "zh": "让哈曼大人一个人战斗、你们不觉得羞耻吗！？"
  },
  {
   "off": "0x1A46",
   "zh": "没错！我们也要跟上哈曼大人！"
  },
  {
   "off": "0x1A86",
   "zh": "用我们自己的手守住阿克西斯！！"
  },
  {
   "off": "0x1AC0",
   "zh": "哈曼大人……是何等可靠……！"
  },
  {
   "off": "0x1AED",
   "zh": "……哈斯勒提督！"
  },
  {
   "off": "0x1B12",
   "zh": "哦哦、夏亚大佐！你没事啊！"
  },
  {
   "off": "0x1B40",
   "zh": "但是、桑吉巴尔遭到了叛乱部队的攻击……"
  },
  {
   "off": "0x1B72",
   "zh": "现在正让阿萨尔姆准备出港。大佐的部队也请赶去那边！"
  },
  {
   "off": "0x1BAA",
   "zh": "……明白了"
  },
  {
   "off": "0x1BEF",
   "zh": "哈曼……我马上就赶过去……！"
  },
  {
   "off": "0x1C01",
   "zh": "在那之前、别乱来啊……！"
  },
  {
   "off": "0x8B3A",
   "zh": "怎、怎么会……！"
  },
  {
   "off": "0x8B4E",
   "zh": "呀啊啊啊！！"
  },
  {
   "off": "0x8B8A",
   "zh": "糟了！本阵若是失守……！！"
  },
  {
   "off": "0x1C29",
   "zh": "可恶……！"
  },
  {
   "off": "0x1C32",
   "zh": "本想兵不血刃拿下阿克西斯、竟坏在区区一个小丫头手里……！！"
  },
  {
   "off": "0x1C50",
   "zh": "既然如此、就用蛮力给它攻下来！！"
  },
  {
   "off": "0x1C8B",
   "zh": "阿萨尔姆、出港准备完毕！"
  },
  {
   "off": "0x1CB7",
   "zh": "好、立刻出港！与哈曼大人会合、痛击敌人！！"
  },
  {
   "off": "0x1CFA",
   "zh": "…………"
  },
  {
   "off": "0x1D03",
   "zh": "简直像座移动要塞啊、这台机动装甲……"
  },
  {
   "off": "0x1D33",
   "zh": "这是我们在阿克西斯开发的、最新锐的机动装甲"
  },
  {
   "off": "0x1D4D",
   "zh": "目前完成度约80%、但应该比勇士好用"
  },
  {
   "off": "0x1D8B",
   "zh": "机动装甲这东西、总觉得不合我的性子……"
  },
  {
   "off": "0x1DA5",
   "zh": "也由不得我挑剔机体了"
  },
  {
   "off": "0x1DE4",
   "zh": "夏亚·阿兹纳布尔……诺耶·吉尔……出击！！"
  },
  {
   "off": "0x1E1F",
   "zh": "好！我们也跟上夏亚大佐！"
  },
  {
   "off": "0x1E33",
   "zh": "阿萨尔姆、出击！！"
  },
  {
   "off": "0x1E64",
   "zh": "没事吧、哈曼？"
  },
  {
   "off": "0x1E89",
   "zh": "您来了、夏亚大佐。我就相信……您一定会来的"
  },
  {
   "off": "0x1EC7",
   "zh": "哈曼？"
  },
  {
   "off": "0x1EF8",
   "zh": "从刚才起、我就一直……一直感觉到……"
  },
  {
   "off": "0x1F10",
   "zh": "……感觉到大佐的心、正触碰着我"
  },
  {
   "off": "0x1F47",
   "zh": "喂喂、哈曼、这里可是战场。这种玩笑就……！？"
  },
  {
   "off": "0x1F7C",
   "zh": "……怎么了、大佐？"
  },
  {
   "off": "0x1FE5",
   "zh": "……是大佐"
  },
  {
   "off": "0x1FED",
   "zh": "……感觉是大佐、触碰了我的心"
  },
  {
   "off": "0x202C",
   "zh": "嗯？这种玩笑还是不要开了吧"
  },
  {
   "off": "0x209A",
   "zh": "…………"
  },
  {
   "off": "0x20C4",
   "zh": "……怎么了、大佐？"
  },
  {
   "off": "0x20F1",
   "zh": "啊、啊啊……没什么"
  },
  {
   "off": "0x20FE",
   "zh": "总之、要多加小心。战场上什么都可能发生"
  },
  {
   "off": "0x2138",
   "zh": "是的！不过、我没事的、夏亚大佐！"
  },
  {
   "off": "0x214B",
   "zh": "因为有大佐守护着我……我、能战斗下去！！"
  },
  {
   "off": "0x218C",
   "zh": "…………"
  },
  {
   "off": "0x21BA",
   "zh": "那些家伙……终于打到这里来了吗……"
  },
  {
   "off": "0x21ED",
   "zh": "零……"
  },
  {
   "off": "0x220F",
   "zh": "没事的、蕾拉。我一定会守护你"
  },
  {
   "off": "0x2243",
   "zh": "不是的、零。我害怕的是……"
  },
  {
   "off": "0x2257",
   "zh": "是好不容易才遇见的你、或许就会在这里离我而去……"
  },
  {
   "off": "0x2278",
   "zh": "……只是忍不住这么想了而已"
  },
  {
   "off": "0x22A3",
   "zh": "蕾拉……"
  },
  {
   "off": "0x22C6",
   "zh": "……别担心、零。我也是能战斗的"
  },
  {
   "off": "0x22DD",
   "zh": "只要你愿意守护我……我也一定会守护你！"
  },
  {
   "off": "0x2328",
   "zh": "……谢谢你、蕾拉"
  },
  {
   "off": "0x2333",
   "zh": "是啊……我们不是孤身一人。战斗吧……两个人一起！！"
  },
  {
   "off": "0x2378",
   "zh": "怎么样、大佐？那台MA用起来感觉如何！？"
  },
  {
   "off": "0x23AB",
   "zh": "我毕竟是开MS的。没有腿的机体、总觉得……不对劲啊"
  },
  {
   "off": "0x23C9",
   "zh": "哈斯勒提督的好意、我固然感激……"
  },
  {
   "off": "0x23FA",
   "zh": "果然、大人物就是不明白这种事吗？"
  },
  {
   "off": "0x242F",
   "zh": "是啊……或许只是宽心话、但据说我倒能驾驭好它"
  },
  {
   "off": "0x2473",
   "zh": "……嗯？"
  },
  {
   "off": "0x2479",
   "zh": "阿波利、大佐他们……到底在说什么……？"
  },
  {
   "off": "0x24B4",
   "zh": "别以为区区一个小丫头、就能拦得住老子！！"
  },
  {
   "off": "0x24EA",
   "zh": "不……我偏要拦给你看！"
  },
  {
   "off": "0x24F9",
   "zh": "父亲大人和瑟娜大人拼命守护的阿克西斯、绝不容你们摆布！"
  },
  {
   "off": "0x2543",
   "zh": "这阿克西斯、是我们好不容易才找到的家"
  },
  {
   "off": "0x255A",
   "zh": "老娘岂会让你们这帮家伙为所欲为！！"
  },
  {
   "off": "0x259B",
   "zh": "我不会再迷茫了……"
  },
  {
   "off": "0x25AA",
   "zh": "如果你们要妨碍我们、就算是兄弟、我也照样打倒你们！"
  },
  {
   "off": "0x25F3",
   "zh": "这艘舰是加米托夫阁下托付于我的、决不能让它沉了……！"
  },
  {
   "off": "0x261C",
   "zh": "暂时后退！！"
  },
  {
   "off": "0x2656",
   "zh": "可、可恶……区区宇宙人、竟敢摆我们一道！！"
  },
  {
   "off": "0x267B",
   "zh": "撤、撤退！全舰后撤！！"
  },
  {
   "off": "0x26BE",
   "zh": "总算是守住了阿克西斯……！！"
  },
  {
   "off": "0x2705",
   "zh": "成功了！我们击退了联邦军！！"
  },
  {
   "off": "0x273B",
   "zh": "哈曼大人、万岁！！"
  },
  {
   "off": "0x2776",
   "zh": "大家……"
  },
  {
   "off": "0x27A2",
   "zh": "……怎么回事！？"
  },
  {
   "off": "0x27C7",
   "zh": "刚才那艘敌舰调头了！正朝阿克西斯冲来！！"
  },
  {
   "off": "0x2807",
   "zh": "那家伙……想干什么！？"
  },
  {
   "off": "0x2846",
   "zh": "巴斯克大佐……真的可以这样做吗？"
  },
  {
   "off": "0x2876",
   "zh": "无妨！开火！！"
  },
  {
   "off": "0x9C5E",
   "zh": "导弹？……难道说！！"
  },
  {
   "off": "0x28A9",
   "zh": "核、核导弹！？"
  },
  {
   "off": "0x28DC",
   "zh": "啧！导弹、给我继续发射！！"
  },
  {
   "off": "0x2914",
   "zh": "不好……！！"
  },
  {
   "off": "0x2943",
   "zh": "什么！？……竟是诱饵！"
  },
  {
   "off": "0x2977",
   "zh": "……快迎击！！"
  },
  {
   "off": "0x299C",
   "zh": "不行！来不及了！！"
  },
  {
   "off": "0x29DF",
   "zh": "力场输出全开！把损害控制在最小限度！！"
  },
  {
   "off": "0x2A0C",
   "zh": "核、核导弹爆炸了……损害……竟、竟然为零……！"
  },
  {
   "off": "0x2A54",
   "zh": "怎、怎么可能！到底发生了什么！？"
  },
  {
   "off": "0x2AA1",
   "zh": "有劳了……哈利"
  },
  {
   "off": "0x2AE0",
   "zh": "两军都收起刀剑！再战下去已属无益！！"
  },
  {
   "off": "0x2B29",
   "zh": "那、那是什么！？到底是从哪儿……"
  },
  {
   "off": "0x2BA3",
   "zh": "……我们是月之民"
  },
  {
   "off": "0x2BB8",
   "zh": "为了回避黑历史、我们自数千年后的遥远未来而来"
  },
  {
   "off": "0x96DE",
   "zh": "自一年战争以来……"
  },
  {
   "off": "0x96EE",
   "zh": "在地球居民与宇宙居民之间不断加深的对立……"
  },
  {
   "off": "0x970E",
   "zh": "随着自称月之民者的登场、骤然宣告终结"
  },
  {
   "off": "0x972E",
   "zh": "来自遥远未来的他们……"
  },
  {
   "off": "0x9746",
   "zh": "那据称发生于宇宙世纪之后的、地球文明的崩坏……"
  },
  {
   "off": "0x9766",
   "zh": "为防止这段「黑历史」、他们着手统治了地球圈"
  },
  {
   "off": "0x978E",
   "zh": "虽然也有一部分军事势力、表现出顽强的反对……"
  },
  {
   "off": "0x97B2",
   "zh": "但面对技术遥遥领先的月之民、他们无力抗衡"
  },
  {
   "off": "0x97D2",
   "zh": "地球联邦政府将地球的统治、移交给了月之民的女王迪安娜……"
  },
  {
   "off": "0x97FA",
   "zh": "一个宇宙居民与地球居民人人平等的时代、就此到来"
  },
  {
   "off": "0x9826",
   "zh": "然而……"
  },
  {
   "off": "0x9832",
   "zh": "那乍看理想的治世、也在短短数年间生出了裂痕"
  },
  {
   "off": "0x985E",
   "zh": "居住在PLANT的调整者们、吸收了月之民的技术力……"
  },
  {
   "off": "0x9886",
   "zh": "组建独立的军事组织扎夫特、并宣布脱离月球独立……"
  },
  {
   "off": "0x98B2",
   "zh": "地球圈各地的诸多势力、由此纷纷开始叛离"
  },
  {
   "off": "0x98D2",
   "zh": "不谙斗争的月之民、终究未能把握住这股潮流"
  },
  {
   "off": "0x98F6",
   "zh": "就这样、地球圈……"
  },
  {
   "off": "0x990A",
   "zh": "再度被战乱的火焰所吞没……"
  },
  {
   "off": "0x994A",
   "zh": "…………"
  },
  {
   "off": "0x9985",
   "zh": "……啊……"
  },
  {
   "off": "0x9996",
   "zh": "……苏醒……之时……已至……"
  },
  {
   "off": "0x99E5",
   "zh": "…………"
