  {
   "off": "0xA1FF",
   "zh": "……嗯"
  },
  {
   "off": "0xA221",
   "zh": "……走吧、爱娜"
  },
  {
   "off": "0xA24D",
   "zh": "嗯、士郎"
  },
  {
   "off": "0x24ED",
   "zh": "……！夏亚！？"
  },
  {
   "off": "0x251C",
   "zh": "对即将迎来觉醒的人类而言、扎比家这种存在已无必要"
  },
  {
   "off": "0x2573",
   "zh": "呵呵、果然……是这样吗……你竟是……"
  },
  {
   "off": "0x2592",
   "zh": "不是吉翁军人的夏……亚、而是……戴肯的……孩子啊……"
  },
  {
   "off": "0x25D7",
   "zh": "…………"
  },
  {
   "off": "0x260F",
   "zh": "…………"
  },
  {
   "off": "0x2633",
   "zh": "……卡尔玛、这是我献给你的祭礼"
  },
  {
   "off": "0x2645",
   "zh": "就和姐姐大人、好好相处吧……"
  },
  {
   "off": "0x2656",
   "zh": "…………"
  },
  {
