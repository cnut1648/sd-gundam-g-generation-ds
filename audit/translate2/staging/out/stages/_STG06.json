  },
  {
   "off": "0x9D5A",
   "zh": "哥……哥？"
  },
  {
   "off": "0x9D86",
   "zh": "爱娜！！"
  },
  {
   "off": "0x9DB6",
   "zh": "爱娜啊！！"
  },
  {
   "off": "0x9DE6",
   "zh": "爱娜……爱娜！"
  },
  {
   "off": "0x9E1C",
   "zh": "是你……"
  },
  {
   "off": "0x9E24",
   "zh": "都是因为你、妹妹才非死不可"
  },
  {
   "off": "0x9E56",
   "zh": "…………"
  },
  {
   "off": "0x9E5F",
   "zh": "哥哥……杀了自己的妹妹……！"
  },
  {
   "off": "0x9E6F",
