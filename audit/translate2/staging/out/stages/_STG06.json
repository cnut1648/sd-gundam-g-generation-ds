  },
  {
   "off": "0x9EA2",
   "zh": "有意思……！"
  },
  {
   "off": "0x9EAB",
   "zh": "我早就想见识一次了、那个所谓的『幽灵』！"
  },
  {
   "off": "0x9EC7",
   "zh": "就当是献给爱娜的祭礼、送你一起上路"
  },
  {
   "off": "0x9F06",
   "zh": "可恶……！"
  },
  {
   "off": "0x9F26",
   "zh": "『快逃、士郎！』"
  },
  {
   "off": "0x9F46",
   "zh": "……！？"
  },
  {
   "off": "0x9F76",
   "zh": "士郎……"
  },
  {
   "off": "0x9FA2",
   "zh": "爱娜！你活着……你还活着啊！！"
  },
  {
   "off": "0x9FD1",
   "zh": "哥哥造的阿普萨拉斯、维系住了我的性命……"
  },
  {
   "off": "0x9FED",
   "zh": "……真是讽刺呢"
  },
  {
   "off": "0xA015",
   "zh": "太好了……爱娜你真的还活着……"
