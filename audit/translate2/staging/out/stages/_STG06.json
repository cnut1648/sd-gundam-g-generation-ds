  },
  {
   "off": "0xA50A",
   "zh": "永别了……哥哥"
  },
  {
   "off": "0xA542",
   "zh": "我的梦想！"
  },
  {
   "off": "0xA554",
   "zh": "给我收下吧！！"
  },
  {
   "off": "0xA58E",
   "zh": "可恶……还没完！！"
  },
  {
   "off": "0xA5CA",
   "zh": "……！？"
  },
  {
   "off": "0xA602",
   "zh": "同归于尽了……？"
  },
  {
   "off": "0xA638",
   "zh": "爱娜·萨哈林……"
  },
  {
   "off": "0xD762",
   "zh": "基尼亚斯·萨哈林……竟栽在那种程度的对手手里、不过如此……"
  },
  {
   "off": "0xA12E",
   "zh": "对……很好、格罗姆林……"
  },
  {
   "off": "0xA149",
   "zh": "由我……亲手造出的你……"
  },
  {
   "off": "0xA162",
