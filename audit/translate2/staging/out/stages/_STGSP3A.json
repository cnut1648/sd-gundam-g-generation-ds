 "briefing": [
  {
   "off": "0x1A0327",
   "zh": "新吉翁企图让阿克西斯连同核弹一起坠向地球……"
  },
  {
   "off": "0x1A0349",
   "zh": "殖民地驻留舰队因惧怕市民暴动、迟迟无法行动"
  },
  {
   "off": "0x1A036A",
   "zh": "现如今、能阻止夏亚阴谋的只有我们隆德·贝尔"
  },
  {
   "off": "0x1A038B",
   "zh": "因此、我们隆德·贝尔队即刻火速赶往阿克西斯……"
  },
  {
   "off": "0x1A03AA",
   "zh": "对新吉翁舰队发起攻击、设法阻止阿克西斯坠落！"
  },
  {
   "off": "0x1A03F0",
   "zh": "那么、下面说明作战内容"
  },
  {
   "off": "0x1A0401",
   "zh": "阿克西斯周边有新吉翁舰队严密驻防……"
  },
  {
   "off": "0x1A041E",
   "zh": "要同时对付舰队并破坏阿克西斯、非常困难"
  },
  {
   "off": "0x1A0438",
   "zh": "因此我们首先要击破担任阿克西斯直卫的敌部队……"
  },
  {
   "off": "0x1A0458",
   "zh": "之后再通过炮击与内部爆破作业来摧毁阿克西斯"
  },
  {
   "off": "0x1A04A0",
   "zh": "虽说要对付的只是担任直卫的部队……"
  },
  {
   "off": "0x1A04C0",
   "zh": "但那可是夏亚亲自率领的部队"
  },
  {
   "off": "0x1A04D1",
   "zh": "想必会是一场恶战。拜托了、各位！"
  }
 ],
