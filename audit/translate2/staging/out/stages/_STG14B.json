 "title_zh": "玻璃般的王国",
 "briefing": [
  {
   "off": "0x19D774",
   "zh": "方才接到友军的联络、"
  },
  {
   "off": "0x19D784",
   "zh": "已经确认、桑古王国正遭受OZ的进攻！"
  },
  {
   "off": "0x19D7A0",
   "zh": "希罗·尤尔已驾驶艾比安出击、正赶往桑古王国"
  },
  {
   "off": "0x19D7BE",
   "zh": "我们将追随他火速赶往桑古王国……"
  },
  {
   "off": "0x19D7D3",
   "zh": "与当地部队协力、从OZ手中保卫桑古王国！"
  },
  {
   "off": "0x19D80A",
   "zh": "另外、关于入侵桑古王国的OZ部队……"
  },
  {
   "off": "0x19D822",
   "zh": "现已查明、这是一支以机动人偶为主力的部队"
  },
  {
   "off": "0x19D841",
   "zh": "另有情报称、在部分入侵部队中目击到高达型MS"
  },
  {
   "off": "0x19D8A7",
   "zh": "若继奥布之后、连桑古王国也被OZ攻陷、"
  },
  {
   "off": "0x19D8C5",
   "zh": "其他中立国恐将如雪崩般屈服于OZ之下"
  },
  {
   "off": "0x19D8EB",
   "zh": "能否在此遏止战火、全看诸君的奋战了"
  },
  {
   "off": "0x19D90B",
   "zh": "拜托了、各位！"
  }
 ],
 "blocks": [
  {
   "off": "0x6C22",
   "zh": "莉莉娜女王！！请您退下！这里太危险了！"
  },
  {
   "off": "0x6C57",
   "zh": "不……我不能那么做"
  },
  {
   "off": "0x6C81",
   "zh": "……莉莉娜女王？"
  },
  {
   "off": "0x6CA7",
   "zh": "身为桑古王国的女王、我绝不能离开此地"
  },
  {
   "off": "0x6CE4",
   "zh": "可是OZ的部队已经近在眼前……"
  },
  {
   "off": "0x6D1A",
   "zh": "不好！莉莉娜女王！您快逃……"
  },
  {
   "off": "0x6D63",
   "zh": "莉莉娜大人！您没事吧！？"
  },
  {
   "off": "0x6D9A",
   "zh": "……诺茵小姐！？"
  },
  {
   "off": "0x6DC6",
   "zh": "我十分清楚、此举有违莉莉娜大人的理念"
  },
  {
   "off": "0x6DE2",
   "zh": "您一定会说、桑古王国不需要这样的兵器"
  },
  {
   "off": "0x6E00",
   "zh": "但我最终认定、若无防卫之力、就只能任人宰割"
  },
  {
   "off": "0x6E24",
   "zh": "一切都是我的独断。事后无论何种处分、我都甘愿领受"
  },
  {
   "off": "0x6E66",
   "zh": "诺茵……！！"
  },
  {
   "off": "0x6E79",
   "zh": "…………"
  },
  {
   "off": "0x6E82",
   "zh": "难道我的理念……实现完全和平终究只是一场梦吗？"
  },
  {
   "off": "0x6EC6",
   "zh": "我一定会保护好莉莉娜大人……"
  },
  {
   "off": "0x6ED8",
   "zh": "……杰克斯！我以与你的约定起誓……！"
  },
  {
   "off": "0x4FCE",
   "zh": "难、难道就到此为止了……"
  },
  {
   "off": "0x744E",
   "zh": "唔……！难道我就到此为止了吗！！"
  },
  {
   "off": "0x740E",
   "zh": "可恶……任务、失败了吗！"
  },
  {
   "off": "0x6F16",
   "zh": "可恶……！对不起、杰克斯……！！"
  },
  {
   "off": "0xC34A",
   "zh": "哼！区区一台机体能成什么事！！"
  },
  {
   "off": "0xC35D",
   "zh": "派出后续部队！连那台MS带王城一起给我抹掉！"
  },
  {
   "off": "0xC3A2",
   "zh": "哼……想凭区区一台机体反抗我们吗"
  },
  {
   "off": "0xC3B9",
   "zh": "派出后续部队！连王城一口气碾个粉碎！！"
  },
  {
   "off": "0x6F5A",
   "zh": "不好、又来新的敌人了！？"
  },
  {
   "off": "0x6F9B",
   "zh": "战术层级、最大效果确认……"
  },
  {
   "off": "0x6FD2",
   "zh": "你是……希罗！？"
  },
  {
   "off": "0x7013",
   "zh": "…………"
  },
  {
   "off": "0x7048",
   "zh": "希罗·尤尔……？"
  },
  {
   "off": "0x7053",
   "zh": "怎么回事？他的样子……"
  },
  {
   "off": "0x709B",
   "zh": "…………"
  },
  {
   "off": "0x70A4",
   "zh": "我的……"
  },
  {
   "off": "0x70AB",
   "zh": "我的敌人在哪里……！！"
  },
  {
   "off": "0x70DE",
   "zh": "希罗·尤尔！？"
  },
  {
   "off": "0x711A",
   "zh": "…………"
  },
  {
   "off": "0x714A",
   "zh": "确认状况……你是敌人吗！？"
  },
  {
   "off": "0x718F",
   "zh": "杰克斯……"
  },
  {
   "off": "0x71BE",
   "zh": "我的敌人、就是想取我性命之人……"
  },
  {
   "off": "0x71DB",
   "zh": "……一切都是我的敌人！！"
  },
  {
   "off": "0x721A",
   "zh": "可恶！是被零式系统吞噬了吗！"
  },
  {
   "off": "0x7239",
   "zh": "既然如此！"
  },
  {
   "off": "0x7272",
   "zh": "我……"
  },
  {
   "off": "0x72AB",
   "zh": "看来你清醒过来了、希罗·尤尔"
  },
  {
   "off": "0x72E4",
   "zh": "杰克斯、你也是来保护莉莉娜的吗……"
  },
  {
   "off": "0x7330",
   "zh": "……当然。现在不是我们自相争斗的时候"
  },
  {
   "off": "0x734A",
   "zh": "还能上吗、希罗·尤尔？"
  },
  {
   "off": "0x737D",
   "zh": "……我还能战斗"
  },
  {
   "off": "0x73BB",
   "zh": "那就没有任何问题了。上吧、希罗·尤尔！"
  },
  {
   "off": "0x73D6",
   "zh": "……为了守护桑古王国！！"
  },
  {
   "off": "0x749A",
   "zh": "一年零两天没见了呢、杰克斯"
  },
  {
   "off": "0x74CB",
   "zh": "是诺茵吗……多亏你保护了莉莉娜。谢谢你"
  },
  {
   "off": "0x7513",
   "zh": "你还是没有摘下那副面具呢？"
  },
  {
   "off": "0x7547",
   "zh": "我这双手毕竟曾染过鲜血"
  },
  {
   "off": "0x7559",
   "zh": "莉莉娜走的是完全和平的光明之路、我这样的兄长配不上她"
  },
  {
   "off": "0x757D",
   "zh": "如今的我、是守护桑古王国的骑士杰克斯……这样就好"
  },
  {
   "off": "0x75C0",
   "zh": "…………"
  },
  {
   "off": "0x75E4",
   "zh": "即便如此、我仍盼望着你公开米利亚尔特之名的那一天"
  },
  {
   "off": "0x760C",
   "zh": "盼望你能以兄长身份、站到莉莉娜大人面前的那一天……"
  },
  {
   "off": "0x765D",
   "zh": "……是啊"
  },
  {
   "off": "0x7666",
   "zh": "总有一天、我也会……"
  },
  {
   "off": "0x7698",
   "zh": "在那之前、我会拼上性命保护莉莉娜大人"
  },
  {
   "off": "0x76B6",
   "zh": "所以、杰克斯、请你……"
  },
  {
   "off": "0x76C2",
   "zh": "请你也找到一条自己认为正确的道路"
  },
  {
   "off": "0x76FD",
   "zh": "……谢谢你、诺茵"
  },
  {
   "off": "0x772E",
   "zh": "希罗！！"
  },
  {
   "off": "0x7757",
   "zh": "……是大天使号吗"
  },
  {
   "off": "0x7782",
   "zh": "看来总算是赶上了"
  },
  {
   "off": "0x7790",
   "zh": "各部队立刻出击！迎击OZ！！"
  },
  {
   "off": "0x17D6",
   "zh": "哇、又来新的！？"
  },
  {
   "off": "0x17E1",
   "zh": "怎么办啊！？计划里可没那玩意！！"
  },
  {
   "off": "0x1813",
   "zh": "…………？"
  },
  {
   "off": "0x183A",
   "zh": "……又没在问你"
  },
  {
   "off": "0x1870",
   "zh": "…………"
  },
  {
   "off": "0x18AB",
   "zh": "啧！要一次应付这么多、真麻烦……"
  },
  {
   "off": "0x18C2",
   "zh": "我要请求增援了！"
  },
  {
   "off": "0x18F3",
   "zh": "……杰克斯！"
  },
  {
   "off": "0x191C",
   "zh": "可恶！敌人的增援吗！！"
  },
  {
   "off": "0x77D2",
   "zh": "……怎么回事！？"
  },
  {
   "off": "0x7802",
   "zh": "那到底是什么……！！"
  },
  {
   "off": "0x7831",
   "zh": "杰克斯！那台MS朝我们冲过来了……！"
  },
  {
   "off": "0x7869",
   "zh": "那也是敌人吗？"
  },
  {
   "off": "0x789A",
   "zh": "找到你了！恶魔高达！！"
  },
  {
   "off": "0x78DB",
   "zh": "是多蒙·卡修吗！！"
  },
  {
   "off": "0x790E",
   "zh": "希罗！！"
  },
  {
   "off": "0x7937",
   "zh": "大天使号吗……"
  },
  {
   "off": "0x7962",
   "zh": "看来总算是赶上了"
  },
  {
   "off": "0x7970",
   "zh": "希罗·尤尔！恶魔高达交给我们来对付！"
  },
  {
   "off": "0x7988",
   "zh": "你就专心保卫王城！"
  },
  {
   "off": "0x79CF",
   "zh": "……了解"
  },
  {
   "off": "0x79FE",
   "zh": "好！全机立刻出击！！"
  },
  {
   "off": "0x7A0D",
   "zh": "迎击恶魔高达和OZ部队！！"
  },
  {
   "off": "0x7A4A",
   "zh": "等着吧、恶魔高达！今天我一定要打倒你！"
  },
  {
   "off": "0x7A8E",
   "zh": "恶魔高达停止行动了！？"
  },
  {
   "off": "0x7ACA",
   "zh": "好！这次一定要给那家伙最后一击！"
  },
  {
   "off": "0x7B26",
   "zh": "可恶！休想得逞！！"
  },
  {
   "off": "0x7B5E",
   "zh": "啊、恶魔高达它！！"
  },
  {
   "off": "0x7B9F",
   "zh": "哈哈哈！对、这样就好！"
  },
  {
   "off": "0x7BD7",
   "zh": "你这家伙！……东方不败！！"
  },
  {
   "off": "0x7C1F",
   "zh": "恶魔高达乃是我的希望……"
  },
  {
   "off": "0x7C2C",
   "zh": "岂容你们这些家伙破坏恶魔高达！！"
  },
  {
   "off": "0x7C68",
   "zh": "你说希望！？"
  },
  {
   "off": "0x7C71",
   "zh": "你是被恶魔高达的力量迷了心窍吗！东方不败·亚洲尊者！"
  },
  {
   "off": "0x7CBE",
   "zh": "哼……对你这个蠢徒弟、就算说了也是白费口舌"
  },
  {
   "off": "0x7CE4",
   "zh": "你若也自称高达斗士、就用拳头来说话！！"
  },
  {
   "off": "0x7D16",
   "zh": "正合我意！东方不败·亚洲尊者！！"
  },
  {
   "off": "0x7D52",
   "zh": "东方不败·亚洲尊者！！今天定要你说出你的企图！"
  },
  {
   "off": "0x7D74",
   "zh": "你得到恶魔高达的力量、到底想干什么！？"
  },
  {
   "off": "0x7DBF",
   "zh": "哼、你那双蒙尘的眼睛、看来什么也映不出来！"
  },
  {
   "off": "0x7DE2",
   "zh": "可悲可叹啊、多蒙！！"
  },
  {
   "off": "0x7E13",
   "zh": "什么！？这是什么意思、东方不败！！"
  },
  {
   "off": "0x7E59",
   "zh": "问答无用！！对现在的你、我无话可说！"
  },
  {
   "off": "0x7E74",
   "zh": "先用我这双拳、重新敲正你这蠢徒弟的心性！"
  },
  {
   "off": "0x7EBA",
   "zh": "东方不败·亚洲尊者……！"
  },
  {
   "off": "0x7EC9",
   "zh": "企图把恶魔高达据为己有的阴谋、我绝不能坐视！"
  },
  {
   "off": "0x7F1E",
   "zh": "……可悲可叹！"
  },
  {
   "off": "0x7F27",
   "zh": "想继承吉翁衣钵的男人、就只有这点见识吗！？"
  },
  {
   "off": "0x7F72",
   "zh": "什么！？"
  },
  {
   "off": "0x7FAC",
   "zh": "我东方不败·亚洲尊者……绝非为私利私欲而战！"
  },
  {
   "off": "0x7FCC",
   "zh": "你也是执掌一方组织的男人、连我的真意都看不穿怎么行！！"
  },
  {
   "off": "0x8007",
   "zh": "东方不败·亚洲尊者……你到底……"
  },
  {
   "off": "0x804F",
   "zh": "唔……！"
  },
  {
   "off": "0x8057",
   "zh": "你们这些人、为何就是不明白！"
  },
  {
   "off": "0x8095",
   "zh": "东方不败！？"
  },
  {
   "off": "0x80B2",
   "zh": "这是怎么回事！？"
  },
  {
   "off": "0x80BC",
   "zh": "东方不败的拳……拳在哭泣！？"
  },
  {
   "off": "0x80D4",
   "zh": "那难道是……东方不败灵魂的呐喊吗！？"
  },
  {
   "off": "0x80FB",
   "zh": "东方不败！你到底……"
  },
  {
   "off": "0x8131",
   "zh": "…………"
  },
  {
   "off": "0x813A",
   "zh": "恶魔高达正是这颗地球仅存的最后希望……"
  },
  {
   "off": "0x8170",
   "zh": "东方不败！？"
  },
  {
   "off": "0x819A",
   "zh": "刚才的话、你们给我牢牢刻在心里！"
  },
  {
   "off": "0x81B8",
   "zh": "下次再会时、我绝不容情！！"
  },
  {
   "off": "0x81EE",
   "zh": "东方不败！！"
  },
  {
   "off": "0x8202",
   "zh": "东方不败·亚洲尊者……你到底是……"
  },
  {
   "off": "0x821A",
   "zh": "…………"
  },
  {
   "off": "0x90AC",
   "zh": "真是的、也太不中用了……"
  },
  {
   "off": "0x8F95",
   "zh": "居然被那么一点敌人打得全军覆没"
  },
  {
   "off": "0x8FDA",
   "zh": "阿兹拉埃尔……！！"
  },
  {
   "off": "0x9018",
   "zh": "哎呀……？"
  },
  {
   "off": "0x9020",
   "zh": "我还当是谁、原来是从OZ叛逃的闪电伯爵先生啊"
  },
  {
   "off": "0x903E",
   "zh": "嘛、来得正好呢"
  },
  {
   "off": "0x904C",
   "zh": "敌人们和叛徒、就在这里一并解决掉吧"
  },
  {
   "off": "0x90E2",
   "zh": "唔……！！"
  },
  {
   "off": "0x9119",
   "zh": "克瓦特罗大尉……！！"
  },
  {
   "off": "0x9145",
   "zh": "以刚经恶战、疲惫不堪的我们、能抵挡到几时……"
  },
  {
   "off": "0x919F",
   "zh": "好了、那么……"
  },
