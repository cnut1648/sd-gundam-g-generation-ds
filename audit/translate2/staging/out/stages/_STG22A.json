 "title_zh": "终末之光",
 "briefing": [
  {
   "off": "0x19CA27",
   "zh": "现已查明、哈曼·卡恩的新吉翁占据了创世纪"
  },
  {
   "off": "0x19CA46",
   "zh": "当然、我们决不能任由创世纪继续落在哈曼手中"
  },
  {
   "off": "0x19CA65",
   "zh": "我军一旦准备就绪、就立即对创世纪发起攻击！"
  },
  {
   "off": "0x19CAAA",
   "zh": "目前、哈曼亲率的新吉翁舰队正驻守着创世纪"
  },
  {
   "off": "0x19CACC",
   "zh": "敌军主力是加撒系列、以高性能型的扎古3为核心"
  },
  {
   "off": "0x19CB16",
   "zh": "虽说自称新吉翁、其中大半只是生于阿克西斯的新兵"
  },
  {
   "off": "0x19CB38",
   "zh": "真正要提防的、是哈曼和她直属麾下的那些人"
  },
  {
   "off": "0x19CB59",
   "zh": "只要能妥善应对那些人、我们就有充分的胜算"
  },
  {
   "off": "0x19CBA0",
   "zh": "能否擒住哈曼、就看诸位的奋战了"
  },
  {
   "off": "0x19CBB8",
   "zh": "拜托了、各位！"
  }
 ],
 "blocks": [
  {
   "off": "0x180E",
   "zh": "看到了、是创世纪！！"
  },
  {
   "off": "0x1842",
   "zh": "全员、进入一级战斗配置！！"
  },
  {
   "off": "0x184E",
   "zh": "我们要从新吉翁手中夺取创世纪！"
  },
  {
   "off": "0x1886",
   "zh": "来了吗……奥古"
  },
  {
   "off": "0x18AB",
   "zh": "……哈曼！！"
  },
  {
   "off": "0x18CF",
   "zh": "居然不惜冒险、特地闯上门来……"
  },
  {
   "off": "0x18E8",
   "zh": "看来对你们来说、这创世纪同样魅力十足啊"
  },
  {
   "off": "0x191E",
   "zh": "我们和你不一样、哈曼！"
  },
  {
   "off": "0x194A",
   "zh": "哼……真是个好演员啊、夏亚"
  },
  {
   "off": "0x195B",
   "zh": "先是铲除提坦斯、如今又要打倒我们和扎夫特"
  },
  {
   "off": "0x1979",
   "zh": "在铲除了一切敌人的世界里、你又打算做什么？"
  },
  {
   "off": "0x19B3",
   "zh": "…………"
  },
  {
   "off": "0x19D7",
   "zh": "克瓦特罗大尉！不必去理会哈曼·卡恩说的那些话！"
  },
  {
   "off": "0x1A15",
   "zh": "迪安娜……？"
  },
  {
   "off": "0x1A3B",
   "zh": "我们应当做的、是平息这场纷争……"
  },
  {
   "off": "0x1A58",
   "zh": "除此之外、我们别无所求、也无意强求！"
  },
  {
   "off": "0x1A92",
   "zh": "凭那种目光短浅的行动、岂能为人类带来未来！"
  },
  {
   "off": "0x1AB3",
   "zh": "复兴扎比家、为世人指明道路！那才是人类应当采取的手段！"
  },
  {
   "off": "0x1AF8",
   "zh": "你想重演一年战争的愚行吗、哈曼！？"
  },
  {
   "off": "0x1B2C",
   "zh": "……哼、终究是两条平行线、谈不到一起吗……"
  },
  {
   "off": "0x1B46",
   "zh": "既然不肯与我同道、就只有消灭你们、奥古！！"
  },
  {
   "off": "0x1B87",
   "zh": "新吉翁！敌方MS展开了！！"
  },
  {
   "off": "0x1BB3",
   "zh": "应战！我方也放出MS！！"
  },
  {
   "off": "0x1BD1",
   "zh": "全员、开始战斗！！"
  },
  {
   "off": "0xB07A",
   "zh": "……不好！这艘舰要是被击毁的话……！"
  },
  {
   "off": "0x1C04",
   "zh": "两军都已疲惫不堪、现在正是好机会！"
  },
  {
   "off": "0x1C1A",
   "zh": "就这样一口气击溃两军！"
  },
  {
   "off": "0xB602",
   "zh": "帕特里克·萨拉这家伙……当成小人物置之不理、竟成了祸根吗"
  },
  {
   "off": "0xB64A",
   "zh": "不好！再这样下去会遭到夹击！！"
  },
  {
   "off": "0x1C5C",
   "zh": "奥古也好、新吉翁也罢、终究是自然人的乌合之众！！"
  },
  {
   "off": "0x1C76",
   "zh": "最后活下来的、是我们调整者！！"
  },
  {
   "off": "0x1CB0",
   "zh": "呵呵……"
  },
  {
   "off": "0x1CB7",
   "zh": "不愧是萨拉议长、完全照我所想的行动"
  },
  {
   "off": "0x1CF4",
   "zh": "克鲁泽队、出击！！"
  },
  {
   "off": "0x24EF",
   "zh": "我军损耗率、已突破5成！"
  },
  {
   "off": "0x2524",
   "zh": "奥古依然健在！"
  },
  {
   "off": "0x2556",
   "zh": "可恶……这群自然人！！"
  },
  {
   "off": "0x256F",
   "zh": "开始输入创世纪瞄准参数！"
  },
  {
   "off": "0x2597",
   "zh": "萨拉议长！？"
  },
  {
   "off": "0x25BB",
   "zh": "目标、地球联邦北部！快！！"
  },
  {
   "off": "0x25E7",
   "zh": "布莱特舰长！创世纪出现能量反应！！"
  },
  {
   "off": "0x2615",
   "zh": "什么！！难道说、他们要发射创世纪！？"
  },
  {
   "off": "0xB99A",
   "zh": "布莱特舰长！"
  },
  {
   "off": "0xB9BD",
   "zh": "阿斯兰·萨拉！？"
  },
  {
   "off": "0xB9E2",
   "zh": "创世纪的内部构造、我也多少有所掌握！"
  },
  {
   "off": "0xB9FC",
   "zh": "我这就突入内部、摧毁控制系统！"
  },
  {
   "off": "0xBA3A",
   "zh": "……阿斯兰！"
  },
  {
   "off": "0xBA67",
   "zh": "放心……交给我！"
  },
  {
   "off": "0x2650",
   "zh": "阿斯兰·萨拉……拜托了！"
  },
  {
   "off": "0x2B53",
   "zh": "你们在干什么！？快！这一击就能终结一切！"
  },
  {
   "off": "0x2B8C",
   "zh": "议长……这一仗、我们已经败了"
  },
  {
   "off": "0x2BA2",
   "zh": "再这样白白增加牺牲、也已经没有……"
  },
  {
   "off": "0x2BCE",
   "zh": "……！？"
  },
  {
   "off": "0x2BF8",
   "zh": "议长！？"
  },
  {
   "off": "0x2C1A",
   "zh": "必须发射！在被击垮之前！"
  },
  {
   "off": "0x2C2F",
   "zh": "快、快点！！发射！把创世纪发射出去！！"
  },
  {
   "off": "0x2C61",
   "zh": "呃……"
  },
  {
   "off": "0x2C68",
   "zh": "议长……您、您这是……！"
  },
  {
   "off": "0x2CB9",
   "zh": "……父亲？"
  },
  {
   "off": "0x2CE9",
   "zh": "发、射……创世……"
  },
  {
   "off": "0x2CF5",
   "zh": "向夺走我们世界的人……降下、报应……"
  },
  {
   "off": "0x2D09",
   "zh": "敌人……！在被打中之前……"
  },
  {
   "off": "0x2D19",
   "zh": "……！"
  },
  {
   "off": "0x2D3D",
   "zh": "…………"
  },
  {
   "off": "0x2D6B",
   "zh": "父亲……！"
  },
  {
   "off": "0x2D88",
   "zh": "唔！？"
  },
  {
   "off": "0x2DAC",
   "zh": "这是……"
  },
  {
   "off": "0x2DB4",
   "zh": "创世纪、竟然和雅金的自爆程序联动着……！？"
  },
  {
   "off": "0x2DD0",
   "zh": "明明就算做这种事、也什么都换不回来……！！"
  },
  {
   "off": "0x2E05",
   "zh": "……解除密码"
  },
  {
   "off": "0x2E41",
   "zh": "自爆程序、启动……"
  },
  {
   "off": "0x2E86",
   "zh": "这样只要能摧毁动力部……"
  },
  {
   "off": "0x2EEB",
   "zh": "……那可就让人困扰了"
  },
  {
   "off": "0x2F16",
   "zh": "……！？"
  },
  {
   "off": "0x2F35",
   "zh": "还能动的机体、立刻突入雅金·杜维！！"
  },
  {
   "off": "0x2F4C",
   "zh": "无论如何都要阻止创世纪发射！！"
  },
  {
   "off": "0x2F88",
   "zh": "……阿斯兰！？"
  },
  {
   "off": "0x2FAC",
   "zh": "唔……小、小心点……"
  },
  {
   "off": "0x2FD9",
   "zh": "怎么了、阿斯兰·萨拉！？里面到底发生了什么！"
  },
  {
   "off": "0x3018",
   "zh": "那架MS是……！！"
  },
  {
   "off": "0x3056",
   "zh": "……真让人困扰、创世纪岂容你擅自破坏"
  },
  {
   "off": "0x3081",
   "zh": "可恶……你这家伙！！"
  },
  {
   "off": "0x30B3",
   "zh": "……既然说了也不明白、那就没办法了"
  },
  {
   "off": "0x30F2",
   "zh": "唔……！！"
  },
  {
   "off": "0x3127",
   "zh": "阿斯兰！！"
  },
  {
   "off": "0x3161",
   "zh": "……！！"
  },
  {
   "off": "0x318E",
   "zh": "……特里埃尔！？"
  },
  {
   "off": "0x31BD",
   "zh": "……！！"
  },
  {
   "off": "0x31EA",
   "zh": "怎么回事？又来了！？"
  },
  {
   "off": "0x3222",
   "zh": "这到底是……！？"
  },
  {
   "off": "0x3255",
   "zh": "你是要妨碍我们吗？区区一个试作品、也想拦我们"
  },
  {
   "off": "0x3293",
   "zh": "『我不会让你们杀害奥古的伙伴』"
  },
  {
   "off": "0x32CD",
   "zh": "……！？"
  },
  {
   "off": "0x32EE",
   "zh": "……没用的、你终究只是台原型机"
  },
  {
   "off": "0x32FF",
   "zh": "绝不是被赋予全部机能的百夫长的对手"
  },
  {
   "off": "0x3341",
   "zh": "特里埃尔！？"
  },
  {
   "off": "0x336F",
   "zh": "我就赐予你……一项新的使命"
  },
  {
   "off": "0x3385",
   "zh": "你虽是旧型、毕竟也是军团的一员"
  },
  {
   "off": "0x33BE",
   "zh": "…………！！"
  },
  {
   "off": "0x33FA",
   "zh": "你这家伙！！放开她！"
  },
  {
   "off": "0x342F",
   "zh": "…………"
  },
  {
   "off": "0x3438",
   "zh": "要反抗吗？……连你们也要？"
  },
  {
   "off": "0x3472",
   "zh": "……什么！？"
  },
  {
   "off": "0x349C",
   "zh": "这、这到底……有多少架啊！？"
  },
  {
   "off": "0x34E4",
   "zh": "……不"
  },
  {
   "off": "0x351D",
   "zh": "……军团全体、即为一体"
  },
  {
   "off": "0x355E",
   "zh": "……全员共享同一个自我、"
  },
  {
   "off": "0x35A3",
   "zh": "……同一个个体"
  },
  {
   "off": "0x35DF",
   "zh": "……那就是军团"
  },
  {
   "off": "0x35EB",
   "zh": "为行恶而被造出的军团……"
  },
  {
   "off": "0x3625",
   "zh": "……你们就暂且退下吧"
  },
  {
   "off": "0x3636",
   "zh": "创世纪对你们而言、是无用之物"
  },
  {
   "off": "0x3648",
   "zh": "只要乖乖退下、便不取你们性命"
  },
  {
   "off": "0x3692",
   "zh": "你们夺取创世纪、到底想干什么！"
  },
  {
   "off": "0x36CC",
   "zh": "……这是一块基石"
  },
  {
   "off": "0x3708",
   "zh": "什么！？"
  },
  {
   "off": "0x3734",
   "zh": "它将成为即将到来的优良人种统治时、不可或缺的基石"
  },
  {
   "off": "0x3752",
   "zh": "……我说的、正是这座创世纪"
  },
  {
   "off": "0x3781",
   "zh": "唔！？"
  },
  {
   "off": "0x3787",
   "zh": "你说……优良人种？"
  },
  {
   "off": "0x37B8",
   "zh": "……那么、你们的答复呢？"
  },
  {
   "off": "0x37E9",
   "zh": "唔……！！"
  },
  {
   "off": "0x37FC",
   "zh": "全员、从创世纪撤退！！"
  },
  {
   "off": "0x3827",
   "zh": "布莱特舰长！？"
  },
  {
   "off": "0x3851",
   "zh": "特里埃尔呢！？要丢下她逃走吗！？"
  },
  {
   "off": "0x388D",
   "zh": "现在……只有这个办法了！"
  },
  {
   "off": "0x389D",
   "zh": "凭这些战力打下去毫无胜算、先撤退重整旗鼓！"
  },
  {
   "off": "0x38BC",
   "zh": "全员、立刻撤退！！"
  },
  {
   "off": "0x38F1",
   "zh": "……明智的判断"
  },
  {
   "off": "0x1D27",
   "zh": "可恶、还没完！！"
  },
  {
   "off": "0x1D58",
   "zh": "我玛修曼·塞罗……哪怕血肉剥落见骨、也要战斗到底！"
  },
  {
   "off": "0x1D7A",
   "zh": "不消灭哈曼大人的敌人、决不罢休！"
  },
  {
   "off": "0x1DB3",
   "zh": "那、那家伙……！"
  },
  {
   "off": "0x1DE9",
   "zh": "何等惊人的压迫感！"
  },
  {
   "off": "0x1E4D",
   "zh": "哈曼大人！万岁！！！"
  },
  {
   "off": "0x1E8F",
   "zh": "一心信奉哈曼·卡恩、到头来竟是那般下场吗……"
  },
  {
   "off": "0x1EAC",
   "zh": "世事无常……"
  },
  {
   "off": "0x1ED9",
   "zh": "你们把老娘当成谁了……"
  },
  {
   "off": "0x1F18",
   "zh": "老娘可是！"
  },
  {
   "off": "0x1F29",
   "zh": "凯拉·辛……！！"
  },
  {
   "off": "0x1F66",
   "zh": "…………"
  },
  {
   "off": "0x1F6F",
   "zh": "一个个都急着去送死……！可恶！！"
  },
  {
   "off": "0x1FAA",
   "zh": "唔……！"
  },
  {
   "off": "0x1FCD",
   "zh": "你的立足之地已经崩塌！一切都结束了、哈曼！"
  },
  {
   "off": "0x2000",
   "zh": "自作聪明的话……也轮得到一个少年来说吗！"
  },
  {
   "off": "0x203C",
   "zh": "哈曼！？"
  },
  {
   "off": "0xB68A",
   "zh": "人类岂能像你所展现的那样、全都成为新人类！"
  },
  {
   "off": "0xB6B5",
   "zh": "在那之前、人类就会先把地球啃食殆尽！"
  },
  {
   "off": "0xB6FA",
   "zh": "你就那么信不过人吗！！"
  },
  {
   "off": "0xB73E",
   "zh": "憎恨、只会催生出新的憎恨……"
  },
  {
   "off": "0xB770",
   "zh": "……给我明白啊！！"
  },
  {
   "off": "0xB7AA",
   "zh": "我没有什么……可倾吐的！！"
  },
  {
   "off": "0xB7EE",
   "zh": "…………"
  },
  {
   "off": "0xB801",
   "zh": "就因为你只被现有的这副肉体束缚住……！！"
  },
  {
   "off": "0xB84A",
   "zh": "正因为有肉体……"
  },
  {
   "off": "0xB886",
   "zh": "……才做得到啊！！"
  },
  {
   "off": "0xB8C2",
   "zh": "糟了！？"
  },
  {
   "off": "0xB8FA",
   "zh": "呵呵……"
  },
  {
   "off": "0xB90B",
   "zh": "……同归于尽吗"
  },
  {
   "off": "0xB91E",
   "zh": "本想这么说、可是……"
  },
  {
   "off": "0xB95E",
   "zh": "……是我输了啊"
  },
  {
   "off": "0xDAC9",
   "zh": "哈曼！！为什么、你不用浮游炮！"
  },
  {
   "off": "0xDB07",
   "zh": "至少这最后一战……堂堂正正地打一场也好、不是吗？"
  },
  {
   "off": "0xDB4B",
