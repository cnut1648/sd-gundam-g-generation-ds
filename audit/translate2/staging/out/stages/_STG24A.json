  {
   "off": "0x92AC",
   "zh": "『Z高达会将大家的意念化为力量……』"
  },
  {
   "off": "0x2104",
   "zh": "『卡缪·维丹……你的那份心意、是对的』"
  },
  {
   "off": "0x214C",
