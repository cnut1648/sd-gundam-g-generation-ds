 "title_zh": "通往未来的路标",
 "briefing": [
  {
   "off": "0x19CDD1",
   "zh": "目前、我军已突破敌人的防卫线、正在接近创世纪！"
  },
  {
   "off": "0x19CDED",
   "zh": "所幸至今尚未遭到敌人阻挠、但基连必定会做最后的抵抗"
  },
  {
   "off": "0x19CE13",
   "zh": "恐怕、这将是一场比以往更加激烈的恶战"
  },
  {
   "off": "0x19CE31",
   "zh": "事已至此、接下来就全靠诸君的奋战了"
  },
  {
   "off": "0x19CE4E",
   "zh": "新吉翁与提坦斯均已倒下、扎夫特也已失去战力"
  },
  {
   "off": "0x19CE6A",
   "zh": "接下来只要打倒基连·扎比、应该就能终结这场战争"
  },
  {
   "off": "0x19CE8E",
   "zh": "拜托了、各位！！"
  }
 ],
 "blocks": [
  {
   "off": "0x1737",
   "zh": "…………"
  },
  {
   "off": "0x1765",
   "zh": "果然早已在此严阵以待"
  },
  {
   "off": "0x1795",
   "zh": "但只要打倒那些家伙、任凭基连再强也无路可退了！"
