  {
   "off": "0x916E",
   "zh": "『……所以我……』"
  },
  {
   "off": "0x1FB0",
   "zh": "肃清人类……？休要狂妄！基连·扎比！！"
  },
  {
   "off": "0x1FCB",
   "zh": "牺牲宇宙市民性命换来的未来、休想让我认同！！"
