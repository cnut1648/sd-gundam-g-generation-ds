  {
   "off": "0x803C",
   "zh": "真的变得和来自异星的怪物、没有两样了吗！？"
  },
  {
   "off": "0x805E",
   "zh": "难道说、你已不再是贝尔纳黛特的父亲了吗！？"
  },
  {
   "off": "0x8090",
   "zh": "够了、吵死了、小鬼！！"
  },
  {
   "off": "0x809F",
   "zh": "休想妨碍老夫啊啊！！"
  },
  {
   "off": "0x80D6",
   "zh": "德卡契……！"
  },
  {
   "off": "0x1EDB",
   "zh": "不要慌！敌人的本体只有一台！！"
  },
  {
   "off": "0x1EF1",
   "zh": "只要盯住德卡契总统乘坐的那台迪比尼达多就行！"
  },
  {
   "off": "0x85CA",
   "zh": "哈哈哈！哇哈哈哈哈哈哈！！"
  },
  {
   "off": "0x85DB",
   "zh": "还没完！还不止这种程度啊！！"
  },
  {
   "off": "0x8616",
   "zh": "什么真正的人类未来！？什么地球无用论！？"
