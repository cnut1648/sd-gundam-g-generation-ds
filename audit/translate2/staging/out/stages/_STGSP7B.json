  {
   "off": "0x7F2E",
   "zh": "呵呵……哈哈哈哈哈！！"
  },
  {
   "off": "0x7F3B",
   "zh": "到了最后的最后、碍眼的果然还是你啊、小鬼！！"
  },
  {
   "off": "0x7F7E",
   "zh": "格拉克斯德卡契！！"
  },
  {
   "off": "0x7FA9",
   "zh": "那家伙就是本体吗！！"
  },
  {
   "off": "0x7FD9",
   "zh": "碍眼的联邦……碍眼的海盗……！！"
  },
  {
   "off": "0x7FED",
   "zh": "还有碍眼的臭小鬼啊啊！！"
  },
  {
   "off": "0x8016",
   "zh": "格拉克斯德卡契……"
  },
  {
   "off": "0x8020",
   "zh": "你已经、真的不再是人类了吗？"
