  {
   "off": "0x7B06",
   "zh": "你的对手是我！扎比涅！！"
  },
  {
   "off": "0x7B34",
   "zh": "金凯度！！"
  },
  {
   "off": "0x7B5C",
   "zh": "让你久等了……贝拉"
  },
  {
   "off": "0x7B8E",
   "zh": "金、金凯度……是你！？"
  },
  {
   "off": "0x1AB2",
   "zh": "……玛琉舰长！那家伙就交给我来对付！！"
  },
  {
   "off": "0x1ACC",
   "zh": "这期间、大家去解决德卡契！！"
