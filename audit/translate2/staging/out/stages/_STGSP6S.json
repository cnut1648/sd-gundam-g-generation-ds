 "title_zh": "燃烧的宇宙",
 "briefing": [
  {
   "off": "0x1A123C",
   "zh": "与贝拉·罗纳的先锋母舰会合之后、我们……"
  },
  {
   "off": "0x1A1252",
   "zh": "为阻止木星帝国进一步兴风作浪、正设法与正规部队会合"
  },
  {
   "off": "0x1A1276",
   "zh": "单凭我们、要对付强大的木星军绝非易事……"
  },
  {
   "off": "0x1A1296",
   "zh": "但只要正规军行动起来、便有可能赶在木星帝国发难之前将其解决"
  },
  {
   "off": "0x1A12B9",
   "zh": "总之现在的当务之急、是尽快与友军会合"
  }
 ],
 "blocks": [
  {
   "off": "0x17B9",
   "zh": "嗯？怎么了？"
  },
  {
   "off": "0x17DE",
   "zh": "军司令部发来了通信"
  },
  {
   "off": "0x17E9",
   "zh": "说是要我们与地球轨道舰队会合"
  },
  {
   "off": "0x181C",
   "zh": "军方这么快就行动了吗"
  },
  {
   "off": "0x1829",
   "zh": "好、航向地球！！与轨道舰队会合！"
  },
  {
   "off": "0x1859",
   "zh": "这里是主天使号队、娜塔尔中佐"
  },
  {
   "off": "0x1889",
   "zh": "我是地球轨道舰队司令"
  },
  {
   "off": "0x1895",
   "zh": "追讨海盗辛苦了、娜塔尔中佐"
  },
  {
   "off": "0x18CE",
   "zh": "那艘就是你们捕获的海盗旗舰吗？"
  },
  {
   "off": "0x18E4",
   "zh": "事不宜迟、把他们移交过来吧"
  },
  {
   "off": "0x1911",
   "zh": "……啊？"
  },
  {
   "off": "0x1918",
   "zh": "请、请等一下！您是不是有什么误会！？"
  },
  {
   "off": "0x1935",
   "zh": "他们是我们的协力者……"
  },
  {
   "off": "0x1969",
   "zh": "……恐怕并非如此啊"
  },
  {
   "off": "0x1999",
   "zh": "那些人、是海盗先锋军"
  },
  {
   "off": "0x19AA",
   "zh": "是长期以来袭击我们木星公社运输船团的海盗"
  },
  {
   "off": "0x19ED",
   "zh": "……是木星帝国！？"
  },
  {
   "off": "0x1A19",
   "zh": "贝拉小姐……！"
  },
  {
   "off": "0x1A48",
   "zh": "……司令阁下！！"
  },
  {
   "off": "0x1A6C",
   "zh": "你们主天使号队应政府之请前去讨伐海盗、并成功将其捕获"
  },
  {
   "off": "0x1A8D",
   "zh": "……事情就是如此吧？娜塔尔中佐"
  },
  {
   "off": "0x1AA1",
   "zh": "否则、就只能将你们视作海盗的同伙一并击毁"
  },
  {
   "off": "0x1AD6",
   "zh": "您、您是说比起我们、更信任木星的人！？"
  },
  {
   "off": "0x1B07",
   "zh": "……那是当然！"
  },
  {
   "off": "0x1B12",
   "zh": "海盗先锋军可是同联邦交过战的！！"
  },
  {
   "off": "0x1B2E",
   "zh": "和一直与联邦保持合作关系的木星公社相比、可信度天差地别！"
  },
  {
   "off": "0x1B55",
   "zh": "来吧、娜塔尔中佐！把海盗们交出来！！"
  },
  {
   "off": "0x1B93",
   "zh": "唔……！"
  },
  {
   "off": "0x1BB5",
   "zh": "娜塔尔中佐！！"
  },
  {
   "off": "0x1BE3",
   "zh": "……这道命令、恕难遵从！"
  },
  {
   "off": "0x1C11",
   "zh": "什么、你这家伙！？"
  },
  {
   "off": "0x1C41",
   "zh": "……娜塔尔舰长！"
  },
  {
   "off": "0x1C6C",
   "zh": "放心、我们绝不会把你们交出去"
  },
  {
   "off": "0x1CA8",
   "zh": "这是什么意思、中佐！？"
  },
  {
   "off": "0x1CDD",
   "zh": "我以前、曾从某个人那里学到过"
  },
  {
   "off": "0x1CF2",
   "zh": "在以军人身份行动之前、首先应当作为一个人、做出正确的行为！"
  },
  {
   "off": "0x1D38",
   "zh": "这里由我来拦住！！快走、贝拉·罗纳！"
  },
  {
   "off": "0x1D6A",
   "zh": "好、好的！！"
  },
  {
   "off": "0x1D98",
   "zh": "海盗们、休想逃！！"
  },
  {
   "off": "0x1DC0",
   "zh": "有埋伏……！？"
  },
  {
   "off": "0x1DF1",
   "zh": "可恶！"
  },
  {
   "off": "0x1E1D",
   "zh": "不行、托比亚！！"
  },
  {
   "off": "0x1E28",
   "zh": "我们不能与联邦军作战！"
  },
  {
   "off": "0x1E5B",
   "zh": "可、可是、贝拉小姐！再这样下去……"
  },
  {
   "off": "0x1EA1",
   "zh": "……呵呵、是啊、托比亚"
  },
  {
   "off": "0x1F0B",
   "zh": "那可就伤脑筋了……得请你们打上一场才行啊！"
  },
  {
   "off": "0x1F45",
   "zh": "扎比涅！？"
  },
  {
   "off": "0x1F71",
   "zh": "呵、呵呵呵……"
  },
  {
   "off": "0x1FA0",
   "zh": "可恶、这群海盗！！"
  },
  {
   "off": "0x1FD3",
   "zh": "司令！！"
  },
  {
   "off": "0x1FF6",
   "zh": "你们都给我待在原地别动！敢动、就把你们也视作海盗一伙！"
  },
  {
   "off": "0x2033",
   "zh": "事到如今还说这种话……！"
  },
  {
   "off": "0x2065",
   "zh": "娜塔尔中佐、你这家伙！？"
  },
  {
   "off": "0x208C",
   "zh": "贵官并不了解木星帝国的危险、这样的劝告我无法服从"
  },
  {
   "off": "0x20AB",
   "zh": "我们主天使号队、将支援先锋母舰！"
  },
  {
   "off": "0x20CA",
   "zh": "各舰立刻进入战斗状态！支援贝拉舰长、突破包围！！"
  },
  {
   "off": "0x70AA",
   "zh": "唔……！竟然在这种地方……！！"
  },
  {
   "off": "0x732E",
   "zh": "想必是地球轨道舰队的诸位吧？"
  },
  {
   "off": "0x7340",
   "zh": "我们奉德卡契阁下之命、前来增援贵队！！"
  },
  {
   "off": "0x737D",
   "zh": "哦哦、是木星的诸位！！感谢相助！"
  },
  {
   "off": "0x73D7",
   "zh": "（呵呵……扎比涅·夏尔……干得漂亮）"
  },
  {
   "off": "0x73EF",
   "zh": "（这样一来、派军进入地球圈就更加容易了……）"
  },
  {
   "off": "0x7414",
   "zh": "好！MS部队、出击！！"
  },
  {
   "off": "0x7423",
   "zh": "协同联邦军、击破海盗们！！"
  },
  {
   "off": "0x7462",
   "zh": "……！？"
  },
  {
   "off": "0x7471",
   "zh": "难道是……贝尔纳黛特！？"
  },
  {
   "off": "0x7499",
   "zh": "托比亚……！！"
  },
  {
   "off": "0x74BD",
   "zh": "果然是你、贝尔纳黛特！！"
  },
  {
   "off": "0x74C9",
   "zh": "为什么你会在这里……！？"
  },
  {
   "off": "0x74EF",
   "zh": "不行、托比亚！快逃！！"
  },
  {
   "off": "0x751A",
   "zh": "贝尔纳黛特！？"
  },
  {
   "off": "0x753E",
   "zh": "不行的！"
  },
  {
   "off": "0x7546",
   "zh": "这台机体不是由我、而是由电脑在操纵……！"
  },
  {
   "off": "0x755F",
   "zh": "我根本停不下它！所以、快逃吧、托比亚！！"
  },
  {
   "off": "0x7594",
   "zh": "可恶！德卡契！！竟对自己的女儿做出这种事！"
  },
  {
   "off": "0x75C9",
   "zh": "托比亚……！"
  },
  {
   "off": "0x75EC",
   "zh": "没事的、贝尔纳黛特！！我马上……"
  },
  {
   "off": "0x7603",
   "zh": "马上就把你从那里救出来！！"
  },
  {
   "off": "0x763A",
   "zh": "怎么回事……！？那台MA……"
  },
  {
   "off": "0x764D",
   "zh": "不是贝尔纳黛特、我感觉到的是另一股气息！！"
  },
  {
   "off": "0x7666",
   "zh": "是谁！是谁在那里面！？"
  },
  {
   "off": "0x76AB",
   "zh": "呵、哈哈哈哈哈！亏你能察觉、小鬼！！"
  },
  {
   "off": "0x76E9",
   "zh": "这个声音！？父亲大人！？"
  },
  {
   "off": "0x771B",
   "zh": "格拉克斯德卡契……！！"
  },
  {
   "off": "0x7759",
   "zh": "……正是如此、小鬼"
  },
  {
   "off": "0x7766",
   "zh": "操纵这台机体的、正是格拉克斯德卡契……"
  },
  {
   "off": "0x777E",
   "zh": "一颗转写了其思考模式的生体脑"
  },
  {
   "off": "0x7792",
   "zh": "不过、就算知道了又能如何、小鬼？"
  },
  {
   "off": "0x77D1",
   "zh": "……什么！？"
  },
  {
   "off": "0x780D",
   "zh": "你想救的那姑娘、就握在我的手心里"
  },
  {
   "off": "0x7826",
   "zh": "你还攻击得了吗！？"
  },
  {
   "off": "0x7857",
   "zh": "那可是你的亲生女儿啊！！"
  },
  {
   "off": "0x7869",
   "zh": "这是人说得出口的话吗！你这混蛋——！！"
  },
  {
   "off": "0x78B3",
   "zh": "哈哈哈哈、真是笑死人了！"
  },
  {
   "off": "0x78C2",
   "zh": "战斗没有干净肮脏之分！这就是战争啊！"
  },
  {
   "off": "0x7905",
   "zh": "德卡契……！！"
  },
  {
   "off": "0x7936",
   "zh": "你说这是战争……！？"
  },
  {
   "off": "0x794B",
   "zh": "格拉克斯德卡契！不管你怎么想……"
  },
  {
   "off": "0x796D",
   "zh": "我这边、可从没打算进行什么战争！！"
  },
  {
   "off": "0x7986",
   "zh": "我要把贝尔纳黛特带回去！"
  },
  {
   "off": "0x7DDA",
   "zh": "……娜塔尔舰长！"
  },
  {
   "off": "0x7DFF",
   "zh": "嗯、明白了！"
  },
  {
   "off": "0x7E0A",
   "zh": "各机、冲向那台MA！"
  },
  {
   "off": "0x7E1B",
   "zh": "拦住它的脚步、救出被囚在机体内部的少女！"
  },
  {
   "off": "0x7E5A",
   "zh": "就是现在！……快去救贝尔纳黛特！！"
  },
  {
   "off": "0x7E8E",
   "zh": "贝尔纳黛特……我这就过去！！"
  },
  {
   "off": "0x7B26",
   "zh": "托比亚！！"
  },
  {
   "off": "0x7B52",
   "zh": "已经没事了、贝尔纳黛特……"
  },
  {
   "off": "0x7B87",
   "zh": "嗯！……嗯！！"
  },
  {
   "off": "0x79BE",
   "zh": "……就是现在！！"
  },
  {
   "off": "0x79EA",
   "zh": "我要把贝尔纳黛特夺回来！！"
  },
  {
   "off": "0x7A2E",
   "zh": "唔！臭小鬼！！"
  },
  {
   "off": "0x7A6A",
   "zh": "她可不是你的东西！"
  },
  {
   "off": "0x7AAA",
   "zh": "那我就像海盗一样……"
  },
  {
   "off": "0x7AEA",
   "zh": "把她给夺走了！！"
  },
  {
   "off": "0x2111",
   "zh": "好！就趁现在！全舰、立即后退！！"
  },
  {
   "off": "0x2151",
   "zh": "看来、木星帝国已经让相当数量的部队、混进了地球圈啊"
  },
  {
   "off": "0x2176",
   "zh": "他们打着协助讨伐海盗的名义、向各地派遣部队"
  },
  {
   "off": "0x21AF",
   "zh": "对不起、都是因为我们……"
  },
  {
   "off": "0x21DC",
   "zh": "不、这不是你们的错、是被木星帝国利用了"
  },
  {
   "off": "0x2214",
   "zh": "木星帝国那帮家伙、现在可是大摇大摆地在地球圈里横行"
  },
  {
   "off": "0x2235",
   "zh": "他们动手的日子、也不远了呢"
  },
  {
   "off": "0x226C",
   "zh": "地球联邦还没有察觉到木星帝国的恶意"
  },
  {
   "off": "0x2287",
   "zh": "如果木星帝国就这样发动攻击……"
  },
  {
   "off": "0x22BD",
   "zh": "联邦军只怕会不堪一击"
  },
  {
   "off": "0x22F3",
   "zh": "…………"
  },
  {
   "off": "0x22FC",
   "zh": "……父亲他"
  },
  {
   "off": "0x2304",
   "zh": "父亲曾说过、地球什么的、根本不需要"
  },
  {
   "off": "0x2339",
   "zh": "你是说……木星帝国连地球本身、都会列为攻击目标吗？"
  },
  {
   "off": "0x2375",
   "zh": "虽然不知道理由、但父亲……一直憎恨着地球"
  },
  {
   "off": "0x2395",
   "zh": "虽然我不愿相信、父亲会做出那种事……"
  },
  {
   "off": "0x23CA",
   "zh": "若战火再次降临到无辜的人们头上……"
  },
  {
   "off": "0x23ED",
   "zh": "那必将像过去的战乱一样、再度酿成许多悲剧"
  },
  {
   "off": "0x240D",
   "zh": "唯有这一点、我们必须阻止"
  },
  {
   "off": "0x2440",
   "zh": "只能去阻止了……用我们自己的手"
  },
  {
   "off": "0x2477",
   "zh": "把各位都卷了进来、实在过意不去……"
  },
  {
   "off": "0x24B1",
   "zh": "无妨、我们不过是去做自己认定该做的事"
  },
  {
   "off": "0x24F0",
   "zh": "胜算嘛……不算高、但也只能干了"
  },
  {
   "off": "0x252C",
   "zh": "不、如果木星帝国的目标是地球、我们就有胜算"
  },
  {
   "off": "0x2563",
   "zh": "托比亚·阿罗纳克斯？"
  },
  {
   "off": "0x2587",
   "zh": "如果说德卡契憎恨着地球……"
  },
  {
   "off": "0x259E",
   "zh": "那个男人一定会想亲手给地球一击"
  },
  {
   "off": "0x25BE",
   "zh": "只要抓住这一点……！"
  },
  {
   "off": "0x25E5",
   "zh": "木星帝国、是由格拉克斯德卡契严密统治的国家……"
  },
  {
   "off": "0x261E",
   "zh": "只要打倒德卡契、帝国就完了！"
  },
  {
   "off": "0x264B",
   "zh": "……动手吧、娜塔尔舰长！为了不再酿成更多的悲剧！"
  },
  {
   "off": "0x268D",
   "zh": "当然、我正有此意！"
  },
  {
   "off": "0x26BE",
   "zh": "各舰立即着手出击准备！"
  },
  {
   "off": "0x26D1",
   "zh": "现在起、我们将向木星帝国军发起决战！！"
  },
  {
   "off": "0x7BBA",
   "zh": "…………"
  },
  {
   "off": "0x7BDE",
   "zh": "托比亚……"
  },
  {
   "off": "0x7C00",
   "zh": "怎么了、贝尔纳黛特？睡不着吗？"
  },
  {
   "off": "0x7C32",
   "zh": "只是稍微、想了点事情……"
  },
  {
   "off": "0x7C41",
   "zh": "…………"
  },
  {
   "off": "0x7C65",
   "zh": "……贝尔纳黛特？"
  },
  {
   "off": "0x7C8A",
   "zh": "爸爸他……"
  },
  {
   "off": "0x7C92",
   "zh": "……我总觉得、爸爸他说不定早就已经死了"
  },
  {
   "off": "0x7CAF",
   "zh": "所以现在对木星军发号施令的、是爸爸的复制人偶！"
  },
  {
   "off": "0x7CCE",
   "zh": "不然的话、他才不会做出那么过分的事……！"
  },
  {
   "off": "0x7D01",
   "zh": "贝尔纳黛特……"
