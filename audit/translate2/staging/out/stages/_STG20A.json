 "title_zh": "生命凋零",
 "briefing": [
  {
   "off": "0x19C4AF",
   "zh": "目前、西罗克率领的提坦斯正向PLANT进军"
  },
  {
   "off": "0x19C4C7",
   "zh": "目标推测是扎夫特的巨型兵器创世纪"
  },
  {
   "off": "0x19C506",
   "zh": "扎夫特那边如何应对？"
  },
  {
   "off": "0x19C53D",
   "zh": "他们正向雅金·杜维集结战力"
  },
  {
   "off": "0x19C54E",
   "zh": "新吉翁的格雷米叛军似乎也摆出了响应之势"
  },
  {
   "off": "0x19C596",
   "zh": "扎夫特与格雷米军的联合、要和提坦斯全面对决吗"
  },
  {
   "off": "0x19C5D4",
   "zh": "必须赶在这演变成地球与宇宙的全面对决之前收拾事态"
  },
  {
   "off": "0x19C622",
   "zh": "两军混战的此刻、反倒可能是个机会"
  },
  {
   "off": "0x19C63F",
   "zh": "只要摧毁两军的指挥系统、双方都将失去续战能力"
  },
  {
   "off": "0x19C683",
   "zh": "这么说来、我们的目标就是击破西罗克与格雷米……"
  },
  {
   "off": "0x19C6C6",
   "zh": "西罗克旗下有强化人部队、格雷米身边也有NT部队"
  },
  {
   "off": "0x19C6E7",
   "zh": "虽然困难重重、但也不得不做"
  },
  {
   "off": "0x19C6FF",
   "zh": "也是为了尽早结束这场战斗"
  }
 ],
 "blocks": [
  {
   "off": "0x1822",
   "zh": "怎么可能！！你说提坦斯打过来了！？"
  },
  {
   "off": "0x1835",
   "zh": "战力处于劣势的联邦军、怎么可能办得到这种事……！"
  },
  {
   "off": "0x186B",
   "zh": "难道说、那帮家伙把中子干扰消除器给……"
  },
  {
   "off": "0x189E",
   "zh": "那更不可能！我们的情报管控应当万无一失！！"
  },
  {
   "off": "0x18D6",
   "zh": "可是提坦斯现在确实……"
  },
  {
   "off": "0x18FD",
   "zh": "可恶……！"
  },
  {
   "off": "0x1905",
   "zh": "向阿克西斯的格雷米·托托请求增援！！"
  },
  {
   "off": "0x191B",
   "zh": "趁他们拖住敌人的工夫、进行创世纪的第二次发射！"
  },
  {
   "off": "0x194C",
   "zh": "核导弹第一波已命中！敌前卫部队似已被清除！！"
  },
  {
   "off": "0x1986",
   "zh": "哎呀……真是了不起啊、这中子干扰消除器"
  },
  {
   "off": "0x199E",
   "zh": "从前不可侵犯的PLANT宙域、如今简直就是座玻璃之城"
  },
  {
   "off": "0x19D8",
   "zh": "好！立刻准备第二波齐射！！"
  },
  {
   "off": "0x1A11",
   "zh": "可恶！居然动用核武、这帮自然人！"
  },
  {
   "off": "0x1A4A",
   "zh": "……真是难看啊"
  },
  {
   "off": "0x1A56",
   "zh": "对技术优势的自满、换来的就是这副惨状吗"
  },
  {
   "off": "0x1A9A",
   "zh": "格、格雷米大人！？"
  },
  {
   "off": "0x1AC0",
   "zh": "放心吧、我们新吉翁的战备万事俱全"
  },
  {
   "off": "0x1ADB",
   "zh": "只要有我新吉翁之力、区区提坦斯……"
  },
  {
   "off": "0x1B10",
   "zh": "『不可以！！』"
  },
  {
   "off": "0x1B37",
   "zh": "唔、什么人！？"
  },
  {
   "off": "0x1B7B",
   "zh": "哦……"
  },
  {
   "off": "0x1BA7",
   "zh": "若那光之刃刺向无辜的人们……"
  },
  {
   "off": "0x1BC4",
   "zh": "必将再度唤来无尽的泪水与憎恨！"
  },
  {
   "off": "0x1BE1",
   "zh": "我要向在这片宙域作战的所有人宣告！！"
  },
  {
   "off": "0x1BFF",
   "zh": "这场战斗毫无意义！请立刻停止战斗！"
  },
  {
   "off": "0x1C40",
   "zh": "…………"
  },
  {
   "off": "0x1C49",
   "zh": "前PLANT议长西格尔之女、PLANT的歌姬拉克丝·克莱因……吗"
  },
  {
   "off": "0x1C83",
   "zh": "帕普提马斯·西罗克……！"
  },
  {
   "off": "0x1CA9",
   "zh": "我承认你的行动力、但你见识之浅薄实在无可救药"
  },
  {
   "off": "0x1CCA",
   "zh": "说到底、自称优等人类、率先挑起战争的正是扎夫特一方"
  },
  {
   "off": "0x1CED",
   "zh": "你是要我宽恕这种行径？"
  },
  {
   "off": "0x1CFB",
   "zh": "那样一来、只会再度纵容扎比家之流跳梁跋扈"
  },
  {
   "off": "0x1D47",
   "zh": "……可笑！愚蠢的是你、西罗克！！"
  },
  {
   "off": "0x1D5D",
   "zh": "人类唯有由优秀的血统来管理、才能在未来存续下去！"
  },
  {
   "off": "0x1D86",
   "zh": "与地球的俗物们联手、玩弄战争的你又懂得什么！"
  },
  {
   "off": "0x1DDC",
   "zh": "哼、执着于血统……不过是对自己缺乏自信者的借口罢了"
  },
  {
   "off": "0x1E27",
   "zh": "看来我与你终究势不两立、帕普提马斯·西罗克！"
  },
  {
   "off": "0x1E43",
   "zh": "全军、开始战斗！！"
  },
  {
   "off": "0x1E52",
   "zh": "把死抱着腐朽地球不放的提坦斯一扫而空！"
  },
  {
   "off": "0x1E96",
   "zh": "搬出扎比家这种过去遗物的男人、事到如今还想……"
  },
  {
   "off": "0x1EC1",
   "zh": "我方也要应战！展开MS部队！"
  },
  {
   "off": "0x1EF2",
   "zh": "……西罗克总裁！？"
  },
  {
   "off": "0x1F18",
   "zh": "对手不过是格雷米·托托之流、我方常规战力便已足够！"
  },
  {
   "off": "0x1F59",
   "zh": "……算了、也好"
  },
  {
   "off": "0x1F66",
   "zh": "不过作为交换……我很期待哦、西罗克总裁"
  },
  {
   "off": "0x1FA1",
   "zh": "…………"
  },
  {
   "off": "0x1FAA",
   "zh": "我们……或许还是来迟了一步"
  },
  {
   "off": "0x1FC2",
   "zh": "但是……"
  },
  {
   "off": "0x1FEE",
   "zh": "基拉·大和！自由、出击！"
  },
  {
   "off": "0x2025",
   "zh": "阿斯兰·萨拉！正义、出击！"
  },
  {
   "off": "0x205A",
   "zh": "口中歌颂着和平、手中却握起枪炮……"
  },
  {
   "off": "0x2072",
   "zh": "这或许同样是一种罪恶的选择……"
  },
  {
   "off": "0x208C",
   "zh": "可无论如何、这无尽的争斗连锁……"
  },
  {
   "off": "0x20A4",
   "zh": "……请赐予斩断它的力量！"
  },
  {
   "off": "0x20D4",
   "zh": "……阿斯兰！"
  },
  {
   "off": "0x20FD",
   "zh": "嗯、我明白！"
  },
  {
   "off": "0x2109",
   "zh": "切入两军之间、让更多的MS失去行动能力……"
  },
  {
   "off": "0x212B",
   "zh": "上吧、基拉！！"
  },
  {
   "off": "0x100FE",
   "zh": "……不好！这艘舰要是被击毁的话……！"
  },
  {
   "off": "0x215B",
   "zh": "凭我们真的无法做到吗……无法斩断这争斗的连锁……"
  },
  {
   "off": "0x3EFA",
   "zh": "唔……！"
  },
  {
   "off": "0x3F02",
   "zh": "区、区区如此、背负血之宿命的我竟……"
  },
  {
   "off": "0x3F40",
   "zh": "……不"
  },
  {
   "off": "0x3F47",
   "zh": "已经结束了、格雷米"
  },
  {
   "off": "0x3F6A",
   "zh": "你说过喜欢我的……"
  },
  {
   "off": "0x3F84",
   "zh": "我不会忘记的、格雷米……"
  },
  {
   "off": "0x3FC0",
   "zh": "露·露卡、是你吗！？"
  },
  {
   "off": "0x3FD7",
   "zh": "我竟、败在你手里……？"
  },
  {
   "off": "0x4013",
   "zh": "怎、怎么会……！背负着血之宿命的我……"
  },
  {
   "off": "0x4037",
   "zh": "竟、在这种、地方……"
  },
  {
   "off": "0x404D",
   "zh": "为什么……！！"
  },
  {
   "off": "0x4087",
   "zh": "你到底是为了什么、才执着于血统的……"
  },
  {
   "off": "0x409E",
   "zh": "忘记了这一原点的你、注定只有失败一途"
  },
  {
   "off": "0x40BD",
   "zh": "……格雷米"
  },
  {
   "off": "0x40C6",
   "zh": "…………"
  },
  {
   "off": "0x3DD8",
   "zh": "……啊！？"
  },
  {
   "off": "0x3E07",
   "zh": "普、普露兹！？"
  },
  {
   "off": "0x3E1C",
   "zh": "怎、怎么会……！得到了普露兹之力的我竟然……"
  },
  {
   "off": "0x3E42",
   "zh": "背负着血之宿命的我……"
  },
  {
   "off": "0x3E5E",
   "zh": "竟、在这种、地方……！！"
  },
  {
   "off": "0x3E9C",
   "zh": "…………"
  },
  {
   "off": "0x3EA5",
   "zh": "可恶……！"
  },
  {
   "off": "0x3EAE",
   "zh": "难道说到头来、也只能落得这个结果吗……！"
  },
  {
   "off": "0x3ECB",
   "zh": "普露兹……！"
  },
  {
   "off": "0x2692",
   "zh": "唔……是爱玛中尉吗！！"
  },
  {
   "off": "0x26BB",
   "zh": "你太像个女人了！！"
  },
  {
   "off": "0x26EC",
   "zh": "没错、我就是女人！"
  },
  {
   "off": "0x26F8",
   "zh": "所以我才会在这里！成为了你的敌人！！"
  },
  {
   "off": "0x102DE",
   "zh": "蕾柯亚·朗德！！"
  },
  {
   "off": "0x1031A",
   "zh": "……！！"
  },
  {
   "off": "0x1032C",
   "zh": "人、人各有各的活法……！"
  },
  {
   "off": "0x1036E",
   "zh": "轮不到别人来干涉！！"
  },
  {
   "off": "0x103AA",
   "zh": "你……！？"
  },
  {
   "off": "0x103FC",
   "zh": "爱玛中尉、你要明白啊……"
  },
  {
   "off": "0x10415",
   "zh": "男人满脑子只有战争、只想把女人当成工具使唤……"
  },
  {
   "off": "0x1043F",
   "zh": "……要不然、就只会羞辱女人……！！"
  },
  {
   "off": "0x104AE",
   "zh": "你说被羞辱……蕾柯亚·朗德……！？"
  },
  {
   "off": "0x2733",
   "zh": "蕾柯亚、你这个人……"
  },
  {
   "off": "0x2793",
   "zh": "这是……蕾柯亚·朗德干的？"
  },
  {
   "off": "0x2763",
   "zh": "……爱玛中尉！？"
  },
  {
   "off": "0x27C8",
   "zh": "……爱玛中尉！！"
  },
  {
   "off": "0x27F8",
   "zh": "爱玛中尉！！"
  },
  {
   "off": "0x2801",
   "zh": "爱玛中尉！请振作一点！！"
  },
  {
   "off": "0x283E",
   "zh": "啊……卡缪？"
  },
  {
   "off": "0x2847",
   "zh": "我、都看到了……"
  },
  {
   "off": "0x2876",
   "zh": "已经够了！不要再说话了！！"
  },
  {
   "off": "0x28BC",
   "zh": "Z高达能将人的意志吸入、化为自己的力量……"
  },
  {
   "off": "0x28DD",
   "zh": "所以……这就要由你来做到……"
  },
  {
   "off": "0x2917",
   "zh": "爱、爱玛中尉……"
  },
  {
   "off": "0x294A",
   "zh": "吸取我的生命！然后、获胜吧！！"
  },
  {
   "off": "0x2962",
   "zh": "卡缪·维丹！"
  },
  {
   "off": "0x2990",
   "zh": "爱、爱玛中尉……！！"
  },
  {
   "off": "0x299D",
   "zh": "…………"
  },
  {
   "off": "0x29A6",
   "zh": "大家、都在死去……！"
  },
  {
   "off": "0x29B4",
   "zh": "这样的死法、难道就甘心吗！又有谁会高兴啊！"
  },
  {
   "off": "0x29D3",
   "zh": "呜啊啊啊啊！！"
  },
  {
   "off": "0x2BEB",
   "zh": "我、我……才没有……后悔……"
  },
  {
   "off": "0x2C09",
   "zh": "能作为一个女人……活过……"
  },
  {
   "off": "0x2C22",
   "zh": "便已知足……"
  },
  {
   "off": "0x2C5A",
   "zh": "蕾柯亚小姐……"
  },
  {
   "off": "0x2A04",
   "zh": "唔……好强！！"
  },
  {
   "off": "0x2A34",
   "zh": "不好！爱玛中尉！！"
  },
  {
   "off": "0x2A67",
   "zh": "爱玛中尉！趁现在赶快后退！！"
  },
  {
   "off": "0x2A9C",
   "zh": "汉肯舰长！？"
  },
  {
   "off": "0x2ACA",
   "zh": "啧、想用战舰给MS当盾牌吗！？"
  },
  {
   "off": "0x2B17",
   "zh": "区区一艘战舰……别小看人！！"
  },
  {
   "off": "0x2B59",
   "zh": "爱玛……中尉……"
  },
  {
   "off": "0x2B88",
   "zh": "汉肯舰长！？"
  },
  {
   "off": "0x2BB6",
   "zh": "汉肯舰长啊啊！！"
  },
  {
   "off": "0x2C88",
   "zh": "这、这下……西罗克总裁！！"
  },
  {
   "off": "0x2CBD",
   "zh": "难道是我们小看那帮家伙了吗！？可恶、多戈斯·基亚、后退！"
  },
  {
   "off": "0x2D0F",
   "zh": "请你们住手吧！！"
  },
  {
   "off": "0x2D1C",
   "zh": "曾经并肩作战的我们、为什么非得自相残杀不可！？"
  },
  {
   "off": "0x2D61",
   "zh": "这事儿根本就不是那么回事啊！"
  },
  {
   "off": "0x2D75",
   "zh": "我们是认定提坦斯没错、才开始打这场仗的！"
  },
  {
   "off": "0x2D92",
   "zh": "事到如今、哪能说撤就撤啊！！"
  },
  {
   "off": "0x2DC9",
   "zh": "说不能撤……到底为什么！？"
  },
  {
   "off": "0x2DFB",
   "zh": "我们有着身为职业军人的骄傲"
  },
  {
   "off": "0x2E13",
   "zh": "自己挑起的仗自己收手、那就跟临阵脱逃没两样……"
  },
  {
   "off": "0x2E32",
   "zh": "这种事绝对干不得！"
  },
  {
   "off": "0x2E6C",
   "zh": "可、可是……！！"
  },
  {
   "off": "0x2E98",
   "zh": "……话就说到这里"
  },
  {
   "off": "0x2EA6",
   "zh": "接下来、我们可就不留情面地放手打了"
  },
  {
   "off": "0x4726",
   "zh": "怎么可能！我、我竟然会……"
  },
  {
   "off": "0x4741",
   "zh": "栽在这帮家伙手里！？"
  },
  {
   "off": "0x107C6",
   "zh": "…………"
  },
  {
   "off": "0x107CF",
   "zh": "就是这种自私自利在毁掉地球……你们为什么就不明白啊"
  },
  {
   "off": "0x107F0",
   "zh": "……所以说、大人们真是！"
  },
  {
   "off": "0x477F",
   "zh": "亚、亚赞队长！！"
  },
  {
   "off": "0x10822",
   "zh": "不可能……拉姆萨斯！？"
  },
  {
   "off": "0x47BC",
   "zh": "呜哇啊啊！！"
  },
  {
   "off": "0x10856",
   "zh": "可恶、邓克尔！！"
  },
  {
   "off": "0x10861",
   "zh": "你们这帮家伙、竟敢！！"
  },
  {
   "off": "0x47F7",
   "zh": "可恶的阿伽玛！你们给我记住！！"
  },
  {
   "off": "0x3240",
   "zh": "我们未必正确、这一点自己也清楚得很……"
  },
  {
   "off": "0x3269",
   "zh": "可是啊……半途而废就更加免谈……"
