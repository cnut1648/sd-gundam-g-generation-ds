  {
   "off": "0x1056E",
   "zh": "你也走了吗……阿尔法"
  },
  {
   "off": "0x1057C",
   "zh": "…………"
  },
  {
   "off": "0x105AA",
   "zh": "混账！你死得也太窝囊了、阿尔法！"
  },
  {
   "off": "0x3313",
   "zh": "抱歉了、各位……"
  },
  {
   "off": "0x332B",
   "zh": "我就先走一步……"
  },
  {
   "off": "0x105EA",
   "zh": "…………"
  },
  {
   "off": "0x105F3",
   "zh": "你小子不会白死的、阿德尔"
  },
  {
   "off": "0x1062E",
   "zh": "可恶、阿德尔这家伙……这么急着去送死！！"
  },
  {
   "off": "0x2532",
   "zh": "哦……奥古出手了吗"
  },
  {
   "off": "0x2558",
   "zh": "他们似乎正与拉克丝·克莱因一道、着手收拾事态"
  },
  {
   "off": "0x258E",
   "zh": "格雷米这家伙、急功近利了啊"
