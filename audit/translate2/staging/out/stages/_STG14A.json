   "zh": "你就是我……去死啊啊啊！！"
  },
  {
   "off": "0x9752",
   "zh": "普露……！！"
  },
  {
   "off": "0x17DC",
   "zh": "……可恶！！"
  },
  {
   "off": "0x977E",
   "zh": "普露……为什么……"
