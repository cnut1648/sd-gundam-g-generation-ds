 "briefing": [
  {
   "off": "0x19B481",
   "zh": "……布莱特舰长"
  },
  {
   "off": "0x19B48A",
   "zh": "雷达捕捉到了一支正在向我们接近的部队"
  },
  {
   "off": "0x19B4CE",
   "zh": "卡拉巴那边有什么情报？"
  },
  {
   "off": "0x19B502",
   "zh": "有情报称、新吉翁军的一部分正与吉翁残党接触"
  },
  {
   "off": "0x19B54E",
   "zh": "这么说、这支部队是新吉翁和残党军的联军吗……"
  },
  {
   "off": "0x19B592",
   "zh": "既然受着新吉翁的支援、其战力便不容小觑"
  },
  {
   "off": "0x19B5D8",
   "zh": "看来、是避不开这一战了……"
  },
  {
   "off": "0x19B5EE",
   "zh": "好、托雷斯、发布一级警戒态势！"
  },
  {
   "off": "0x19B604",
   "zh": "敌人若是打过来、就迎头痛击！"
  },
  {
   "off": "0x19B642",
   "zh": "了解！"
  }
 ],
 "blocks": [
  {
   "off": "0x152A",
   "zh": "雷达出现反应！是新吉翁军！！"
  },
  {
   "off": "0x155A",
   "zh": "竟然先动手了！！全员战斗部署！"
  },
  {
   "off": "0x1586",
   "zh": "已经咬住阿伽玛了！各机、歼灭奥古！"
  },
  {
   "off": "0x93DA",
   "zh": "放心交给我吧、格雷米、我会让你赢的！"
  },
  {
   "off": "0x941A",
   "zh": "务必报答格雷米阁下的恩义！卡多、出击！"
  },
  {
   "off": "0x9457",
   "zh": "……是！！"
  },
  {
   "off": "0x9486",
   "zh": "上吧、奥古！这次绝不容情！"
  },
  {
   "off": "0x15C6",
   "zh": "……要来了！MS部队立刻出击！"
  },
  {
   "off": "0x15DB",
   "zh": "迎击新吉翁！！"
  },
  {
   "off": "0x9192",
   "zh": "……不好！这艘舰要是被击毁的话……！"
  },
  {
   "off": "0x2326",
   "zh": "可恶……后面就交给你们了！！"
  },
  {
   "off": "0x2364",
   "zh": "该死……！下次见面给我等着瞧！！"
  },
  {
   "off": "0x97BA",
   "zh": "…………"
  },
  {
   "off": "0x97EE",
   "zh": "……普露"
  },
  {
   "off": "0x9821",
   "zh": "我知道的、捷多、那个驾驶员是谁"
  },
  {
   "off": "0x9836",
   "zh": "……那是我"
  },
  {
   "off": "0x983F",
   "zh": "只继承了我最激烈那一面的、另一个我……"
  },
  {
   "off": "0x9882",
   "zh": "普露你想怎么做？"
  },
  {
   "off": "0x98AA",
   "zh": "……不知道"
  },
  {
   "off": "0x98B4",
   "zh": "可是、我觉得不能让她那样下去"
  },
  {
   "off": "0x98C7",
   "zh": "跟格雷米在一起、那孩子会变得不幸的……"
  },
  {
   "off": "0x98FF",
   "zh": "…………"
  },
  {
   "off": "0x23AB",
   "zh": "如今唯有隐忍了吗……不甘啊"
  },
  {
   "off": "0x23F0",
   "zh": "可恶……！"
  },
  {
   "off": "0x23F8",
   "zh": "难道我复兴吉翁的信念、对那些家伙行不通吗！？"
  },
  {
   "off": "0x243F",
   "zh": "只要卡多少佐还拘泥于吉翁之名、就不可能打倒我们"
  },
  {
   "off": "0x247F",
   "zh": "……什么！？"
  },
  {
   "off": "0x24A4",
   "zh": "归根结底、吉翁公国……"
  },
  {
   "off": "0x24B0",
   "zh": "在接受扎比家统治的那一刻、其理想就已经扭曲了……"
  },
  {
   "off": "0x24CF",
   "zh": "扭曲传承吉翁·戴肯理想的吉翁公国、早已完成了它的使命"
  },
  {
   "off": "0x250F",
   "zh": "那、那么……夏亚大佐是说、我所坚信的吉翁是错的！？"
  },
  {
   "off": "0x254A",
   "zh": "创造历史的、不是扎比家的血统或思想！"
  },
  {
   "off": "0x2568",
   "zh": "……而是年轻人们的自觉！我正是为此而战"
  },
  {
   "off": "0x25AB",
   "zh": "…………"
  },
  {
   "off": "0x25B4",
   "zh": "夏亚大佐、您……"
  },
  {
   "off": "0x1C37",
   "zh": "唔！！"
  },
  {
   "off": "0x1C3F",
   "zh": "竟让如此幼童上阵厮杀……何其无道、奥古！！"
  },
  {
   "off": "0x1C81",
   "zh": "喂、等一下！普露原本就是新吉翁的人啊！！"
  },
  {
   "off": "0x1CBE",
   "zh": "……什么！？"
  },
  {
   "off": "0x1CFA",
   "zh": "…………"
  },
  {
   "off": "0x1D1A",
   "zh": "好烫烫烫……！全身都烧起来了哦哦哦！！"
  },
  {
   "off": "0x1D76",
   "zh": "啊啊、哈曼大人……哈曼大人……！！"
  },
  {
   "off": "0x1DDF",
   "zh": "…………"
  },
  {
   "off": "0x1E24",
   "zh": "普露普露普露普露普露……！"
  },
  {
   "off": "0x1E7C",
   "zh": "…………"
  },
  {
   "off": "0x1E85",
   "zh": "……唔！确、确实是新吉翁的涂装！"
  },
  {
   "off": "0x1E9D",
   "zh": "……虽然不甘、却无言以对"
  },
  {
   "off": "0x1A84",
   "zh": "看来不吃一次苦头、你是不会明白的呢！"
  },
  {
   "off": "0x1AC1",
   "zh": "你才是、一副扭曲的心性！就由我来给你矫正！"
  },
  {
   "off": "0x1B06",
   "zh": "为什么、卡多！！为什么要帮格雷米那种人！？"
  },
  {
   "off": "0x1B40",
   "zh": "我发过誓！哪怕赌上性命、也要复兴吉翁！"
  },
  {
   "off": "0x1B5E",
   "zh": "岂容你这种人来阻挠！！"
  },
  {
   "off": "0x1B94",
   "zh": "我不会再问理由了……"
  },
  {
   "off": "0x1BA2",
   "zh": "若你执意站在新吉翁那边、我就……打倒你！"
  },
  {
   "off": "0x1BE2",
   "zh": "……原来如此、昔日的红色彗星早已死了吗"
  },
  {
   "off": "0x1BF9",
   "zh": "那我便将你当作奥古的克瓦特罗、讨灭便是！！"
  },
  {
   "off": "0x1ED3",
   "zh": "对手可是那个所罗门的噩梦……只能全力以赴了！"
  },
  {
   "off": "0x1F10",
   "zh": "好的、士郎！！"
  },
  {
   "off": "0x1F4C",
   "zh": "唔、您是萨哈林家的！？"
  },
  {
   "off": "0x1F5D",
   "zh": "可悲……！你忘了身为吉翁名门的骄傲了吗！"
  },
  {
   "off": "0x1F9D",
   "zh": "骄傲、名誉、血统……"
  },
  {
   "off": "0x1FAB",
   "zh": "士郎教会了我、世上有远比那些更重要的东西！"
  },
  {
   "off": "0x1FF0",
   "zh": "什么……！？"
  },
  {
   "off": "0x202B",
   "zh": "你就是阿伽玛的那个捷多吧！你的脑袋、我收下了！！"
  },
  {
   "off": "0x205B",
   "zh": "什么！这家伙……普露！？你到底是谁！？"
  },
  {
   "off": "0x209A",
   "zh": "我感觉得到……！这孩子和我一样……"
  },
  {
   "off": "0x20D0",
   "zh": "你在胡说八道些什么！我就是我！"
  },
  {
   "off": "0x211D",
   "zh": "想妨碍我吗！？就凭那种MS！！"
  },
  {
   "off": "0x216A",
   "zh": "……唔！"
  },
  {
   "off": "0x2178",
   "zh": "这份狂暴太危险了！对不住捷多、可是……"
  },
  {
   "off": "0x21B5",
   "zh": "……夏亚·阿兹纳布尔吗"
  },
  {
   "off": "0x21C0",
   "zh": "……我可听说了！你想把世界握进手中！！"
  },
  {
   "off": "0x21FA",
   "zh": "……！？"
  },
  {
   "off": "0x221D",
   "zh": "为成就我吉翁的血之王国、碍事的你就给我消失吧！"
  },
  {
   "off": "0x225D",
   "zh": "血之王国……？"
  },
  {
   "off": "0x228F",
   "zh": "够了、你也太纠缠不休了！格雷米！！"
  },
  {
   "off": "0x22C3",
   "zh": "露·露卡小姐！怎么能说出这么无情的话……！！"
  },
  {
   "off": "0x22DE",
   "zh": "我这被敌我立场生生撕裂的心情、你就不明白吗！？"
  },
  {
   "off": "0x160F",
   "zh": "……！？"
  },
  {
   "off": "0x161C",
   "zh": "骗人……这孩子？"
  },
  {
   "off": "0x1661",
   "zh": "什么！？这令人不快的波动是！？"
  },
  {
   "off": "0x1699",
   "zh": "是你吗！这股恼人杂音的源头！？"
  },
  {
   "off": "0x16B1",
   "zh": "为什么开着那种MS、就敢来挑战精神感应高达！"
  },
  {
   "off": "0x16EA",
   "zh": "觉得不愉快的话……"
  },
  {
   "off": "0x16F3",
   "zh": "……就回天上去、回宇宙去吧！！！"
  },
  {
   "off": "0x1732",
   "zh": "……普露！？"
  },
  {
   "off": "0x1766",
   "zh": "我知道的、捷多、那台精神感应高达的驾驶员……"
  },
  {
   "off": "0x17A2",
   "zh": "普露、不行！！"
  },
  {
   "off": "0x94C2",
   "zh": "这家伙！还想再来吗！？真是个讨厌的家伙……！！"
  },
  {
   "off": "0x950E",
   "zh": "……会不愉快、那是当然的啦"
  },
  {
   "off": "0x9527",
   "zh": "人啊……人类啊……看到自己就会觉得不愉快……"
  },
  {
   "off": "0x954E",
   "zh": "可是啊……不管有多不愉快、有多憎恨……"
  },
  {
   "off": "0x9574",
   "zh": "也无法杀死自己……更无法不再做自己啊！"
  },
  {
   "off": "0x95C6",
   "zh": "住、住手！！别过来！"
  },
  {
   "off": "0x9606",
   "zh": "我就是你……而你……就是我啊！！"
  },
  {
   "off": "0x9627",
   "zh": "你不就是只继承了我最激烈那一面的人吗！？"
  },
  {
   "off": "0x967D",
   "zh": "我是、艾露比·普露！！"
  },
  {
   "off": "0x96BA",
   "zh": "我、我是普露兹……"
  },
  {
   "off": "0x96D1",
   "zh": "……是普露兹！！"
  },
  {
