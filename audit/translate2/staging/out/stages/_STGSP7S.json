 ],
 "title_zh": "人与继承者之间",
 "briefing": [
  {
   "off": "0x1A1329",
   "zh": "如今、我们因木星帝国的谋略、被扣上了叛乱者的帽子……"
  },
  {
   "off": "0x1A134C",
   "zh": "事态因此变得愈发严峻"
  },
  {
   "off": "0x1A1361",
   "zh": "木星军以追捕我们为名、将部队派往了地球圈各地、"
  },
  {
   "off": "0x1A1385",
   "zh": "联邦军对此毫无察觉、等于已经被木星军所包围"
  },
  {
   "off": "0x1A13A8",
   "zh": "木星军早晚会发动进攻、届时联邦军必败无疑"
  },
  {
   "off": "0x1A13CB",
   "zh": "因此、我们将潜伏在轨道上的残骸带中避过追击……"
  },
  {
   "off": "0x1A13EA",
   "zh": "以防备木星帝国军开始行动"
  },
  {
   "off": "0x1A141C",
   "zh": "根据刚才贝尔纳黛特小姐所说的情况……"
  },
  {
   "off": "0x1A1434",
   "zh": "我们已经得知、德卡契总统很可能会直接把矛头指向地球"
  },
  {
   "off": "0x1A1473",
   "zh": "因此、一旦木星军开始行动、我们也随即出击、"
  },
  {
   "off": "0x1A148D",
   "zh": "作战方案、就是直接攻击企图染指地球的德卡契总统"
  },
  {
   "off": "0x1A14AD",
   "zh": "敌军本阵有我们刚交过手的MA迪比尼达多……"
  },
  {
   "off": "0x1A14C6",
   "zh": "预计还会有众多高性能MS严阵以待"
  },
  {
   "off": "0x1A14E6",
   "zh": "但我们一旦战败、联邦就再无退路"
  },
  {
   "off": "0x1A14F9",
   "zh": "望各位牢记这一点、专心清除德卡契总统"
  },
  {
   "off": "0x1A151B",
   "zh": "说地球的命运托付在诸君手上、也毫不为过"
  },
  {
   "off": "0x1A1540",
   "zh": "拜托了、诸君！！"
  },
  {
   "off": "0x1A4236",
   "zh": "『宇宙世纪0079、1月3日』"
  },
  {
   "off": "0x1A4252",
   "zh": "『SIDE2殖民地』"
  },
  {
   "off": "0x1A427A",
   "zh": "『队、队长！』"
  },
  {
   "off": "0x1A428A",
   "zh": "『殖民地它……』"
  },
  {
   "off": "0x1A429A",
   "zh": "『人们……人们都死了……』"
  },
  {
   "off": "0x1A42B2",
   "zh": "『……西玛队长！！』"
  },
  {
   "off": "0x1A42C2",
   "zh": "啊……怎、怎么会……"
  },
  {
   "off": "0x1A42D9",
   "zh": "不是说那只是催泪瓦斯吗……"
  },
  {
   "off": "0x1A42F3",
   "zh": "我……"
  },
  {
   "off": "0x1A4305",
   "zh": "竟然是毒气……"
  },
  {
   "off": "0x1A431E",
   "zh": "我什么都不知道啊！！"
  },
  {
   "off": "0x1A4332",
   "zh": "时值宇宙世纪0079……"
  },
  {
   "off": "0x1A4342",
   "zh": "距离地球最远的殖民地SIDE3、向地球联邦政府发起了独立战争"
  },
  {
   "off": "0x1A436E",
   "zh": "面对国力占绝对优势的地球联邦、吉翁公国投入了「机动战士」"
  },
  {
   "off": "0x1A4396",
   "zh": "一举压制联邦军、取得了占领半个地球的辉煌战果"
  },
  {
   "off": "0x1A43BE",
   "zh": "然而……"
  },
  {
   "off": "0x1A43CA",
   "zh": "战事的旷日持久出乎当初的预料、令吉翁公国疲惫不堪……"
  },
  {
   "off": "0x1A43F2",
   "zh": "随着联邦军成功开发出机动战士、战局就此逆转"
  },
  {
   "off": "0x1A4416",
   "zh": "在联邦军的数量攻势面前、吉翁军全线崩溃、"
  },
  {
   "off": "0x1A443A",
   "zh": "在各地节节败退"
  },
  {
   "off": "0x1A444E",
   "zh": "而最终……"
  },
  {
   "off": "0x1A445E",
   "zh": "联邦军的宇宙反攻作战、即将拉开序幕……"
  },
  {
   "off": "0x1A4732",
   "zh": "可恶啊啊啊！！"
  },
  {
   "off": "0x1A4772",
   "zh": "岂有此理……！区、区区一台机动战士……"
  },
  {
   "off": "0x1A47BA",
   "zh": "……可恶！"
  },
  {
   "off": "0x1A47D7",
   "zh": "休想得逞！休想得逞啊！！"
  },
  {
   "off": "0x1A481E",
   "zh": "凭你这种机动战士、休想夺走吉翁的荣光！！"
  },
  {
   "off": "0x1A4868",
   "zh": "你、你到底是什么人……！？"
  },
  {
   "off": "0x1A489B",
   "zh": "只要有我在、就休想……"
  },
  {
   "off": "0x1A48DE",
   "zh": "你这家伙……"
  },
  {
   "off": "0x1A490A",
   "zh": "我绝不会让战友死在这里！"
  },
  {
   "off": "0x1A494E",
   "zh": "我、不会死！"
  },
  {
   "off": "0x1A4963",
   "zh": "我要活着……"
  },
  {
   "off": "0x1A499A",
   "zh": "活着和爱娜厮守一生！！"
  },
  {
   "off": "0x1A49D0",
   "zh": "什么！？你就是爱娜大人的……？"
  },
  {
   "off": "0x1A4A16",
   "zh": "…………"
  },
  {
   "off": "0x1A4A29",
   "zh": "竟能遇上爱娜大人的心上人……"
  },
  {
   "off": "0x1A4A45",
   "zh": "这一生、真有意思……"
  },
  {
   "off": "0x1A4A76",
   "zh": "想来碍事吗……那就先送你上路！！"
  },
  {
   "off": "0x1A4ECE",
   "zh": "拉拉！？"
  },
  {
   "off": "0x1A4F06",
   "zh": "你来得太迟了！"
  },
  {
   "off": "0x1A4F22",
   "zh": "为什么你到现在才出现！？"
  },
  {
   "off": "0x1A4F66",
   "zh": "太迟了！？"
  },
  {
   "off": "0x1A4FA2",
   "zh": "你明明能像这样战斗！……为什么！？"
  },
  {
   "off": "0x1A4FC6",
   "zh": "明明你连一个要守护的人都没有……"
  },
  {
   "off": "0x1A5005",
   "zh": "唔！？"
  },
  {
   "off": "0x1A5030",
   "zh": "我看得见……"
  },
  {
   "off": "0x1A5046",
   "zh": "你没有故乡、也没有家人……"
  },
  {
   "off": "0x1A5066",
   "zh": "……甚至不曾爱过谁！"
  },
  {
   "off": "0x1A50A6",
   "zh": "那又……那又怎么样……"
  },
  {
   "off": "0x1A50E2",
   "zh": "又能说明什么啊！！"
  },
  {
   "off": "0x1A514A",
   "zh": "没有要守护的人、就不能战斗了吗！？"
  },
  {
   "off": "0x1A518F",
   "zh": "那样是不自然的……"
  },
  {
   "off": "0x1A519C",
   "zh": "我、是在为救了我的人而战……"
  },
  {
   "off": "0x1A51E1",
   "zh": "仅仅、为了这一个理由……？"
  },
  {
   "off": "0x1A5218",
   "zh": "这……正是人活下去的真理……！"
  },
  {
   "off": "0x1A5258",
   "zh": "那么！我们俩这样的相遇又算什么啊！？"
  },
  {
   "off": "0x1A52B0",
   "zh": "啊啊啊！"
  },
  {
   "off": "0x1A52BA",
   "zh": "为什么啊！？为什么我遇见你、竟遇得这样迟？"
  },
  {
   "off": "0x1A52D8",
   "zh": "就算相遇了……也已是无可挽回的相遇！！"
  },
  {
   "off": "0x1A5315",
   "zh": "如果这就是命运、也未免太过分了……太残酷了"
  },
  {
   "off": "0x1A5339",
   "zh": "明明相遇就能相互理解……为什么却只能以这种方式……"
  },
  {
   "off": "0x1A5356",
   "zh": "对我来说、你来得太迟……"
  },
  {
   "off": "0x1A5371",
   "zh": "而对我来说、你又来得太突然……"
  },
  {
   "off": "0x1A53DA",
   "zh": "……拉拉！！"
  },
  {
   "off": "0x1A540E",
   "zh": "别再和那家伙说胡话了！！"
  },
  {
   "off": "0x1A544E",
   "zh": "……夏亚！！"
  },
  {
   "off": "0x1A548A",
   "zh": "可恶！！"
  },
  {
   "off": "0x1A54C6",
   "zh": "……什么！？"
  },
  {
   "off": "0x1A5502",
   "zh": "夏亚！觉悟吧！！"
  },
  {
   "off": "0x1A553E",
   "zh": "不可以……！！"
  },
  {
   "off": "0x1A5587",
   "zh": "拉拉！？"
  },
  {
   "off": "0x1A55DB",
   "zh": "『人是可以改变的、就像我们一样……』"
  },
  {
   "off": "0x1A5637",
   "zh": "『是啊……正如拉拉所说……』"
  },
  {
   "off": "0x1A5658",
   "zh": "『我和你不也这样相互理解了吗』"
  },
  {
   "off": "0x1A5675",
   "zh": "『人总有一天……连时间都能够支配……』"
  },
  {
   "off": "0x1A56D2",
   "zh": "『啊、阿姆罗……』"
  },
  {
   "off": "0x1A56E8",
   "zh": "『我看到时间了……！』"
  },
  {
   "off": "0x1A58EE",
   "zh": "爱娜……事到如今、已经顾不上手段了"
  },
  {
   "off": "0x1A5912",
   "zh": "我……要杀了你的哥哥！"
  },
  {
   "off": "0x1A594D",
   "zh": "……嗯"
  },
  {
   "off": "0x1A5986",
   "zh": "这是你们粉碎我完成格罗姆林之梦的回礼……"
  },
  {
   "off": "0x1A59AD",
   "zh": "首先、就拿你们……！"
  },
  {
   "off": "0x1A59EE",
   "zh": "上了、爱娜！"
  },
  {
   "off": "0x1A5A1D",
   "zh": "……"
  },
  {
   "off": "0x1A5A2E",
   "zh": "永别了……哥哥"
  },
  {
   "off": "0x1A5A66",
   "zh": "我的梦想！"
  },
  {
   "off": "0x1A5A78",
   "zh": "你们给我接下吧！！"
  },
  {
   "off": "0x1A5AB2",
   "zh": "唔……还没完！！"
  },
  {
   "off": "0x1A5AEE",
   "zh": "……！？"
  },
  {
   "off": "0x1A5B12",
   "zh": "为了证明众多英灵并非白白牺牲……"
  },
  {
   "off": "0x1A5B39",
   "zh": "为了再次高举吉翁的理想！为了星尘作战的成功！"
  },
  {
   "off": "0x1A5B72",
   "zh": "所罗门哟！我回来了！！"
  },
  {
   "off": "0x1A5BA2",
   "zh": "自一年战争以来……"
  },
  {
   "off": "0x1A5BB2",
   "zh": "在地球住民与宇宙住民之间日渐加深的对立……"
  },
  {
   "off": "0x1A5BD2",
   "zh": "随着自称月之民者的登场、骤然宣告了终结"
  },
  {
   "off": "0x1A5BF2",
   "zh": "来自遥远未来的他们……"
  },
  {
   "off": "0x1A5C0A",
   "zh": "据说在宇宙世纪之后、地球文明曾走向崩溃……"
  },
  {
   "off": "0x1A5C2A",
   "zh": "为阻止这段『黑历史』、他们着手统治了地球圈"
  },
  {
   "off": "0x1A5C52",
   "zh": "虽有部分军方势力表现出顽强的反抗……"
  },
  {
   "off": "0x1A5C76",
   "zh": "但根本无力抗衡技术远为先进的月之民"
  },
  {
   "off": "0x1A5C96",
   "zh": "地球联邦政府将地球的统治、移交给了月之民的女王迪安娜……"
  },
  {
   "off": "0x1A5CBE",
   "zh": "一个宇宙居民与地球居民一视同仁的时代、就此到来"
  },
  {
   "off": "0x1A5CEA",
   "zh": "然而……"
  },
  {
   "off": "0x1A5CF6",
   "zh": "这看似理想的治世、仅仅数年便产生了裂痕"
  },
  {
   "off": "0x1A5D22",
   "zh": "居住在PLANT的调整者们、吸收了月之民的技术力……"
  },
  {
   "off": "0x1A5D4A",
   "zh": "组建了独立的军事组织扎夫特、并宣布脱离月球独立……"
  },
  {
   "off": "0x1A5D76",
   "zh": "地球圈各地的诸多势力、开始纷纷叛离"
  },
  {
   "off": "0x1A5D96",
   "zh": "不谙斗争的月之民、无从把握这股潮流"
  },
  {
   "off": "0x1A5DBA",
   "zh": "就这样、地球圈……"
  },
  {
   "off": "0x1A5DCE",
   "zh": "再度被战乱的烈火所吞没……"
  },
  {
   "off": "0x1A5E0E",
   "zh": "…………"
  },
  {
   "off": "0x1A5E49",
   "zh": "……啊……"
  },
  {
   "off": "0x1A5E5A",
   "zh": "……觉醒……之时……已到……"
  },
  {
   "off": "0x1A5EA9",
   "zh": "…………"
  },
  {
   "off": "0x1A5EBC",
   "zh": "到来了……那一刻"
  },
  {
   "off": "0x1A5EF7",
   "zh": "……去吧……"
  },
  {
   "off": "0x1A5F09",
   "zh": "地球……荣光……制裁……"
  },
  {
   "off": "0x1A5F57",
   "zh": "……是"
  },
  {
   "off": "0x1A5F68",
   "zh": "谨遵……您的旨意"
  },
  {
   "off": "0x1A5F9C",
   "zh": "『大家、住手啊！！』"
  },
  {
   "off": "0x1A5FBE",
   "zh": "……哈曼大人！？"
  },
  {
   "off": "0x1A5FE4",
   "zh": "是、是内部广播！哈曼大人她……"
  },
  {
   "off": "0x1A6050",
   "zh": "同为吉翁的同胞、为什么非要自相残杀！？"
  },
  {
   "off": "0x1A606E",
   "zh": "难道我们离开地球圈、就是为了做这种事吗！？"
  },
  {
   "off": "0x1A608B",
   "zh": "父亲大人和泽娜大人拼上性命守护的阿克西斯、"
  },
  {
   "off": "0x1A60AB",
   "zh": "眼看就要遭到联邦军的攻击、大家为什么还不站出来！？"
  },
  {
   "off": "0x1A60D2",
   "zh": "我不要！我不要这个阿克西斯就此消失！"
  },
  {
   "off": "0x1A60EB",
   "zh": "如果谁都不肯战斗……"
  },
  {
   "off": "0x1A60FD",
   "zh": "那我一个人也要战斗！！"
  },
  {
   "off": "0x1A624E",
   "zh": "不知黑历史为何物的民兵、也配谈论战斗……！！"
  }
 ],
 "blocks": [
  {
   "off": "0x72B2",
   "zh": "遭、遭到攻击！？到底是从哪里……！？"
  },
  {
   "off": "0x72EA",
   "zh": "是、是木星军！木星军突然发起了攻击……"
  },
  {
   "off": "0x739F",
   "zh": "这、这是核弹！？怎么可能！！"
  },
  {
   "off": "0x73CA",
   "zh": "德、德卡契阁下！！这到底是怎么回事！？"
  },
  {
   "off": "0x73FE",
   "zh": "如你们所见……战争已经开始了、对手正是你们地球联邦"
  },
  {
   "off": "0x743C",
   "zh": "什么！？你、你这家伙！把地球联邦当成什么了！！"
  },
  {
   "off": "0x745B",
   "zh": "竟敢无视南极条约发动核攻击！别以为能就这么算了！！"
  },
  {
   "off": "0x7492",
   "zh": "呵呵……呵呵……"
  },
  {
   "off": "0x749F",
   "zh": "条约什么的、不过是你们地球人自说自话定下的东西……"
  },
  {
   "off": "0x74BC",
   "zh": "我从一开始就没打算遵守"
  },
  {
   "off": "0x74E7",
   "zh": "什、么……？"
  },
