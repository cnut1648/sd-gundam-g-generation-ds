  {
   "off": "0xE545",
   "zh": "作为人……"
  },
  {
   "off": "0xE576",
   "zh": "大家……！？"
  },
  {
   "off": "0xE59A",
   "zh": "地球是生活在这片宇宙中所有人的原点啊！"
