  {
   "off": "0x4A04",
   "zh": "哎呀、请直接叫我拉克丝就好……基拉"
  },
  {
   "off": "0x4A1B",
   "zh": "不过、您还记得我、真让人高兴呢"
  },
  {
   "off": "0x4A4C",
   "zh": "我……明明、已经……死了、才对……"
  },
  {
   "off": "0x4AC3",
   "zh": "基拉啊啊啊！"
  },
  {
   "off": "0x4B14",
   "zh": "阿斯兰！！"
  },
  {
   "off": "0x4BD4",
   "zh": "我杀了、他的……伙伴……阿斯兰、也杀了我的……朋友……！"
  },
  {
   "off": "0x4BFA",
   "zh": "所以……"
  },
  {
   "off": "0x4C1C",
   "zh": "所以您、就想要杀死阿斯兰、对吗？"
  },
  {
   "off": "0x4C4D",
   "zh": "……！"
  },
  {
   "off": "0x4C6F",
   "zh": "而阿斯兰、也想要杀死您"
