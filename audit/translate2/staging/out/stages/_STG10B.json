  {
   "off": "0xB214",
   "zh": "『亚洲』"
  },
  {
   "off": "0xB245",
   "zh": "士郎、那是……"
  },
  {
   "off": "0xB271",
   "zh": "那么多的MS……到底发生什么事了？"
  },
  {
   "off": "0x3D5A",
   "zh": "破晓行动、正在各地顺利进行中！"
  },
  {
   "off": "0x3D88",
   "zh": "…………"
  },
  {
   "off": "0x3DC7",
   "zh": "特林顿基地的当地部队正在抵抗！收到了增援请求！"
  },
  {
   "off": "0x3E02",
   "zh": "……没那个必要"
