  {
   "off": "0xB0A5",
   "zh": "『……D号』"
  },
  {
   "off": "0xB118",
   "zh": "『……试验……』"
  },
  {
   "off": "0xB185",
   "zh": "『……战斗……继续……你的……任务……』"
