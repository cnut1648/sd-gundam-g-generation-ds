  },
  {
   "off": "0x4ECB",
   "zh": "啊……我叫、贝尔纳黛特"
  },
  {
   "off": "0x4EF8",
   "zh": "我是托比亚！托比亚·阿罗纳克斯！！"
  },
  {
   "off": "0x4F0A",
   "zh": "起飞会有点猛！给我抓稳了……贝尔纳黛特"
  },
