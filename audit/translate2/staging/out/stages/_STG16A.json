 "title_zh": "月世界之门",
 "briefing": [
  {
   "off": "0x19BC18",
   "zh": "……托雷斯、有什么新情报进来吗？"
  },
  {
   "off": "0x19BC48",
   "zh": "目前、新吉翁和提坦斯都没有动静"
  },
  {
   "off": "0x19BC63",
   "zh": "PLANT周边、扎夫特与联邦军的战斗似乎仍在继续……"
  },
  {
   "off": "0x19BC83",
   "zh": "不过那边也几乎、陷入了胶着状态"
  },
  {
   "off": "0x19BCB9",
   "zh": "就是说、各方势力都在暗中窥伺、寻找打击对方的可乘之机……"
  },
  {
   "off": "0x19BCDD",
   "zh": "可以的话、真想在战端开启之前把事态收拾好"
  },
  {
   "off": "0x19BD16",
   "zh": "只要月之民的混乱平息、要制住其他势力也并非不可能"
  },
  {
   "off": "0x19BD35",
   "zh": "正因如此、必须尽早抵达月球才行"
  }
 ],
 "blocks": [
  {
   "off": "0x7CD6",
   "zh": "什么！？迪安娜女王她！？"
  },
  {
   "off": "0x7D01",
   "zh": "是！恐怕是亲卫队暗中接应！！"
  },
  {
   "off": "0x7D2F",
   "zh": "糟、糟了！无论如何都要把她找出来！！"
  },
  {
   "off": "0x7D6B",
   "zh": "迪安娜女王、请快！"
  },
  {
   "off": "0x7DA4",
   "zh": "……是"
  },
  {
   "off": "0x7DC2",
   "zh": "……怎么样？"
  },
  {
   "off": "0x7DEC",
   "zh": "不行！他们还在追上来！！"
  },
  {
   "off": "0x7E26",
   "zh": "……哇啊！！"
  },
  {
   "off": "0x7E30",
   "zh": "那、那些家伙……是知道迪安娜大人在船上吗！？"
  },
  {
   "off": "0x7E76",
   "zh": "……无妨、继续攻击"
  },
  {
   "off": "0x7EB7",
   "zh": "可恶！引擎输出……！！"
  },
  {
   "off": "0x7EEA",
   "zh": "这就弃船脱出、迪安娜大人！"
  },
  {
   "off": "0x7F1E",
   "zh": "出来了！别让他们跑了！"
  },
  {
   "off": "0x7F52",
   "zh": "可恶啊啊啊！！"
  },
  {
   "off": "0x7F86",
   "zh": "就是现在！！"
  },
  {
   "off": "0x7FB6",
   "zh": "糟了！？"
  },
  {
   "off": "0x7FE6",
   "zh": "还是让他们……逃掉了呢"
  },
  {
   "off": "0x8011",
   "zh": "是……万分抱歉"
  },
  {
   "off": "0x803D",
   "zh": "道歉就不必了、抓紧去捉拿女王吧"
  },
  {
   "off": "0x808D",
   "zh": "编组突入班！立刻突入内部、把女王……"
  },
  {
   "off": "0x14E2",
   "zh": "……那是！！"
  },
  {
   "off": "0x150D",
   "zh": "是之前在非洲遭遇过的部队吗！！"
  },
  {
   "off": "0x80D2",
   "zh": "……看来和那支部队、还真是有缘呢"
  },
  {
   "off": "0x8103",
   "zh": "您打算如何处置？"
  },
  {
   "off": "0x812A",
   "zh": "……排除掉就是了、那股力量迟早会碍事"
  },
  {
   "off": "0x815D",
   "zh": "……是！"
  },
  {
   "off": "0x1543",
   "zh": "…………"
  },
  {
   "off": "0x154C",
   "zh": "（泽诺比亚……你也在那里吗？）"
  },
  {
   "off": "0x1583",
   "zh": "MS部队展开！正朝我们过来！！"
  },
  {
   "off": "0x15B5",
   "zh": "怎么看、都不像是在欢迎我们啊"
  },
  {
   "off": "0x15E5",
   "zh": "是打算攻击我们吗……托雷斯、MS部队出击！"
  },
  {
   "off": "0x15FD",
   "zh": "各机立刻展开、迎击敌人！"
  },
  {
   "off": "0x818A",
   "zh": "……罗兰？"
  },
  {
   "off": "0x81AD",
   "zh": "还没对倒A下达出击命令啊！怎么了、罗兰！？"
  },
  {
   "off": "0x81F2",
   "zh": "我也搞不清楚！高达它对什么东西起了反应……"
  },
  {
   "off": "0x822F",
   "zh": "……起反应？"
  },
  {
   "off": "0x1637",
   "zh": "布莱特舰长！"
  },
  {
   "off": "0x163F",
   "zh": "那台高达、连我们月之民也没能掌握全貌！"
  },
  {
   "off": "0x165C",
   "zh": "既然那台倒A起了反应、就可以断定必有蹊跷！"
  },
  {
   "off": "0x1696",
   "zh": "明白了、哈利中尉！"
  },
  {
   "off": "0x16AD",
   "zh": "罗兰就这样直接参战！其他人严加警戒、迎向敌人！"
  },
  {
   "off": "0x7AEA",
   "zh": "……不好！这艘舰要是被击毁的话……！"
  },
  {
   "off": "0x16F5",
   "zh": "……！？"
  },
  {
   "off": "0x1730",
   "zh": "怎、怎么回事！？"
  },
  {
   "off": "0x176D",
   "zh": "那是……月光蝶吗！？"
  },
  {
   "off": "0x8289",
   "zh": "外面好像正在交战呢"
  },
  {
   "off": "0x82B8",
   "zh": "会是友军吗？"
  },
  {
   "off": "0x82DE",
   "zh": "……不清楚"
  },
  {
   "off": "0x82E9",
   "zh": "不过、待在表层区块太危险了"
  },
  {
   "off": "0x8300",
   "zh": "我们往深处去吧"
  },
  {
   "off": "0x8328",
   "zh": "请、请留步、迪安娜大人！里面还不知道有什么危险……"
  },
  {
   "off": "0x8362",
   "zh": "不、不会有危险、这里的构造我很清楚"
  },
  {
   "off": "0x8397",
   "zh": "咦……？"
  },
  {
   "off": "0x83B9",
   "zh": "恐怕是时空移动的时候、被一同卷了进来吧……"
  },
  {
   "off": "0x83D6",
   "zh": "……这里是米斯尔托、与索雷尔家渊源颇深的地方"
  },
  {
   "off": "0x840D",
   "zh": "米斯尔托……吗？"
  },
  {
   "off": "0x8435",
   "zh": "那是月之民大浮游的时代……"
  },
  {
   "off": "0x8445",
   "zh": "为了再生空气和粮食、索雷尔家曾在这里进行农业实验"
  },
  {
   "off": "0x8478",
   "zh": "……走吧"
  },
  {
   "off": "0x8483",
   "zh": "到了深处、说不定能让动力恢复"
  },
  {
   "off": "0x84B6",
   "zh": "…………"
  },
  {
   "off": "0x17AB",
   "zh": "唔……何等惊人的压迫感！！"
  },
  {
   "off": "0x17E1",
   "zh": "和、和上次交手的对手……完全不同！"
  },
  {
   "off": "0x84E6",
   "zh": "……这就是所谓的新人类吧？"
  },
  {
   "off": "0x84F8",
   "zh": "这个我已经「学会」了"
  },
  {
   "off": "0x853B",
   "zh": "……什么！？"
  },
  {
   "off": "0x856A",
   "zh": "这是……"
  },
  {
   "off": "0x8572",
   "zh": "……原来还剩下一个啊"
  },
  {
   "off": "0x85A6",
   "zh": "啊……"
  },
  {
   "off": "0x181B",
   "zh": "…………"
  },
  {
   "off": "0x183F",
   "zh": "可恶！难道说它又复活了吗！？"
  },
  {
   "off": "0x1878",
   "zh": "怎么回事！？"
  },
  {
   "off": "0x189B",
   "zh": "布莱特舰长！6点钟方向出现新的舰影！！"
  },
  {
   "off": "0x18CD",
   "zh": "什么！？"
  },
  {
   "off": "0x85CE",
   "zh": "感觉到有趣的力量、过来一看……"
  },
  {
   "off": "0x85E2",
   "zh": "竟不过如此、只有个冒牌货罢了"
  },
  {
   "off": "0x861A",
   "zh": "基姆·金卡拉姆……为什么、你会在这里……？"
  },
  {
   "off": "0x8633",
   "zh": "此时此刻采取行动、没有任何好处……"
  },
  {
   "off": "0x866A",
   "zh": "……哼、休想对本人指手画脚！"
  },
  {
   "off": "0x86A2",
   "zh": "比起这个……原来如此、那就是和你们交战的敌人吗"
  },
  {
   "off": "0x86BE",
   "zh": "呵呵……看来是个相当有趣的对手啊"
  },
  {
   "off": "0x86FA",
   "zh": "……正配得上我金卡拉姆一门的首战出阵！！"
  },
  {
   "off": "0x873A",
   "zh": "基姆·金卡拉姆！！"
  },
  {
   "off": "0x875F",
   "zh": "哈哈哈、原来你也会发出那种声音啊！"
  },
  {
   "off": "0x8799",
   "zh": "唔……"
  },
  {
   "off": "0x87BB",
   "zh": "我说过、休想对本人指手画脚"
  },
  {
   "off": "0x87CE",
   "zh": "还是说、想让我用倒X把那台什么百夫长轰上天？"
  },
  {
   "off": "0x880C",
   "zh": "……！"
  },
  {
   "off": "0x883A",
   "zh": "哼……"
  },
  {
   "off": "0x885C",
   "zh": "敌方部队似乎还有一部分残留？"
  },
  {
   "off": "0x888C",
   "zh": "无妨、正好拿来热热身"
  },
  {
   "off": "0x88AD",
   "zh": "……本人基姆·金卡拉姆、出阵！！"
  },
  {
   "off": "0x88E2",
   "zh": "那是……倒X！？"
  },
  {
   "off": "0x890B",
   "zh": "哈哈哈！这不是哈利·奥德吗！！"
  },
  {
   "off": "0x8921",
   "zh": "竟在那种地方鬼鬼祟祟地乱晃！！"
  },
  {
   "off": "0x8953",
   "zh": "这是怎么回事、金卡拉姆！！"
  },
  {
   "off": "0x8960",
   "zh": "金卡拉姆一门……你们的舰队应该已被冻结才对！！"
  },
  {
   "off": "0x897E",
   "zh": "未得迪安娜大人允许就擅自出击、还把倒X都搬了出来！！"
  },
  {
   "off": "0x89B8",
   "zh": "正因斗争时代拉开了帷幕、我等才走上台前！！"
  },
  {
   "off": "0x89DB",
   "zh": "我金卡拉姆一门、乃司掌武事之家门！"
  },
  {
   "off": "0x89EE",
   "zh": "没必要事事请示不识战事的索雷尔家和曼特纳！"
  },
  {
   "off": "0x18FA",
   "zh": "哈利中尉、那是！？"
  },
  {
   "off": "0x1928",
   "zh": "那些人是金卡拉姆一门！月之民中司掌武事的一族！！"
  },
  {
   "off": "0x1944",
   "zh": "虽说他们没有实战经验、战力却在迪安娜反攻部队之上"
  },
  {
   "off": "0x195D",
   "zh": "千万小心、布莱特舰长！"
  },
  {
   "off": "0x1989",
   "zh": "了解、哈利中尉"
  },
  {
   "off": "0x199E",
   "zh": "全员、转入对金卡拉姆舰队的迎击态势！"
  },
  {
   "off": "0x19B3",
   "zh": "敌人的战力还是未知数！小心作战！"
  },
  {
   "off": "0x8A36",
   "zh": "对！就是这个……！！"
  },
  {
   "off": "0x8A44",
   "zh": "这股力量……"
  },
  {
   "off": "0x8A4C",
   "zh": "哈哈哈哈哈哈！！"
  },
  {
   "off": "0x8A7E",
   "zh": "难道说……！！"
  },
  {
   "off": "0x8AA9",
   "zh": "月光蝶是也！！"
  },
  {
   "off": "0x8ADA",
   "zh": "……！？"
  },
  {
   "off": "0x8B0A",
   "zh": "月光蝶起反应了吗！哈哈哈哈、好样的、兄弟！！"
  },
  {
   "off": "0x19EF",
   "zh": "唔……怎么回事！？"
  },
  {
   "off": "0x1A16",
   "zh": "第一装甲板、严重受损！"
  },
  {
   "off": "0x1A23",
   "zh": "啊、不对！这是……！"
  },
  {
   "off": "0x1A34",
   "zh": "并不是被击毁！外部装甲正在被分解！！"
  },
  {
   "off": "0x1A6D",
   "zh": "你说什么！？"
  },
  {
   "off": "0x1A9B",
   "zh": "那正是月光蝶……"
  },
  {
   "off": "0x1AC6",
   "zh": "哈利中尉！你知道些什么吗！？"
  },
  {
   "off": "0x1AF7",
   "zh": "那是月光蝶……"
  },
  {
   "off": "0x1B03",
   "zh": "那是相传曾毁灭地球文明的、月光蝶系统之光！！"
  },
  {
   "off": "0x1B40",
   "zh": "毁灭了……地球文明？"
  },
  {
   "off": "0x8B4E",
   "zh": "哈哈哈哈、果然不出所料！"
  },
  {
   "off": "0x8B60",
   "zh": "我就料到、你们定能唤醒这倒X的月光蝶！"
  },
  {
   "off": "0x8BA0",
   "zh": "基姆·金卡拉姆！那就是你的企图吗！！"
  },
  {
   "off": "0x8BD1",
   "zh": "这下斗争时代的大幕、已然拉开！！"
  },
  {
   "off": "0x8BE5",
   "zh": "早晚要与你们在相称的大舞台上一争霸业！"
  },
  {
   "off": "0x8C04",
   "zh": "哈哈哈哈哈哈！！"
  },
  {
   "off": "0x8C36",
   "zh": "可恶……你这基姆·金卡拉姆……！"
  },
  {
   "off": "0x1B74",
   "zh": "『……你是谁？』"
  },
  {
   "off": "0x1B85",
   "zh": "『……之前被我打倒的你』"
  },
  {
   "off": "0x1B9A",
   "zh": "『……消失了的你、就在那里』"
  },
  {
   "off": "0x1BAF",
   "zh": "『……为什么？』"
  },
  {
   "off": "0x1BD8",
   "zh": "……军团既是全体、亦是个体"
  },
  {
   "off": "0x1BEA",
   "zh": "……是一切彼此相连的存在"
  },
  {
   "off": "0x1BFB",
   "zh": "正因你是脱离了那完美之环的存在、必须予以废弃……"
  },
  {
   "off": "0x1C39",
   "zh": "『……我吗？』"
  },
  {
   "off": "0x1C60",
   "zh": "作恶的军团、容不下异分子……逝去吧、你也一样"
  },
  {
   "off": "0x8C6E",
   "zh": "哟、兄弟！！"
  },
  {
   "off": "0x8C95",
   "zh": "兄弟！？我根本不认识你！！"
  },
  {
   "off": "0x8CC9",
   "zh": "哈哈哈哈！是兄弟的、是这两台MS！！"
  },
  {
   "off": "0x8CDF",
   "zh": "这倒X和倒A、可是在黑历史中厮杀过的兄弟！！"
  },
  {
   "off": "0x8D18",
   "zh": "这台倒A和倒X……？"
  },
  {
   "off": "0x8D4E",
   "zh": "改投迪安娜反攻部队、就摆出忠臣嘴脸吗、哈利·奥德！？"
  },
  {
   "off": "0x8D6E",
   "zh": "你这没节操的家伙！！"
  },
  {
   "off": "0x8D97",
   "zh": "没节操的分明是你们吧！！"
  },
  {
   "off": "0x8DA9",
   "zh": "正因你们不分场合滥开战端、我才与金卡拉姆一门恩断义绝！！"
  },
  {
   "off": "0x8DF2",
   "zh": "哼、区区一帮民兵！！"
  },
  {
   "off": "0x8E01",
   "zh": "让你们见识见识、演习了两千五百年的武门之力！"
  },
  {
   "off": "0x8E41",
   "zh": "我们这边也一样！！"
  },
  {
   "off": "0x8E4A",
   "zh": "要是只比模拟训练的时长、克莉丝也不会输给谁！"
  },
  {
   "off": "0x8E7F",
   "zh": "等等、巴尼！！什么叫「只比」啊！？"
  },
  {
   "off": "0x8EBF",
   "zh": "呃、抱、抱歉……"
  },
  {
   "off": "0x1CD2",
   "zh": "……凯利、手臂的伤不要紧吗？"
  },
  {
   "off": "0x1CFF",
   "zh": "没什么、就算只剩一条手臂也无大碍"
  },
  {
   "off": "0x1D0F",
   "zh": "一想到能与你并肩作战、这点小事不足挂齿"
  },
  {
   "off": "0x1D45",
   "zh": "呵……这确实像你的风格"
  },
  {
   "off": "0x1D6D",
   "zh": "这是我们重新选择的道路、并肩战斗到最后一刻吧、卡多！"
  },
  {
   "off": "0x1DBF",
   "zh": "啊啊、凯利……与你并肩！！"
  },
  {
   "off": "0x8EF2",
   "zh": "……大小姐！请别那么冒进！"
  },
  {
