  },
  {
   "off": "0x1B0D",
   "zh": "加洛德！！"
  },
  {
   "off": "0x1B32",
   "zh": "蒂法！！"
  },
  {
   "off": "0x1B5E",
   "zh": "蒂法！我来救你了！！"
  },
  {
   "off": "0x1B8D",
