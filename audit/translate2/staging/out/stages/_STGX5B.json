  {
   "off": "0x1E04",
   "zh": "去那边就行了吧、蒂法？……好嘞！！"
  },
  {
   "off": "0x1E45",
   "zh": "难、难道那个少年……！！"
  },
  {
   "off": "0x1E6B",
