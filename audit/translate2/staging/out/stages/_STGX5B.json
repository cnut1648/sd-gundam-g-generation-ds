 "title_zh": "其名为东方不败",
 "briefing": [
  {
   "off": "0x19D322",
   "zh": "已经查明、在我们的航线上存在着一座提坦斯的研究所"
  },
  {
   "off": "0x19D341",
   "zh": "现在有情报传来、说是有什么人正在这座研究所进行战斗、"
  },
  {
   "off": "0x19D366",
   "zh": "假如对方正是恶魔高达、置之不理将会非常危险"
  },
  {
   "off": "0x19D385",
   "zh": "因此、我们将立刻赶往现场、进行情报的确认"
  },
  {
   "off": "0x19D3BE",
   "zh": "多蒙·卡修的神高达已经先行赶往当地"
  },
  {
   "off": "0x19D3D7",
   "zh": "趁他拖住敌人的期间赶到现场、一举击破恶魔高达！"
  },
  {
   "off": "0x19D3F5",
   "zh": "各位、拜托了！"
  }
 ],
 "blocks": [
  {
   "off": "0x1682",
   "zh": "可恶、这些家伙到底是什么！刚打倒转眼又涌出来！！"
