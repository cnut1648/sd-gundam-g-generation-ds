 "title_zh": "宇宙要塞阿·巴瓦·库",
 "briefing": [
  {
   "off": "0x1992BB",
   "zh": "联邦舰队正逼近阿·巴瓦·库、想必诸君也已知晓"
  },
  {
   "off": "0x1992E3",
   "zh": "我们此次的任务、就是排除进逼阿·巴瓦·库的敌舰队"
  },
  {
   "off": "0x199305",
   "zh": "玛利根、进行说明"
  },
  {
   "off": "0x199336",
   "zh": "……是！"
  },
  {
   "off": "0x19933E",
   "zh": "我们负责的、是阿·巴瓦·库的S区域……"
  },
  {
   "off": "0x19935B",
   "zh": "那里是要塞炮十字火力的死角……"
  },
  {
   "off": "0x199374",
   "zh": "联邦也在这一区域、部署了以木马为首的精锐部队"
  },
  {
   "off": "0x1993BC",
   "zh": "毫无疑问、这将是一场相当严酷的战斗"
  },
  {
   "off": "0x1993FF",
   "zh": "我方也不只有我们、奇美拉队和亲卫队也将按计划前来增援"
  },
  {
   "off": "0x199424",
   "zh": "希望各位与这些部队通力合作、共同击破敌军"
  },
  {
   "off": "0x199442",
   "zh": "阿·巴瓦·库是吉翁的最终防线、"
  },
  {
   "off": "0x19945E",
   "zh": "此地一旦被突破、便可能直接导致吉翁公国的败北"
  },
  {
   "off": "0x19947F",
   "zh": "拜托了、诸君"
  }
 ],
 "blocks": [
  {
   "off": "0x159A",
   "zh": "……雷比尔将军、是大德金号"
  },
  {
   "off": "0x15CB",
   "zh": "没想到公王竟会亲自前来、进行和平谈判……"
  },
  {
   "off": "0x15E3",
   "zh": "……吉翁的处境、也很艰难啊"
  },
  {
   "off": "0x1609",
   "zh": "……阁下！太阳激光炮启动准备、已经就绪！"
  },
  {
   "off": "0x1642",
   "zh": "……嗯"
  },
  {
   "off": "0x1649",
   "zh": "那么、以盖尔·多尔巴为照准、发射太阳激光炮"
  },
  {
   "off": "0x167F",
   "zh": "……是！太阳激光炮、照准盖尔·多尔巴！"
  },
  {
   "off": "0x16E7",
   "zh": "……这、这是！？"
  },
  {
   "off": "0x173A",
   "zh": "基、基连……！！"
  },
  {
   "off": "0x1780",
   "zh": "听着！我忠勇的吉翁将士们！！"
  },
  {
   "off": "0x1797",
   "zh": "如今、地球联邦军舰队的半数、已被太阳激光炮从宇宙中抹去！"
  },
  {
   "off": "0x17DD",
   "zh": "…………"
  },
  {
   "off": "0x1818",
   "zh": "遭受决定性打击的地球联邦军、无论还残存多少战力……"
  },
  {
   "off": "0x183F",
   "zh": "都已只是徒具形骸的空壳！"
  },
  {
   "off": "0x184F",
   "zh": "请允许我说……他们是渣滓！！"
  },
  {
   "off": "0x188F",
   "zh": "……哼"
  },
  {
   "off": "0x18C8",
   "zh": "我在此断言、那群软弱的乌合之众、绝不可能攻破阿·巴瓦·库！！"
  },
  {
   "off": "0x18F1",
   "zh": "……人类！"
  },
  {
   "off": "0x18FA",
   "zh": "唯有在我等天选优良种族、吉翁国民的管理运营之下！"
  },
  {
   "off": "0x191D",
   "zh": "才能够生存下去！！"
  },
  {
   "off": "0x1952",
   "zh": "…………"
  },
  {
   "off": "0x1994",
   "zh": "要让地球联邦的无能之辈们领教！为了明天的未来！"
  },
  {
   "off": "0x19B4",
   "zh": "我等吉翁公国国民、必须奋起而战！"
  },
  {
   "off": "0x19CE",
   "zh": "……吉翁万岁！"
  },
  {
   "off": "0x1ABE",
   "zh": "……看来是出现了啊"
  },
  {
   "off": "0x1AEF",
   "zh": "嗯？贵官是……"
  },
  {
   "off": "0x1B18",
   "zh": "我是强尼莱汀少佐"
  },
  {
   "off": "0x1B23",
   "zh": "奉基西莉亚阁下之命、前来支援贵队"
  },
  {
   "off": "0x1B3D",
   "zh": "多多关照了"
  },
  {
   "off": "0x1B66",
   "zh": "彼此彼此、能与真红闪电并肩作战、是我的荣幸"
  },
  {
   "off": "0x1B7D",
   "zh": "还请多多指教"
  },
  {
   "off": "0x1BAB",
   "zh": "……夏亚大佐！"
  },
  {
   "off": "0x1BD3",
   "zh": "布拉德中佐吗。MS部队的指挥就拜托了！"
  },
  {
   "off": "0x1BE7",
   "zh": "我将驾驶吉翁号、前去迎击高达！"
  },
  {
   "off": "0x1A82",
   "zh": "独立第300战队、开始战斗！"
  },
  {
   "off": "0xFE0A",
   "zh": "难、难道就到此为止了……！"
  },
  {
   "off": "0xFE4A",
   "zh": "糟糕！旗舰要是被击毁、就全完了……"
  },
  {
   "off": "0x1DCD",
   "zh": "到此为止了、高达！"
  },
  {
   "off": "0x1E00",
   "zh": "大、大佐！？"
  },
  {
   "off": "0xFE92",
   "zh": "怎么会……夏亚大佐他！？"
  },
  {
   "off": "0x1E2F",
   "zh": "基西莉亚阁下！吉翁号的识别信号……！"
  },
  {
   "off": "0x1E60",
   "zh": "……我知道"
  },
  {
   "off": "0x1E6B",
   "zh": "哼……赤色彗星、也算是威名扫地了"
  },
  {
   "off": "0x215F",
   "zh": "到此为止了！！"
  },
  {
   "off": "0x218E",
   "zh": "给我沉下去！"
  },
  {
   "off": "0x21C5",
   "zh": "可恶……这家伙！"
  },
  {
   "off": "0x2201",
   "zh": "夏亚你自己、应该也明白！！"
  },
  {
   "off": "0x221E",
   "zh": "真正应该打倒的敌人、到底是谁！！"
  },
  {
   "off": "0x2242",
   "zh": "真正的敌人、不正是扎比家吗！？"
  },
  {
   "off": "0x2286",
   "zh": "对我来说并非如此！！"
  },
  {
   "off": "0x22C3",
   "zh": "可恶……！"
  },
  {
   "off": "0x22FA",
   "zh": "这、这点损伤算什么！"
  },
  {
   "off": "0x2336",
   "zh": "什么！？"
  },
  {
   "off": "0x2387",
   "zh": "刚才……"
  },
  {
   "off": "0x2398",
   "zh": "拉拉对我说了……"
  },
  {
   "off": "0x23AD",
   "zh": "新人类、不是用来互相残杀的工具……"
  },
  {
   "off": "0x2406",
   "zh": "当今这个时代、人们只会把新人类当作杀戮的工具！"
  },
  {
   "off": "0x2430",
   "zh": "拉拉她、本就注定难逃一死……！"
  },
  {
   "off": "0x248D",
   "zh": "可你自己……不也是新人类吗……！！"
  },
  {
   "off": "0x24D1",
   "zh": "……阿姆罗！？"
  },
  {
   "off": "0x2516",
   "zh": "啊……"
  },
  {
   "off": "0x2526",
   "zh": "是了……"
  },
  {
   "off": "0x2554",
   "zh": "我们……"
  },
  {
   "off": "0x2568",
   "zh": "应该做的……事……"
  },
  {
   "off": "0x257F",
   "zh": "现在……终于……明白了……"
  },
  {
   "off": "0x25BC",
   "zh": "咦？阿姆罗……？"
  },
  {
   "off": "0x260F",
   "zh": "『夏亚……并不是敌人……』"
  },
  {
   "off": "0x2638",
   "zh": "阿姆罗……"
  },
  {
   "off": "0x265A",
   "zh": "『塞拉小姐、请忘了我被击坠的事』"
  },
  {
   "off": "0x267D",
   "zh": "『……去协助夏亚的计划吧』"
  },
  {
   "off": "0x26BF",
   "zh": "你是说……要我们协助夏亚吗、阿姆罗！？"
  },
  {
   "off": "0x2710",
   "zh": "怎么回事！？到底、发生了什么！？"
  },
  {
   "off": "0x2789",
   "zh": "…………"
  },
  {
   "off": "0x27B0",
   "zh": "拉拉！？"
  },
  {
   "off": "0x27FF",
   "zh": "『大佐……我很感谢您』"
  },
  {
   "off": "0x2819",
   "zh": "『因为开创出这个契机的、正是大佐您……』"
  },
  {
   "off": "0x2865",
   "zh": "拉拉……"
  },
  {
   "off": "0x28AB",
   "zh": "『人啊……大家……』"
  },
  {
   "off": "0x28C1",
   "zh": "『都像这样活着、膨胀……绽放光辉……』"
  },
  {
   "off": "0x2984",
   "zh": "『夏亚·阿兹纳布尔……我做了对不起你的事……』"
  },
  {
   "off": "0x29CB",
   "zh": "阿姆罗……雷……"
  },
  {
   "off": "0x2A14",
   "zh": "『像我这样的小鬼、杀死了拉拉·辛……』"
  },
  {
   "off": "0x2A3A",
   "zh": "『又未能洞察你的谋划、从中作梗……』"
  },
  {
   "off": "0x2A5F",
   "zh": "『……真的、很抱歉……』"
  },
  {
   "off": "0x2A90",
   "zh": "…………"
  },
  {
   "off": "0x2AA3",
   "zh": "白色基地队！所有还能行动的单位、全部后撤！"
  },
  {
   "off": "0x2AC8",
   "zh": "赤色彗星不是我们的敌人！"
  },
  {
   "off": "0x2AE4",
   "zh": "我们应当讨伐的敌人、就在那座要塞之中！！"
  },
  {
   "off": "0xFED2",
   "zh": "…………"
  },
  {
   "off": "0xFEE5",
   "zh": "是叫我们别白白消耗战力吗。明白了……阿姆罗"
  },
  {
   "off": "0xFF32",
   "zh": "可恶！居然就这么擅自死掉了！！"
  },
  {
   "off": "0xFF7A",
   "zh": "夏亚大佐！木马正在后撤……"
  },
  {
   "off": "0xFFB4",
   "zh": "嗯、我知道"
  },
  {
   "off": "0xFFE8",
   "zh": "那、到底是……"
  },
  {
   "off": "0x1001B",
   "zh": "现在只需专心击退残余的敌军部队、玛利根"
  },
  {
   "off": "0x10042",
   "zh": "他们的意图、我心里有数"
  },
  {
   "off": "0x1007E",
   "zh": "……！遵命！！"
  },
  {
   "off": "0x2B2E",
   "zh": "…………"
  },
  {
   "off": "0x2B41",
   "zh": "阿姆罗……雷……"
  },
  {
   "off": "0x2B55",
   "zh": "你是要我不再作为夏亚、而是作为卡斯巴尔去行动……"
  },
  {
   "off": "0x2B78",
   "zh": "……是这个意思吧"
  },
  {
   "off": "0x2B8F",
   "zh": "…………"
  },
  {
   "off": "0x2BC7",
   "zh": "居然打倒了木马……这仗打得漂亮"
  },
  {
   "off": "0x2BFC",
   "zh": "……基西莉亚阁下？"
  },
  {
   "off": "0x2C24",
   "zh": "既已成功击退木马、联邦再无值得警惕的敌手"
  },
  {
   "off": "0x2C41",
   "zh": "以这S区域为基点、一举歼灭敌军舰队！"
  },
  {
   "off": "0x100BA",
   "zh": "…………"
  },
  {
   "off": "0x100C3",
   "zh": "见大局已定、就跑来捞取战功了吗……这只母狐狸"
  },
  {
   "off": "0x100FF",
   "zh": "迪拉兹阁下……？"
  },
  {
   "off": "0x10127",
   "zh": "既然基西莉亚舰队已经到场、我军战力便再无必要"
  },
  {
   "off": "0x10140",
   "zh": "迪拉兹舰队后撤、转去支援其他区域！"
  },
  {
   "off": "0x101F2",
   "zh": "迪、迪拉兹阁下……"
  },
  {
   "off": "0x1021B",
   "zh": "唔……"
  },
  {
   "off": "0x1022D",
   "zh": "全机返航！我队现在放弃阿·巴瓦·库！"
  },
  {
   "off": "0x2C82",
   "zh": "哼……迪拉兹那家伙、是想对基连尽忠吗"
  },
  {
   "off": "0x2C9B",
   "zh": "不过、也罢。若只是扫平当面之敌、手头的战力也足够了"
  },
  {
   "off": "0x2CF4",
   "zh": "S区域全体将士听令！"
  },
  {
   "off": "0x2D03",
   "zh": "我军现在开始、对联邦军发起总攻！"
  },
  {
   "off": "0x2EB7",
   "zh": "呜……啊啊……"
  },
  {
   "off": "0x2ECB",
   "zh": "我也要……去拉拉那里了吗……"
  },
  {
   "off": "0x2EF7",
   "zh": "『新人类、不是用来互相残杀的、对吧？』"
  },
  {
   "off": "0x2F49",
   "zh": "拉拉……？"
  },
  {
   "off": "0x2F73",
   "zh": "『呵呵……我随时都能和阿姆罗一起玩呀……』"
  },
  {
   "off": "0x2FA2",
   "zh": "啊……说得也是呢、拉拉……"
  },
  {
   "off": "0x2FBD",
   "zh": "我还有……能够回去的地方……"
  },
  {
   "off": "0x4D0F",
   "zh": "我岂能在此被击沉……！"
  },
  {
   "off": "0x4D24",
   "zh": "剩下的就拜托了！格瓦利布、后撤！！"
  },
  {
   "off": "0x2FF5",
   "zh": "嗯……是阿姆罗吗！？"
  },
  {
   "off": "0x3000",
   "zh": "什么？要我们撤出这里？"
  },
  {
   "off": "0x3010",
   "zh": "这样啊、既然联邦赢定了的话……"
  },
  {
   "off": "0x3048",
   "zh": "怎么回事？"
  },
  {
   "off": "0x304F",
   "zh": "这声音……？是阿姆罗吗！？"
  },
  {
   "off": "0x305F",
   "zh": "……你说什么！？"
  },
  {
   "off": "0x306A",
   "zh": "联邦军要发起总攻？没必要勉强作战！？"
  },
  {
   "off": "0x3082",
   "zh": "我知道了、阿姆罗！"
  },
  {
   "off": "0x30B2",
   "zh": "啊……！？"
  },
  {
   "off": "0x30ED",
   "zh": "『不要放弃、塞拉小姐！』"
  },
  {
   "off": "0x3135",
   "zh": "阿姆罗！？这声音是阿姆罗吗？"
  },
  {
   "off": "0x3151",
   "zh": "……咦？附近有友军？"
  },
  {
   "off": "0x316C",
   "zh": "我明白了、阿姆罗！"
  },
  {
   "off": "0x31A6",
   "zh": "阿姆罗……！？"
  },
  {
   "off": "0x31AF",
   "zh": "……什么！再不下达弃舰命令就会全灭！？"
  },
  {
   "off": "0x31C6",
   "zh": "我知道了！！"
  },
  {
   "off": "0x31FB",
   "zh": "全员弃舰！放弃白色基地！"
  },
  {
   "off": "0x320E",
   "zh": "各员乘联络艇、立刻撤离！！"
  },
  {
   "off": "0x4503",
   "zh": "呜哇！真的来了！"
  },
  {
   "off": "0x4532",
   "zh": "凯、小心！那台MS……速度很快！！"
  },
  {
   "off": "0x4577",
   "zh": "哦……没想到联邦也有红色的MS啊！"
  },
  {
   "off": "0x4590",
   "zh": "那家伙配不配得上红色、就由本大爷来测一测吧！"
  },
  {
   "off": "0x45E3",
   "zh": "哈、也不过如此嘛！联邦的红色MS！"
  },
  {
   "off": "0x4610",
   "zh": "那、那当然了！我这台可是支援用的机体！"
  },
