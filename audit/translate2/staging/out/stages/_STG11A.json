 ],
 "title_zh": "哈曼的嘲弄",
 "briefing": [
  {
   "off": "0x19AC7B",
   "zh": "现在、在月球轨道上……"
  },
  {
   "off": "0x19AC8B",
   "zh": "布雷克斯准将正与提坦斯、新吉翁进行会谈"
  },
  {
   "off": "0x19ACA7",
   "zh": "我方并不希望战斗、但视会谈结果而定、也可能发生交火"
  },
  {
   "off": "0x19ACCC",
   "zh": "为防万一、希望各位切勿疏于交战准备"
  },
  {
   "off": "0x19AD15",
   "zh": "此外、就提坦斯与新吉翁的战力、在此补充说明"
  },
  {
   "off": "0x19AD33",
   "zh": "提坦斯是以旗舰多戈斯·基亚为核心的机动部队、"
  },
  {
   "off": "0x19AD4D",
   "zh": "除已确认的量产机之外、似乎还部署了部分新型机"
  },
  {
   "off": "0x19AD73",
   "zh": "而另一方的新吉翁……"
  },
  {
   "off": "0x19AD85",
   "zh": "这边的主力是称为加撒系列的性能较低的量产机、"
  },
  {
   "off": "0x19ADA7",
   "zh": "士官级则配备高性能机、编制呈两极分化"
  },
  {
   "off": "0x19ADF0",
   "zh": "提坦斯与新吉翁是各具特点的两支军队"
  },
  {
   "off": "0x19AE0C",
   "zh": "若同时与两方为敌、想必免不了一场苦战"
  },
  {
   "off": "0x19AE27",
   "zh": "战斗时须充分理解各自的特点、灵活周旋才行"
  }
 ],
 "blocks": [
  {
   "off": "0x17D6",
   "zh": "容我来介绍……"
  },
  {
   "off": "0xE122",
   "zh": "扎比家正统的继承人、米涅瓦·扎比公主！"
  },
  {
   "off": "0x1808",
   "zh": "……！？"
  },
  {
   "off": "0x182B",
   "zh": "……加米托夫阁下"
  },
  {
   "off": "0x184F",
   "zh": "…………"
  },
  {
   "off": "0x185B",
   "zh": "哈曼·卡恩……为何那个男人会在这里？"
  },
  {
   "off": "0x1892",
   "zh": "…………"
  },
  {
   "off": "0x189B",
   "zh": "恕在下介绍来迟、我是扎夫特的劳·鲁·克鲁泽"
  },
  {
   "off": "0x18B5",
   "zh": "各位就当我是此次会谈的……观察员之类的角色吧"
  },
  {
   "off": "0x18F1",
   "zh": "你们这些宇宙人相互勾结、还敢惺惺作态……！"
  },
  {
   "off": "0x1926",
   "zh": "住口！此乃米涅瓦大人御前！"
  },
  {
   "off": "0x1955",
   "zh": "唔……"
  },
  {
   "off": "0x1976",
   "zh": "……来、米涅瓦大人"
  },
  {
   "off": "0x19A2",
   "zh": "……嗯"
  },
  {
   "off": "0x19E9",
   "zh": "奥古的布雷克斯·弗拉、提坦斯的加米托夫·海曼"
  },
  {
   "off": "0x1A02",
   "zh": "首先、两位爽快应允会谈之邀、我深感欣慰"
  },
  {
   "off": "0x1A20",
   "zh": "我、吉翁·戴肯的继承人米涅瓦·扎比……"
  },
  {
   "off": "0x1A3A",
   "zh": "愿以宇宙居民代表的身份、与各位共筑富有成果的关系"
  },
  {
   "off": "0x1A79",
   "zh": "…………"
  },
  {
   "off": "0x1A82",
   "zh": "在此之前、我有一事想问"
  },
  {
   "off": "0x1AB1",
   "zh": "……啊！夏亚！！"
  },
  {
   "off": "0x1ABE",
   "zh": "你是夏亚没错吧！！"
  },
  {
   "off": "0x1AE5",
   "zh": "…………"
  },
  {
   "off": "0x1B09",
   "zh": "果然是夏亚！！"
  },
  {
   "off": "0x1B13",
   "zh": "能再见到你真开心！你陪我玩过、我还记得哦！！"
  },
  {
   "off": "0x1B4E",
   "zh": "2岁时的事……米涅瓦大人您当真记得？"
  },
  {
   "off": "0x1B8A",
   "zh": "咦、这个嘛……"
  },
  {
   "off": "0x1BB6",
   "zh": "（……米涅瓦大人、请照这样继续说下去）"
  },
  {
   "off": "0x1BF1",
   "zh": "（啊、嗯、嗯……）"
  },
  {
   "off": "0x1BFF",
   "zh": "长年的侦察辛苦你了、夏亚"
  },
  {
   "off": "0x1C16",
   "zh": "我等新吉翁行动的时刻、终于到来了"
  },
  {
   "off": "0x1C2B",
   "zh": "夏亚、愿你将力量献于扎比家的复兴……"
  },
  {
   "off": "0x1C68",
   "zh": "哈曼！！"
  },
  {
   "off": "0x1C98",
   "zh": "……呀！！"
  },
  {
   "off": "0x1CC7",
   "zh": "你竟敢把米涅瓦教成这副样子！"
  },
  {
   "off": "0x1CDA",
   "zh": "把人养成满脑子偏见、你意欲何为！？"
  },
  {
   "off": "0x1D0D",
   "zh": "此乃米涅瓦大人御前！不得再放肆！！"
  },
  {
   "off": "0x1D5C",
   "zh": "……！？"
  },
  {
   "off": "0x1DA3",
   "zh": "……进展如何？"
  },
  {
   "off": "0x1DD4",
   "zh": "轮机部发生小型爆炸……一切照计划、损伤轻微"
  },
  {
   "off": "0x1E15",
   "zh": "……撤离吧"
  },
  {
   "off": "0x1E21",
   "zh": "记得要让他们发现……从正面走"
  },
  {
   "off": "0x1E48",
   "zh": "哈曼大人！向您报告……"
  },
  {
   "off": "0x1E9A",
   "zh": "……是蓄意破坏！？"
  },
  {
   "off": "0x1F11",
   "zh": "哼……"
  },
  {
   "off": "0x1F39",
   "zh": "西罗克！？"
  },
  {
   "off": "0x1F78",
   "zh": "怎么回事、西罗克、那场爆炸是你指使的？"
  },
  {
   "off": "0x1FB8",
   "zh": "此刻就算矢口否认、也无法让那个女人信服"
  },
  {
   "off": "0x1FD9",
   "zh": "看来是有哪位贵人、想把我们塑造成恶人啊……"
  },
  {
   "off": "0x201B",
   "zh": "哼……"
  },
  {
   "off": "0x2047",
   "zh": "无论如何、这是个绝好的机会、在场各势力的首脑……"
  },
  {
   "off": "0x2068",
   "zh": "只要将他们一举铲除……"
  },
  {
   "off": "0x2099",
   "zh": "西罗克、你这家伙……！！"
  },
  {
   "off": "0x210A",
   "zh": "克鲁泽队长！！"
  },
  {
   "off": "0x2131",
   "zh": "扎夫特……！？"
  },
  {
   "off": "0x2155",
   "zh": "呵呵……能瞬间切换目标、这点确实了得……"
  },
  {
   "off": "0x2176",
   "zh": "但你以为凭这种见机行事、就能改变大势……"
  },
  {
   "off": "0x219A",
   "zh": "作为谋士、你终究是二流！西罗克！"
  },
  {
   "off": "0x21CC",
   "zh": "……啧！"
  },
  {
   "off": "0x2261",
   "zh": "追！别让他跑了！！"
  },
  {
   "off": "0x22AF",
   "zh": "布雷克斯准将！趁现在赶快撤离！！"
  },
  {
   "off": "0x22E3",
   "zh": "啊、啊啊……！"
  },
  {
   "off": "0x2304",
   "zh": "怎么回事！？"
  },
  {
   "off": "0x2327",
   "zh": "确认新吉翁旗舰发生爆炸！"
  },
  {
   "off": "0x2338",
   "zh": "……！这是！！"
  },
  {
   "off": "0x236A",
   "zh": "消失了……！？"
  },
  {
   "off": "0x2399",
   "zh": "可恶！是奥古搞的鬼吗！！"
  },
  {
   "off": "0x23CE",
   "zh": "……巴斯克大佐！！"
  },
  {
   "off": "0x23F4",
   "zh": "MS部队、出击！救出加米托夫阁下！！"
  },
  {
   "off": "0x242E",
   "zh": "新吉翁、提坦斯均已展开MS！！"
  },
  {
   "off": "0x245C",
   "zh": "……不好！MS部队立即迎击敌机！"
  },
  {
   "off": "0x2471",
   "zh": "全体机组、立刻出击！！"
  },
  {
   "off": "0x24E6",
   "zh": "糟了！克瓦特罗大尉他们……！！"
  },
  {
   "off": "0x24A6",
   "zh": "居然到这般地步……全员撤离！！"
  },
  {
   "off": "0x33FD",
   "zh": "唔……！"
  },
  {
   "off": "0x342C",
   "zh": "哈、哈斯勒提督！请您快撤离……！！"
  },
  {
   "off": "0x3466",
   "zh": "……没用的、已经来不及了"
  },
  {
   "off": "0x34A5",
   "zh": "新生的吉翁……"
  },
  {
   "off": "0x34B9",
   "zh": "愿荣光……归于新吉翁！！"
  },
  {
   "off": "0xE4EE",
   "zh": "哈斯勒提督……"
  },
  {
   "off": "0xE4F7",
   "zh": "若你不曾效忠错了对象、你我本可携手并肩……"
  },
  {
   "off": "0xE516",
   "zh": "…………"
  },
  {
   "off": "0x34F9",
   "zh": "哈、哈斯勒提督他！！"
  },
  {
   "off": "0x3505",
   "zh": "不好！全舰、后退！！"
  },
  {
   "off": "0x353C",
   "zh": "新吉翁舰队、正在后退！"
  },
  {
   "off": "0x356B",
   "zh": "不要穷追！当务之急是迎击提坦斯！！"
  },
  {
   "off": "0x28DE",
   "zh": "在那里！别让他们跑了！！"
  },
  {
   "off": "0x2959",
   "zh": "可恶……那边也被堵死了吗！！"
  },
  {
   "off": "0x296D",
   "zh": "准将、这边走！！"
  },
  {
   "off": "0x2993",
   "zh": "等等、克瓦特罗大尉！蕾柯亚少尉还……"
  },
  {
   "off": "0x29C7",
   "zh": "现在准将您的安全最要紧！……快走！"
  },
  {
   "off": "0x29FA",
   "zh": "可、可是……"
  },
  {
   "off": "0x2A43",
   "zh": "找到了、奥古的家伙！！"
  },
  {
   "off": "0x2AA4",
   "zh": "……呃啊！！"
  },
  {
   "off": "0x2ACA",
   "zh": "不好！布雷克斯准将！？"
  },
  {
   "off": "0x2B24",
   "zh": "……布雷克斯准将！！"
  },
  {
   "off": "0x2B57",
   "zh": "克、克瓦特罗大尉……"
  },
  {
   "off": "0x2B7D",
   "zh": "准将！……请您撑住！！"
  },
  {
   "off": "0x2BB5",
   "zh": "宽慰的话……就不必了……我……已经、不行了……"
  },
  {
   "off": "0x2BD1",
   "zh": "你、由你……由你来指挥奥古……"
  },
  {
   "off": "0x2BE7",
   "zh": "夏亚……呃！"
  },
  {
   "off": "0x2C12",
   "zh": "准、准将……！？"
  },
  {
   "off": "0x2C47",
   "zh": "…………"
  },
  {
   "off": "0x2C8F",
   "zh": "布雷克斯准将！"
  },
  {
   "off": "0x2CAF",
   "zh": "加米托夫阁下还没有撤出来吗！？"
  },
  {
   "off": "0x2CE1",
   "zh": "是、目前还没有……"
  },
  {
   "off": "0x2D09",
   "zh": "可恶、西罗克这家伙！到底在搞什么名堂……"
  },
  {
   "off": "0x2D42",
   "zh": "……加米托夫阁下"
  },
  {
   "off": "0x2D66",
   "zh": "唔？是西罗克啊、其他人都到哪里去了？"
  },
  {
   "off": "0x2D98",
   "zh": "呵呵……"
  },
  {
   "off": "0x2DA9",
   "zh": "这里只有我们两人……加米托夫阁下"
  },
  {
   "off": "0x2DBE",
   "zh": "而且、马上就只剩我一个了……"
  },
  {
   "off": "0x2E00",
   "zh": "西罗克……你这家伙"
  },
  {
   "off": "0x2E24",
   "zh": "……就是这么回事、抱歉了、加米托夫"
  },
  {
   "off": "0xE152",
   "zh": "…………"
  },
  {
   "off": "0xE182",
   "zh": "……西罗克！加米托夫阁下怎么样了！？"
  },
  {
   "off": "0xE1B5",
   "zh": "加米托夫阁下死了、死在新吉翁手上"
  },
  {
   "off": "0xE1E9",
   "zh": "……什么！？"
  },
  {
   "off": "0xE20D",
   "zh": "这是阁下的遗命、今后提坦斯由我指挥"
  },
  {
   "off": "0xE247",
   "zh": "岂、岂有此理！！"
  },
  {
   "off": "0xE251",
   "zh": "加米托夫阁下怎会把后事托付给你这种东西……"
  },
  {
   "off": "0xE26C",
   "zh": "！？难道说、西罗克……是你干的！！"
  },
  {
   "off": "0xE2B3",
   "zh": "竟敢违抗加米托夫阁下的遗志、您疯了吗、巴斯克大佐"
  },
  {
   "off": "0xE2F6",
   "zh": "……你这家伙！？"
  },
  {
   "off": "0xE324",
   "zh": "呃！！"
  },
  {
   "off": "0xE332",
   "zh": "可、可恶的西罗克……你算计了我……！！"
  },
  {
   "off": "0xE367",
   "zh": "呵呵……"
  },
  {
   "off": "0xE3F2",
   "zh": "告提坦斯全体将士！！"
  },
  {
   "off": "0xE401",
   "zh": "加米托夫阁下遭新吉翁与奥古合谋暗杀身亡！！"
  },
  {
   "off": "0xE422",
   "zh": "这等卑劣至极的行径、绝不能姑息！"
  },
  {
   "off": "0xE443",
   "zh": "提坦斯的将士们！请助我一臂之力！！"
  },
  {
   "off": "0xE45D",
   "zh": "让我们一同为阁下雪恨！"
  },
  {
   "off": "0xE396",
   "zh": "哦……巴斯克·欧姆居然也被干掉了"
  },
  {
   "off": "0xE3AD",
   "zh": "这倒省去了我动手铲除的工夫……呵呵"
  },
  {
   "off": "0x2E4E",
   "zh": "克瓦特罗大尉他们有联络吗！？"
  },
  {
   "off": "0x2E79",
   "zh": "没有、还没……！！"
  },
  {
   "off": "0x2EA0",
   "zh": "可恶……大尉、你可要平安无事啊……！！"
  },
  {
   "off": "0x2EDC",
   "zh": "……蕾柯亚少尉！"
  },
  {
   "off": "0x2F01",
   "zh": "啊……克瓦特罗……大尉"
  },
  {
   "off": "0x2F29",
   "zh": "蕾柯亚少尉！你没事啊！！"
  },
  {
   "off": "0x2F55",
   "zh": "大尉您也平安真是太好了……那个、布雷克斯准将呢……？"
  },
  {
   "off": "0x2F8C",
   "zh": "…………"
  },
  {
   "off": "0x2F96",
   "zh": "……准将倒在了凶弹之下"
  },
  {
   "off": "0x2FC1",
   "zh": "……！？"
  },
  {
   "off": "0x2FE4",
   "zh": "我们再磨蹭下去、也会落得同样的下场"
  },
  {
   "off": "0x3001",
   "zh": "赶快去机库、蕾柯亚少尉"
  },
  {
   "off": "0x3024",
   "zh": "……等一下！！"
  },
  {
   "off": "0x303B",
   "zh": "那边有士兵守着！要过就走这边！"
  },
  {
   "off": "0x3071",
   "zh": "……你是？"
  },
  {
   "off": "0x3094",
   "zh": "我是捷多·亚西塔"
  },
  {
   "off": "0x309F",
   "zh": "我妹妹被新吉翁一个叫格雷米的家伙带走了"
  },
  {
   "off": "0x30BC",
   "zh": "我偷偷溜进了这艘战舰、结果这场骚乱让警备变严了……"
  },
  {
   "off": "0x30E1",
   "zh": "我帮你们逃出去、能不能也带上我？"
  },
  {
   "off": "0x3115",
   "zh": "捷多·亚西塔吗……好、我们合作吧"
  },
  {
   "off": "0x3142",
