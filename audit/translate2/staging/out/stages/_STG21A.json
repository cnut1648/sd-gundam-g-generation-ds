 "title_zh": "驰骋宇宙",
 "briefing": [
  {
   "off": "0x19C77E",
   "zh": "后撤的提坦斯舰队目前正在重整战力、"
  },
  {
   "off": "0x19C797",
   "zh": "重启对PLANT的核攻击、只是时间问题"
  },
  {
   "off": "0x19C7B3",
   "zh": "为防止地球与宇宙的全面对决、这一点必须绝对阻止"
  },
  {
   "off": "0x19C802",
   "zh": "那么、下面由我说明作战内容"
  },
  {
   "off": "0x19C813",
   "zh": "提坦斯舰队虽在PLANT周边广泛展开……"
  },
  {
   "off": "0x19C82E",
   "zh": "但装备核武的、只是其中一部分部队、"
  },
  {
   "off": "0x19C841",
   "zh": "这部分目前正由迪安娜回归军设法咬住"
  },
  {
   "off": "0x19C85B",
   "zh": "我们的目标、是趁此空隙突袭提坦斯本队……"
  },
  {
   "off": "0x19C87A",
   "zh": "摧毁其指挥系统、使提坦斯全军瘫痪"
  },
  {
   "off": "0x19C89A",
   "zh": "另外、关于敌方战力……"
  },
  {
   "off": "0x19C8AA",
   "zh": "有西罗克麾下的强化人部队、以及那台使用光之翼的黑色MS等……"
  },
  {
   "off": "0x19C8D0",
   "zh": "与上次几乎相同的战力、正展开于旗舰多戈斯·基亚附近"
  },
  {
   "off": "0x19C8EE",
   "zh": "此外、虽然尚未得到确认……"
  },
  {
   "off": "0x19C8FD",
   "zh": "也有情报称、目击到了疑似迪安娜回归军的机体"
  },
  {
   "off": "0x19C942",
   "zh": "迪安娜回归军？难道说菲尔他们要协助我们……"
  },
  {
   "off": "0x19C984",
   "zh": "金卡拉姆舰队始终按兵不动、这一点也令人在意啊"
  },
  {
   "off": "0x19C9A0",
   "zh": "这场战斗……恐怕会比我们预想的更加激烈啊"
  }
 ],
 "blocks": [
  {
   "off": "0x177A",
   "zh": "全舰、已进入指定位置！"
  },
  {
   "off": "0x17B5",
   "zh": "好！立刻发动总攻！！"
  },
  {
   "off": "0x17C6",
   "zh": "把调整者们的据点炸得连渣都不剩……"
  },
  {
   "off": "0x1803",
   "zh": "什、什么！？"
  },
  {
   "off": "0x1833",
   "zh": "那、那是……迪安娜回归军！？"
  },
  {
   "off": "0x185E",
   "zh": "迪安娜回归军各战队、已开始行动！"
  },
  {
   "off": "0x1891",
   "zh": "好！全舰最大战速！！"
  },
  {
   "off": "0x18A0",
   "zh": "趁迪安娜回归军咬住提坦斯、直捣敌军本阵！！"
  },
  {
   "off": "0x18E1",
   "zh": "发现了！是提坦斯主力！！"
  },
  {
   "off": "0x1917",
   "zh": "好！全员一级战斗配置！！"
  },
  {
   "off": "0x1928",
   "zh": "一定要阻止提坦斯攻击PLANT！！"
  },
  {
   "off": "0x195F",
   "zh": "不射杀他人、便无法守护的未来……"
  },
  {
   "off": "0x1972",
   "zh": "而被击倒之人、再无未来……"
  },
  {
   "off": "0x1982",
   "zh": "亲手染血所换来的东西、究竟有何价值、我并不知晓"
  },
  {
   "off": "0x19A7",
   "zh": "但是、无论核弹还是那道光、都绝不能让它们射向彼此……"
  },
  {
   "off": "0x19CB",
   "zh": "此刻、唯将这份心愿铭记于胸……诸位、拜托了……！！"
  },
  {
   "off": "0x1A0C",
   "zh": "全员、开始战斗！！"
  },
  {
   "off": "0xEDA6",
   "zh": "……不好！这艘舰要是被击毁的话……！"
  },
  {
   "off": "0x34EA",
   "zh": "这、这是……！到底是在开什么玩笑！？"
  },
  {
   "off": "0x3528",
   "zh": "不、不行了！主引擎已经到达临界……"
  },
  {
   "off": "0xFB7A",
   "zh": "呜哦哦！？御、御大将……！！"
  },
  {
   "off": "0x1250A",
   "zh": "啧、斯特罗这家伙！真是个废物！"
  },
  {
   "off": "0xFB1E",
   "zh": "骗人！？"
  },
  {
   "off": "0xFB30",
   "zh": "战斗都还完全没到高潮呢、为什么会这样！？"
  },
  {
   "off": "0x1247E",
   "zh": "梅丽贝尔小姐！"
  },
  {
   "off": "0x124AE",
   "zh": "啧！梅丽贝尔这家伙！！"
  },
  {
   "off": "0x124BB",
   "zh": "从运河人那里把她捡回来的恩情、都还没让她报答呢！"
  },
  {
   "off": "0xFBCF",
   "zh": "唔……不好！快让威尔盖姆后退！！"
  },
  {
   "off": "0xFBFB",
   "zh": "后、后退又能退到哪里去！这艘船已经完蛋了啊！！"
  },
  {
   "off": "0xFC2E",
   "zh": "啊、喂！不许擅自离开岗位！！"
  },
  {
   "off": "0xFC6B",
   "zh": "不、公子！这艘船已经完了！"
  },
  {
   "off": "0xFCA3",
   "zh": "米哈埃尔大佐！？"
  },
  {
   "off": "0xFCD1",
   "zh": "有意与我一同下船的人、听我指挥！弃舰！！"
  },
  {
   "off": "0xFD14",
   "zh": "我不许你们擅自下船！"
  },
  {
   "off": "0xFD43",
   "zh": "大家的意思是、我们已经无法再追随公子您了！"
  },
  {
   "off": "0xFD7F",
   "zh": "……！你们这些家伙……早有预谋！！"
  },
  {
   "off": "0xFDAD",
   "zh": "我可没有搞阴谋的头脑、也没那个胆量！！"
  },
  {
   "off": "0xFDD2",
   "zh": "这里是米哈埃尔！！全体船员立刻弃舰！！"
  },
  {
   "off": "0xFE08",
   "zh": "米哈埃尔大佐！！"
  },
  {
   "off": "0xFE43",
   "zh": "连部下都弃我而去……我……"
  },
  {
   "off": "0xFE57",
   "zh": "哈哈、哈哈哈……"
  },
  {
   "off": "0xFE63",
   "zh": "那么、事到如今……！"
  },
  {
   "off": "0x2562",
   "zh": "那是！！精神感应高达！？"
  },
  {
   "off": "0x25A0",
   "zh": "到头来、能依靠的只有自己一个！"
  },
  {
   "off": "0x25B3",
   "zh": "我要用这黑色玩偶破坏一切、建立起我的王国！！"
  },
  {
   "off": "0xFEA7",
   "zh": "啊啊！！"
  },
  {
   "off": "0xFEAF",
   "zh": "萝拉！回到我的身边来！"
  },
  {
   "off": "0xFEE0",
   "zh": "请、请住手！！我可是男人啊！"
  },
  {
   "off": "0xFF28",
   "zh": "那又有什么关系！！"
  },
  {
   "off": "0xFF38",
   "zh": "我要你成为我的白银女王、与我共同将世界……"
  },
  {
   "off": "0xFF73",
   "zh": "您一定是疯了！！"
  },
  {
   "off": "0xFF7F",
   "zh": "我既不是萝拉、也不是您的人偶！！"
  },
  {
   "off": "0xFFAE",
   "zh": "萝拉！我……！！"
  },
  {
   "off": "0xFFE2",
   "zh": "格温·莱因福德……"
  },
  {
   "off": "0xFFEE",
   "zh": "以你的才干、本该有别的路可走才是……"
  },
  {
   "off": "0x10011",
   "zh": "何其愚蠢……"
  },
  {
   "off": "0x1003E",
   "zh": "我、我只是……"
  },
  {
   "off": "0x10053",
   "zh": "想建立由月之民……为月之民而立的国家……"
  },
  {
   "off": "0x10076",
   "zh": "是我……太愚蠢了吗……"
  },
  {
   "off": "0x12546",
   "zh": "为、为什么！？菲尔少佐啊啊啊！！"
  },
  {
   "off": "0x1258A",
   "zh": "你们误入歧途、追根溯源、皆因我之不明……"
  },
  {
   "off": "0x125A9",
   "zh": "……原谅我、菲尔"
  },
  {
   "off": "0x125DA",
   "zh": "……波！？"
  },
  {
   "off": "0x100B6",
   "zh": "菲、菲尔少佐！"
  },
  {
   "off": "0x100CB",
   "zh": "我、我……呜啊啊！！"
  },
  {
   "off": "0x12612",
   "zh": "只因让你陪我走上了这条路……"
  },
  {
   "off": "0x12623",
   "zh": "……对不起、波"
  },
  {
   "off": "0x282C",
   "zh": "我、我竟然会败……！"
  },
  {
   "off": "0x2846",
   "zh": "竟然要输了吗……！？"
  },
  {
   "off": "0x2885",
   "zh": "…………"
  },
  {
   "off": "0x288E",
   "zh": "一味追求理性、轻侮人的可能性、这就是你的败因"
  },
  {
   "off": "0x28B0",
   "zh": "……西罗克"
  },
  {
   "off": "0x10C26",
   "zh": "（绝不能让你们这些木星人搅乱地球……）"
  },
  {
   "off": "0x10C4C",
   "zh": "（你的失败、本就是注定的）"
  },
  {
   "off": "0x10C61",
   "zh": "西罗克……"
  },
  {
   "off": "0x10C92",
   "zh": "…………"
  },
  {
   "off": "0x10C9B",
   "zh": "你、你竟敢……！！"
  },
  {
   "off": "0x10CA7",
   "zh": "竟敢杀了西罗克！杀了那个成为我栖身之巢的男人！！"
  },
  {
   "off": "0x28DF",
   "zh": "可恶！卡缪、唯独你……！！"
  },
  {
   "off": "0x2918",
   "zh": "……捷利特！？"
  },
  {
   "off": "0x10CEA",
   "zh": "去死吧、卡缪！！"
  },
  {
   "off": "0x10D26",
   "zh": "……唔！？"
  },
  {
   "off": "0x10D54",
   "zh": "把我逼上战场的人就是你！"
  },
  {
   "off": "0x10D6F",
   "zh": "不把这份怨恨还给你、我咽不下这口气！！"
  },
  {
   "off": "0x10DB4",
   "zh": "我不是杀人凶手！！"
  },
  {
   "off": "0x10DF2",
   "zh": "那我就亲手杀了你！"
  },
  {
   "off": "0x10E0F",
   "zh": "那样你就不用再战斗了吧！"
  },
  {
   "off": "0x10E52",
   "zh": "唔……我会让你得逞吗！！"
  },
  {
   "off": "0x10E92",
   "zh": "卡、卡缪……！"
  },
  {
   "off": "0x10EA7",
   "zh": "你是我的……！！"
  },
  {
   "off": "0x2946",
   "zh": "大家都在死去……！"
  },
  {
   "off": "0x2953",
   "zh": "这种死法、你就满足了吗！？有谁会高兴啊！？"
  },
  {
   "off": "0x2971",
   "zh": "可恶啊啊！！"
  },
  {
   "off": "0x29A2",
   "zh": "玛、玛雅……"
  },
  {
   "off": "0x29B5",
   "zh": "我……"
  },
  {
   "off": "0x10F5E",
   "zh": "…………"
  },
  {
   "off": "0x10F67",
   "zh": "这样的死法你就满足了吗……？捷利特、你……！"
  },
  {
   "off": "0x10F82",
   "zh": "可恶！！"
  },
  {
   "off": "0x29EB",
   "zh": "唔……！"
  },
  {
   "off": "0x2A1F",
   "zh": "卡迪珍娜小姐！？"
  },
  {
   "off": "0x2A3F",
   "zh": "为什么会这样……"
  },
  {
   "off": "0x2A48",
   "zh": "果然不对劲啊……卡迪珍娜小姐……"
  },
  {
   "off": "0x2A81",
   "zh": "可恶啊！！"
  },
  {
   "off": "0x2A95",
   "zh": "你们所有人……"
  },
  {
   "off": "0x2AA8",
   "zh": "……所有人都合起伙来愚弄我啊啊！"
  },
  {
   "off": "0xFA26",
   "zh": "……成功了吗！？"
  },
  {
   "off": "0x236C",
   "zh": "倒X居然……！"
  },
  {
   "off": "0x239C",
   "zh": "……罗兰！？"
  },
  {
   "off": "0x23C0",
   "zh": "我、我没事……总算撑过来了……"
  },
  {
   "off": "0x23D4",
   "zh": "只是、机体已经……"
  },
  {
   "off": "0x23E1",
   "zh": "……接下来、就拜托各位了"
  },
  {
   "off": "0x2414",
   "zh": "好、这下打倒倒X了！接下来集中扫荡残敌！"
  },
  {
   "off": "0xFA56",
   "zh": "可恶！这种程度的攻击算得了什么！！"
  },
  {
   "off": "0xFA8E",
   "zh": "什、什么！？"
  },
  {
   "off": "0xFABE",
   "zh": "这是！月、月光蝶居然！？"
  },
  {
   "off": "0x245B",
   "zh": "倒、倒X它……"
  },
  {
   "off": "0x2493",
   "zh": "消失了……？"
  },
  {
   "off": "0x24C8",
   "zh": "是说他被月光蝶的暴走卷进去了吗？"
  },
  {
   "off": "0x250C",
   "zh": "总之、倒X的威胁算是就此消除了"
  },
  {
   "off": "0x2528",
   "zh": "好！接下来集中扫荡残敌！"
  },
  {
   "off": "0x1CEE",
   "zh": "果然……！月光蝶是毁灭人类的恶魔之光！"
  },
  {
   "off": "0x1D08",
   "zh": "这么危险的武器、绝不该存在于这个世界！！"
  },
  {
   "off": "0x1D43",
   "zh": "哈哈哈！口气倒是不小！！"
  },
  {
   "off": "0x1D57",
   "zh": "但倒X和黑历史、可不是光凭一腔意气就能打倒的、小鬼！"
  },
  {
   "off": "0x1DAC",
   "zh": "不、我要打倒它！"
  },
  {
   "off": "0x1DB7",
   "zh": "我一定会打倒它！我有办法！！"
  },
  {
   "off": "0x1DF5",
   "zh": "什、什么！？"
  },
  {
   "off": "0x1E1B",
   "zh": "我的身体……借给大家！！"
  },
  {
   "off": "0xF57E",
   "zh": "这、这是……！？"
  },
  {
   "off": "0xF5BA",
   "zh": "唔……！"
  },
  {
   "off": "0x10EE2",
   "zh": "月光蝶……消失了？"
  },
  {
   "off": "0x10F1C",
   "zh": "好、机会来了！集中攻击倒X！"
  },
  {
   "off": "0x1E52",
   "zh": "哈哈哈！"
  },
  {
   "off": "0x1E5A",
   "zh": "想打倒倒X、你的力量还差了点啊、少年！！"
  },
  {
   "off": "0x1E96",
   "zh": "你说什么！"
  },
  {
   "off": "0x1E9E",
   "zh": "为了莉娜、我也绝不能输！！"
  },
  {
   "off": "0x1ED2",
   "zh": "为了女人而战吗、小鬼！真是软弱！！"
  },
  {
   "off": "0x1F05",
   "zh": "你搞错了！基姆·金卡拉姆！"
  },
  {
   "off": "0x1F33",
   "zh": "什么！？"
  },
  {
   "off": "0x1F56",
   "zh": "像你这种轻视生命的家伙、也许不会明白……"
  },
  {
   "off": "0x1F76",
   "zh": "为了某个人而战、是非常重要的事啊！！"
  },
  {
   "off": "0x1FB8",
   "zh": "唔！这股气是怎么回事……！？"
  },
  {
   "off": "0x1FE7",
   "zh": "这就是ZZ的！"
  },
  {
   "off": "0x1FF3",
   "zh": "是把大家的力量凝聚为一的高达之力！"
  },
  {
   "off": "0x2031",
   "zh": "哼……有点本事、但终究是地球人造的机体！"
  },
  {
   "off": "0x2053",
   "zh": "根本当不了倒X的对手！！"
  },
  {
   "off": "0x2089",
   "zh": "开什么玩笑！"
  },
  {
   "off": "0x209B",
   "zh": "区区一两台MS！看我把它们统统击落！"
  },
  {
   "off": "0x20DD",
   "zh": "这是……！精神感应框架的共振吗！？"
  },
  {
   "off": "0x2116",
   "zh": "这台高达可不是摆设！！"
  },
  {
   "off": "0x214D",
   "zh": "那台叫倒X的MS、是非常危险的东西！"
  },
  {
   "off": "0x2166",
   "zh": "难道你不明白吗！？"
  },
  {
