 "title_zh": "终末之光",
 "briefing": [
  {
   "off": "0x19EA87",
   "zh": "此次的目标、是使扎夫特军的巨型兵器创世纪失去机能、或将其摧毁"
  },
  {
   "off": "0x19EAA9",
   "zh": "目前创世纪周围有扎夫特军展开布防、从正面进攻十分困难"
  },
  {
   "off": "0x19EACA",
   "zh": "因此、本次将采取从内部破坏创世纪的作战"
  },
  {
   "off": "0x19EB0E",
   "zh": "那么、下面说明作战内容"
  },
  {
   "off": "0x19EB21",
   "zh": "首先、由大天使号等三舰、进攻创世纪的防卫线……"
  },
  {
   "off": "0x19EB3E",
   "zh": "将护卫战力从创世纪身边引开"
  },
  {
   "off": "0x19ED13",
   "zh": "随后、趁敌军警戒松懈之际、由正义高达突破敌阵……"
  },
  {
   "off": "0x19EE25",
   "zh": "从内部破坏创世纪"
  },
  {
   "off": "0x19EF01",
   "zh": "另外、关于敌方战力……"
  },
  {
   "off": "0x19EF0D",
   "zh": "除了此前交战过的扎夫特制MS之外、还确认了高达型机体的存在"
  },
  {
   "off": "0x19EF59",
   "zh": "是克鲁泽的神意高达吧"
  },
  {
   "off": "0x19EF67",
   "zh": "我们一旦试图接近创世纪、他必定会全力前来阻止"
  },
  {
   "off": "0x19EF88",
   "zh": "必须多加小心才行啊"
  },
  {
   "off": "0x19EFC0",
   "zh": "万一事态演变到创世纪向地球发射的地步、"
  },
  {
   "off": "0x19EFDF",
   "zh": "地球上的生命、就会几乎灭绝殆尽！"
  },
  {
   "off": "0x19EFF5",
   "zh": "无论如何、都必须阻止创世纪的发射！！"
  }
 ],
