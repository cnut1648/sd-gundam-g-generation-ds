 "title_zh": "通往未来的路标",
 "briefing": [
  {
   "off": "0x19FC4E",
   "zh": "劳·鲁·克鲁泽率领所属不明的MS部队……"
  },
  {
   "off": "0x19FC6A",
   "zh": "目前正占据着创世纪"
  },
  {
   "off": "0x19FC79",
   "zh": "他的目的、是以创世纪攻击地球……"
  },
  {
   "off": "0x19FC90",
   "zh": "唯有此事、我们必须不惜一切代价阻止"
  },
  {
   "off": "0x19FCA4",
   "zh": "我们即将与奥古协同、尝试夺回创世纪！"
  },
  {
   "off": "0x19FCBF",
   "zh": "此外、这次为了分散创世纪的目标……"
  },
  {
   "off": "0x19FCD9",
   "zh": "大天使号、奥古与我们、将各自分头行动"
  },
  {
   "off": "0x19FCF2",
   "zh": "能动用的战力虽只有我方部队、但相应地、敌人的战力应该也已分散"
  },
  {
   "off": "0x19FD19",
   "zh": "这想必会是一场苦战、但拜托了、诸君！"
  }
 ],
 "blocks": [
  {
   "off": "0x17D6",
   "zh": "这里是奥古、阿伽玛队！即刻开始突入！"
  },
  {
   "off": "0x183F",
   "zh": "这里是大天使号、我们这就开始突入、娜塔尔！！"
  },
  {
   "off": "0x18C4",
   "zh": "阿伽玛、大天使号、突入创世纪！"
  },
  {
   "off": "0x18D5",
   "zh": "咱们这边也随时能上！"
  },
  {
   "off": "0x1902",
   "zh": "好、作战现在开始！！全舰、突入！！"
  },
  {
   "off": "0x1947",
   "zh": "呵呵……"
  },
  {
   "off": "0x1969",
   "zh": "那家伙是……！！"
  },
  {
   "off": "0x1994",
   "zh": "劳·鲁·克鲁泽吗！！"
  },
  {
   "off": "0x19C8",
   "zh": "哈哈哈哈！"
  },
  {
   "off": "0x19D0",
   "zh": "果然、成为最后障碍的、还是你们这些人啊！"
  },
  {
   "off": "0x1A06",
   "zh": "看来抽中头彩的、是老娘我们这边啊！"
  },
  {
   "off": "0x1A3A",
   "zh": "创世纪已经进入了发射准备"
  },
  {
   "off": "0x1A4D",
   "zh": "就算你们赶到了、也阻止不了它的发射！"
  },
  {
   "off": "0x1A83",
   "zh": "你是打算用那门创世纪、轰击地球吗？"
  },
  {
   "off": "0x1A99",
   "zh": "那将酿成何等悲剧、你不会不明白吧"
  },
  {
   "off": "0x1ACF",
   "zh": "正因为如此！！"
  },
  {
   "off": "0x1ADA",
   "zh": "创世纪一旦发射、大地便遭焚烧！泪水与悲鸣、将化作新一轮争斗的狼烟！"
  },
  {
   "off": "0x1B01",
   "zh": "没错……！！人类无数预言中的那一日！！"
  },
  {
   "off": "0x1B1A",
   "zh": "人类的灭亡！终于到了实现之时！！"
  },
  {
   "off": "0x1B4D",
   "zh": "那种事……！别以为我们会让你得逞！！"
  },
  {
   "off": "0x1B81",
   "zh": "哈哈哈、那是当然！！"
  },
  {
   "off": "0x1B8D",
   "zh": "所以我才一直等着！！等着你们亲自踏进这里来！"
  },
  {
   "off": "0x1BD9",
   "zh": "…………"
  },
  {
   "off": "0x1C07",
   "zh": "原来如此……真正的主角总算露面了吗！"
  },
  {
   "off": "0x1C3B",
   "zh": "…………"
  },
  {
   "off": "0x1C69",
   "zh": "她们正是军团……"
  },
  {
   "off": "0x1C77",
   "zh": "自人心黑暗中诞生的人造天使！与我一样、是有资格毁灭人类之人！"
  },
  {
   "off": "0x1CC5",
   "zh": "娜塔尔舰长！"
  },
  {
   "off": "0x1CE8",
   "zh": "……啊、我明白"
  },
  {
   "off": "0x1CF7",
   "zh": "毁灭人类……这种事、绝不能让他们得逞！"
  },
  {
   "off": "0x1D14",
   "zh": "主天使号、里恩霍斯Jr！立即转入战斗态势！！"
  },
  {
   "off": "0x1D2F",
   "zh": "击破克鲁泽与军团、阻止创世纪的发射！！"
  },
  {
   "off": "0x1D71",
   "zh": "全体人员、开始战斗！！"
  },
  {
   "off": "0xB122",
   "zh": "可恶……！岂能倒在、这种地方……！！"
  },
  {
   "off": "0x1DA4",
   "zh": "我们所失去的、已经再也回不来了……"
  },
  {
   "off": "0x1DC4",
   "zh": "所以、我们……"
  },
  {
   "off": "0x1DF5",
   "zh": "…………"
  },
  {
   "off": "0x1DFE",
   "zh": "别再做无谓的抵抗、接受吧……接受灭亡"
  },
  {
   "off": "0x1E3A",
   "zh": "没错……已经没有任何人能阻止了"
  },
  {
   "off": "0x1E78",
   "zh": "是这个世界、抹去了对我们而言无可替代的主……"
  },
  {
   "off": "0x1E9C",
   "zh": "灭亡、正是与这个世界相称的末路"
  },
  {
   "off": "0x1EDC",
   "zh": "你说……主？"
  },
  {
   "off": "0x1EE6",
   "zh": "你们不是听命于劳·鲁·克鲁泽的吗……"
  },
  {
   "off": "0x1F27",
   "zh": "……不"
  },
  {
   "off": "0x1F2E",
   "zh": "他只是目的一致的协力者、我们的主另有其人"
  },
  {
   "off": "0x1F70",
   "zh": "……不、曾经存在过、但如今已经不在了"
  },
  {
   "off": "0x1F92",
   "zh": "吉翁公国总帅、基连·扎比……那就是创造我们之人的名字"
  },
  {
   "off": "0x1FCE",
   "zh": "你说基连·扎比！？"
  },
  {
   "off": "0x1FF5",
   "zh": "没错……"
  },
  {
   "off": "0x1FFC",
   "zh": "那位大人从月之民那里、得知了将要到来的未来……"
  },
  {
   "off": "0x2018",
   "zh": "为了把历史修正为应有的模样、创造出了我们"
  },
  {
   "off": "0x2036",
   "zh": "可是、那位总帅也在战火中一去不返了"
  },
  {
   "off": "0x206F",
   "zh": "复仇……是这么回事吗"
  },
  {
   "off": "0x2097",
   "zh": "复仇……"
  },
  {
   "off": "0x20A8",
   "zh": "也许是吧、也许其实怎样都无所谓"
  },
  {
   "off": "0x20E1",
   "zh": "…………！？"
  },
  {
   "off": "0x2103",
   "zh": "因为那个人的死、这个世界对我们而言、已变得毫无价值"
  },
  {
   "off": "0x2128",
   "zh": "所以……"
  },
  {
   "off": "0x214A",
   "zh": "于是便助克鲁泽一臂之力、毁灭人类……是这么回事吗！！"
  },
  {
   "off": "0x2182",
   "zh": "……是他给了我们目的"
  },
  {
   "off": "0x2193",
   "zh": "毁灭人类这个目的、所以我们才把力量借给他……"
  },
  {
   "off": "0x21B1",
   "zh": "你们若要阻拦、那就请你们先灭亡"
  },
  {
   "off": "0x21F2",
   "zh": "那道光、是倒X放出的……！？"
  },
  {
   "off": "0x2228",
   "zh": "难道说、是月光蝶！？"
  },
  {
   "off": "0x225B",
   "zh": "没错……这是纳米机械之光"
  },
  {
   "off": "0x226B",
   "zh": "是将你们归于虚无的、纳米机械之光……"
  },
  {
   "off": "0x22A7",
   "zh": "基连·扎比这个男人……！竟造出这种东西……！！"
  },
  {
   "off": "0x22DE",
   "zh": "你们也已经……完了"
  },
  {
   "off": "0x2313",
   "zh": "唔……！"
  },
  {
   "off": "0x235A",
   "zh": "不会让你们得逞的！"
  },
  {
   "off": "0x238D",
   "zh": "基拉·大和！？"
  },
  {
   "off": "0x23B8",
   "zh": "我们是来支援的！娜塔尔小姐！！"
  },
  {
   "off": "0x23EF",
   "zh": "您没事吧！娜塔尔舰长！？"
  },
  {
   "off": "0x241C",
   "zh": "你们是……"
  },
  {
   "off": "0x244A",
   "zh": "听说正主就在这边、我就赶来了！"
  },
  {
   "off": "0x2460",
   "zh": "总之我召集了一帮志同道合的伙伴、赶来助阵啦！"
  },
  {
   "off": "0x24A1",
   "zh": "其他方向的敌人、阿伽玛和大天使号正缠着呢"
  },
  {
   "off": "0x24B8",
   "zh": "就这样一口气拿下他们！娜塔尔舰长！"
  },
  {
   "off": "0x24EE",
   "zh": "……明白了！"
  },
  {
   "off": "0x251D",
   "zh": "全体人员、与永恒号协力、全力击破军团！"
  },
  {
   "off": "0x2651",
   "zh": "好好看着吧……阿姆罗"
  },
  {
   "off": "0x265E",
   "zh": "你未能完全展现的、人心之光……"
  },
  {
   "off": "0x2677",
   "zh": "就由我代你展现出来！"
  },
  {
   "off": "0x26AC",
   "zh": "唔！？这股力量……！？"
  },
  {
   "off": "0x26D5",
   "zh": "这台高达可不是摆设！！上了！！"
  },
  {
   "off": "0x271D",
   "zh": "好嘞！上了、你们俩！！"
  },
  {
   "off": "0x274F",
   "zh": "难得的决战、不露一手帅气的怎么行！！"
  },
  {
   "off": "0x2789",
   "zh": "…………"
  },
  {
   "off": "0xB462",
   "zh": "可恶……！"
  },
  {
   "off": "0xB46B",
   "zh": "你们不也是人类因私欲、制造出来的存在吗！？"
  },
  {
   "off": "0xB489",
   "zh": "为何还要站在人类那边！！"
  },
  {
   "off": "0xB4BE",
   "zh": "就算这样、凭什么就得帮你这种家伙啊！？"
  },
  {
   "off": "0xB4F8",
   "zh": "就因为自己不正常、所以要毁灭世界……这种想法、我很不爽"
  },
  {
   "off": "0xB536",
   "zh": "就是就是！！"
  },
  {
   "off": "0xB53F",
   "zh": "给你这种闹别扭的家伙帮忙？我才不干呢！！"
  },
  {
   "off": "0xB57C",
   "zh": "唔……！？"
  },
  {
   "off": "0xB5A0",
   "zh": "克罗特、夏尼！！一口气分出胜负、把那家伙干倒！"
  },
  {
   "off": "0xB5E1",
   "zh": "……明白"
  },
  {
   "off": "0xB609",
   "zh": "嘿嘿！包在我身上！！"
  },
  {
   "off": "0xB63E",
   "zh": "一个再也不用任何人去战斗的世界……"
  },
  {
   "off": "0xB654",
   "zh": "去得到它吧！用我们自己的手！！"
  },
  {
   "off": "0xB68E",
   "zh": "嗯！干吧、基拉！！"
  },
  {
   "off": "0xB6C2",
   "zh": "让我们斩断吧……憎恨与争斗的连锁！！"
  },
  {
   "off": "0x27B7",
   "zh": "这样的战斗……就由我来终结它！！"
  },
  {
   "off": "0x27F2",
   "zh": "也许正如你们所说、人是愚蠢而无可救药的存在……"
  },
  {
   "off": "0x2816",
   "zh": "但是啊、就算是这样的人类、也有好人、也有坏人"
  },
  {
   "off": "0x2834",
   "zh": "只盯着人的坏处就要毁灭人类、这种事岂能容忍！"
  },
  {
   "off": "0x2856",
   "zh": "上了、西格！蜜安！！"
  },
  {
   "off": "0x2886",
   "zh": "好！！"
  },
  {
   "off": "0x28AE",
   "zh": "交给我吧！！"
  },
  {
   "off": "0x28DB",
   "zh": "那是……！？"
  },
  {
   "off": "0x2917",
   "zh": "这里是扎夫特雅金·杜维防卫队、是主天使号的娜塔尔中佐吧！？"
  },
  {
   "off": "0x2933",
   "zh": "我队即刻起支援贵队！！"
  },
  {
   "off": "0x296B",
   "zh": "不能只让扎夫特去战斗！我们也要参战！"
  },
  {
   "off": "0x29AE",
   "zh": "好！上吧、你们俩！！"
  },
  {
   "off": "0x29D9",
   "zh": "了解啦！！"
  },
  {
   "off": "0x29FF",
   "zh": "…………"
  },
  {
   "off": "0xB702",
   "zh": "怎么可能！"
  },
  {
   "off": "0xB709",
   "zh": "直到刚才还在互相厮杀的扎夫特和联邦、竟然……！！"
  },
  {
   "off": "0xB745",
   "zh": "为什么……？"
  },
  {
   "off": "0xB74D",
   "zh": "明明是敌对的扎夫特和联邦、为什么会现身相助！？"
  },
  {
   "off": "0x2A26",
   "zh": "全军、前进！！"
  },
  {
   "off": "0x2A30",
   "zh": "无论如何、都要阻止创世纪的发射！"
  },
  {
   "off": "0x2A8C",
   "zh": "现在不是自然人与调整者、相互争斗的时候！"
  },
  {
   "off": "0x2AC4",
   "zh": "全舰、向雅金·杜维进击！"
  },
  {
   "off": "0x2AD3",
   "zh": "将盘踞在创世纪上的敌军部队、尽数清除！！"
  },
  {
   "off": "0x2B2D",
   "zh": "迪安娜殿下！"
  },
  {
   "off": "0x2B35",
   "zh": "迪安娜回归军全舰、已各就各位！"
  },
  {
   "off": "0x2B6B",
   "zh": "很好！那么、迪安娜回归军、全军出击！"
  },
  {
   "off": "0x2BA2",
   "zh": "……是！！"
  },
  {
   "off": "0xB77E",
   "zh": "相互对立之人、竟携起手来……！？"
  },
  {
   "off": "0xB794",
   "zh": "怎么会有这种荒唐事……！"
  },
  {
   "off": "0xB7CA",
   "zh": "相互对立的人、彼此牵起手来？"
  },
  {
   "off": "0xB7DA",
   "zh": "明明是直到刚才还在交战的人们、为什么能做到这种事……"
  },
  {
   "off": "0x2BC2",
   "zh": "这说明、人类并不像你们断定的那般愚蠢！"
  },
  {
   "off": "0x2BEF",
   "zh": "好、胜机就是现在！全体、转入总攻！！"
  },
  {
   "off": "0x2C2C",
   "zh": "就算打倒我、也阻止不了创世纪的发射！"
  },
  {
   "off": "0x2C45",
   "zh": "纵使我不动手、军团她们也会完成！！"
  },
  {
   "off": "0x2C68",
   "zh": "不！纵使她们不动手！人心之暗、也必将吞噬人类自身！！"
  },
  {
   "off": "0x2CAB",
   "zh": "人类！人类才不是那种东西……！！"
  },
  {
   "off": "0x2CD9",
   "zh": "哈哈哈！说什么呢！！你的力量、不也是人类之业的产物吗！"
  },
  {
   "off": "0x2CFD",
   "zh": "超越人类、乃至调整者的力量！知晓之人、谁都会渴望变成你这样！"
  },
  {
   "off": "0x2D3F",
   "zh": "我、我……！！"
  },
  {
   "off": "0x2D6C",
   "zh": "这样的你、却在宣讲虚假的希望！所以不可饶恕！你这个存在也是！！"
  },
  {
   "off": "0x2DB8",
   "zh": "……！？"
  },
  {
   "off": "0xB81E",
   "zh": "还想继续受苦吗！？想着总有一天、终会有那么一天！"
  },
  {
   "off": "0xB844",
   "zh": "被这甜美的毒药耍得团团转！你们又战斗了多少岁月！？"
  },
  {
   "off": "0xB86E",
   "zh": "说到底、你也不过是个力量被人类利用的、可悲的人偶罢了！！"
  },
  {
   "off": "0x2DE5",
   "zh": "我的存在、并不只有力量！！"
  },
  {
   "off": "0x2E26",
   "zh": "那有谁能明白！？"
  },
  {
   "off": "0x2E62",
   "zh": "又能明白什么！？"
  },
  {
   "off": "0x2E77",
   "zh": "没人会明白、谁都不会！！"
  },
  {
   "off": "0x2EAB",
   "zh": "唔……"
  },
  {
   "off": "0x2EE1",
   "zh": "即便如此！我也……！！"
  },
  {
   "off": "0x2EFC",
   "zh": "有想要守护的世界啊！！"
