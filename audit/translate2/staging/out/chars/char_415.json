  {"file": "0.bin", "record": "0x2D35C", "zh": "这家伙……挺有两下子！"},
  {"file": "0.bin", "record": "0x2D37C", "zh": "啧……！是我太轻敌了！"},
  {"file": "0.bin", "record": "0x2D39C", "zh": "哇啊！！竟、竟是直击！？"},
  {"file": "0.bin", "record": "0x2D3BC", "zh": "可、可恶！甩不掉！！"},
  {"file": "0.bin", "record": "0x2D3D8", "zh": "嘿嘿……没用没用！！"},
  {"file": "0.bin", "record": "0x2D3F4", "zh": "哎呀……！这套我可不吃！"},
  {"file": "0.bin", "record": "0x2D414", "zh": "贵客上门了！快给我散开！！"},
  {"file": "0.bin", "record": "0x2D438", "zh": "老实点就饶你一命！"},
