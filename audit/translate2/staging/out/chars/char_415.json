 "barks": [
  {"file": "0.bin", "record": "0x2D1E4", "zh": "嘿嘿嘿……你看哪儿呢！"},
  {"file": "0.bin", "record": "0x2D204", "zh": "好了……让老子乐一乐！"},
  {"file": "0.bin", "record": "0x2D224", "zh": "哈哈哈！跳啊、跳啊！！"},
  {"file": "0.bin", "record": "0x2D244", "zh": "让我刷刷击坠数吧！"},
  {"file": "0.bin", "record": "0x2D264", "zh": "猎物任挑！我就不客气了！"},
