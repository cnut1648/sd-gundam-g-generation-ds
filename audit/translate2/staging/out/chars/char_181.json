 "barks": [
  {"file": "0.bin", "record": "0x17C10", "zh": "说过了、挡路的绝不轻饶！"},
  {"file": "0.bin", "record": "0x17C34", "zh": "说过了、挡路的绝不轻饶！"},
  {"file": "0.bin", "record": "0x17C58", "zh": "不快之敌！给我消失！"},
  {"file": "0.bin", "record": "0x17C78", "zh": "啊哈哈哈！全都烧光吧！"},
  {"file": "0.bin", "record": "0x17C98", "zh": "为了找回记忆、就得打倒更多敌人！"},
