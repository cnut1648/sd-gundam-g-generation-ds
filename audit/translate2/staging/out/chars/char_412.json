 "barks": [
  {"file": "0.bin", "record": "0x121A5", "zh": "好嘞！"},
  {"file": "0.bin", "record": "0x122C8", "zh": "呜哇！！"},
  {"file": "0.bin", "record": "0x1235A", "zh": "正、正在干！"},
  {"file": "0.bin", "record": "0x2CA64", "zh": "先下手！全炮门打开！"},
  {"file": "0.bin", "record": "0x2CA84", "zh": "来轮齐射伺候！……开火！！"},
  {"file": "0.bin", "record": "0x2CAA8", "zh": "、准备好了？……开火！！"},
  {"file": "0.bin", "record": "0x2CAC8", "zh": "不是打得多就行！各炮座、给我好好瞄准了！"},
  {"file": "0.bin", "record": "0x2CAFC", "zh": "射击准备！打偏了可没完！"},
  {"file": "0.bin", "record": "0x2CB20", "zh": "太天真了！这样可打不赢仗！"},
  {"file": "0.bin", "record": "0x2CB44", "zh": "别管损伤！打、打、给我猛打！！"},
  {"file": "0.bin", "record": "0x2CB6C", "zh": "吃定你了……！一口气解决！"},
  {"file": "0.bin", "record": "0x2CB90", "zh": "可恶！！太狼狈了……！！"},
  {"file": "0.bin", "record": "0x2CBB0", "zh": "眼睛长哪了！？"},
  {"file": "0.bin", "record": "0x2CBCC", "zh": "嘿嘿嘿……刚才可真悬……！"},
  {"file": "0.bin", "record": "0x2CBF0", "zh": "哈！算打招呼？"},
  {"file": "0.bin", "record": "0x2CC08", "zh": "看来还挺有种嘛！？"},
  {"file": "0.bin", "record": "0x2CC28", "zh": "可恶！竟敢耍老子……！"},
  {"file": "0.bin", "record": "0x2CC48", "zh": "什么！？臭小子……竟敢！！"},
  {"file": "0.bin", "record": "0x2CC6C", "zh": "可恶！这下不妙……！！"},
  {"file": "0.bin", "record": "0x2CC8C", "zh": "哼！……不痛不痒！"},
  {"file": "0.bin", "record": "0x2CCAC", "zh": "哇哈哈哈、蠢货才会中那玩意！"},
  {"file": "0.bin", "record": "0x2CCD4", "zh": "小子们、来客人了！别中弹！"},
  {"file": "0.bin", "record": "0x2CCF8", "zh": "那机体归我们用了！"},
  {"file": "0.bin", "record": "0x2CD18", "zh": "可恶……真窝囊……！"},
  {"file": "0.bin", "record": "0x2CD34", "zh": "你们……找死！"}
 ],
