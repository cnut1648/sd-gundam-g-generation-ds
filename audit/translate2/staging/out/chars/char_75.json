 "barks": [
  {"file": "0.bin", "record": "0x8CFC", "zh": "哼……"},
  {"file": "0.bin", "record": "0x8D0C", "zh": "……去死！"},
  {"file": "0.bin", "record": "0x8D20", "zh": "……去死！"},
  {"file": "0.bin", "record": "0x8D34", "zh": "抱歉、垫脚石就由你来当……呵呵呵"},
  {"file": "0.bin", "record": "0x8D60", "zh": "这大好机会……岂能错过！"},
  {"file": "0.bin", "record": "0x8D84", "zh": "这点对手、岂能磨蹭……"},
  {"file": "0.bin", "record": "0x8DA8", "zh": "那么……该把世界收拾干净了"},
  {"file": "0.bin", "record": "0x8DD0", "zh": "杀敌就该又快又准……绝不犹豫！"},
  {"file": "0.bin", "record": "0x8DFC", "zh": "啧……！是哪里失算了吗……！！"},
  {"file": "0.bin", "record": "0x8E20", "zh": "无法处理感情的人不过是垃圾……"},
  {"file": "0.bin", "record": "0x8E48", "zh": "我不能倒下！现在还不行！"},
