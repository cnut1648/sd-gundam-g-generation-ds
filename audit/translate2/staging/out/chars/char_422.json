 "barks": [
  {"file": "0.bin", "record": "0x252E6", "zh": "是！发射！"},
  {"file": "0.bin", "record": "0x253A8", "zh": "已回避炮击！恢复航向！"},
  {"file": "0.bin", "record": "0x258B4", "zh": "敌影捕捉！可先发制人！"},
  {"file": "0.bin", "record": "0x25940", "zh": "阁下正看着呢！别丢人现眼！"},
  {"file": "0.bin", "record": "0x2597C", "zh": "已捕捉敌人！开始攻击！"},
  {"file": "0.bin", "record": "0x25A1C", "zh": "已回避攻击！"},
  {"file": "0.bin", "record": "0x25A74", "zh": "损伤轻微！没有问题！"},
  {"file": "0.bin", "record": "0x269A4", "zh": "敌人已进入射程！"},
  {"file": "0.bin", "record": "0x26AE0", "zh": "7区中弹！"},
  {"file": "0.bin", "record": "0x2E340", "zh": "竟敢来送死……给叛军点颜色看看！"},
  {"file": "0.bin", "record": "0x2E36C", "zh": "臭宇宙人！"},
  {"file": "0.bin", "record": "0x2E380", "zh": "挡路者绝不留情！将其彻底歼灭！！"},
  {"file": "0.bin", "record": "0x2E3AC", "zh": "敌人不过是叛乱分子！全数歼灭！"},
  {"file": "0.bin", "record": "0x2E3D4", "zh": "胆敢违抗提坦斯、让他们后悔！"},
  {"file": "0.bin", "record": "0x2E3FC", "zh": "挡路者别留情！"},
  {"file": "0.bin", "record": "0x2E418", "zh": "给我彻底歼灭！"},
  {"file": "0.bin", "record": "0x2E434", "zh": "、准备！……好、打下来！"},
  {"file": "0.bin", "record": "0x2E458", "zh": "竟会败在叛军手里……可恶……！"},
  {"file": "0.bin", "record": "0x2E480", "zh": "哼、白费力气！"},
  {"file": "0.bin", "record": "0x2E498", "zh": "身为精英、岂会轻易落败！"},
  {"file": "0.bin", "record": "0x2E4BC", "zh": "哼……不值一提！"},
  {"file": "0.bin", "record": "0x2E4D8", "zh": "竟被打中！？回避太松懈了！"},
  {"file": "0.bin", "record": "0x2E4F8", "zh": "可恶！护卫的MS在干什么！"},
