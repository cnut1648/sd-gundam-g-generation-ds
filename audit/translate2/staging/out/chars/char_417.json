 "ids": [
  {"idn": 1251, "name_zh": "为迪安娜！", "cutin_zh": "为了迪安娜大人！！", "notes": "原name_zh为迪安娜！！占6格超出5格上限、压缩为5格并保留与名台词共通的关键词。detail归char_140所有、未输出。"}
 ],
 "barks": [
  {"file": "0.bin", "record": "0x2D648", "zh": "进入射程了！？很好、开火！！"},
  {"file": "0.bin", "record": "0x2D66C", "zh": "为迪安娜大人！"},
  {"file": "0.bin", "record": "0x2D684", "zh": "目标锁定！开始射击！"},
  {"file": "0.bin", "record": "0x2D6A0", "zh": "各炮座！瞄准后一齐射击！"},
  {"file": "0.bin", "record": "0x2D6C0", "zh": "打开全炮门！齐射30秒！……开火！"},
  {"file": "0.bin", "record": "0x2D6E8", "zh": "敌人攻击不算什么！保持直进！！"},
  {"file": "0.bin", "record": "0x2D710", "zh": "光束轮展开！就这样突击！！"},
  {"file": "0.bin", "record": "0x2D734", "zh": "接近战！提高舰首光束出力！"},
  {"file": "0.bin", "record": "0x2D754", "zh": "不妙！退避！快退避！！"},
  {"file": "0.bin", "record": "0x2D774", "zh": "很好！回避成功！"},
  {"file": "0.bin", "record": "0x2D78C", "zh": "迪、迪安娜大人赐予的舰、岂容沉没！！"},
  {"file": "0.bin", "record": "0x2D7B8", "zh": "很好、力场似乎起效了"},
  {"file": "0.bin", "record": "0x2D7D8", "zh": "唔！别让敌人靠近！"},
  {"file": "0.bin", "record": "0x2D7F4", "zh": "可恶！赶快应战！"},
  {"file": "0.bin", "record": "0x2D810", "zh": "只、只是一击……这绝非寻常兵器！"},
  {"file": "0.bin", "record": "0x2D838", "zh": "不妙！这样下去本舰也……"},
  {"file": "0.bin", "record": "0x2D858", "zh": "很好！光束盾似乎起效了！"},
  {"file": "0.bin", "record": "0x2D87C", "zh": "回避机动、快！"},
  {"file": "0.bin", "record": "0x2D894", "zh": "要来了！散开躲避！"},
  {"file": "0.bin", "record": "0x2D8B0", "zh": "乖乖投降！"},
  {"file": "0.bin", "record": "0x2D8C8", "zh": "怎、怎么会……"},
  {"file": "0.bin", "record": "0x2D8E0", "zh": "哼！休想得逞！！"}
 ],
 "notes": "DC=迪安娜回归军(Diana Counter、∀高达月之民义勇军)士官、舰长口吻的月之民军队指挥腔。术语按repo惯例：ビームホイール=光束轮、ビームシールド=光束盾、フィールド=力场、ディアナさま=迪安娜大人。0x2D7B8按JP原文不加感叹号。0x2D66C预算11字节放不下为了……大人！！全句、取最优压缩为迪安娜大人！。"
}
