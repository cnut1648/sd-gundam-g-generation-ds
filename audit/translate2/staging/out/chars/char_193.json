 "barks": [
  {"file": "0.bin", "record": "0x199A8", "zh": "这招早看穿了！"},
  {"file": "0.bin", "record": "0x199C4", "zh": "联邦王牌蒙夏大爷不好惹！"},
  {"file": "0.bin", "record": "0x199E8", "zh": "好嘞！！击坠分到手啦！"},
  {"file": "0.bin", "record": "0x19A08", "zh": "打得你哑口无言！"},
  {"file": "0.bin", "record": "0x19A28", "zh": "敢碍事、有你好受的！"},
  {"file": "0.bin", "record": "0x19A48", "zh": "给我倒下！！"},
  {"file": "0.bin", "record": "0x19A60", "zh": "嘿嘿嘿……让爷好好疼疼你！"},
  {"file": "0.bin", "record": "0x19A84", "zh": "看谁先进棺材……啊、对面的老兄！！"},
  {"file": "0.bin", "record": "0x19AB0", "zh": "什、什么！？本大爷竟然输了！？"},
  {"file": "0.bin", "record": "0x19AD8", "zh": "怎么啦！？腿软了吗！？"},
  {"file": "0.bin", "record": "0x19AF8", "zh": "好险……你搞什么名堂！"},
  {"file": "0.bin", "record": "0x19B18", "zh": "今天爷窝在舱里……明天保准还在舱里！"},
  {"file": "0.bin", "record": "0x19B48", "zh": "切！嫌我不配当对手！？"},
  {"file": "0.bin", "record": "0x19B6C", "zh": "东打西打、揍个没完！！"},
  {"file": "0.bin", "record": "0x19B90", "zh": "嗷啊啊！？什、什么！？"},
  {"file": "0.bin", "record": "0x19BB0", "zh": "喂、喂……！开什么玩笑！？"},
  {"file": "0.bin", "record": "0x19BD4", "zh": "哼！回去洗把脸再来！"},
  {"file": "0.bin", "record": "0x19BF4", "zh": "这可不是观光旅行！"},
  {"file": "0.bin", "record": "0x19C14", "zh": "瞧好了！什么叫默契配合！！"},
  {"file": "0.bin", "record": "0x19C3C", "zh": "来吧！给我老实点！"},
  {"file": "0.bin", "record": "0x19C58", "zh": "什！？什么啊啊！？"},
  {"file": "0.bin", "record": "0x19C78", "zh": "这边有这边的难处啊！"},
  {"file": "1de.bin", "record": "0x66E0", "zh": "好！一架不留全干掉！！跟上本大爷！！"},
  {"file": "1de.bin", "record": "0x670C", "zh": "好！这边蒙夏、收到！！"},
  {"file": "1de.bin", "record": "0x672C", "zh": "交给我吧、队长！本大爷能顶百人！"},
  {"file": "1de.bin", "record": "0x6758", "zh": "好、贝特！让他们见识我们的本事！"},
  {"file": "1de.bin", "record": "0x6780", "zh": "好！别手软、阿德尔！"},
  {"file": "1de.bin", "record": "0x67A0", "zh": "这次可是特别帮你！明白吗、浦木！？"},
  {"file": "1de.bin", "record": "0x67CC", "zh": "好！这边蒙夏、收到！！"}
 ],
 "notes": "0x19C14的□□实为未映射外字{SLOT:1997}{SLOT:2149}、语境唯一吻合的定型语是阿吽の呼吸（默契配合）、并非队名：现行硬塞不死队系误读、改译瞧好了！什么叫默契配合！！。队名规范随char_22/char_74取不死身的第4小队（灰机wiki）、本条修正后无需塞入队名。0x19C58现行的——不在允许标点集内、改用啊啊拖长音。撃墜スコア随char_22（贝特）统一作击坠分。0x199C4/0x19A48/0x19B6C/0x19AD8/0x19AF8/0x19BF4/0x6758/0x6780保留现行译文（实测字节在预算内且措辞到位）。人名对齐：贝特=阿尔法·A·贝特、阿德尔=查普·阿德尔、浦木（浦木宏无点）。0x670C/0x67CC同一句日文、给出相同译文。0x19C3C理想为来吧来吧！给我老实点！（预算16放不下、退为来吧！）。伯纳德·蒙夏与biligame条目一致、无需改名"
}
