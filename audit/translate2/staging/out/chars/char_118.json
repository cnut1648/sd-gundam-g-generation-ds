 "barks": [
  {"file": "0.bin", "record": "0xECF8", "zh": "来杀者杀无赦……是这样吧、零式！"},
  {"file": "0.bin", "record": "0xED20", "zh": "零式！赐我胜利！！"},
  {"file": "0.bin", "record": "0xED3C", "zh": "零式！赐我胜利！！"},
  {"file": "0.bin", "record": "0xED58", "zh": "休想逃！！"},
  {"file": "0.bin", "record": "0xED6C", "zh": "决胜一击！！"},
  {"file": "0.bin", "record": "0xED84", "zh": "了断吧！！"},
  {"file": "0.bin", "record": "0xED98", "zh": "休想逃！！"},
  {"file": "0.bin", "record": "0xEDAC", "zh": "这是为终结战斗的战斗！"},
  {"file": "0.bin", "record": "0xEDD0", "zh": "唔！漂亮……！！"},
  {"file": "0.bin", "record": "0xEDE8", "zh": "哼……"},
  {"file": "0.bin", "record": "0xEDFC", "zh": "终究是血染的宿命！无意逃避！"},
  {"file": "0.bin", "record": "0xEE24", "zh": "唔！……"},
  {"file": "0.bin", "record": "0xEE38", "zh": "哦……！打中了……这个我！！"},
  {"file": "0.bin", "record": "0xEE5C", "zh": "唔……！区区这点！"},
  {"file": "0.bin", "record": "0xEE78", "zh": "我为何如此天真……！"},
  {"file": "0.bin", "record": "0xEE98", "zh": "我还没有……承认败北！"},
  {"file": "0.bin", "record": "0xEEB8", "zh": "这场战斗有何意义？究竟有何意义！"},
  {"file": "0.bin", "record": "0xEEE4", "zh": "…………"},
  {"file": "0.bin", "record": "0xEEF4", "zh": "来了！？全机、回避！"},
  {"file": "0.bin", "record": "0xEF10", "zh": "不！他不是我该战斗的对手！"},
  {"file": "0.bin", "record": "0xEF34", "zh": "真耻辱！"},
  {"file": "0.bin", "record": "0xEF48", "zh": "可恶！别小看我！"},
  {"file": "1de.bin", "record": "0x4458", "zh": "零式啊、为我指引胜利！"},
  {"file": "1de.bin", "record": "0x447C", "zh": "很好、一同突击吧！"},
