  {"file": "0.bin", "record": "0x3C80", "zh": "哼……别嚣张！"},
  {"file": "0.bin", "record": "0x3C98", "zh": "别想一直得逞！！"},
  {"file": "0.bin", "record": "0x3CB4", "zh": "……真是的、净使唤人……"},
  {"file": "0.bin", "record": "0x3CD4", "zh": "真讨厌……"},
  {"file": "0.bin", "record": "0x3CEC", "zh": "车到山前必有路！"},
  {"file": "0.bin", "record": "0x3D0C", "zh": "唉……捡回一条命"},
  {"file": "0.bin", "record": "0x3D28", "zh": "这家伙腿脚慢……"},
  {"file": "0.bin", "record": "0x3D44", "zh": "真有你的啊！"},
  {"file": "0.bin", "record": "0x3D60", "zh": "哼、真不可爱"},
  {"file": "0.bin", "record": "0x3D78", "zh": "可恶！别开玩笑！！"},
  {"file": "0.bin", "record": "0x3D94", "zh": "死在棺材里吗！……开什么玩笑！"},
  {"file": "0.bin", "record": "0x3DBC", "zh": "得、得救了……"},
  {"file": "0.bin", "record": "0x3DD4", "zh": "想得美！！"},
  {"file": "0.bin", "record": "0x3DEC", "zh": "来了！全机回避！"},
  {"file": "0.bin", "record": "0x3E08", "zh": "老实点！！"},
  {"file": "0.bin", "record": "0x3E1C", "zh": "骗、骗人的吧！？"},
  {"file": "0.bin", "record": "0x3E38", "zh": "谁会输给你们！！"},
  {"file": "1de.bin", "record": "0xDE4", "zh": "全员一齐上！！"},
  {"file": "1de.bin", "record": "0xDFC", "zh": "好！掩护交给我！"},
  {"file": "1de.bin", "record": "0xE18", "zh": "好、这边OK！隼人！"},
  {"file": "1de.bin", "record": "0xE38", "zh": "好！掩护交给我！"},
  {"file": "1de.bin", "record": "0xE54", "zh": "好！掩护交给我！"},
