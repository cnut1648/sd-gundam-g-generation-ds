  {"idn": 105, "name_zh": "打仗这种事", "cutin_zh": "打仗这种事、胆小一点刚刚好！", "detail_effect_zh": "回避率上升20%、装甲增加2", "notes": "剧场版めぐりあい宇宙名台词、社区通行译法为胆小一点刚刚好（灰机wiki凯·西汀条目）"},
  {"idn": 106, "name_zh": "好快好快！", "cutin_zh": "好快、好快啊！这种时候、谁慌谁就输！", "notes": ""},
  {"idn": 108, "name_zh": "……小心为妙", "cutin_zh": "……还是小心为妙", "detail_effect_zh": "回避率上升40%、装甲增加4", "notes": "出自Z高达第9话、凯对蕾科亚的轻佻回答つつしみましょ"},
  {"idn": 109, "name_zh": "我活下来了", "cutin_zh": "我也是从那场战争里活下来的！", "notes": ""},
  {"idn": 110, "name_zh": "走神可不行", "cutin_zh": "稍一走神、可是会送命的", "detail_effect_zh": "命中率与攻击力各上升20%、团队间接攻击时封印敌方散开", "notes": "原效果译文写成解除封印是反义错误、已改为封印敌方散开"},
  {"idn": 111, "name_zh": "气息在动！", "cutin_zh": "看穿了！气息在动！！", "detail_effect_zh": "攻击力增加20%、攻击必定暴击", "notes": "小说版凯NT觉醒察觉基连气息的场面、原指令名看穿你气息不通顺、改为与名台词同词的气息在动！"},
  {"idn": 112, "name_zh": "射穿独善！", "cutin_zh": "我要射穿一个独善！好坏对错、日后再说！", "detail_effect_zh": "攻击力增加20%、团队间接攻击时使敌方无法散开", "notes": "独善即自以为是的正义、高达语境常用词、保留一つの独善的原文力度"},
  {"idn": 113, "name_zh": "我也感觉到", "cutin_zh": "我明白、阿姆罗！我也感觉到了！！", "notes": "小说版名场面判るぞ！俺にも！アムロ！"},
  {"idn": 114, "name_zh": "气息在动！", "cutin_zh": "看穿了！气息在动！！", "detail_effect_zh": "攻击力增加20%、攻击必定暴击、必定回避敌方攻击", "notes": "与idn111同一共享字符串、同值"},
  {"idn": 115, "name_zh": "射穿独善……", "cutin_zh": "我要射穿一个独善！好坏对错、日后再说！", "detail_effect_zh": "攻击力增加20%、无效化敌方装甲、间接攻击时封印敌方散开", "notes": "指令名按原文以……收尾、四汉字加两省略号合64px、与……小心为妙同宽"},
  {"idn": 116, "name_zh": "展现心之光", "cutin_zh": "……我懂的、阿姆罗、必须展现出人心之光、对吧？", "notes": "呼应逆袭的夏亚阿姆罗名言、中文圈标准译法人心之光；原译把阿姆罗误当主语、已改为呼语"}
