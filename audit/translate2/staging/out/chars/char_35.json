  {"file": "1de.bin", "record": "0xE8C", "zh": "好！掩护交给我！"},
  {"file": "0.bin", "record": "0x3E54", "zh": "这种时候、谁慌谁输！"},
  {"file": "0.bin", "record": "0x3E74", "zh": "别小看我！"},
  {"file": "0.bin", "record": "0x3E88", "zh": "那么……就大干一场吧！"},
  {"file": "0.bin", "record": "0x3EA8", "zh": "这就叫宝刀未老……"},
  {"file": "0.bin", "record": "0x3EC8", "zh": "别把我只当成记者、会吃苦头的"},
  {"file": "0.bin", "record": "0x3EF0", "zh": "抱歉、不会手软"},
  {"file": "0.bin", "record": "0x3F0C", "zh": "我也有两下子吧？"},
  {"file": "0.bin", "record": "0x3F28", "zh": "别太得意忘形啊"},
  {"file": "0.bin", "record": "0x3F44", "zh": "可恶、失手了！撤退！"},
  {"file": "0.bin", "record": "0x3F60", "zh": "打仗这种事、胆小点刚好"},
  {"file": "0.bin", "record": "0x3F84", "zh": "要是在这倒下、就全完了！"},
  {"file": "0.bin", "record": "0x3FA8", "zh": "啧！不赖嘛！"},
  {"file": "0.bin", "record": "0x3FC0", "zh": "别开玩笑了……"},
  {"file": "0.bin", "record": "0x3FD8", "zh": "真好意思啊……"},
  {"file": "0.bin", "record": "0x3FF0", "zh": "真是的！荒废太久了……"},
  {"file": "0.bin", "record": "0x4010", "zh": "进棺材送命这种事、还是免了吧……"},
  {"file": "0.bin", "record": "0x403C", "zh": "这可不行啊？"},
  {"file": "0.bin", "record": "0x4058", "zh": "我可不打算被打中！"},
  {"file": "0.bin", "record": "0x4074", "zh": "小心！要来了！"},
  {"file": "0.bin", "record": "0x4090", "zh": "好、乖孩子、老实待着！"},
  {"file": "0.bin", "record": "0x40B4", "zh": "真是软弱者……"},
  {"file": "0.bin", "record": "0x40D0", "zh": "别想随心所欲！"},
  {"file": "1de.bin", "record": "0xEA8", "zh": "一口气冲！！"},
  {"file": "1de.bin", "record": "0xEC0", "zh": "我是凯、收到！"},
  {"file": "1de.bin", "record": "0xED8", "zh": "真让人想起从前！"},
  {"file": "1de.bin", "record": "0xEF4", "zh": "明白、塞拉！这边敌人交给我！"},
  {"file": "1de.bin", "record": "0xF1C", "zh": "我不会做没风度的事……帮你一把！"},
  {"file": "1de.bin", "record": "0xF48", "zh": "我是凯、收到！"},
  {"file": "1de.bin", "record": "0xF60", "zh": "我是凯、收到！"},
  {"file": "0.bin", "record": "0x40EC", "zh": "休想得逞！"},
  {"file": "0.bin", "record": "0x4104", "zh": "感到了！你的『气』！！"},
  {"file": "0.bin", "record": "0x4124", "zh": "我不再悲伤了！"},
  {"file": "0.bin", "record": "0x413C", "zh": "我不再悲伤了！"},
