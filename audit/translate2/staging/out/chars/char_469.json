 "barks": [
  {"file": "0.bin", "record": "0x35540", "zh": "冲过来？是吗……那么想死吗！"},
  {"file": "0.bin", "record": "0x35568", "zh": "我们才是人类希望！！"},
  {"file": "0.bin", "record": "0x35588", "zh": "敢抵抗……一律排除！"},
  {"file": "0.bin", "record": "0x355A8", "zh": "违抗巴顿财团的蠢货！死吧！"},
  {"file": "0.bin", "record": "0x355CC", "zh": "地球圈支配者是我们！"},
  {"file": "0.bin", "record": "0x355EC", "zh": "把你碾碎！！"},
  {"file": "0.bin", "record": "0x35604", "zh": "违抗巴顿财团的蠢货、必须处置！"},
  {"file": "0.bin", "record": "0x3562C", "zh": "胜者……是我们！！"},
  {"file": "0.bin", "record": "0x35648", "zh": "难、难道！？我们竟会败北！！"},
  {"file": "0.bin", "record": "0x3566C", "zh": "白费力气！"},
  {"file": "0.bin", "record": "0x35680", "zh": "岂能死在这！"},
  {"file": "0.bin", "record": "0x35698", "zh": "啧！敢违抗我们！"},
  {"file": "0.bin", "record": "0x356B4", "zh": "别为这点得意！！"},
  {"file": "0.bin", "record": "0x356D0", "zh": "敢违抗我们、让你后悔！！"},
  {"file": "0.bin", "record": "0x356F4", "zh": "什么！？地球还有这种兵器！？"},
  {"file": "0.bin", "record": "0x35718", "zh": "可恶！怎会这样……！！"},
  {"file": "0.bin", "record": "0x35738", "zh": "挣扎到几时！？"},
  {"file": "0.bin", "record": "0x35754", "zh": "这种攻击避开就行！"},
  {"file": "0.bin", "record": "0x35770", "zh": "注意！！攻击来了！！"},
  {"file": "0.bin", "record": "0x35790", "zh": "那机体、我们玛莉梅亚收下了！！"},
  {"file": "0.bin", "record": "0x357B8", "zh": "可恶！真丢脸！"},
  {"file": "0.bin", "record": "0x357D0", "zh": "谁会输给你！死！！"}
 ],
