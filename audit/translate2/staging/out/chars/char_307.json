 "barks": [
  {"file": "0.bin", "record": "0x22A1C", "zh": "少耍花招！"},
  {"file": "0.bin", "record": "0x22A34", "zh": "由我金卡拉姆超度你！"},
  {"file": "0.bin", "record": "0x22A58", "zh": "由我金卡拉姆超度你！"},
  {"file": "0.bin", "record": "0x22A7C", "zh": "斗争时代开幕！就在此刻！！"},
  {"file": "0.bin", "record": "0x22AA0", "zh": "索雷尔家之耻！由我金卡拉姆家洗雪！"},
  {"file": "0.bin", "record": "0x22ACC", "zh": "妨碍我们战斗的人……谁都饶不了！"},
  {"file": "0.bin", "record": "0x22AF8", "zh": "唯有战斗、方能唤醒人的斗争本能！"},
  {"file": "0.bin", "record": "0x22B20", "zh": "三千年的梦想终于实现……实战之世来了！！"},
  {"file": "0.bin", "record": "0x22B50", "zh": "唔！！可恶啊啊啊！！"},
  {"file": "0.bin", "record": "0x22B70", "zh": "哈哈！状态良好！"},
  {"file": "0.bin", "record": "0x22B8C", "zh": "少废话！真不可爱的家伙！！"},
  {"file": "0.bin", "record": "0x22BB0", "zh": "哼！终究是市民出身的兵！"},
  {"file": "0.bin", "record": "0x22BD4", "zh": "对、很好！这才叫实战之世！！"},
  {"file": "0.bin", "record": "0x22BFC", "zh": "现实比模拟游戏有趣……哈哈！"},
  {"file": "0.bin", "record": "0x22C24", "zh": "可恶、机能不全！"},
  {"file": "0.bin", "record": "0x22C40", "zh": "混账！竟敢口出狂言！！"},
  {"file": "0.bin", "record": "0x22C60", "zh": "哼、下民！以为那能管用吗！？"},
  {"file": "0.bin", "record": "0x22C88", "zh": "休得放肆！"},
  {"file": "0.bin", "record": "0x22CA0", "zh": "休得放肆！"},
  {"file": "0.bin", "record": "0x22CB8", "zh": "求饶吧、滚下机体！！"},
  {"file": "0.bin", "record": "0x22CD4", "zh": "唔！大意了……！！"},
  {"file": "0.bin", "record": "0x22CEC", "zh": "可恶！住口、下民们！！"},
  {"file": "1.bin", "record": "0x89C", "zh": "打仗就精神百倍！罗拉！"},
  {"file": "1.bin", "record": "0x8BC", "zh": "意识到死、才切实感到活着！！"},
  {"file": "1.bin", "record": "0x907", "zh": "不、不对啊！！"},
  {"file": "1.bin", "record": "0x91E", "zh": "生命要轮回就必须战斗、所以才留下！"},
  {"file": "1.bin", "record": "0x96C", "zh": "你在战斗？"},
  {"file": "1.bin", "record": "0x999", "zh": "我是人类！岂能一直被封印下去！"},
  {"file": "1.bin", "record": "0x9D9", "zh": "封得住吗！？我金卡拉姆！？"},
  {"file": "1.bin", "record": "0xA42", "zh": "骄傲为迪安娜所赐、也为她所夺！"},
  {"file": "1.bin", "record": "0xA6C", "zh": "连句慰劳都没有、就下了地球！"},
  {"file": "1.bin", "record": "0xAA4", "zh": "为那种迪安娜而战、休想胜我！！"},
  {"file": "1.bin", "record": "0xACC", "zh": "月光蝶！！！"},
  {"file": "1.bin", "record": "0xB00", "zh": "享受战斗之人！！"},
  {"file": "c4f.bin", "record": "0x574", "zh": "月光蝶！！！"},
  {"file": "0.bin", "record": "0x22D0C", "zh": "少耍花招！"},
  {"file": "0.bin", "record": "0x22D30", "zh": "若肯求饶、倒也不是不能饶你！？"},
  {"file": "0.bin", "record": "0x22D58", "zh": "战斗从没有过火一说、这得让你们知道！！"},
  {"file": "0.bin", "record": "0x22D88", "zh": "随斗争本能而战……这才是人的正确姿态吧？"},
  {"file": "0.bin", "record": "0x22DB8", "zh": "随系统摆布而死……不也很有趣吗！？"},
  {"file": "0.bin", "record": "0x22DE4", "zh": "哈哈哈！这才是我的盛世！！"},
  {"file": "0.bin", "record": "0x22E08", "zh": "用这台倒X毁灭一切！开创新的时代！"},
  {"file": "0.bin", "record": "0x22E34", "zh": "唔唔！可恶啊啊啊！！"},
  {"file": "0.bin", "record": "0x22E54", "zh": "哈哈！状态良好！"},
  {"file": "0.bin", "record": "0x22E70", "zh": "对！很好！！这才是世界应有的姿态！"},
  {"file": "0.bin", "record": "0x22E9C", "zh": "哈哈！打仗就精神百倍！！"},
  {"file": "0.bin", "record": "0x22EC0", "zh": "哦、有两下子！要进金卡拉姆队吗！？"},
  {"file": "0.bin", "record": "0x22EEC", "zh": "没错！这性命相搏、才是人应有的姿态！！"},
  {"file": "0.bin", "record": "0x22F1C", "zh": "有两下子！……但是！此耻！必当洗雪！"},
  {"file": "0.bin", "record": "0x22F4C", "zh": "生命！为了轮回！人就必须不断战斗！"},
  {"file": "0.bin", "record": "0x22F7C", "zh": "你们休想封印我基姆·金卡拉姆！"},
  {"file": "0.bin", "record": "0x22FA4", "zh": "凭你们、打不倒我金卡拉姆！"},
  {"file": "0.bin", "record": "0x22FC8", "zh": "放肆的家伙！！"},
  {"file": "0.bin", "record": "0x22FE4", "zh": "求饶吧、滚下机体！！"},
  {"file": "0.bin", "record": "0x23000", "zh": "怎么可能！"},
  {"file": "0.bin", "record": "0x23018", "zh": "此机体、你们驾驭不了！"},
  {"file": "0.bin", "record": "0x23038", "zh": "来了！！用E小调迎接他们！！"},
  {"file": "0.bin", "record": "0x23074", "zh": "毁灭一切、开新时代！"},
  {"file": "0.bin", "record": "0x23094", "zh": "以十字崩直捣敌阵！！别大意！！"},
  {"file": "0.bin", "record": "0x230DC", "zh": "演习两千年的武门之力！让他们领教！！"},
  {"file": "0.bin", "record": "0x23124", "zh": "怎么打都不算过火！尽情开战！！"},
  {"file": "0.bin", "record": "0x23171", "zh": "好！齐声喊杀！！"},
  {"file": "0.bin", "record": "0x2318C", "zh": "战斗无过火一说、教教他们！"},
  {"file": "0.bin", "record": "0x231B0", "zh": "进军！！第1战队为枪！第2队为盾！"},
  {"file": "0.bin", "record": "0x231DC", "zh": "啧！我明明还没战够呢！！"},
  {"file": "0.bin", "record": "0x23220", "zh": "很好！用身体记住实战！"},
  {"file": "0.bin", "record": "0x23240", "zh": "没错！！亮出武门的骨气！"},
  {"file": "0.bin", "record": "0x23264", "zh": "哈哈！像虫咬一样、没感觉！"},
  {"file": "0.bin", "record": "0x23288", "zh": "哈哈！有点像场仗了嘛！！"},
  {"file": "0.bin", "record": "0x232AC", "zh": "别慌！这才叫实战啊！！"},
  {"file": "0.bin", "record": "0x232E5", "zh": "可恶！放肆！！"},
  {"file": "0.bin", "record": "0x23300", "zh": "真没出息！武门的骨气哪去了！！"},
  {"file": "0.bin", "record": "0x23328", "zh": "跟你们档次不同！当然！！"},
  {"file": "0.bin", "record": "0x2334C", "zh": "哼、打不中的！"},
  {"file": "0.bin", "record": "0x23364", "zh": "来了！别照手册来打！"},
  {"file": "0.bin", "record": "0x23384", "zh": "求饶吧、滚下机体！！"},
  {"file": "0.bin", "record": "0x233A0", "zh": "可恶！何等失态！"},
  {"file": "0.bin", "record": "0x233BC", "zh": "这等屈辱！我岂会接受！！"}
 ],
 "notes": "全部候选串已用lib_apply真实编码器实测字节数、逐条<=budget；name实测px<=64。重点修复：0x23038补回E小调作战（38话Eマイナー名场面、旧译好好迎接丢了专名）；0x23094十字炮火改十字崩（十字崩し是金卡拉姆舰队具名战法、非炮火）；0x230DC数千年改两千年（JP二千年、数字必须一致）；0x22F7C旧译休想小看系误译（封じられはせん=封印不住）、改你们休想封印我基姆·金卡拉姆；0x23264的□按惯用语蚊に刺された应为蚊、但蚊/叮不在字表、保留虫咬变通。月光蝶である！！（0xACC/c4f 0x574）预算仅9字节、这就是月光蝶（12B）放不下、保留月光蝶！！！的呐喊式处理；理想全句为这就是月光蝶（repo规则、与char_228对齐）。1.bin 0x89C理想句为一打起仗来就精神百倍啊！罗拉！（20B放不下）、现取打仗就精神百倍！罗拉！保住定型词精神百倍+罗拉。另发现data/zh/event_text.json仍有吉姆·金加纳姆/金加纳姆残留（1655/5393/5819/6011行）、与canon基姆·金卡拉姆不一致、非本entity文件、仅在此报告。"
