 "barks": [
  {"file": "0.bin", "record": "0x24680", "zh": "战斗讲究时机！"},
  {"file": "0.bin", "record": "0x2469C", "zh": "别想再得逞！"},
  {"file": "0.bin", "record": "0x246B4", "zh": "别想再得逞！"},
  {"file": "0.bin", "record": "0x246CC", "zh": "命运女神、必向格雷米微笑……"},
  {"file": "0.bin", "record": "0x246F4", "zh": "重现吉翁血之王国！"},
  {"file": "0.bin", "record": "0x24714", "zh": "我身负使命、必须达成！"},
  {"file": "0.bin", "record": "0x24738", "zh": "无大义的俗物！从我面前消失！"},
  {"file": "0.bin", "record": "0x24760", "zh": "这是我自己选的路！绝无半点后悔！"},
  {"file": "0.bin", "record": "0x2478C", "zh": "我、我至今……做了什么……"},
  {"file": "0.bin", "record": "0x247B0", "zh": "凭这机动性、你们不是对手！"},
  {"file": "0.bin", "record": "0x247D8", "zh": "不、不能输！在完成使命之前！"},
  {"file": "0.bin", "record": "0x24800", "zh": "别小看我！！"},
  {"file": "0.bin", "record": "0x2481C", "zh": "毫无正义、为何而战！？"},
  {"file": "0.bin", "record": "0x2483C", "zh": "你只是为形势而战！"},
  {"file": "0.bin", "record": "0x2485C", "zh": "唔！糟了！……我大意了！？"},
  {"file": "0.bin", "record": "0x24880", "zh": "唔！……什么？这股缠身的不快感？"},
  {"file": "0.bin", "record": "0x248AC", "zh": "这也是上天的指引……天命我取胜！"},
  {"file": "0.bin", "record": "0x248D8", "zh": "可恶！就凭你们！"},
  {"file": "0.bin", "record": "0x248F4", "zh": "哼、来了！各机散开躲避！"},
  {"file": "0.bin", "record": "0x24918", "zh": "那机体、就让它为新吉翁效力吧！"},
  {"file": "0.bin", "record": "0x24940", "zh": "唔！竟被俘虏了！？到此为止……！"},
  {"file": "0.bin", "record": "0x24968", "zh": "别开玩笑！岂会轻易被抓！"},
  {"file": "0.bin", "record": "0x24C5C", "zh": "谁也挡不住我们的去路！！"},
  {"file": "0.bin", "record": "0x24C80", "zh": "普露兹……力量归格雷米！"},
  {"file": "0.bin", "record": "0x24CA4", "zh": "打倒想束缚你的敌人吧！"},
  {"file": "0.bin", "record": "0x24D00", "zh": "消灭敌人！你的心情就会好转！"},
  {"file": "0.bin", "record": "0x24D4C", "zh": "我有必战之大义！"},
  {"file": "0.bin", "record": "0x24D83", "zh": "敌人还在、疼痛就不会停！"},
  {"file": "0.bin", "record": "0x24DA8", "zh": "你我之力、送敌人入宇宙黑暗！"},
  {"file": "0.bin", "record": "0x24DD0", "zh": "怎、怎么会！？两人之力也赢不了！？"},
  {"file": "0.bin", "record": "0x24DFC", "zh": "选择严酷之道的我、绝不可能输！"},
  {"file": "0.bin", "record": "0x24E40", "zh": "那东西没用！"},
  {"file": "0.bin", "record": "0x24E88", "zh": "该死！非要违抗我吗！！"},
  {"file": "0.bin", "record": "0x24EA8", "zh": "使命在身的我竟……！"},
  {"file": "0.bin", "record": "0x24EC8", "zh": "你们打不倒我和普露兹！滚！"},
  {"file": "0.bin", "record": "0x24EFF", "zh": "好！回避！"},
  {"file": "0.bin", "record": "0x24F2C", "zh": "我们的崇高之战……休想妨碍！"},
  {"file": "0.bin", "record": "0x24F54", "zh": "我……从未后悔过……！"},
  {"file": "0.bin", "record": "0x24F74", "zh": "可恶！从我们眼前消失！"},
  {"file": "0.bin", "record": "0x2498C", "zh": "上！压制敌人势头！！"},
  {"file": "0.bin", "record": "0x249AC", "zh": "在那！！"},
  {"file": "0.bin", "record": "0x249C0", "zh": "为新吉翁荣光！"},
  {"file": "0.bin", "record": "0x249DC", "zh": "诸君！建立吉翁荣光正当时！"},
  {"file": "0.bin", "record": "0x24A18", "zh": "好、上吧！！"},
  {"file": "0.bin", "record": "0x24A30", "zh": "大义在我方！"},
  {"file": "0.bin", "record": "0x24A48", "zh": "大义在我方！"},
  {"file": "0.bin", "record": "0x24A60", "zh": "大义在我方！"},
  {"file": "0.bin", "record": "0x24A78", "zh": "该死！此仇我必报！！"},
  {"file": "0.bin", "record": "0x24A98", "zh": "命运女神、必向格雷米微笑！"},
  {"file": "0.bin", "record": "0x24ABC", "zh": "我岂会败在你们这种俗人手里！"},
  {"file": "0.bin", "record": "0x24AE8", "zh": "哼……终究不过如此！！"},
  {"file": "0.bin", "record": "0x24B08", "zh": "别退缩！胜机正在我方！！"},
  {"file": "0.bin", "record": "0x24B2C", "zh": "可恶……！你们也就得意到现在了！"},
  {"file": "0.bin", "record": "0x24B54", "zh": "该死！想阻挠我们的伟业！？"},
  {"file": "0.bin", "record": "0x24B78", "zh": "忍、忍耐！胜机必定会到来！"},
  {"file": "0.bin", "record": "0x24B9C", "zh": "命运女神、必向格雷米微笑！"},
  {"file": "0.bin", "record": "0x24BC0", "zh": "浪费弹药"},
  {"file": "0.bin", "record": "0x24BD4", "zh": "浪费弹药"},
  {"file": "0.bin", "record": "0x24BE8", "zh": "那机体、就让它为新吉翁效力吧！"},
  {"file": "0.bin", "record": "0x24C10", "zh": "这样、新吉翁复兴只是场梦……"},
  {"file": "0.bin", "record": "0x24C38", "zh": "这等无礼行为、决不容许！"}
 ],
 "notes": "重点修正：0x2485C原译「是流弹吗」系误译（油断=大意）、改为「我大意了」；0x2478C/0x247D8/0x24DD0补回原文口吃顿挫；0x24DFC与名台词637/640保持同词（严酷之道/绝不可能输）；血之王国相关（0x246F4·958）统一为「血之王国」（原bark作「血统王国」不一致）。0x24BC0/0x24BD4预算仅8字节、放不下「……！」、理想为「白费弹药……！」；0x24CA4预算不足以保留称呼、理想为「普露兹、打倒想束缚你的敌人！」；0x24EA8预算不足以保留开头的「唔！」。全部bark按简报字节规则复核≤budget_bytes、字符均在可编码表内（向/方走一字节、其余为ZH双字节）。"
}
