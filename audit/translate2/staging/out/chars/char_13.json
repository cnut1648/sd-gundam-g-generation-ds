 "barks": [
  {"file": "0.bin", "record": "0x14AC", "zh": "气势可嘉……可惜对手是只雏鸟！！"},
  {"file": "0.bin", "record": "0x14D8", "zh": "无需多言……"},
  {"file": "0.bin", "record": "0x14F0", "zh": "不退吗？……好胆识！"},
  {"file": "0.bin", "record": "0x150C", "zh": "成就大业、才会有后继者！"},
  {"file": "0.bin", "record": "0x1530", "zh": "为吉翁荣光！！"},
