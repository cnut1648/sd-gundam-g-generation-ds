 ],
 "barks": [
  {"file": "0.bin", "record": "0x32F98", "zh": "杂鱼们……特地来送死吗！"},
  {"file": "0.bin", "record": "0x32FB8", "zh": "！"},
  {"file": "0.bin", "record": "0x32FC8", "zh": "统统烧成灰！"},
  {"file": "0.bin", "record": "0x32FE0", "zh": "杂鱼、碍眼！"},
  {"file": "0.bin", "record": "0x32FF8", "zh": "全看穿了！"},
  {"file": "0.bin", "record": "0x33010", "zh": "让你见识实力差距！"},
  {"file": "0.bin", "record": "0x3302C", "zh": "呵呵呵……把你切碎！"},
  {"file": "0.bin", "record": "0x3304C", "zh": "敢与我们作对、后悔去吧！"},
  {"file": "0.bin", "record": "0x33070", "zh": "怎会……不该这样……！"},
  {"file": "0.bin", "record": "0x33090", "zh": "也就这点本事……不算什么！"},
  {"file": "0.bin", "record": "0x330B4", "zh": "可、可恶！别得意忘形！"},
  {"file": "0.bin", "record": "0x330D4", "zh": "啧……！烦死人了！"},
  {"file": "0.bin", "record": "0x330F0", "zh": "什么！？"},
  {"file": "0.bin", "record": "0x33104", "zh": "就、就这点！不算什么！"},
  {"file": "0.bin", "record": "0x33124", "zh": "不、不可能……这等威力！？"},
  {"file": "0.bin", "record": "0x33144", "zh": "撑、撑不住了！谁来支援我！"},
  {"file": "0.bin", "record": "0x33168", "zh": "那种招没用！"},
  {"file": "0.bin", "record": "0x33180", "zh": "蠢货……！打得中我吗！"},
  {"file": "0.bin", "record": "0x331A0", "zh": "来了！立刻散开！"},
  {"file": "0.bin", "record": "0x331BC", "zh": "老实点！抵抗就不留情！"},
  {"file": "0.bin", "record": "0x331DC", "zh": "不、不可能！？怎么会……"},
  {"file": "0.bin", "record": "0x331FC", "zh": "该死！岂会败给你们……！"}
 ],
 "notes": "语气统一为倨傲精英兵：蔑称杂鱼、炫耀差距、败退时结巴慌乱(与char_448-451兄弟卷风格一致)。恢复了现行译文丢失的多处……与结巴(く、くそっ/こ、この/バ、バカな)。剁字stage面不可编码、改用切碎。"
}
