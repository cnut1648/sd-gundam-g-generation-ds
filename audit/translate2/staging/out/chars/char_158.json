 "barks": [
  {"file": "0.bin", "record": "0x14A60", "zh": "……不来吗？那就由我上！"},
  {"file": "0.bin", "record": "0x14A80", "zh": "是时候……出手了！"},
  {"file": "0.bin", "record": "0x14A9C", "zh": "是时候……出手了！"},
  {"file": "0.bin", "record": "0x14AB8", "zh": "为爱娜与基尼亚斯大人！"},
  {"file": "0.bin", "record": "0x14AD8", "zh": "是我的！！"},
  {"file": "0.bin", "record": "0x14AF0", "zh": "好眼力……反会要你命！"},
  {"file": "0.bin", "record": "0x14B10", "zh": "觉悟吧！"},
  {"file": "0.bin", "record": "0x14B24", "zh": "就此结束！"},
  {"file": "0.bin", "record": "0x14B3C", "zh": "到此为止了吗……！"},
  {"file": "0.bin", "record": "0x14B58", "zh": "竟被重力束缚！……可恶的陆地人！"},
  {"file": "0.bin", "record": "0x14B80", "zh": "想让我死？没那么简单！"},
  {"file": "0.bin", "record": "0x14BA0", "zh": "哼……！"},
  {"file": "0.bin", "record": "0x14BB4", "zh": "唔……敌人竟如此了得！"},
  {"file": "0.bin", "record": "0x14BD4", "zh": "唔……有点本事嘛！"},
  {"file": "0.bin", "record": "0x14BF0", "zh": "什么……竟这么强！？"},
  {"file": "0.bin", "record": "0x14C0C", "zh": "这里……是我的死地？"},
  {"file": "0.bin", "record": "0x14C2C", "zh": "别做无用功！你没胜算！"},
