  {"file": "0.bin", "record": "0x14C70", "zh": "各机散开！炮击来了！"},
  {"file": "0.bin", "record": "0x14C90", "zh": "那机体归我！"},
  {"file": "0.bin", "record": "0x14CA8", "zh": "竟想抓住我……"},
