 "barks": [
  {"file": "0.bin", "record": "0x1DEB4", "zh": "战斗、夺取未来！！"},
  {"file": "0.bin", "record": "0x1DED0", "zh": "排除一切敌对者！"},
  {"file": "0.bin", "record": "0x1DEF0", "zh": "敌对者、全部排除！"},
  {"file": "0.bin", "record": "0x1DF10", "zh": "战斗……唯有战斗才美！！"},
  {"file": "0.bin", "record": "0x1DF34", "zh": "我已亲临战场……不容敌人再猖狂！！"},
  {"file": "0.bin", "record": "0x1DF60", "zh": "此时此地、击溃你！"},
  {"file": "0.bin", "record": "0x1DF80", "zh": "休想让你们得逞！"},
  {"file": "0.bin", "record": "0x1DF9C", "zh": "绝不容许抵抗！！"},
  {"file": "0.bin", "record": "0x1DFB8", "zh": "坦然迎接败北……方是战士之姿"},
  {"file": "0.bin", "record": "0x1DFE0", "zh": "我的作战无误！"},
  {"file": "0.bin", "record": "0x1DFFC", "zh": "没错！朝我开枪！……去肯定你自己！！"},
  {"file": "0.bin", "record": "0x1E028", "zh": "我无意否定你……但我的正义也不容否定！"},
  {"file": "0.bin", "record": "0x1E058", "zh": "所以为敌！你和我！！"},
  {"file": "0.bin", "record": "0x1E078", "zh": "胜败无关紧要！必须让时代前进！"},
  {"file": "0.bin", "record": "0x1E0A4", "zh": "这……！撼动时代之力吗！！"},
  {"file": "0.bin", "record": "0x1E0C8", "zh": "作为军人或许天真……但做人我够严格"},
  {"file": "0.bin", "record": "0x1E0F8", "zh": "可别嫌无趣？这也是战争之道！！"},
  {"file": "0.bin", "record": "0x1E124", "zh": "我必抵抗！这是军人的义务！！"},
  {"file": "0.bin", "record": "0x1E14C", "zh": "11点方向！全机、散开！"},
  {"file": "0.bin", "record": "0x1E170", "zh": "立刻投降、把机体交出来！"},
  {"file": "0.bin", "record": "0x1E194", "zh": "我居然……！"},
  {"file": "0.bin", "record": "0x1E1AC", "zh": "可别小看我！"},
  {"file": "1de.bin", "record": "0x735C", "zh": "夺取我们的未来！"},
  {"file": "1de.bin", "record": "0x7378", "zh": "看来有时联手也是必要的！"},
  {"file": "1de.bin", "record": "0x73A0", "zh": "……下次就为您准备玫瑰精华吧"},
  {"file": "1de.bin", "record": "0x73C8", "zh": "没想到、竟会与你并肩作战……"},
  {"file": "1de.bin", "record": "0x73F0", "zh": "是火吧！？金、收到！！"},
  {"file": "1de.bin", "record": "0x7410", "zh": "看来有时联手也是必要的！"},
  {"file": "1de.bin", "record": "0x7438", "zh": "看来有时联手也是必要的！"},
  {"file": "0.bin", "record": "0x1E1C8", "zh": "不行呢……世界已和平……"},
  {"file": "0.bin", "record": "0x1E1EC", "zh": "来……一起迎接新时代吧"},
  {"file": "0.bin", "record": "0x1E210", "zh": "把战斗之心留在旧时代吧、未来不需要它"},
  {"file": "0.bin", "record": "0x1E240", "zh": "来……一起迎接新时代吧"},
  {"file": "0.bin", "record": "0x1E264", "zh": "一起让宇宙和平吧"},
  {"file": "0.bin", "record": "0x1E284", "zh": "停止无益的争斗、为了我们的未来……"},
  {"file": "0.bin", "record": "0x1E2B0", "zh": "引导世界和平……那是我们今后的使命"},
  {"file": "0.bin", "record": "0x1E2DC", "zh": "来、放下枪吧……携手并进的时刻到了"},
  {"file": "0.bin", "record": "0x1E314", "zh": "在我心中战争早已结束了……"},
  {"file": "0.bin", "record": "0x1E33C", "zh": "是这份可爱呢……令一切疯狂"},
  {"file": "0.bin", "record": "0x1E364", "zh": "你那份力量、能否为和平所用呢？"},
  {"file": "0.bin", "record": "0x1E390", "zh": "战斗的英姿也令我心动……但现在该放下枪了"},
  {"file": "0.bin", "record": "0x1E3C4", "zh": "为何还要战斗？世界已如此和平……"},
  {"file": "0.bin", "record": "0x1E3F0", "zh": "啊！？为、为什么你们……！！"},
  {"file": "0.bin", "record": "0x1E414", "zh": "不、不对……啊啊！不对！啊、啊啊……！"},
  {"file": "0.bin", "record": "0x1E440", "zh": "住手吧……别抵抗"},
  {"file": "0.bin", "record": "0x1E45C", "zh": "我理解你的心情……但那是不必要的"},
  {"file": "0.bin", "record": "0x1E488", "zh": "谁都不必再……战斗或是死去了"},
  {"file": "0.bin", "record": "0x1E4B0", "zh": "为了宇宙和平、和我一同学习吧……"},
  {"file": "0.bin", "record": "0x1E4DC", "zh": "啊啊！要被抓住了！？"},
  {"file": "0.bin", "record": "0x1E4FC", "zh": "没办法呢……我还有必须完成的事"},
  {"file": "1de.bin", "record": "0x7460", "zh": "没办法呢……应战吧"},
  {"file": "1de.bin", "record": "0x747C", "zh": "哎呀……真可怕呢"},
  {"file": "1de.bin", "record": "0x7498", "zh": "特列斯大人渴望战斗……"},
  {"file": "1de.bin", "record": "0x74B8", "zh": "哎呀……真可怕呢"},
  {"file": "1de.bin", "record": "0x74D4", "zh": "哎呀……真可怕呢"},
  {"file": "1de.bin", "record": "0x74F0", "zh": "哎呀……真可怕呢"},
  {"file": "1de.bin", "record": "0x750C", "zh": "哎呀……真可怕呢"},
  {"file": "0.bin", "record": "0x1E528", "zh": "必定挡住！！"},
  {"file": "0.bin", "record": "0x1E540", "zh": "奋战夺取！我们的未来……！"},
  {"file": "0.bin", "record": "0x1E564", "zh": "若战斗才是正道……我绝不犹豫！！"},
  {"file": "0.bin", "record": "0x1E590", "zh": "奋战夺取！我们的未来……！"},
  {"file": "0.bin", "record": "0x1E5B4", "zh": "你的行为正确……我的行为也同样正确！"},
  {"file": "0.bin", "record": "0x1E5E4", "zh": "不能再容许力量继续暴走了！"},
  {"file": "0.bin", "record": "0x1E60C", "zh": "必定阻止……！！"},
  {"file": "0.bin", "record": "0x1E628", "zh": "这是……非打不可的一战！"},
  {"file": "0.bin", "record": "0x1E64C", "zh": "特列斯大人……对不起……"},
  {"file": "0.bin", "record": "0x1E66C", "zh": "此刻、为和平的牺牲仍在累积……"},
  {"file": "0.bin", "record": "0x1E694", "zh": "我不能退！为了我们的未来！！"},
  {"file": "0.bin", "record": "0x1E6BC", "zh": "纯粹的心……于无解的世界受苦……"},
  {"file": "0.bin", "record": "0x1E6E4", "zh": "好吧！开枪吧！！……去肯定你自己！"},
  {"file": "0.bin", "record": "0x1E710", "zh": "这无关胜败！这是必要之事！！"},
  {"file": "0.bin", "record": "0x1E738", "zh": "唔！作为军人……这是宝贵的一课……"},
  {"file": "0.bin", "record": "0x1E764", "zh": "做人……我活得够严格……"},
  {"file": "0.bin", "record": "0x1E788", "zh": "别白费力气！！"},
  {"file": "0.bin", "record": "0x1E7A4", "zh": "我会抵抗！若这是军人义务！！"},
  {"file": "0.bin", "record": "0x1E7CC", "zh": "！各机！散开！！"},
  {"file": "0.bin", "record": "0x1E7E4", "zh": "就算为敌、也不能眼看你死！"},
  {"file": "0.bin", "record": "0x1E80C", "zh": "现在的我……是空壳"},
  {"file": "0.bin", "record": "0x1E828", "zh": "与其被抓……不如死战！"},
  {"file": "1de.bin", "record": "0x7528", "zh": "必须阻止！！"},
  {"file": "1de.bin", "record": "0x7540", "zh": "预防者·金……收到！"},
  {"file": "1de.bin", "record": "0x7560", "zh": "您要出战了！"},
  {"file": "1de.bin", "record": "0x7578", "zh": "是风呢！？金、收到！！"},
  {"file": "1de.bin", "record": "0x7598", "zh": "是风呢！？金、收到！！"},
  {"file": "1de.bin", "record": "0x75B8", "zh": "收到、火！金这就去支援！"},
  {"file": "1de.bin", "record": "0x75DC", "zh": "预防者·金……收到！"}
 ],
 "notes": "三张卡对应三重人格：223=眼镜军人（简体直接果断）、224=圣女（敬体柔和）、225=人格融合后（EW预防者时期）、语气按此分层。特列斯人名与char_153一致（特列斯、称呼用特列斯大人）。预防者代号按biligame预防者页：金=蕾蒂·安、火=诺茵、风=杰克斯、旧译在火、金代号外侧加的方引号为禁字、已去除并让代号直接入句。JP原文0x1DFFC与0x1E6E4的首定应为肯定的ROM原文异体/误植、按肯定翻译。0x7560受12字节预算限制无法容纳称呼、理想译文为：要出战了吧、特列斯大人！。0x1E33C与0x1E6BC与674名台词同出TV第25话中弹独白、已按同一语境成套翻译（爱くるしさ=这份可爱、答えの見えぬ世界=无解的世界受预算所限）。"
}
