 "barks": [
  {"file": "0.bin", "record": "0x27238", "zh": "冲着我来吗……那就奉陪到底！！"},
  {"file": "0.bin", "record": "0x27260", "zh": "好！冲上去！"},
  {"file": "0.bin", "record": "0x27278", "zh": "好！冲上去！"},
  {"file": "0.bin", "record": "0x27290", "zh": "狮子搏兔、亦用全力！"},
  {"file": "0.bin", "record": "0x272B8", "zh": "我的使命、便是不负这玫瑰芬芳！"},
  {"file": "0.bin", "record": "0x272E0", "zh": "玛修曼、参上！！"},
  {"file": "0.bin", "record": "0x272F8", "zh": "以哈曼大人骑士之名……出击！！"},
  {"file": "0.bin", "record": "0x27320", "zh": "堂堂正正决胜负！"},
  {"file": "0.bin", "record": "0x2733C", "zh": "哇啊！玫、玫瑰……哈曼大人赐的玫瑰！"},
  {"file": "0.bin", "record": "0x27368", "zh": "还想挣扎！！！"},
  {"file": "0.bin", "record": "0x27380", "zh": "可恶！我是绝不能输的！！"},
  {"file": "0.bin", "record": "0x273A4", "zh": "正合我这火热的身体！"},
  {"file": "0.bin", "record": "0x273C0", "zh": "哦！倒有几分本事！"},
  {"file": "0.bin", "record": "0x273DC", "zh": "哈哈哈！这才值得一战！"},
  {"file": "0.bin", "record": "0x27400", "zh": "什、什么！？"},
  {"file": "0.bin", "record": "0x2741C", "zh": "这……这点程度、休想让我退缩！！"},
  {"file": "0.bin", "record": "0x27444", "zh": "虽有违骑士道、为正世道……请见谅！！"},
  {"file": "0.bin", "record": "0x27474", "zh": "可恶！放冷箭真无耻！"},
  {"file": "0.bin", "record": "0x27494", "zh": "哈曼大人赐予的机体、绝不容有损！！"},
  {"file": "0.bin", "record": "0x274C0", "zh": "无伤夺下机体、献给哈曼大人！"},
  {"file": "0.bin", "record": "0x274E8", "zh": "可恶！放开！放开！给我堂堂正正地打！"},
  {"file": "0.bin", "record": "0x27518", "zh": "干什么！放肆！！"},
  {"file": "1.bin", "record": "0x408", "zh": "敢辱哈曼大人！？"},
  {"file": "1.bin", "record": "0x422", "zh": "你才是整天追着迪安娜屁股跑的！"},
  {"file": "1.bin", "record": "0x490", "zh": "说屁股有错吗！！"},
  {"file": "1.bin", "record": "0x4AA", "zh": "迪安娜不及哈曼大人万一！！"},
  {"file": "1.bin", "record": "0x510", "zh": "说我发型怪！？"},
  {"file": "1.bin", "record": "0x527", "zh": "屡次侮辱哈曼大人、绝不轻饶！！"},
  {"file": "1.bin", "record": "0x550", "zh": "纵使血肉从骨上被削尽、也要取你性命！！"},
  {"file": "0.bin", "record": "0x27534", "zh": "敢冲过来！不要命了！"},
  {"file": "0.bin", "record": "0x27554", "zh": "我已得到力量！岂会输给你们！！"},
  {"file": "0.bin", "record": "0x2757C", "zh": "敢违抗我们、这就是你的死地！！"},
  {"file": "0.bin", "record": "0x275A4", "zh": "新吉翁荣光……岂容尔等染指！"},
  {"file": "0.bin", "record": "0x275CC", "zh": "放马过来！一架不剩全部击落！！"},
  {"file": "0.bin", "record": "0x275F4", "zh": "胜利属于新吉翁！休想阻拦！！"},
  {"file": "0.bin", "record": "0x2761C", "zh": "我乃新吉翁的骑士、岂会输给尔等！！"},
  {"file": "0.bin", "record": "0x27648", "zh": "逆哈曼大人者、由我玛修曼制裁！"},
  {"file": "0.bin", "record": "0x27670", "zh": "哈曼大人万岁！！"},
  {"file": "0.bin", "record": "0x2768C", "zh": "哼！无谓抵抗！！"},
  {"file": "0.bin", "record": "0x276A8", "zh": "我绝不能倒下啊！！"},
  {"file": "0.bin", "record": "0x276C4", "zh": "可恶！烦人的家伙！！"},
  {"file": "0.bin", "record": "0x276E4", "zh": "可恶！这种程度！"},
  {"file": "0.bin", "record": "0x27700", "zh": "还没完！！！"},
  {"file": "0.bin", "record": "0x27718", "zh": "唔！可恶……但是……！！"},
  {"file": "0.bin", "record": "0x27738", "zh": "我玛修曼……岂会就此倒下！！"},
  {"file": "0.bin", "record": "0x2775C", "zh": "无谓的抵抗！！！"},
  {"file": "0.bin", "record": "0x27778", "zh": "徒劳"},
  {"file": "0.bin", "record": "0x27788", "zh": "各机、散开！跟我上！！"},
  {"file": "0.bin", "record": "0x277A8", "zh": "无伤夺下机体、献给哈曼大人！"},
  {"file": "0.bin", "record": "0x277D0", "zh": "此姿、无颜见哈曼大人……"},
  {"file": "0.bin", "record": "0x277F4", "zh": "我岂会被尔等所擒！"}
 ],
 "notes": "统一玛修曼的浮夸骑士腔（尔等、岂会、参上、赌上骑士之名）。重点修正：0x27290狮子捕猎→中文成语狮子搏兔、亦用全力；0x272B8补回「回应玫瑰芬芳的使命」原意；0x277D0补回哈曼大人（原译只有大人）；0x27518好无礼→放肆；1.bin 0x490补回与上句0x422呼应的「说屁股有错吗」笑点；1.bin 0x4AA月とスッポン→不及万一。0x272E0/0x273A4/0x273C0/0x27534/1.bin 0x510保留现译（其实际编码字节数已达预算上限、按成本规则重写反而需要削减内容）。所有新句按成本规则均在budget_bytes内、省略号成对、全程无逗号。"
}
