 "barks": [
  {"file": "0.bin", "record": "0x2853C", "zh": "很遗憾……我可没空陪你玩！"},
  {"file": "0.bin", "record": "0x28560", "zh": "呵呵、拿下了"},
  {"file": "0.bin", "record": "0x28578", "zh": "你已经死了……"},
  {"file": "0.bin", "record": "0x28594", "zh": "就让你在这里消失吧……"},
  {"file": "0.bin", "record": "0x285B8", "zh": "看来有只烦人的苍蝇……在飞来飞去"},
  {"file": "0.bin", "record": "0x285E4", "zh": "……这也是必然之事"},
  {"file": "0.bin", "record": "0x28604", "zh": "战斗必须取胜……"},
  {"file": "0.bin", "record": "0x28620", "zh": "那么……趁现在让你沉没吧"},
  {"file": "0.bin", "record": "0x28644", "zh": "也只好如此、呵呵呵……"},
  {"file": "0.bin", "record": "0x28664", "zh": "这点身手打不倒我"},
  {"file": "0.bin", "record": "0x28680", "zh": "不巧、没打算死在这里！！"},
  {"file": "0.bin", "record": "0x286A4", "zh": "不动手、下个死的或许是自己？"},
  {"file": "0.bin", "record": "0x286CC", "zh": "哦……！确实不可小看"},
  {"file": "0.bin", "record": "0x286EC", "zh": "正因如此才有趣啊！"},
  {"file": "0.bin", "record": "0x2870C", "zh": "竟让它拥有这等火力……！"},
  {"file": "0.bin", "record": "0x28730", "zh": "战力超乎预想……看准退路！"},
  {"file": "0.bin", "record": "0x28754", "zh": "这点力量无济于事！"},
  {"file": "0.bin", "record": "0x28774", "zh": "事情可没那么容易照计划进行！"},
  {"file": "0.bin", "record": "0x2879C", "zh": "来了……！各机、散开！"},
  {"file": "0.bin", "record": "0x287BC", "zh": "这机体归我了！"},
  {"file": "0.bin", "record": "0x287D4", "zh": "唉……这也是必然吗"},
  {"file": "0.bin", "record": "0x287F0", "zh": "天真……！能下杀手时别犹豫！"},
  {"file": "c4f.bin", "record": "0x3A4", "zh": "哼"},
  {"file": "0.bin", "record": "0x28814", "zh": "我有！宇宙唯我一人！有权裁决全人类！"},
  {"file": "0.bin", "record": "0x28844", "zh": "谁也阻止不了了！笼罩宇宙的憎恨漩涡！"},
  {"file": "0.bin", "record": "0x28874", "zh": "人注定灭亡！被自酿的黑暗吞噬！"},
  {"file": "0.bin", "record": "0x288A0", "zh": "还不够痛苦吗！……你！？"},
  {"file": "0.bin", "record": "0x288C4", "zh": "没人懂！……没人！"},
  {"file": "0.bin", "record": "0x288E0", "zh": "这就是宿命！！……你的！！"},
  {"file": "0.bin", "record": "0x28904", "zh": "世界并不如歌般温柔……！！"},
  {"file": "0.bin", "record": "0x28928", "zh": "在无尽欲望中挣扎吧！！"},
  {"file": "0.bin", "record": "0x28948", "zh": "终究我也……只是血肉之躯……"},
  {"file": "0.bin", "record": "0x28970", "zh": "再怎么喊也迟了！已无阻止之法！"},
  {"file": "0.bin", "record": "0x2899C", "zh": "没错！随欲望挣扎吧！"},
  {"file": "0.bin", "record": "0x289BC", "zh": "憎恨的眼与心！人的本性！"},
  {"file": "0.bin", "record": "0x289E4", "zh": "你可真难缠！！"},
  {"file": "0.bin", "record": "0x28A00", "zh": "比人强！比人快！比人高！……人类真了不起！！"},
  {"file": "0.bin", "record": "0x28A34", "zh": "如此罪业……！是谁积下的！？"},
  {"file": "0.bin", "record": "0x28A58", "zh": "你相信什么？为何相信！？"},
  {"file": "0.bin", "record": "0x28A7C", "zh": "那不是勇气……那叫鲁莽！"},
  {"file": "0.bin", "record": "0x28AA0", "zh": "你不够格！！"},
  {"file": "0.bin", "record": "0x28AB8", "zh": "你不够格！！"},
  {"file": "0.bin", "record": "0x28AD0", "zh": "机体归我！！"},
  {"file": "0.bin", "record": "0x28AE8", "zh": "这……失态了"},
  {"file": "0.bin", "record": "0x28B00", "zh": "已经迟了！再无阻止之法！"},
  {"file": "c4f.bin", "record": "0x3B4", "zh": "谁也阻止不了了！笼罩宇宙的憎恨漩涡！"}
 ],
 "notes": "0x28A34的業原译本事系误译、按克鲁泽人の業主题改为罪业。0x285B8的ハエ改回名场面用词苍蝇（对穆的挖苦）。0x28814受字节预算限制、完整社区译法为我有！在这宇宙中唯我一人！拥有裁决全人类的权利！。0x28874理想全译为人注定灭亡！被自己孕育的黑暗吞噬！（超预算故压缩为自酿）。0x289BC理想全译为憎恨的眼与心！那才是人的本性！（超预算）。"
}
