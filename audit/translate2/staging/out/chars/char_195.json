  {"file": "0.bin", "record": "0x1A010", "zh": "想逃掉？死了这条心吧！！"},
  {"file": "0.bin", "record": "0x1A038", "zh": "见识下老手的厉害！"},
  {"file": "0.bin", "record": "0x1A058", "zh": "休想回避！"},
  {"file": "0.bin", "record": "0x1A070", "zh": "可恶啊！！"},
  {"file": "0.bin", "record": "0x1A088", "zh": "这家伙！少胡闹！"},
  {"file": "0.bin", "record": "0x1A0A4", "zh": "中、中弹了！？菲尔少佐！"},
  {"file": "0.bin", "record": "0x1A0C4", "zh": "我可没那么容易输！"},
  {"file": "0.bin", "record": "0x1A0E4", "zh": "这……区区这点程度！"},
  {"file": "0.bin", "record": "0x1A104", "zh": "烦死人了……！尽是这种对手！！"},
  {"file": "0.bin", "record": "0x1A12C", "zh": "中弹！？损伤！？下次是直击吗？"},
  {"file": "0.bin", "record": "0x1A154", "zh": "嚣张！竟想用火力击退我吗！"},
  {"file": "0.bin", "record": "0x1A17C", "zh": "没、没听说有这种武器！"},
  {"file": "0.bin", "record": "0x1A1A0", "zh": "这样下去我要颜面扫地！"},
  {"file": "0.bin", "record": "0x1A1C4", "zh": "别开玩笑！！"},
  {"file": "0.bin", "record": "0x1A1DC", "zh": "凭那种！！"},
  {"file": "0.bin", "record": "0x1A1F0", "zh": "……来了！各机、散开！"},
  {"file": "0.bin", "record": "0x1A210", "zh": "这家伙！乖乖就擒吧！"},
  {"file": "0.bin", "record": "0x1A230", "zh": "什么！？怎么会！！"},
