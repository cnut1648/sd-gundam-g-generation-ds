 "ids": [
  {"idn": 993, "name_zh": "立场不保！", "cutin_zh": "若坐视敌人不管、我在加米托夫面前就立场不保了！", "notes": "加米托夫·海曼为库内既定译名（biligame同）。名与台词共用关键词立场不保、与bark 0x2688A同源。"},
  {"idn": 994, "name_zh": "彻底干掉！", "cutin_zh": "我要彻底干掉你们！", "notes": ""},
  {"idn": 995, "name_zh": "绝不罢休！", "cutin_zh": "不给那帮家伙一记痛击、我绝不罢休！！", "notes": "JP原文开头的ャツら是ヤツら的提取残缺、按那帮家伙翻译。与bark 0x26670同源。"},
  {"idn": 996, "name_zh": "毫无意义！", "cutin_zh": "让你见识、违抗提坦斯毫无意义！", "detail_effect_zh": "命中率+40%。全队进行间接攻击时、使对方无法散开", "notes": "灰机wiki记载的代表性狂言（违抗提坦斯是无意义的）、沿用社区措辞。原效果文只译了命中+40%且把散開封印误写成解除封印、已按JP整句重译、与固定摘要命中↑・封散一致。"},
  {"idn": 997, "name_zh": "提坦斯崛起", "cutin_zh": "我等提坦斯、就此崛起！", "notes": "出自提坦斯结成宣言一系（Gジェネ0083结尾バスク台词我々ティターンズが立つのだ）、立つ按组织崛起处理、原译崛起了时态别扭已顺。"},
  {"idn": 998, "name_zh": "我即提坦斯", "cutin_zh": "我就是提坦斯本身！怎么可能会输！！", "notes": "无社区定译、按原文直译；補回JP结尾的！！。"}
 ],
 "barks": [
  {"file": "0.bin", "record": "0x26648", "zh": "竟特意找上门来……斩尽杀绝！"},
  {"file": "0.bin", "record": "0x26670", "zh": "不痛击敌人绝不罢休！！"},
  {"file": "0.bin", "record": "0x26690", "zh": "教他们明白违抗无意义！"},
  {"file": "0.bin", "record": "0x266CC", "zh": "一架都别放跑！开火！"},
  {"file": "0.bin", "record": "0x266EC", "zh": "动手！齐射！！"},
  {"file": "0.bin", "record": "0x26704", "zh": "动手！齐射！！"},
  {"file": "0.bin", "record": "0x2671C", "zh": "动手！齐射！！"},
  {"file": "0.bin", "record": "0x26734", "zh": "宇宙人……休想活着回去！"},
  {"file": "0.bin", "record": "0x26758", "zh": "可恶……！丢人现眼！"},
  {"file": "0.bin", "record": "0x26774", "zh": "……不碍事！继续前进！"},
  {"file": "0.bin", "record": "0x26794", "zh": "在此沉没、就成笑柄了！"},
  {"file": "0.bin", "record": "0x267B4", "zh": "不过如此！"},
  {"file": "0.bin", "record": "0x267EC", "zh": "那种事无所谓！快歼灭敌人！"},
  {"file": "0.bin", "record": "0x26814", "zh": "可恶……！一群臭虫！"},
  {"file": "0.bin", "record": "0x2684A", "zh": "可恶……！杂鱼也敢嚣张！"},
  {"file": "0.bin", "record": "0x2688A", "zh": "退了无颜见加米托夫！继续战斗！"},
  {"file": "0.bin", "record": "0x268B4", "zh": "违抗我毫无意义、懂了？"},
  {"file": "0.bin", "record": "0x268D4", "zh": "哼！自作聪明！！"},
  {"file": "0.bin", "record": "0x268F0", "zh": "哼！自作聪明！！"},
  {"file": "0.bin", "record": "0x2690C", "zh": "那机体、我们收下！"},
  {"file": "0.bin", "record": "0x2692C", "zh": "什么！这、这是……！"},
  {"file": "0.bin", "record": "0x26948", "zh": "蠢货！自寻死路！"},
  {"file": "0.bin", "record": "0x26964", "zh": "全军迎击！！"},
  {"file": "0.bin", "record": "0x26980", "zh": "违抗提坦斯毫无意义！"},
  {"file": "0.bin", "record": "0x269BE", "zh": "好！肃清叛乱分子！！"},
  {"file": "0.bin", "record": "0x269DC", "zh": "一架不剩全击落！"},
  {"file": "0.bin", "record": "0x269F8", "zh": "彻底打垮他们！！开火！"},
  {"file": "0.bin", "record": "0x26A18", "zh": "让你开开眼！"},
  {"file": "0.bin", "record": "0x26A30", "zh": "休想得逞！"},
  {"file": "0.bin", "record": "0x26A48", "zh": "定要全歼你们！"},
  {"file": "0.bin", "record": "0x26A64", "zh": "可、可恶！宇宙人……！！"},
  {"file": "0.bin", "record": "0x26A84", "zh": "杂鱼！叫你们嚣张！！"},
  {"file": "0.bin", "record": "0x26AA4", "zh": "可恶！直援部队在干什么！"},
  {"file": "0.bin", "record": "0x26AC8", "zh": "哼！小聪明！"},
  {"file": "0.bin", "record": "0x26AF5", "zh": "可恶、在干什么！快反击！"},
  {"file": "0.bin", "record": "0x26B18", "zh": "该死！休想就此回去！"},
  {"file": "0.bin", "record": "0x26B38", "zh": "唔！竟敢小看我！！"},
  {"file": "0.bin", "record": "0x26B54", "zh": "可恶！后退！确保航路！"},
  {"file": "0.bin", "record": "0x26B78", "zh": "凭这点战力……别自大！"},
  {"file": "0.bin", "record": "0x26B98", "zh": "毫无新意的攻击！"},
  {"file": "0.bin", "record": "0x26BB4", "zh": "别中这点攻击！"},
  {"file": "0.bin", "record": "0x26BD0", "zh": "效忠提坦斯、便饶你一命！"},
  {"file": "0.bin", "record": "0x26BF8", "zh": "这东西……想要就给你！"},
  {"file": "0.bin", "record": "0x26C18", "zh": "想指挥我！？少开玩笑！"}
 ],
 "notes": "巴斯克·欧姆与biligame词条一致、无异议。语气基调：提坦斯残暴总指挥、傲慢高压、蔑称敌方为杂鱼臭虫、对下属亦颐指气使。0x268F0与0x268D4为同一句JP（ふんっ！小ざかしい！！）、原译厚颜无耻是错译、已统一为自作聪明。宇宙人め按字面保留宇宙人（人物志用宇宙居民、但21字节预算放不下）。0x26948わざわざ死にに来たか取自寻死路以保留わざわざ的自投罗网感。蛆虫不在字库、蔑称沿用库内已有的臭虫。所有bark按每CJK2字节、、。！？…・（）各1字节核算、均不超budget_bytes。"
}
