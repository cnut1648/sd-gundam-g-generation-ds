 "barks": [
  {"file": "0.bin", "record": "0x266B1", "zh": "是！开始攻击！"},
  {"file": "0.bin", "record": "0x32A08", "zh": "哼……活靶子！射击准备！一举解决！"},
  {"file": "0.bin", "record": "0x32A34", "zh": "齐射准备！……开火！！"},
  {"file": "0.bin", "record": "0x32A54", "zh": "、预备！30秒全力射击！"},
  {"file": "0.bin", "record": "0x32A78", "zh": "宇宙人……地球是我们的！！"},
  {"file": "0.bin", "record": "0x32A9C", "zh": "好、各炮座瞄准！别浪费弹药！！"},
  {"file": "0.bin", "record": "0x32AC4", "zh": "别让敌人反击！"},
  {"file": "0.bin", "record": "0x32AE0", "zh": "冲进敌人怀里！"},
  {"file": "0.bin", "record": "0x32AFC", "zh": "我们不可能输！"},
  {"file": "0.bin", "record": "0x32B18", "zh": "骗、骗人吧！？我们怎会败……呜哇啊！"},
  {"file": "0.bin", "record": "0x32B44", "zh": "哼、废物！！"},
  {"file": "0.bin", "record": "0x32B5C", "zh": "可、可恶……！刚、刚才多危险啊！"},
  {"file": "0.bin", "record": "0x32B84", "zh": "徒劳挣扎！"},
  {"file": "0.bin", "record": "0x32B9C", "zh": "中弹了！？索敌班、眼睛长哪了！！"},
  {"file": "0.bin", "record": "0x32BC4", "zh": "什……！怎么会轻易中弹！？不许说敌人更强！！"},
  {"file": "0.bin", "record": "0x32BF8", "zh": "唔！……不是直击吧！？喂、不要紧吧！？"},
  {"file": "0.bin", "record": "0x32C24", "zh": "可恶！不行了！！请示司令部撤退！"},
  {"file": "0.bin", "record": "0x32C4C", "zh": "我们是精锐！岂能与杂兵并论！！"},
  {"file": "0.bin", "record": "0x32C74", "zh": "哼、打不中的！"},
  {"file": "0.bin", "record": "0x32C8C", "zh": "哼、打不中的！"},
  {"file": "0.bin", "record": "0x32CA4", "zh": "停止顽抗！你们赢不了的！！"},
  {"file": "0.bin", "record": "0x32CC8", "zh": "精英竟成俘虏！？怎么会……！？"},
  {"file": "0.bin", "record": "0x32CF0", "zh": "让我蒙羞吗！退下！退下！"}
 ],
 "notes": "通用联邦精英士官语音组：口吻取自负傲慢的精锐军官、汇报体与char_448/449（是！开始……）保持一致。0x32A54保留原文行首结构性顿号。0x32C74/0x32C8C为同文重复、译文一致（编码器实测11/11字节）。detail均非本实体所有、未输出。"
