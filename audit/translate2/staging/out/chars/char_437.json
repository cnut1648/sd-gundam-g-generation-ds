   "idn": 1311,
   "name_zh": "我做得到！",
   "cutin_zh": "我做得到……我一定做得到！！",
   "notes": "阿姆罗第12话名台词的杂兵引用、沿用社区通行译法我做得到"
  }
 ],
 "barks": [
  {"file": "0.bin", "record": "0x30BA0", "zh": "不开火！？那我就不客气了！"},
  {"file": "0.bin", "record": "0x30BC4", "zh": "立下战功就好办了！"},
  {"file": "0.bin", "record": "0x30BE4", "zh": "立下战功就好办了！"},
  {"file": "0.bin", "record": "0x30C04", "zh": "一击解决！"},
  {"file": "0.bin", "record": "0x30C1C", "zh": "打胜仗、出人头地！"},
  {"file": "0.bin", "record": "0x30C38", "zh": "人头我收下了！！"},
  {"file": "0.bin", "record": "0x30C54", "zh": "真碍眼！！"},
  {"file": "0.bin", "record": "0x30C68", "zh": "把你碾碎！！"},
  {"file": "0.bin", "record": "0x30C80", "zh": "呜啊啊！我、我还不想死……！"},
  {"file": "0.bin", "record": "0x30CA4", "zh": "哈！不过如此！"},
  {"file": "0.bin", "record": "0x30CBC", "zh": "谁、谁要死啊！"},
  {"file": "0.bin", "record": "0x30CD4", "zh": "什么？是来真的吗！？"},
  {"file": "0.bin", "record": "0x30CF4", "zh": "你竟敢抵抗！！"},
  {"file": "0.bin", "record": "0x30D0C", "zh": "可、可恶！被盯上了！？"},
  {"file": "0.bin", "record": "0x30D2C", "zh": "哇啊啊！跟说好的不一样！"},
  {"file": "0.bin", "record": "0x30D50", "zh": "来、来人！支援！快支援！"},
  {"file": "0.bin", "record": "0x30D74", "zh": "那种武器没用！"},
  {"file": "0.bin", "record": "0x30D90", "zh": "打不中的！！"},
  {"file": "0.bin", "record": "0x30DA8", "zh": "没用……！！"},
  {"file": "0.bin", "record": "0x30DBC", "zh": "那机体我们替你好好用！"},
  {"file": "0.bin", "record": "0x30DE0", "zh": "就到这了吗……！"},
  {"file": "0.bin", "record": "0x30DFC", "zh": "可恶！别过来！别过来！"}
 ],
 "notes": "杂兵语音、口吻与char_431/432(军官/高官)的立功恩赏路线保持一致。修正两处误译：手柄さえ立てちまえば=立战功(原译占了上风)、話が違いすぎる=跟说好的不一样(原译实力相差太悬殊)。"
