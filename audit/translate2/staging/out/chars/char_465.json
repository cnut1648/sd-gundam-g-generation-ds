 "barks": [
  {"file": "0.bin", "record": "0x34A68", "zh": "休想反击！！"},
  {"file": "0.bin", "record": "0x34A80", "zh": "新时代由我们亲手开创！"},
  {"file": "0.bin", "record": "0x34AA4", "zh": "新时代由我们亲手开创！"},
  {"file": "0.bin", "record": "0x34AC8", "zh": "必须将你们尽数肃清！"},
  {"file": "0.bin", "record": "0x34AEC", "zh": "妨碍我们、就是这下场！"},
  {"file": "0.bin", "record": "0x34B0C", "zh": "接受肃清之刃吧！"},
  {"file": "0.bin", "record": "0x34B28", "zh": "下个时代不需要你们！"},
  {"file": "0.bin", "record": "0x34B48", "zh": "这是革命！"},
  {"file": "0.bin", "record": "0x34B60", "zh": "为何！？我们怎会败！？"},
  {"file": "0.bin", "record": "0x34B80", "zh": "终究不过这点程度！"},
  {"file": "0.bin", "record": "0x34BA0", "zh": "不可能输……我们不可能输！"},
  {"file": "0.bin", "record": "0x34BC4", "zh": "你们就这点本事吗？"},
  {"file": "0.bin", "record": "0x34BE4", "zh": "唔……大意了！"},
  {"file": "0.bin", "record": "0x34BFC", "zh": "小看你们了……"},
  {"file": "0.bin", "record": "0x34C14", "zh": "敌人竟有这种装备！？"},
  {"file": "0.bin", "record": "0x34C34", "zh": "甩不掉！谁来支援！！"},
  {"file": "0.bin", "record": "0x34C54", "zh": "那招没用！"},
  {"file": "0.bin", "record": "0x34C6C", "zh": "以为我会乖乖当靶子吗！！"},
  {"file": "0.bin", "record": "0x34C90", "zh": "攻击来袭！快散开！"},
  {"file": "0.bin", "record": "0x34CB0", "zh": "老实点！饶你一条命！"},
  {"file": "0.bin", "record": "0x34CD0", "zh": "可恶！这等屈辱……！"},
  {"file": "0.bin", "record": "0x34CEC", "zh": "谁会任你们摆布……！"}
