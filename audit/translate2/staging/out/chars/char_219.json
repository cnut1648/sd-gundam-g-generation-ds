 "ids": [
  {"idn": 657, "name_zh": "只能战斗！", "cutin_zh": "现在只能战斗了！对不起……", "notes": "原名「如今只能战」截断生硬、改为与名台词共用关键词的完整短语"},
  {"idn": 658, "name_zh": "也能幸福！", "cutin_zh": "强化人也能……获得幸福！", "notes": "强化人为社区通行术语"},
  {"idn": 659, "name_zh": "借我力量！", "cutin_zh": "父亲大人、母亲大人……请把力量借给我！", "notes": "父さま母さま译作父亲大人·母亲大人以保留敬称语气"},
  {"idn": 660, "name_zh": "跪下哭喊！", "cutin_zh": "给我跪下哭喊吧！那样我就饶你一命！", "notes": ""},
  {"idn": 661, "name_zh": "想赢我……", "cutin_zh": "什么嘛！你真以为赢得了我？", "notes": "指令名避用？（标签字段禁用）、以省略号收尾贴合原文って……"},
  {"idn": 662, "name_zh": "快去死吧！", "cutin_zh": "快点去死吧！败犬就该夹着尾巴逃跑！！", "notes": "お逝きなさい沿用哈曼系通行译法去死吧、句尾！！按原文保留"}
 ],
 "barks": [
  {"file": "0.bin", "record": "0x1D340", "zh": "我不能……放过你！"},
  {"file": "0.bin", "record": "0x1D360", "zh": "我懂……就那里！！"},
  {"file": "0.bin", "record": "0x1D37C", "zh": "只能战斗了……对不起！"},
  {"file": "0.bin", "record": "0x1D39C", "zh": "我要赢得……与他的未来！"},
  {"file": "0.bin", "record": "0x1D3C0", "zh": "命已不只属于我、不能死！"},
  {"file": "0.bin", "record": "0x1D3E4", "zh": "我的力量……若能帮上点忙！"},
  {"file": "0.bin", "record": "0x1D408", "zh": "若不让开……只能打倒你！"},
  {"file": "0.bin", "record": "0x1D42C", "zh": "我不再是……谁的人偶！"},
  {"file": "0.bin", "record": "0x1D44C", "zh": "零……"},
  {"file": "0.bin", "record": "0x1D45C", "zh": "……打不中！"},
  {"file": "0.bin", "record": "0x1D474", "zh": "我、我才不会……死在这里！"},
  {"file": "0.bin", "record": "0x1D498", "zh": "擦到而已！这不算什么！"},
  {"file": "0.bin", "record": "0x1D4B8", "zh": "不好！动作被看穿了！？"},
  {"file": "0.bin", "record": "0x1D4D8", "zh": "……！反应、慢了……！"},
  {"file": "0.bin", "record": "0x1D4F4", "zh": "这人好强……！"},
  {"file": "0.bin", "record": "0x1D50C", "zh": "我……就这么死了吗……？"},
  {"file": "0.bin", "record": "0x1D52C", "zh": "别再抵抗了！我不想再杀了！"},
  {"file": "0.bin", "record": "0x1D550", "zh": "打不中……！"},
  {"file": "0.bin", "record": "0x1D568", "zh": "大家小心！攻击来了！"},
  {"file": "0.bin", "record": "0x1D588", "zh": "求你别抵抗！不想你死！"},
  {"file": "0.bin", "record": "0x1D5AC", "zh": "啊！？"},
  {"file": "0.bin", "record": "0x1D5C0", "zh": "休想得逞！！"},
  {"file": "1de.bin", "record": "0x700C", "zh": "上！靠大家的力量！"},
  {"file": "1de.bin", "record": "0x7028", "zh": "嗯！一起上！！"},
  {"file": "1de.bin", "record": "0x7040", "zh": "嗯！我永远陪你、零！！"},
  {"file": "1de.bin", "record": "0x7060", "zh": "上！靠大家的力量！"},
  {"file": "1de.bin", "record": "0x707C", "zh": "上！靠大家的力量！"},
  {"file": "1de.bin", "record": "0x7098", "zh": "上！靠大家的力量！"},
  {"file": "1de.bin", "record": "0x70B4", "zh": "上！靠大家的力量！"},
  {"file": "0.bin", "record": "0x1D5D8", "zh": "不出所料……早知你会来这招！"},
  {"file": "0.bin", "record": "0x1D600", "zh": "呵呵……逃到哪都没用！"},
  {"file": "0.bin", "record": "0x1D620", "zh": "就凭你……怎么可能打倒我！"},
  {"file": "0.bin", "record": "0x1D644", "zh": "来吧！快点去死吧！"},
  {"file": "0.bin", "record": "0x1D660", "zh": "喂……想让我打哪里！？"},
  {"file": "0.bin", "record": "0x1D680", "zh": "不要……别靠近我！！"},
  {"file": "0.bin", "record": "0x1D6A0", "zh": "你、真碍眼！"},
  {"file": "0.bin", "record": "0x1D6B8", "zh": "你这家伙、你这家伙……消失吧！！"},
  {"file": "0.bin", "record": "0x1D6E0", "zh": "怎么！？我竟中弹……"},
  {"file": "0.bin", "record": "0x1D700", "zh": "你瞄哪里呢？蠢死了……"},
  {"file": "0.bin", "record": "0x1D720", "zh": "哈……哈……！无法再战！"},
  {"file": "0.bin", "record": "0x1D740", "zh": "呵呵……慌什么、真蠢！"},
  {"file": "0.bin", "record": "0x1D760", "zh": "中弹！？……为什么！！"},
  {"file": "0.bin", "record": "0x1D77C", "zh": "这种事……！绝对只是侥幸！"},
  {"file": "0.bin", "record": "0x1D7A0", "zh": "啊……！不要啊啊！！"},
  {"file": "0.bin", "record": "0x1D7BC", "zh": "不对！不是我……不是我啊啊啊啊！"},
  {"file": "0.bin", "record": "0x1D7E8", "zh": "那种东西怎么会有效！？"},
  {"file": "0.bin", "record": "0x1D808", "zh": "靠那种……真蠢！"},
  {"file": "0.bin", "record": "0x1D824", "zh": "说了没用、还不懂吗！？"},
  {"file": "0.bin", "record": "0x1D844", "zh": "那机体归我！"},
  {"file": "0.bin", "record": "0x1D85C", "zh": "不、不要……！别碰我！！"},
  {"file": "0.bin", "record": "0x1D87C", "zh": "别过来！别过来！凭你们……！"},
  {"file": "1de.bin", "record": "0x70D0", "zh": "你们、上！解决掉他们！"},
