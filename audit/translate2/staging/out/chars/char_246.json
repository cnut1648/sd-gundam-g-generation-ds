 "barks": [
  {"file": "0.bin", "record": "0x20A70", "zh": "趁敌不备、速战速决！"},
  {"file": "0.bin", "record": "0x20A90", "zh": "……开火！"},
  {"file": "0.bin", "record": "0x20AA4", "zh": "为我们称霸地球圈之日！……上吧！"},
  {"file": "0.bin", "record": "0x20ACC", "zh": "齐射准备！……开火！"},
  {"file": "0.bin", "record": "0x20B07", "zh": "联邦……见识我们的力量！"},
  {"file": "0.bin", "record": "0x20B28", "zh": "为吉翁复兴……突击！"},
  {"file": "0.bin", "record": "0x20B48", "zh": "将我们逐至边境之辈、如今要付出代价！"},
  {"file": "0.bin", "record": "0x20B78", "zh": "为吉翁！"},
  {"file": "0.bin", "record": "0x20B8C", "zh": "唔……吉翁万岁！"},
  {"file": "0.bin", "record": "0x20BA8", "zh": "觉悟与你们不同！"},
  {"file": "0.bin", "record": "0x20BE1", "zh": "很好！拿出吉翁的骨气！"},
  {"file": "0.bin", "record": "0x20C04", "zh": "这点程度、不成大碍……"},
  {"file": "0.bin", "record": "0x20C24", "zh": "继承吉翁精神的我们……还不能退！"},
  {"file": "0.bin", "record": "0x20C72", "zh": "嗯、转入反击！"},
  {"file": "0.bin", "record": "0x20C8C", "zh": "唔！必须挺住！"},
  {"file": "0.bin", "record": "0x20CA8", "zh": "还不能退！为吉翁荣光！！"},
  {"file": "0.bin", "record": "0x20CCC", "zh": "可别小看了我们……！"},
  {"file": "0.bin", "record": "0x20CEC", "zh": "敌方远程攻击！回避！"},
  {"file": "0.bin", "record": "0x20D0C", "zh": "这种距离打不中！"},
