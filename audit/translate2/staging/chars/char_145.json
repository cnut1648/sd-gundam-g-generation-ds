   "record": "0x12ED4",
   "budget_bytes": 20,
   "jp": "お前と遊んでいるヒマは……ないッ！",
   "zh_current": "没空陪你玩、少废话！！",
   "zh_current_bytes": 18
  },
  {
   "file": "0.bin",
   "record": "0x12EF4",
   "budget_bytes": 10,
   "jp": "はぁぁぁぁぁぁっ！！",
   "zh_current": "啊啊啊啊！！",
   "zh_current_bytes": 10
  },
  {
   "file": "0.bin",
   "record": "0x12F0C",
   "budget_bytes": 25,
   "jp": "来るなら来い！オレは何度でも食らいついてやる！",
   "zh_current": "要来就来！多少次我都奉陪！！",
   "zh_current_bytes": 21
  },
  {
   "file": "0.bin",
   "record": "0x12F34",
   "budget_bytes": 16,
   "jp": "そのまま…寝ていろおおおっ！",
   "zh_current": "就那样、睡过去吧！",
   "zh_current_bytes": 16
  },
  {
   "file": "0.bin",
   "record": "0x12F50",
   "budget_bytes": 20,
   "jp": "はぁぁぁ……！たぁぁりゃぁぁーーっ！",
   "zh_current": "哈啊……！嘿呀啊啊啊！",
   "zh_current_bytes": 18
  },
  {
   "file": "0.bin",
   "record": "0x12F70",
   "budget_bytes": 10,
   "jp": "はぁぁぁぁぁぁっ！！",
   "zh_current": "哈啊啊啊！！",
   "zh_current_bytes": 10
  },
  {
   "file": "0.bin",
   "record": "0x12F88",
   "budget_bytes": 11,
   "jp": "とりゃあああああッ！！",
   "zh_current": "嘿啊啊啊！！！",
   "zh_current_bytes": 11
  },
  {
   "file": "0.bin",
   "record": "0x12FA0",
   "budget_bytes": 27,
   "jp": "裏拳！正拳！肘打ち！とりゃあああ！",
   "zh_current": "背拳！正拳！顶击！嘿呀啊！",
   "zh_current_bytes": 22
  },
  {
   "file": "0.bin",
   "record": "0x12FC8",
   "budget_bytes": 17,
   "jp": "クッ……！これがオレの実力か！",
   "zh_current": "这就是我的实力吗……！",
   "zh_current_bytes": 17
  },
  {
   "file": "0.bin",
   "record": "0x12FE8",
   "budget_bytes": 16,
   "jp": "しょせんキサマはファイターにあらず！",
   "zh_current": "你终究不是斗士！",
   "zh_current_bytes": 14
  },
  {
   "file": "0.bin",
   "record": "0x13004",
   "budget_bytes": 22,
   "jp": "来るなら来てみろ！何度でもかわしてやる！",
   "zh_current": "放马过来！我会一一躲开！",
   "zh_current_bytes": 18
  },
  {
   "file": "0.bin",
   "record": "0x13028",
   "budget_bytes": 18,
   "jp": "そんな魂のこもらぬ攻撃などでッ！",
   "zh_current": "那种没有灵魂的攻击！",
   "zh_current_bytes": 18
  },
  {
   "file": "0.bin",
   "record": "0x13048",
   "budget_bytes": 10,
   "jp": "……少しはできるな！",
   "zh_current": "……还行嘛！",
   "zh_current_bytes": 8
  },
  {
   "file": "0.bin",
   "record": "0x13060",
   "budget_bytes": 22,
   "jp": "お前が強くなればなるほど……俺も燃える！！",
   "zh_current": "你越强、我越热血！！",
   "zh_current_bytes": 16
  },
  {
   "file": "0.bin",
   "record": "0x13084",
   "budget_bytes": 8,
   "jp": "な、何て力だ！！",
   "zh_current": "好、好强！",
   "zh_current_bytes": 8
  },
  {
   "file": "0.bin",
   "record": "0x13098",
   "budget_bytes": 23,
   "jp": "ま、まだだ……！まだ勝負はついちゃいない！",
   "zh_current": "还、还没！胜负还未分晓",
   "zh_current_bytes": 19
  },
  {
   "file": "0.bin",
   "record": "0x130BC",
   "budget_bytes": 18,
   "jp": "分身殺法！ゴッド·シャドー！！",
